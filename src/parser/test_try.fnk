
test 'try bare', fn:
  expect ast fn:
    try foo
  | equals_ast
    Try
      Ident 'foo'

test 'try with application', fn:
  expect ast fn:
    try foo bar
  | equals_ast
    Try
      Apply
        Ident 'foo'
        Ident 'bar'

test 'try bound to name', fn:
  expect ast fn:
    a = try open 'file.txt'
  | equals_ast
    Bind
      Ident 'a'
      Try
        Apply
          Ident 'open'
          LitStr 'file.txt'

test 'try in pipe', fn:
  expect ast fn:
    try foo | bar
  | equals_ast
    Pipe
      Try
        Ident 'foo'
      Ident 'bar'
