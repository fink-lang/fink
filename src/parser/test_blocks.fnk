
test 'block with no args and expression body', fn:
  expect ast fn:
    test_block: 'hello'
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
      LitStr 'hello'

test 'block with patterns and expression body', fn:
  expect ast fn:
    test_block a, b: a + b
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
        Ident 'a'
        Ident 'b'
      InfixOp '+'
        Ident 'a'
        Ident 'b'

test 'block with patterns and multiline body', fn:
  expect ast fn:
    test_block a, b:
      x = a + b
      x * 2
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
        Ident 'a'
        Ident 'b'
      Bind
        Ident 'x'
        InfixOp '+'
          Ident 'a'
          Ident 'b'
      InfixOp '*'
        Ident 'x'
        LitInt '2'

test 'block with arms', fn:
  expect ast fn:
    test_block a:
      1: 'one'
      2: 'two'
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
        Ident 'a'
      Arm
        LitInt '1'
        LitStr 'one'
      Arm
        LitInt '2'
        LitStr 'two'

test 'block bound to name', fn:
  expect ast fn:
    result = test_block a, b:
      a + b
  | equals_ast
    Bind
      Ident 'result'
      Block
        Ident 'test_block'
        Patterns
          Ident 'a'
          Ident 'b'
        InfixOp '+'
          Ident 'a'
          Ident 'b'

test 'inline block in application', fn:
  expect ast fn:
    log test_block: 'hello'
  | equals_ast
    Apply
      Ident 'log'
      Block
        Ident 'test_block'
        Patterns
        LitStr 'hello'

test 'block with sequence destructure param', fn:
  expect ast fn:
    test_block [a, b]: a + b
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
        LitSeq
          Ident 'a'
          Ident 'b'
      InfixOp '+'
        Ident 'a'
        Ident 'b'

test 'block with record destructure param', fn:
  expect ast fn:
    test_block {x, y}: x + y
  | equals_ast
    Block
      Ident 'test_block'
      Patterns
        LitRec
          Ident 'x'
          Ident 'y'
      InfixOp '+'
        Ident 'x'
        Ident 'y'
