---
arithmetic
---

test 'unary minus', fn:
  expect ast fn:
    -a
  | equals_ast
    UnaryOp '-'
      Ident 'a'

test 'add', fn:
  expect ast fn:
    a + b
  | equals_ast
    InfixOp '+'
      Ident 'a'
      Ident 'b'

test 'subtract', fn:
  expect ast fn:
    a - b
  | equals_ast
    InfixOp '-'
      Ident 'a'
      Ident 'b'

test 'multiply', fn:
  expect ast fn:
    a * b
  | equals_ast
    InfixOp '*'
      Ident 'a'
      Ident 'b'

test 'divide', fn:
  expect ast fn:
    a / b
  | equals_ast
    InfixOp '/'
      Ident 'a'
      Ident 'b'

test 'integer divide', fn:
  expect ast fn:
    a // b
  | equals_ast
    InfixOp '//'
      Ident 'a'
      Ident 'b'

test 'power', fn:
  expect ast fn:
    a ** b
  | equals_ast
    InfixOp '**'
      Ident 'a'
      Ident 'b'

test 'remainder', fn:
  expect ast fn:
    a % b
  | equals_ast
    InfixOp '%'
      Ident 'a'
      Ident 'b'

test 'true modulus', fn:
  expect ast fn:
    a %% b
  | equals_ast
    InfixOp '%%'
      Ident 'a'
      Ident 'b'

test 'divmod', fn:
  expect ast fn:
    a /% b
  | equals_ast
    InfixOp '/%'
      Ident 'a'
      Ident 'b'

test 'power is right associative', fn:
  expect ast fn:
    a ** b ** c
  | equals_ast
    InfixOp '**'
      Ident 'a'
      InfixOp '**'
        Ident 'b'
        Ident 'c'

test 'multiply binds tighter than add', fn:
  expect ast fn:
    a + b * c
  | equals_ast
    InfixOp '+'
      Ident 'a'
      InfixOp '*'
        Ident 'b'
        Ident 'c'


---
logical
---

test 'not', fn:
  expect ast fn:
    not a
  | equals_ast
    UnaryOp 'not'
      Ident 'a'

test 'and', fn:
  expect ast fn:
    a and b
  | equals_ast
    InfixOp 'and'
      Ident 'a'
      Ident 'b'

test 'or', fn:
  expect ast fn:
    a or b
  | equals_ast
    InfixOp 'or'
      Ident 'a'
      Ident 'b'

test 'xor', fn:
  expect ast fn:
    a xor b
  | equals_ast
    InfixOp 'xor'
      Ident 'a'
      Ident 'b'

test 'not binds tighter than and', fn:
  expect ast fn:
    not a and not b
  | equals_ast
    InfixOp 'and'
      UnaryOp 'not'
        Ident 'a'
      UnaryOp 'not'
        Ident 'b'

test 'and binds tighter than or', fn:
  expect ast fn:
    a or b and c
  | equals_ast
    InfixOp 'or'
      Ident 'a'
      InfixOp 'and'
        Ident 'b'
        Ident 'c'

test 'add binds tighter than and', fn:
  expect ast fn:
    a + b and c + d
  | equals_ast
    InfixOp 'and'
      InfixOp '+'
        Ident 'a'
        Ident 'b'
      InfixOp '+'
        Ident 'c'
        Ident 'd'


---
comparison
---

test 'greater than', fn:
  expect ast fn:
    a > b
  | equals_ast
    InfixOp '>'
      Ident 'a'
      Ident 'b'

test 'greater than or equal', fn:
  expect ast fn:
    a >= b
  | equals_ast
    InfixOp '>='
      Ident 'a'
      Ident 'b'

test 'less than', fn:
  expect ast fn:
    a < b
  | equals_ast
    InfixOp '<'
      Ident 'a'
      Ident 'b'

test 'less than or equal', fn:
  expect ast fn:
    a <= b
  | equals_ast
    InfixOp '<='
      Ident 'a'
      Ident 'b'

test 'equal', fn:
  expect ast fn:
    a == b
  | equals_ast
    InfixOp '=='
      Ident 'a'
      Ident 'b'

test 'not equal', fn:
  expect ast fn:
    a != b
  | equals_ast
    InfixOp '!='
      Ident 'a'
      Ident 'b'

test 'chained comparison same op', fn:
  expect ast fn:
    a > b > c
  | equals_ast
    ChainedCmp
      Ident 'a'
      '>'
      Ident 'b'
      '>'
      Ident 'c'

test 'chained comparison mixed ops', fn:
  expect ast fn:
    a >= b > c
  | equals_ast
    ChainedCmp
      Ident 'a'
      '>='
      Ident 'b'
      '>'
      Ident 'c'

test 'containment', fn:
  expect ast fn:
    a in b
  | equals_ast
    InfixOp 'in'
      Ident 'a'
      Ident 'b'

test 'not containment', fn:
  expect ast fn:
    a not in b
  | equals_ast
    InfixOp 'not in'
      Ident 'a'
      Ident 'b'

test 'disjoint', fn:
  expect ast fn:
    a >< b
  | equals_ast
    InfixOp '><'
      Ident 'a'
      Ident 'b'

test 'comparison binds tighter than and', fn:
  expect ast fn:
    a > 0 and b < 10
  | equals_ast
    InfixOp 'and'
      InfixOp '>'
        Ident 'a'
        LitInt '0'
      InfixOp '<'
        Ident 'b'
        LitInt '10'


---
bitwise
---

test 'bitwise not', fn:
  expect ast fn:
    ~a
  | equals_ast
    UnaryOp '~'
      Ident 'a'

test 'bitwise and', fn:
  expect ast fn:
    a & b
  | equals_ast
    InfixOp '&'
      Ident 'a'
      Ident 'b'

test 'bitwise xor', fn:
  expect ast fn:
    a ^ b
  | equals_ast
    InfixOp '^'
      Ident 'a'
      Ident 'b'

test 'shift right', fn:
  expect ast fn:
    a >> b
  | equals_ast
    InfixOp '>>'
      Ident 'a'
      Ident 'b'

test 'shift left', fn:
  expect ast fn:
    a << b
  | equals_ast
    InfixOp '<<'
      Ident 'a'
      Ident 'b'

test 'rotate right', fn:
  expect ast fn:
    a >>> b
  | equals_ast
    InfixOp '>>>'
      Ident 'a'
      Ident 'b'

test 'rotate left', fn:
  expect ast fn:
    a <<< b
  | equals_ast
    InfixOp '<<<'
      Ident 'a'
      Ident 'b'


---
member access
---

test 'member by name', fn:
  expect ast fn:
    foo.bar
  | equals_ast
    Member
      Ident 'foo'
      Ident 'bar'

test 'chained member access', fn:
  expect ast fn:
    foo.bar.spam
  | equals_ast
    Member
      Member
        Ident 'foo'
        Ident 'bar'
      Ident 'spam'

test 'member by hyphenated name', fn:
  expect ast fn:
    foo.bar-spam
  | equals_ast
    Member
      Ident 'foo'
      Ident 'bar-spam'

test 'member by expression', fn:
  expect ast fn:
    foo.(expr)
  | equals_ast
    Member
      Ident 'foo'
      Group
        Ident 'expr'

test 'sequence index', fn:
  expect ast fn:
    [1, 2, 3].(0)
  | equals_ast
    Member
      LitSeq
        LitInt '1'
        LitInt '2'
        LitInt '3'
      Group
        LitInt '0'

test 'sequence range slice', fn:
  expect ast fn:
    [0, 1, 2, 3, 4].(2...3)
  | equals_ast
    Member
      LitSeq
        LitInt '0'
        LitInt '1'
        LitInt '2'
        LitInt '3'
        LitInt '4'
      Group
        InfixOp '...'
          LitInt '2'
          LitInt '3'

test 'ident range', fn:
  expect ast fn:
    start..end
  | equals_ast
    InfixOp '..'
      Ident 'start'
      Ident 'end'

test 'member access on record literal', fn:
  expect ast fn:
    {foo: 123}.foo
  | equals_ast
    Member
      LitRec
        Arm
          Ident 'foo'
          LitInt '123'
      Ident 'foo'

test 'member by string key', fn:
  expect ast fn:
    {'ni nu': 123}.('ni nu')
  | equals_ast
    Member
      LitRec
        Arm
          LitStr 'ni nu'
          LitInt '123'
      Group
        LitStr 'ni nu'

test 'member by sequence key', fn:
  expect ast fn:
    [0, 1, 2, 3, 4].([2, 3])
  | equals_ast
    Member
      LitSeq
        LitInt '0'
        LitInt '1'
        LitInt '2'
        LitInt '3'
        LitInt '4'
      Group
        LitSeq
          LitInt '2'
          LitInt '3'
