--- --- ---
strings
--- --- ---

---
simple string
---
'hello world'
# expect
LitStr 'hello world'

---
string escape sequences
---
'\n\t\r\\\''
# expect
LitStr '\n\t\r\\\''

---
string vertical tab backspace formfeed
---
'\v\b\f'
# expect
LitStr '\v\b\f'

---
string hex escape
---
'\x41\x42'
# expect
LitStr 'AB'

---
string unicode escape
---
'\u0041\u0042'
# expect
LitStr 'AB'

---
multiline string
---
'
  hello
  world
'
# expect
LitStr '\n  hello\n  world\n'

---
string interpolation
---
'hello ${1 + 2}'
# expect
StrTempl
  LitStr 'hello '
  InfixOp '+'
    LitInt '1'
    LitInt '2'

---
string interpolation leading expression
---
'${1 + 2} world'
# expect
StrTempl
  InfixOp '+'
    LitInt '1'
    LitInt '2'
  LitStr ' world'

---
tagged template string
---
fmt'hello ${1 + 2}'
# expect
Apply
  Ident 'fmt'
  StrRawTempl
    LitStr 'hello '
    InfixOp '+'
      LitInt '1'
      LitInt '2'

---
tagged template string in argument position
---
store env, id'foo', v
# expect
Apply
  Ident 'store'
  Ident 'env'
  Apply
    Ident 'id'
    StrRawTempl
      LitStr 'foo'
  Ident 'v'

---
rendered template string
---
fmt 'hello ${1 + 2}'
# expect
Apply
  Ident 'fmt'
  StrTempl
    LitStr 'hello '
    InfixOp '+'
      LitInt '1'
      LitInt '2'


--- --- ---
sequences
--- --- ---

---
empty sequence
---
[]
# expect
LitSeq

---
sequence literal
---
[1, 2, 3]
# expect
LitSeq
  LitInt '1'
  LitInt '2'
  LitInt '3'

---
sequence constructor
---
seq 1, 2, 3
# expect
Apply
  Ident 'seq'
  LitInt '1'
  LitInt '2'
  LitInt '3'

---
multiline sequence constructor
---
seq
  1
  2
  seq 3, 4
# expect
Apply
  Ident 'seq'
  LitInt '1'
  LitInt '2'
  Apply
    Ident 'seq'
    LitInt '3'
    LitInt '4'


--- --- ---
records
--- --- ---

---
empty record
---
{}
# expect
LitRec

---
record literal
---
{foo: 1, bar: 2}
# expect
LitRec
  Arm
    Ident 'foo'
    LitInt '1'
  Arm
    Ident 'bar'
    LitInt '2'

---
record with computed key
---
{(a + b): 3}
# expect
LitRec
  Arm
    Group
      InfixOp '+'
        Ident 'a'
        Ident 'b'
    LitInt '3'

---
multiline record
---
{
  foo: 1
  bar: {
    spam: 3
  }
}
# expect
LitRec
  Arm
    Ident 'foo'
    LitInt '1'
  Arm
    Ident 'bar'
    LitRec
      Arm
        Ident 'spam'
        LitInt '3'

---
record shorthand fields
---
{foo, bar}
# expect
LitRec
  Ident 'foo'
  Ident 'bar'


--- --- ---
dicts
--- --- ---

---
dict literal
---
dict {foo: 1, 'bar': 2, (key): 3}
# expect
Apply
  Ident 'dict'
  LitRec
    Arm
      Ident 'foo'
      LitInt '1'
    Arm
      LitStr 'bar'
      LitInt '2'
    Arm
      Group
        Ident 'key'
      LitInt '3'


