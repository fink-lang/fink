--- --- ---

---
integer tagged literal
---
10sec
# expect
Apply
  Ident 'sec'
  LitInt '10'

---
float tagged literal
---
10.5min
# expect
Apply
  Ident 'min'
  LitFloat '10.5'

---
grouped tagged literal
---
(foo)min
# expect
Apply
  Ident 'min'
  Ident 'foo'

---
sequence tagged literal
---
[1, 2, 3]foo
# expect
Apply
  Ident 'foo'
  LitSeq
    LitInt '1'
    LitInt '2'
    LitInt '3'

---
record tagged literal
---
{foo: bar}spam
# expect
Apply
  Ident 'spam'
  LitRec
    Arm
      Ident 'foo'
      Ident 'bar'
