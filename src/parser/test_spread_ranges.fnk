---
spread
---

test 'spread into sequence', fn:
  expect ast fn:
    [head, ..tail]
  | equals_ast
    LitSeq
      Ident 'head'
      Spread
        Ident 'tail'

test 'spread concat sequences', fn:
  expect ast fn:
    [..seq1, ..seq2]
  | equals_ast
    LitSeq
      Spread
        Ident 'seq1'
      Spread
        Ident 'seq2'

test 'spread into record', fn:
  expect ast fn:
    {foo: bar, ..rest}
  | equals_ast
    LitRec
      Arm
        Ident 'foo'
        Ident 'bar'
      Spread
        Ident 'rest'

test 'spread merge records', fn:
  expect ast fn:
    {..rec1, ..rec2}
  | equals_ast
    LitRec
      Spread
        Ident 'rec1'
      Spread
        Ident 'rec2'

test 'bare spread in sequence pattern', fn:
  expect ast fn:
    [..]
  | equals_ast
    LitSeq
      Spread

test 'bare spread in record pattern', fn:
  expect ast fn:
    {..}
  | equals_ast
    LitRec
      Spread

test 'spread with range guard', fn:
  expect ast fn:
    [head, ..(0..2), ..rest]
  | equals_ast
    LitSeq
      Ident 'head'
      Spread
        InfixOp '..'
          LitInt '0'
          LitInt '2'
      Spread
        Ident 'rest'

test 'spread with function guard', fn:
  expect ast fn:
    [..(is_odd), ..evens]
  | equals_ast
    LitSeq
      Spread
        Ident 'is_odd'
      Spread
        Ident 'evens'

test 'spread with range expression guard', fn:
  expect ast fn:
    [..(1 + 2)..(3 + 4)]
  | equals_ast
    LitSeq
      Spread
        InfixOp '..'
          InfixOp '+'
            LitInt '1'
            LitInt '2'
          Group
            InfixOp '+'
              LitInt '3'
              LitInt '4'

test 'spread with ident range guard', fn:
  expect ast fn:
    [..foo...bar]
  | equals_ast
    LitSeq
      Spread
        InfixOp '...'
          Ident 'foo'
          Ident 'bar'

test 'spread with bare range guard', fn:
  expect ast fn:
    [head, ..0..2, ..rest]
  | equals_ast
    LitSeq
      Ident 'head'
      Spread
        InfixOp '..'
          LitInt '0'
          LitInt '2'
      Spread
        Ident 'rest'

test 'spread with range to grouped expression', fn:
  expect ast fn:
    [..0..(l)]
  | equals_ast
    LitSeq
      Spread
        InfixOp '..'
          LitInt '0'
          Group
            Ident 'l'


---
ranges
---

test 'exclusive range', fn:
  expect ast fn:
    0..10
  | equals_ast
    InfixOp '..'
      LitInt '0'
      LitInt '10'

test 'inclusive range', fn:
  expect ast fn:
    0...10
  | equals_ast
    InfixOp '...'
      LitInt '0'
      LitInt '10'

test 'char range', fn:
  expect ast fn:
    'a'...'z'
  | equals_ast
    InfixOp '...'
      LitStr 'a'
      LitStr 'z'

test 'expression range exclusive', fn:
  expect ast fn:
    (1 + 2)..(3 + 4)
  | equals_ast
    InfixOp '..'
      Group
        InfixOp '+'
          LitInt '1'
          LitInt '2'
      Group
        InfixOp '+'
          LitInt '3'
          LitInt '4'

test 'expression range inclusive', fn:
  expect ast fn:
    (1 + 2)...(3 + 4)
  | equals_ast
    InfixOp '...'
      Group
        InfixOp '+'
          LitInt '1'
          LitInt '2'
      Group
        InfixOp '+'
          LitInt '3'
          LitInt '4'
