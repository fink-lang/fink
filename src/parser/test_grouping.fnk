---
parentheses
---

test 'grouping preserves Group node in arithmetic', fn:
  expect ast fn:
    (1 + 2) * (2 + 3)
  | equals_ast
    InfixOp '*'
      Group
        InfixOp '+'
          LitInt '1'
          LitInt '2'
      Group
        InfixOp '+'
          LitInt '2'
          LitInt '3'

test 'grouping application args without comma', fn:
  expect ast fn:
    [(add 1, 2), (add 3, 4)]
  | equals_ast
    LitSeq
      Group
        Apply
          Ident 'add'
          LitInt '1'
          LitInt '2'
      Group
        Apply
          Ident 'add'
          LitInt '3'
          LitInt '4'

test 'grouping to override right-to-left application', fn:
  expect ast fn:
    foo (bar spam) ham
  | equals_ast
    Apply
      Ident 'foo'
      Group
        Apply
          Ident 'bar'
          Ident 'spam'
      Ident 'ham'


---
comma vs semicolon
---

test 'comma separates args weakly', fn:
  expect ast fn:
    add mul 2, 3, mul 3, 4
  | equals_ast
    Apply
      Ident 'add'
      Apply
        Ident 'mul'
        LitInt '2'
        LitInt '3'
        Apply
          Ident 'mul'
          LitInt '3'
          LitInt '4'

test 'semicolon groups strongly', fn:
  expect ast fn:
    add mul 2, 3; mul 3, 4
  | equals_ast
    Apply
      Ident 'add'
      Apply
        Ident 'mul'
        LitInt '2'
        LitInt '3'
      Apply
        Ident 'mul'
        LitInt '3'
        LitInt '4'


---
newline as separator
---

test 'multiline args - same AST as inline with semicolons', fn:
  expect ast fn:
    add
      mul 2, 3
      mul 3, 4
  | equals_ast
    Apply
      Ident 'add'
      Apply
        Ident 'mul'
        LitInt '2'
        LitInt '3'
      Apply
        Ident 'mul'
        LitInt '3'
        LitInt '4'

test 'trailing comma continues onto next line', fn:
  expect ast fn:
    foo bar,
      spam
  | equals_ast
    Apply
      Ident 'foo'
      Ident 'bar'
      Ident 'spam'


---
disambiguation with semicolon
---

test 'semicolon makes spread guard boundary explicit', fn:
  expect ast fn:
    [is_odd head; ..tail] = [3, 4, 5]
  | equals_ast
    Bind
      LitSeq
        Apply
          Ident 'is_odd'
          Ident 'head'
        Spread
          Ident 'tail'
      LitSeq
        LitInt '3'
        LitInt '4'
        LitInt '5'
