---
continuation lifting tests
---

# Continuation lifting — hoists inline App continuation bodies into LetFn nodes
# so that every continuation is a named function by the time closure_lifting runs.
#
# Rewrite for App { func, args, cont: Cont::Expr { arg, body } } where body is non-trivial:
#
#   Before:
#     ·apply func, args, fn arg: <non-trivial body>
#
#   After:
#     ·fn fn arg: <non-trivial body>     ← new LetFn (Bind::Cont)
#       fn ·ƒ_N:
#         ·apply func, args, ·ƒ_N        ← App with Cont::Ref(·ƒ_N)
#
# Test format:
#   test 'name', fn:
#     expect cont_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>

{test, equals, expect, fink, cont_lift} = import 'fake!'

---
trivial App body — no hoisting
---

test 'trivial App body (Ret) is unchanged', fn:
  expect cont_lift fink":
    main = fn a, b:
      a + b
  | equals fink":
    ·fn
      fn a, b, ·ƒ_4: ·op_plus a, b, ·ƒ_4
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
yield with non-trivial cont body — hoisting
---

test 'yield — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      yield 42
      1 + 2

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_4:
            ·let ·v_4, fn ·v_6:
              ·op_plus 1, 2, ·ƒ_2
          fn ·ƒ_22: ·yield 42, ·ƒ_22
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
match nodes with non-trivial cont bodies — hoisting
---

test 'seq destructure — MatchDone cont body hoisted', fn:
  expect cont_lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5:
            ·fn
              fn ·v_6, ·v_7:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_11: ·op_plus a, 1, ·ƒ_3
                    fn ·ƒ_35: ·match_done ·v_7, ·panic, ·ƒ_35
              fn ·ƒ_38: ·match_next ·v_5, ·panic, ·ƒ_38
          fn ·ƒ_41: ·match_seq foo, ·panic, ·ƒ_41
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
MatchLetVal — plain ident destructure
---

test 'MatchLetVal — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·op_plus a, 1, ·ƒ_3
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchValue — literal pattern
---

test 'MatchValue — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      1 = foo
      foo + 2

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_11: ·op_plus foo, 2, ·ƒ_3
          fn ·ƒ_21:
            ·match_value foo, 1, ·panic, fn: ·ƒ_21 _
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRec + MatchField — record destructure
---

test 'MatchRec/MatchField — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5:
            ·fn
              fn ·v_6, ·v_7:
                ·let ·v_6, fn x:
                  ·op_plus x, 1, ·ƒ_3
              fn ·ƒ_32: ·match_field ·v_5, 'x', ·panic, ·ƒ_32
          fn ·ƒ_35: ·match_rec foo, ·panic, ·ƒ_35
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRest — spread tail in seq
---

test 'MatchRest — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [..rest] = foo
      rest

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5:
            ·fn
              fn ·v_7:
                ·let ·v_7, fn rest:
                  ·ƒ_3 rest
              fn ·ƒ_25: ·match_rest ·v_5, ·panic, ·ƒ_25
          fn ·ƒ_28: ·match_seq foo, ·panic, ·ƒ_28
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchNotDone — spread with no binding
---

test 'MatchNotDone — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [a, ..] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5:
            ·fn
              fn ·v_6, ·v_7:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_18: ·op_plus a, 1, ·ƒ_3
                    fn ·ƒ_35:
                      ·match_not_done ·v_7, ·panic, fn: ·ƒ_35 _
              fn ·ƒ_38: ·match_next ·v_5, ·panic, ·ƒ_38
          fn ·ƒ_41: ·match_seq foo, ·panic, ·ƒ_41
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchBlock — match expression
---

test 'MatchBlock — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn x:
      r = match x:
        1: 10
        2: 20
      r + 1

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·fn
          fn ·v_18:
            ·fn
              fn ·v_32:
                ·fn
                  fn ·v_34:
                    ·let ·v_34, fn r:
                      ·op_plus r, 1, ·ƒ_3
                  fn ·ƒ_56: ·match_block x, ·v_18, ·v_32, ·ƒ_56
              fn ·ƒ_59:
                ·fn
                  fn ·ƒ_25:
                    ·let 20, fn ·v_27:
                      ·ƒ_25 ·v_27
                  fn ·ƒ_61:
                    ·fn
                      fn ·v_22, ·ƒ_20, ·ƒ_21:
                        ·match_value ·v_22, 2, ·ƒ_20, fn: ·ƒ_21 _
                      fn ·ƒ_63: ·match_arm ·ƒ_63, ·ƒ_61, ·ƒ_59
          fn ·ƒ_68:
            ·fn
              fn ·ƒ_11:
                ·let 10, fn ·v_13:
                  ·ƒ_11 ·v_13
              fn ·ƒ_70:
                ·fn
                  fn ·v_8, ·ƒ_6, ·ƒ_7:
                    ·match_value ·v_8, 1, ·ƒ_6, fn: ·ƒ_7 _
                  fn ·ƒ_72: ·match_arm ·ƒ_72, ·ƒ_70, ·ƒ_68
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchBlock — arm body with non-trivial computation
---

test 'MatchBlock — chained App inside arm body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn n:
      r = match n:
        _:
          x = 1 + 2
          x + 3
      r

  | equals fink":
    ·fn
      fn n, ·ƒ_3:
        ·fn
          fn ·v_27:
            ·fn
              fn ·v_29:
                ·let ·v_29, fn r:
                  ·ƒ_3 r
              fn ·ƒ_44: ·match_block n, ·v_27, ·ƒ_44
          fn ·ƒ_47:
            ·fn
              fn ·ƒ_10:
                ·fn
                  fn ·v_13:
                    ·let ·v_13, fn x:
                      ·op_plus x, 3, ·ƒ_10
                  fn ·ƒ_49: ·op_plus 1, 2, ·ƒ_49
              fn ·ƒ_52:
                ·fn
                  fn ·v_8, ·ƒ_6, ·ƒ_7: ·ƒ_7 _
                  fn ·ƒ_54: ·match_arm ·ƒ_54, ·ƒ_52, ·ƒ_47
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchIf body — hoisting
---

test 'MatchIf — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a > 0 = foo
      a * 2 + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·fn
            fn ·v_18:
              ·fn
                fn ·v_10: ·op_plus ·v_10, 1, ·ƒ_3
                fn ·ƒ_30: ·op_mul a, 2, ·ƒ_30
            fn ·ƒ_33:
              ·match_if ·op_gt, a, 0, ·panic, fn: ·ƒ_33 _
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
non-trivial App body — hoisting
---

test 'chained arithmetic — App body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_5:
            ·let ·v_5, fn x:
              ·op_plus x, 4, ·ƒ_2
          fn ·ƒ_23: ·op_mul 2, 3, ·ƒ_23
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


