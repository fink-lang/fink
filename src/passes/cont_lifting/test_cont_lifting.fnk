---
continuation lifting tests
---

# Continuation lifting — hoists inline App continuation bodies into LetFn nodes
# so that every continuation is a named function by the time closure_lifting runs.
#
# Rewrite for App { func, args, cont: Cont::Expr { arg, body } } where body is non-trivial:
#
#   Before:
#     ·apply func, args, fn arg: <non-trivial body>
#
#   After:
#     ·fn fn arg: <non-trivial body>     ← new LetFn (Bind::Cont)
#       fn ·ƒ_N:
#         ·apply func, args, ·ƒ_N        ← App with Cont::Ref(·ƒ_N)
#
# Test format:
#   test 'name', fn:
#     expect cont_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>


---
trivial App body — no hoisting
---

test 'trivial App body (Ret) is unchanged', fn:
  expect cont_lift fink":
    main = fn a, b:
      a + b
  | equals fink":
    ·fn
      fn a, b, ·ƒ_4:
        ·apply ·op_plus, a, b, fn ·v_4:
          ·ƒ_4 ·v_4
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
yield with non-trivial cont body — hoisting
---

test 'yield — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      yield 42
      1 + 2

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_4, ·ƒ_24:
            ·let ·v_4, fn ·v_6:
              ·apply ·op_plus, 1, 2, fn ·v_2:
                ·ƒ_2 ·v_2
          fn ·ƒ_23:
            ·yield 42, fn ·v_23:
              ·ƒ_23 ·v_23
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
match nodes with non-trivial cont bodies — hoisting
---

test 'seq destructure — MatchDone cont body hoisted', fn:
  expect cont_lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_46:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_42:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_11, ·ƒ_38:
                      ·apply ·op_plus, a, 1, fn ·v_3:
                        ·ƒ_3 ·v_3
                    fn ·ƒ_37:
                      ·match_done ·v_7, ·panic, fn ·v_37:
                        ·ƒ_37 ·v_37
              fn ·ƒ_41:
                ·match_next ·v_5, ·panic, fn ·v_41:
                  ·ƒ_41 ·v_41
          fn ·ƒ_45:
            ·match_seq foo, ·panic, fn ·v_45:
              ·ƒ_45 ·v_45
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
MatchLetVal — plain ident destructure
---

test 'MatchLetVal — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·apply ·op_plus, a, 1, fn ·v_3:
            ·ƒ_3 ·v_3
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchValue — literal pattern
---

test 'MatchValue — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      1 = foo
      foo + 2

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_11, ·ƒ_22:
            ·apply ·op_plus, foo, 2, fn ·v_3:
              ·ƒ_3 ·v_3
          fn ·ƒ_21:
            ·match_value foo, 1, ·panic, fn: ·ƒ_21
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRec + MatchField — record destructure
---

test 'MatchRec/MatchField — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_38:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_34:
                ·let ·v_6, fn x:
                  ·apply ·op_plus, x, 1, fn ·v_3:
                    ·ƒ_3 ·v_3
              fn ·ƒ_33:
                ·match_field ·v_5, 'x', ·panic, fn ·v_33:
                  ·ƒ_33 ·v_33
          fn ·ƒ_37:
            ·match_rec foo, ·panic, fn ·v_37:
              ·ƒ_37 ·v_37
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRest — spread tail in seq
---

test 'MatchRest — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [..rest] = foo
      rest

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_32:
            ·fn
              fn ·v_7, ·ƒ_28:
                ·let ·v_7, fn rest:
                  ·ƒ_3 rest
              fn ·ƒ_27:
                ·match_rest ·v_5, ·panic, fn ·v_27:
                  ·ƒ_27 ·v_27
          fn ·ƒ_31:
            ·match_seq foo, ·panic, fn ·v_31:
              ·ƒ_31 ·v_31
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchNotDone — spread with no binding
---

test 'MatchNotDone — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [a, ..] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_46:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_42:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_18, ·ƒ_38:
                      ·apply ·op_plus, a, 1, fn ·v_3:
                        ·ƒ_3 ·v_3
                    fn ·ƒ_37:
                      ·match_not_done ·v_7, ·panic, fn: ·ƒ_37
              fn ·ƒ_41:
                ·match_next ·v_5, ·panic, fn ·v_41:
                  ·ƒ_41 ·v_41
          fn ·ƒ_45:
            ·match_seq foo, ·panic, fn ·v_45:
              ·ƒ_45 ·v_45
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchBlock — match expression
---

test 'MatchBlock — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn x:
      r = match x:
        1: 10
        2: 20
      r + 1

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·fn
          fn ·v_26, ·ƒ_47:
            ·let ·v_26, fn r:
              ·apply ·op_plus, r, 1, fn ·v_3:
                ·ƒ_3 ·v_3
          fn ·ƒ_46:
            ·match_block x,
              ·match_arm
                fn ·v_12:
                  ·match_value ·v_5, 1, ·ƒ_fail, fn: ·ƒ_11
                fn ·ƒ_11:
                  ·let 10, fn ·v_9:
                    ·ƒ_3 ·v_9
              ·match_arm
                fn ·v_22:
                  ·match_value ·v_5, 2, ·ƒ_fail, fn: ·ƒ_21
                fn ·ƒ_21:
                  ·let 20, fn ·v_19:
                    ·ƒ_3 ·v_19
              fn ·v_46: ·ƒ_46 ·v_46
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchIf body — hoisting
---

test 'MatchIf — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a > 0 = foo
      a * 2 + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·fn
            fn ·v_18, ·ƒ_36:
              ·fn
                fn ·v_10, ·ƒ_32:
                  ·apply ·op_plus, ·v_10, 1, fn ·v_3:
                    ·ƒ_3 ·v_3
                fn ·ƒ_31:
                  ·apply ·op_mul, a, 2, fn ·v_31:
                    ·ƒ_31 ·v_31
            fn ·ƒ_35:
              ·match_if ·op_gt, a, 0, ·panic, fn: ·ƒ_35
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
non-trivial App body — hoisting
---

test 'chained arithmetic — App body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_5, ·ƒ_26:
            ·let ·v_5, fn x:
              ·apply ·op_plus, x, 4, fn ·v_2:
                ·ƒ_2 ·v_2
          fn ·ƒ_25:
            ·apply ·op_mul, 2, 3, fn ·v_25:
              ·ƒ_25 ·v_25
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main



