---
continuation lifting tests
---

# Continuation lifting — hoists inline App continuation bodies into LetFn nodes
# so that every continuation is a named function by the time closure_lifting runs.
#
# Rewrite for App { func, args, cont: Cont::Expr { arg, body } } where body is non-trivial:
#
#   Before:
#     ·apply func, args, fn arg: <non-trivial body>
#
#   After:
#     ·fn fn arg: <non-trivial body>     ← new LetFn (Bind::Cont)
#       fn ·ƒ_N:
#         ·apply func, args, ·ƒ_N        ← App with Cont::Ref(·ƒ_N)
#
# Test format:
#   test 'name', fn:
#     expect cont_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>

{test, equals, expect, fink, cont_lift} = import 'fake!'

---
trivial App body — no hoisting
---

test 'trivial App body (Ret) is unchanged', fn:
  expect cont_lift fink":
    main = fn a, b:
      a + b
  | equals fink":
    ·fn
      fn a, b, ·ƒ_4:
        ·op_plus a, b, fn ·v_4:
          ·ƒ_4 ·v_4
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
yield with non-trivial cont body — hoisting
---

test 'yield — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      yield 42
      1 + 2

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_4, ·ƒ_23:
            ·let ·v_4, fn ·v_6:
              ·op_plus 1, 2, fn ·v_2:
                ·ƒ_2 ·v_2
          fn ·ƒ_22:
            ·yield 42, fn ·v_22:
              ·ƒ_22 ·v_22
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
match nodes with non-trivial cont bodies — hoisting
---

test 'seq destructure — MatchDone cont body hoisted', fn:
  expect cont_lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_44:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_40:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_11, ·ƒ_36:
                      ·op_plus a, 1, fn ·v_3:
                        ·ƒ_3 ·v_3
                    fn ·ƒ_35:
                      ·match_done ·v_7, ·panic, fn ·v_35:
                        ·ƒ_35 ·v_35
              fn ·ƒ_39:
                ·match_next ·v_5, ·panic, fn ·v_39:
                  ·ƒ_39 ·v_39
          fn ·ƒ_43:
            ·match_seq foo, ·panic, fn ·v_43:
              ·ƒ_43 ·v_43
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
MatchLetVal — plain ident destructure
---

test 'MatchLetVal — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·op_plus a, 1, fn ·v_3:
            ·ƒ_3 ·v_3
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchValue — literal pattern
---

test 'MatchValue — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      1 = foo
      foo + 2

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_11, ·ƒ_22:
            ·op_plus foo, 2, fn ·v_3:
              ·ƒ_3 ·v_3
          fn ·ƒ_21:
            ·match_value foo, 1, ·panic, fn: ·ƒ_21 _
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRec + MatchField — record destructure
---

test 'MatchRec/MatchField — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_37:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_33:
                ·let ·v_6, fn x:
                  ·op_plus x, 1, fn ·v_3:
                    ·ƒ_3 ·v_3
              fn ·ƒ_32:
                ·match_field ·v_5, 'x', ·panic, fn ·v_32:
                  ·ƒ_32 ·v_32
          fn ·ƒ_36:
            ·match_rec foo, ·panic, fn ·v_36:
              ·ƒ_36 ·v_36
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchRest — spread tail in seq
---

test 'MatchRest — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [..rest] = foo
      rest

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_30:
            ·fn
              fn ·v_7, ·ƒ_26:
                ·let ·v_7, fn rest:
                  ·ƒ_3 rest
              fn ·ƒ_25:
                ·match_rest ·v_5, ·panic, fn ·v_25:
                  ·ƒ_25 ·v_25
          fn ·ƒ_29:
            ·match_seq foo, ·panic, fn ·v_29:
              ·ƒ_29 ·v_29
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchNotDone — spread with no binding
---

test 'MatchNotDone — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      [a, ..] = foo
      a + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·fn
          fn ·v_5, ·ƒ_44:
            ·fn
              fn ·v_6, ·v_7, ·ƒ_40:
                ·let ·v_6, fn a:
                  ·fn
                    fn ·v_18, ·ƒ_36:
                      ·op_plus a, 1, fn ·v_3:
                        ·ƒ_3 ·v_3
                    fn ·ƒ_35:
                      ·match_not_done ·v_7, ·panic, fn: ·ƒ_35 _
              fn ·ƒ_39:
                ·match_next ·v_5, ·panic, fn ·v_39:
                  ·ƒ_39 ·v_39
          fn ·ƒ_43:
            ·match_seq foo, ·panic, fn ·v_43:
              ·ƒ_43 ·v_43
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchBlock — match expression
---

test 'MatchBlock — cont body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn x:
      r = match x:
        1: 10
        2: 20
      r + 1

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·fn
          fn ·v_32, ·ƒ_59:
            ·let ·v_32, fn r:
              ·op_plus r, 1, fn ·v_3:
                ·ƒ_3 ·v_3
          fn ·ƒ_58:
            ·match_block x,
              ·fn
                fn ·ƒ_11, ·ƒ_51:
                  ·let 10, fn ·v_13:
                    ·ƒ_11 ·v_13
                fn ·ƒ_50:
                  ·match_arm
                    fn ·v_8, ·ƒ_6, ·ƒ_7:
                      ·match_value ·v_8, 1, ·ƒ_6, fn: ·ƒ_7 _
                    fn ·v_50: ·ƒ_50 ·v_50
              ·fn
                fn ·ƒ_24, ·ƒ_55:
                  ·let 20, fn ·v_26:
                    ·ƒ_24 ·v_26
                fn ·ƒ_54:
                  ·match_arm
                    fn ·v_21, ·ƒ_19, ·ƒ_20:
                      ·match_value ·v_21, 2, ·ƒ_19, fn: ·ƒ_20 _
                    fn ·v_54: ·ƒ_54 ·v_54
              fn ·v_58: ·ƒ_58 ·v_58
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchBlock — arm body with non-trivial computation
---

test 'MatchBlock — chained App inside arm body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn n:
      r = match n:
        _:
          x = 1 + 2
          x + 3
      r

  | equals fink":
    ·fn
      fn n, ·ƒ_3:
        ·fn
          fn ·v_28, ·ƒ_50:
            ·let ·v_28, fn r:
              ·ƒ_3 r
          fn ·ƒ_49:
            ·match_block n,
              ·fn
                fn ·ƒ_10, ·ƒ_46:
                  ·fn
                    fn ·v_13, ·ƒ_42:
                      ·let ·v_13, fn x:
                        ·op_plus x, 3, fn ·v_10:
                          ·ƒ_10 ·v_10
                    fn ·ƒ_41:
                      ·op_plus 1, 2, fn ·v_41:
                        ·ƒ_41 ·v_41
                fn ·ƒ_45:
                  ·match_arm
                    fn ·v_8, ·ƒ_6, ·ƒ_7: ·ƒ_7 _
                    fn ·v_45: ·ƒ_45 ·v_45
              fn ·v_49: ·ƒ_49 ·v_49
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main

---
MatchIf body — hoisting
---

test 'MatchIf — body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn foo:
      a > 0 = foo
      a * 2 + 1

  | equals fink":
    ·fn
      fn foo, ·ƒ_3:
        ·let foo, fn a:
          ·fn
            fn ·v_18, ·ƒ_35:
              ·fn
                fn ·v_10, ·ƒ_31:
                  ·op_plus ·v_10, 1, fn ·v_3:
                    ·ƒ_3 ·v_3
                fn ·ƒ_30:
                  ·op_mul a, 2, fn ·v_30:
                    ·ƒ_30 ·v_30
            fn ·ƒ_34:
              ·match_if ·op_gt, a, 0, ·panic, fn: ·ƒ_34 _
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main


---
non-trivial App body — hoisting
---

test 'chained arithmetic — App body hoisted to LetFn', fn:
  expect cont_lift fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn ·v_5, ·ƒ_24:
            ·let ·v_5, fn x:
              ·op_plus x, 4, fn ·v_2:
                ·ƒ_2 ·v_2
          fn ·ƒ_23:
            ·op_mul 2, 3, fn ·v_23:
              ·ƒ_23 ·v_23
      fn ·v_1:
        ·let ·v_1, fn main:
          ·ƒ_0 main



