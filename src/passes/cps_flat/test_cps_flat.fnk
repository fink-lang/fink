---
cps_flat — flat pretty-printer tests
---

# Renders lifted CPS IR as flat assignments instead of deeply nested ·fn/·let.
# Every LetFn/LetVal becomes `name = rhs` at its scope's indent level.

{test, equals, expect, fink, cps_flat} = import 'fake!'


test 'trivial — single fn binding', fn:
  expect cps_flat fink":
    main = fn a, b:
      a + b

  | equals fink":
    main = ·v_1 = fn a, b, ·v_4:
      ·op_plus a, b, ·v_4

    ·v_0 main


test 'seq destructure', fn:
  expect cps_flat fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_62 = fn ·v_60, ·v_5:
      [·v_38, ·v_40] = ·fn_closure ·v_55, ·v_3
      ·match_next ·v_5, panic, ·v_38

    ·v_55 = fn ·v_53, ·v_6, ·v_7:
      a = ·v_6
      [·v_35, ·v_37] = ·fn_closure ·v_48, a, ·v_3
      ·match_done ·v_7, panic, ·v_35

    ·v_48 = fn a, ·v_45, ·v_11:
      ·op_plus a, 1, ·v_3

    main = ·v_1 = fn foo, ·v_3:
      [·v_41, ·v_43] = ·fn_closure ·v_62, ·v_3
      ·match_seq foo, panic, ·v_41

    ·v_0 main


test 'plain ident destructure', fn:
  expect cps_flat fink":
    main = fn foo:
      a = foo
      a + 1

  | equals fink":
    main = ·v_1 = fn foo, ·v_3:
      a = foo
      ·op_plus a, 1, ·v_3

    ·v_0 main


test 'chained arithmetic', fn:
  expect cps_flat fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_28 = fn ·v_26, ·v_5:
      x = ·v_5
      ·op_plus x, 4, ·v_2

    main = ·v_1 = fn ·v_2:
      [·v_23, ·v_25] = ·fn_closure ·v_28, ·v_2
      ·op_mul 2, 3, ·v_23

    ·v_0 main


---
cont_lifting inputs
---

test 'yield', fn:
  expect cps_flat fink":
    main = fn:
      yield 42
      1 + 2

  | equals fink":
    ·v_27 = fn ·v_25, ·v_4:
      ·v_6 = ·v_4
      ·op_plus 1, 2, ·v_2

    main = ·v_1 = fn ·v_2:
      [·v_22, ·v_24] = ·fn_closure ·v_27, ·v_2
      ·yield 42, ·v_22

    ·v_0 main


test 'literal pattern', fn:
  expect cps_flat fink":
    main = fn foo:
      1 = foo
      foo + 2

  | equals fink":
    ·v_28 = fn foo, ·v_25, ·v_11:
      ·op_plus foo, 2, ·v_3

    main = ·v_1 = fn foo, ·v_3:
      [·v_21, ·v_23] = ·fn_closure ·v_28, foo, ·v_3
      ·match_value foo, 1, panic, ·v_21

    ·v_0 main


test 'record destructure', fn:
  expect cps_flat fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_47 = fn ·v_45, ·v_5:
      [·v_32, ·v_34] = ·fn_closure ·v_40, ·v_3
      ·match_field ·v_5, 'x', panic, ·v_32

    ·v_40 = fn ·v_38, ·v_6, ·v_7:
      x = ·v_6
      ·op_plus x, 1, ·v_3

    main = ·v_1 = fn foo, ·v_3:
      [·v_35, ·v_37] = ·fn_closure ·v_47, ·v_3
      ·match_rec foo, panic, ·v_35

    ·v_0 main


test 'spread tail', fn:
  expect cps_flat fink":
    main = fn foo:
      [..rest] = foo
      rest

  | equals fink":
    main = ·v_1 = fn foo, ·v_3:
      ·v_28 = fn ·v_5:
        ·v_25 = fn ·v_7:
          rest = ·v_7
          ·v_3 rest
        ·match_rest ·v_5, panic, ·v_25
      ·match_seq foo, panic, ·v_28

    ·v_0 main


test 'spread no bind', fn:
  expect cps_flat fink":
    main = fn foo:
      [a, ..] = foo
      a + 1

  | equals fink":
    ·v_62 = fn ·v_60, ·v_5:
      [·v_38, ·v_40] = ·fn_closure ·v_55, ·v_3
      ·match_next ·v_5, panic, ·v_38

    ·v_55 = fn ·v_53, ·v_6, ·v_7:
      a = ·v_6
      [·v_35, ·v_37] = ·fn_closure ·v_48, a, ·v_3
      ·match_not_done ·v_7, panic, ·v_35

    ·v_48 = fn a, ·v_45, ·v_18:
      ·op_plus a, 1, ·v_3

    main = ·v_1 = fn foo, ·v_3:
      [·v_41, ·v_43] = ·fn_closure ·v_62, ·v_3
      ·match_seq foo, panic, ·v_41

    ·v_0 main



test 'match block', fn:
  expect cps_flat fink":
    main = fn x:
      r = match x:
        1: 10
        2: 20
      r + 1

  | equals fink":
    ·v_99 = fn ·v_95, x, ·v_18:
      [·v_59, ·v_67] = ·fn_closure ·v_88, ·v_3, x, ·v_18
      ·v_61 = fn ·v_25:
        ·v_27 = 20
        ·v_25 ·v_27
      ·v_63 = fn ·v_22, ·v_20, ·v_21:
        ·match_value ·v_22, 2, ·v_20, ·v_21
      ·match_arm ·v_63, ·v_61, ·v_59

    ·v_79 = fn ·v_77, ·v_34:
      r = ·v_34
      ·op_plus r, 1, ·v_3

    ·v_88 = fn ·v_82, x, ·v_84, ·v_32:
      [·v_56, ·v_58] = ·fn_closure ·v_79, ·v_3
      ·match_block x, ·v_18, ·v_32, ·v_56

    main = ·v_1 = fn x, ·v_3:
      [·v_68, ·v_76] = ·fn_closure ·v_99, ·v_3, x
      ·v_70 = fn ·v_11:
        ·v_13 = 10
        ·v_11 ·v_13
      ·v_72 = fn ·v_8, ·v_6, ·v_7:
        ·match_value ·v_8, 1, ·v_6, ·v_7
      ·match_arm ·v_72, ·v_70, ·v_68

    ·v_0 main


test 'match guard', fn:
  expect cps_flat fink":
    main = fn foo:
      a > 0 = foo
      a * 2 + 1

  | equals fink":
    ·v_38 = fn ·v_36, ·v_10:
      ·op_plus ·v_10, 1, ·v_3

    ·v_45 = fn ·v_41, a, ·v_18:
      [·v_30, ·v_32] = ·fn_closure ·v_38, ·v_3
      ·op_mul a, 2, ·v_30

    main = ·v_1 = fn foo, ·v_3:
      a = foo
      [·v_33, ·v_35] = ·fn_closure ·v_45, ·v_3, a
      ·match_if ·op_gt, a, 0, panic, ·v_33

    ·v_0 main


test 'match chained arm', fn:
  expect cps_flat fink":
    main = fn n:
      r = match n:
        _:
          x = 1 + 2
          x + 3
      r
  | equals fink":
    ·v_61 = fn ·v_59, ·v_13:
      x = ·v_13
      ·op_plus x, 3, ·v_10

    ·v_66 = fn n, ·v_27:
      ·v_44 = fn ·v_29:
        r = ·v_29
        ·v_3 r
      ·match_block n, ·v_27, ·v_44

    main = ·v_1 = fn n, ·v_3:
      [·v_47, ·v_58] = ·fn_closure ·v_66, n
      ·v_52 = fn ·v_10:
        [·v_49, ·v_51] = ·fn_closure ·v_61, ·v_10
        ·op_plus 1, 2, ·v_49
      ·v_54 = fn ·v_8, ·v_6, ·v_7:
        ·v_7 _
      ·match_arm ·v_54, ·v_52, ·v_47

    ·v_0 main


---
closure_lifting inputs
---

test 'pure fn', fn:
  expect cps_flat fink":
    f = fn x: x
  | equals fink":
    f = ·v_1 = fn x, ·v_3:
      ·v_5 = x
      ·v_3 ·v_5

    ·v_0 f


test 'pure nested fn', fn:
  expect cps_flat fink":
    foo = fn a:
      fn b: b

  | equals fink":
    foo = ·v_1 = fn a, ·v_3:
      ·v_4 = fn b, ·v_6:
        ·v_8 = b
        ·v_6 ·v_8
      ·v_3 ·v_4

    ·v_0 foo


test 'captured binding', fn:
  expect cps_flat fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_22 = fn a, b, ·v_6:
      ·op_plus a, b, ·v_6

    foo = ·v_1 = fn a, ·v_3:
      ·v_4 = ·fn_closure ·v_22, a
      ·v_3 ·v_4

    ·v_0 foo


test 'depth-2 closure', fn:
  expect cps_flat fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_56 = fn a, b, ·v_6:
      ·v_7 = ·fn_closure ·v_44, a, b
      ·v_6 ·v_7

    ·v_37 = fn c, ·v_34, ·v_12:
      ·op_plus ·v_12, c, ·v_9

    ·v_44 = fn a, b, c, ·v_9:
      [·v_30, ·v_32] = ·fn_closure ·v_37, c, ·v_9
      ·op_plus a, b, ·v_30

    foo = ·v_1 = fn a, ·v_3:
      ·v_4 = ·fn_closure ·v_56, a
      ·v_3 ·v_4

    ·v_0 foo


test 'multiple captures', fn:
  expect cps_flat fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_39 = fn a, b, ·v_6:
      ·v_7 = ·fn_closure ·v_29, a, b
      ·v_6 ·v_7

    ·v_29 = fn a, b, c, ·v_9:
      ·op_plus a, b, ·v_9

    foo = ·v_1 = fn a, ·v_3:
      ·v_4 = ·fn_closure ·v_39, a
      ·v_3 ·v_4

    ·v_0 foo


test 'two module bindings', fn:
  expect cps_flat fink":
    f = fn x: x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_38 = fn a, b, ·v_16:
      ·op_plus a, b, ·v_16

    ·v_1 = fn ·v_2:
      f = ·v_3 = fn x, ·v_5:
        ·v_7 = x
        ·v_5 ·v_7
      g = ·v_11 = fn a, ·v_13:
        ·v_14 = ·fn_closure ·v_38, a
        ·v_13 ·v_14
      ·v_2 g

    ·v_0 ·v_1


test 'match — no forward refs after lift', fn:
  expect cps_flat fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·v_44 = fn n, ·v_41, ·v_18:
      ·match_block n, ·v_18, ·v_3

    foo = ·v_1 = fn n, ·v_3:
      [·v_31, ·v_39] = ·fn_closure ·v_44, n, ·v_3
      ·v_33 = fn ·v_11:
        ·v_13 = 42
        ·v_11 ·v_13
      ·v_35 = fn ·v_8, ·v_6, ·v_7:
        ·match_value ·v_8, 0, ·v_6, ·v_7
      ·match_arm ·v_35, ·v_33, ·v_31

    ·v_0 foo
