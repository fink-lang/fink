{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'ƒink block with no args', fn:
  expect ast ƒink:
    {ƒink} = import '@fink/parse/blocks.fnk'
    ƒink: 'hello'
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒink'
        Apply
          Ident 'import'
          LitStr '@fink/parse/blocks.fnk'
      Block ':',
        Ident 'ƒink'
        Patterns
        LitStr 'hello'


test 'ƒink block with params and body', fn:
  expect ast ƒink:
    {ƒink} = import '@fink/parse/blocks.fnk'
    ƒink a, b:
      x = a + b
      x * 2
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒink'
        Apply
          Ident 'import'
          LitStr '@fink/parse/blocks.fnk'
      Block ':',
        Ident 'ƒink'
        Patterns
          Ident 'a'
          Ident 'b'
        Bind '=',
          Ident 'x'
          InfixOp '+',
            Ident 'a'
            Ident 'b'
        InfixOp '*',
          Ident 'x'
          LitInt '2'


test 'ƒtok block with no args', fn:
  expect ast ƒink:
    {ƒtok} = import '@fink/parse/blocks.fnk'
    ƒtok: a + b
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒtok'
        Apply
          Ident 'import'
          LitStr '@fink/parse/blocks.fnk'
      Block ':',
        Ident 'ƒtok'
        Patterns
        Token 'a'
        Token '+'
        Token 'b'


test 'ƒtok block with params and body', fn:
  expect ast ƒink:
    {ƒtok} = import '@fink/parse/blocks.fnk'
    ƒtok a, b:
      x = a + b
      x * 2
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒtok'
        Apply
          Ident 'import'
          LitStr '@fink/parse/blocks.fnk'
      Block ':',
        Ident 'ƒtok'
        Patterns
          Ident 'a'
          Ident 'b'
        Token 'x'
        Token '='
        Token 'a'
        Token '+'
        Token 'b'
        Token 'x'
        Token '*'
        Token '2'
