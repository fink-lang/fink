{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


test 'try bare', fn:
  ast ƒink:
    try foo
  | equals ƒink:
    Module
      Try
        Ident 'foo'

test 'try with application', fn:
  ast ƒink:
    try foo bar
  | equals ƒink:
    Module
      Try
        Apply
          Ident 'foo'
          Ident 'bar'

test 'try bound to name', fn:
  ast ƒink:
    a = try open 'file.txt'
  | equals ƒink:
    Module
      Bind '=',
        Ident 'a'
        Try
          Apply
            Ident 'open'
            LitStr 'file.txt'

test 'try in pipe', fn:
  ast ƒink:
    try foo | bar
  | equals ƒink:
    Module
      Pipe
        Try
          Ident 'foo'
        Ident 'bar'
