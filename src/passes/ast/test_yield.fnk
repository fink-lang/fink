---
yield — suspension point for async/generators/channels
---

test 'yield bare', fn:
  expect ast fink":
    yield foo

  | equals fink":
    Module
      Yield
        Ident 'foo'

test 'yield with application', fn:
  expect ast fink":
    yield foo bar

  | equals fink":
    Module
      Yield
        Apply
          Ident 'foo'
          Ident 'bar'

test 'yield bound to name', fn:
  expect ast fink":
    result = yield value

  | equals fink":
    Module
      Bind '=',
        Ident 'result'
        Yield
          Ident 'value'
