{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
yield — suspension point for async/generators/channels
---

test 'yield bare', fn:
  expect ast ƒink:
    yield foo

  | equals ƒink:
    Module
      Yield
        Ident 'foo'

test 'yield with application', fn:
  expect ast ƒink:
    yield foo bar

  | equals ƒink:
    Module
      Yield
        Apply
          Ident 'foo'
          Ident 'bar'

test 'yield bound to name', fn:
  expect ast ƒink:
    result = yield value

  | equals ƒink:
    Module
      Bind '=',
        Ident 'result'
        Yield
          Ident 'value'
