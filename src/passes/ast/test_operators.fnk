{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
arithmetic
---

test 'unary minus', fn:
  expect ast ƒink:
    -a
  | equals ƒink:
    Module
      UnaryOp '-',
        Ident 'a'

test 'add', fn:
  expect ast ƒink:
    a + b
  | equals ƒink:
    Module
      InfixOp '+',
        Ident 'a'
        Ident 'b'

test 'subtract', fn:
  expect ast ƒink:
    a - b
  | equals ƒink:
    Module
      InfixOp '-',
        Ident 'a'
        Ident 'b'

test 'multiply', fn:
  expect ast ƒink:
    a * b
  | equals ƒink:
    Module
      InfixOp '*',
        Ident 'a'
        Ident 'b'

test 'divide', fn:
  expect ast ƒink:
    a / b
  | equals ƒink:
    Module
      InfixOp '/',
        Ident 'a'
        Ident 'b'

test 'integer divide', fn:
  expect ast ƒink:
    a // b
  | equals ƒink:
    Module
      InfixOp '//',
        Ident 'a'
        Ident 'b'

test 'power', fn:
  expect ast ƒink:
    a ** b
  | equals ƒink:
    Module
      InfixOp '**',
        Ident 'a'
        Ident 'b'

test 'remainder', fn:
  expect ast ƒink:
    a % b
  | equals ƒink:
    Module
      InfixOp '%',
        Ident 'a'
        Ident 'b'

test 'true modulus', fn:
  expect ast ƒink:
    a %% b
  | equals ƒink:
    Module
      InfixOp '%%',
        Ident 'a'
        Ident 'b'

test 'divmod', fn:
  expect ast ƒink:
    a /% b
  | equals ƒink:
    Module
      InfixOp '/%',
        Ident 'a'
        Ident 'b'

test 'power is right associative', fn:
  expect ast ƒink:
    a ** b ** c
  | equals ƒink:
    Module
      InfixOp '**',
        Ident 'a'
        InfixOp '**',
          Ident 'b'
          Ident 'c'

test 'multiply binds tighter than add', fn:
  expect ast ƒink:
    a + b * c
  | equals ƒink:
    Module
      InfixOp '+',
        Ident 'a'
        InfixOp '*',
          Ident 'b'
          Ident 'c'


---
logical
---

test 'not', fn:
  expect ast ƒink:
    not a
  | equals ƒink:
    Module
      UnaryOp 'not',
        Ident 'a'

test 'and', fn:
  expect ast ƒink:
    a and b
  | equals ƒink:
    Module
      InfixOp 'and',
        Ident 'a'
        Ident 'b'

test 'or', fn:
  expect ast ƒink:
    a or b
  | equals ƒink:
    Module
      InfixOp 'or',
        Ident 'a'
        Ident 'b'

test 'xor', fn:
  expect ast ƒink:
    a xor b
  | equals ƒink:
    Module
      InfixOp 'xor',
        Ident 'a'
        Ident 'b'

test 'not binds tighter than and', fn:
  expect ast ƒink:
    not a and not b
  | equals ƒink:
    Module
      InfixOp 'and',
        UnaryOp 'not',
          Ident 'a'
        UnaryOp 'not',
          Ident 'b'

test 'and binds tighter than or', fn:
  expect ast ƒink:
    a or b and c
  | equals ƒink:
    Module
      InfixOp 'or',
        Ident 'a'
        InfixOp 'and',
          Ident 'b'
          Ident 'c'

test 'add binds tighter than and', fn:
  expect ast ƒink:
    a + b and c + d
  | equals ƒink:
    Module
      InfixOp 'and',
        InfixOp '+',
          Ident 'a'
          Ident 'b'
        InfixOp '+',
          Ident 'c'
          Ident 'd'


---
comparison
---

test 'greater than', fn:
  expect ast ƒink:
    a > b
  | equals ƒink:
    Module
      InfixOp '>',
        Ident 'a'
        Ident 'b'

test 'greater than or equal', fn:
  expect ast ƒink:
    a >= b
  | equals ƒink:
    Module
      InfixOp '>=',
        Ident 'a'
        Ident 'b'

test 'less than', fn:
  expect ast ƒink:
    a < b
  | equals ƒink:
    Module
      InfixOp '<',
        Ident 'a'
        Ident 'b'

test 'less than or equal', fn:
  expect ast ƒink:
    a <= b
  | equals ƒink:
    Module
      InfixOp '<=',
        Ident 'a'
        Ident 'b'

test 'equal', fn:
  expect ast ƒink:
    a == b
  | equals ƒink:
    Module
      InfixOp '==',
        Ident 'a'
        Ident 'b'

test 'not equal', fn:
  expect ast ƒink:
    a != b
  | equals ƒink:
    Module
      InfixOp '!=',
        Ident 'a'
        Ident 'b'

test 'chained comparison same op', fn:
  expect ast ƒink:
    a > b > c
  | equals ƒink:
    Module
      ChainedCmp
        Ident 'a'
        '>'
        Ident 'b'
        '>'
        Ident 'c'

test 'chained comparison mixed ops', fn:
  expect ast ƒink:
    a >= b > c
  | equals ƒink:
    Module
      ChainedCmp
        Ident 'a'
        '>='
        Ident 'b'
        '>'
        Ident 'c'

test 'containment', fn:
  expect ast ƒink:
    a in b
  | equals ƒink:
    Module
      InfixOp 'in',
        Ident 'a'
        Ident 'b'

test 'not containment', fn:
  expect ast ƒink:
    a not in b
  | equals ƒink:
    Module
      InfixOp 'not in',
        Ident 'a'
        Ident 'b'

test 'disjoint', fn:
  expect ast ƒink:
    a >< b
  | equals ƒink:
    Module
      InfixOp '><',
        Ident 'a'
        Ident 'b'

test 'comparison binds tighter than and', fn:
  expect ast ƒink:
    a > 0 and b < 10
  | equals ƒink:
    Module
      InfixOp 'and',
        InfixOp '>',
          Ident 'a'
          LitInt '0'
        InfixOp '<',
          Ident 'b'
          LitInt '10'


---
bitwise
---

test 'bitwise not', fn:
  expect ast ƒink:
    ~a
  | equals ƒink:
    Module
      UnaryOp '~',
        Ident 'a'

test 'bitwise and', fn:
  expect ast ƒink:
    a & b
  | equals ƒink:
    Module
      InfixOp '&',
        Ident 'a'
        Ident 'b'

test 'bitwise xor', fn:
  expect ast ƒink:
    a ^ b
  | equals ƒink:
    Module
      InfixOp '^',
        Ident 'a'
        Ident 'b'

test 'shift right', fn:
  expect ast ƒink:
    a >> b
  | equals ƒink:
    Module
      InfixOp '>>',
        Ident 'a'
        Ident 'b'

test 'shift left', fn:
  expect ast ƒink:
    a << b
  | equals ƒink:
    Module
      InfixOp '<<',
        Ident 'a'
        Ident 'b'

test 'rotate right', fn:
  expect ast ƒink:
    a >>> b
  | equals ƒink:
    Module
      InfixOp '>>>',
        Ident 'a'
        Ident 'b'

test 'rotate left', fn:
  expect ast ƒink:
    a <<< b
  | equals ƒink:
    Module
      InfixOp '<<<',
        Ident 'a'
        Ident 'b'


---
member access
---

test 'member by name', fn:
  expect ast ƒink:
    foo.bar
  | equals ƒink:
    Module
      Member '.',
        Ident 'foo'
        Ident 'bar'

test 'chained member access', fn:
  expect ast ƒink:
    foo.bar.spam
  | equals ƒink:
    Module
      Member '.',
        Member '.',
          Ident 'foo'
          Ident 'bar'
        Ident 'spam'

test 'member by hyphenated name', fn:
  expect ast ƒink:
    foo.bar-spam
  | equals ƒink:
    Module
      Member '.',
        Ident 'foo'
        Ident 'bar-spam'

test 'member by expression', fn:
  expect ast ƒink:
    foo.(expr)
  | equals ƒink:
    Module
      Member '.',
        Ident 'foo'
        Group '(..)',
          Ident 'expr'

test 'sequence index', fn:
  expect ast ƒink:
    [1, 2, 3].(0)
  | equals ƒink:
    Module
      Member '.',
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'
        Group '(..)',
          LitInt '0'

test 'sequence range slice', fn:
  expect ast ƒink:
    [0, 1, 2, 3, 4].(2...3)
  | equals ƒink:
    Module
      Member '.',
        LitSeq '[..]',
          LitInt '0'
          LitInt '1'
          LitInt '2'
          LitInt '3'
          LitInt '4'
        Group '(..)',
          InfixOp '...',
            LitInt '2'
            LitInt '3'

test 'ident range', fn:
  expect ast ƒink:
    start..end
  | equals ƒink:
    Module
      InfixOp '..',
        Ident 'start'
        Ident 'end'

test 'member access on record literal', fn:
  expect ast ƒink:
    {foo: 123}.foo
  | equals ƒink:
    Module
      Member '.',
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            LitInt '123'
        Ident 'foo'

test 'member by string key', fn:
  expect ast ƒink:
    {'ni nu': 123}.('ni nu')
  | equals ƒink:
    Module
      Member '.',
        LitRec '{..}',
          Arm ':',
            LitStr 'ni nu'
            LitInt '123'
        Group '(..)',
          LitStr 'ni nu'

test 'member by sequence key', fn:
  expect ast ƒink:
    [0, 1, 2, 3, 4].([2, 3])
  | equals ƒink:
    Module
      Member '.',
        LitSeq '[..]',
          LitInt '0'
          LitInt '1'
          LitInt '2'
          LitInt '3'
          LitInt '4'
        Group '(..)',
          LitSeq '[..]',
            LitInt '2'
            LitInt '3'


test 'infix rhs multiline block application', fn:
  expect ast ƒink:
    [3, 7] == seq
      add 1, 2
      add 3, 4
  | equals ƒink:
    Module
      InfixOp '==',
        LitSeq '[..]',
          LitInt '3'
          LitInt '7'
        Apply
          Ident 'seq'
          Apply
            Ident 'add'
            LitInt '1'
            LitInt '2'
          Apply
            Ident 'add'
            LitInt '3'
            LitInt '4'

---
operator vs application precedence
`a - add b` should parse as `a - (add b)`, not `(a - add) b`
---

test 'subtract with call rhs', fn:
  expect ast ƒink:
    a - add b
  | equals ƒink:
    Module
      InfixOp '-',
        Ident 'a'
        Apply
          Ident 'add'
          Ident 'b'


test 'add with multi-arg call rhs', fn:
  expect ast ƒink:
    a + foo 1, 2
  | equals ƒink:
    Module
      InfixOp '+',
        Ident 'a'
        Apply
          Ident 'foo'
          LitInt '1'
          LitInt '2'


test 'call rhs with trailing infix', fn:
  expect ast ƒink:
    a - foo b + c
  | equals ƒink:
    Module
      InfixOp '-',
        Ident 'a'
        Apply
          Ident 'foo'
          InfixOp '+',
            Ident 'b'
            Ident 'c'


test 'call on both sides of infix', fn:
  expect ast ƒink:
    foo a - bar b
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        InfixOp '-',
          Ident 'a'
          Apply
            Ident 'bar'
            Ident 'b'


test 'multiply with call rhs', fn:
  expect ast ƒink:
    a * foo b
  | equals ƒink:
    Module
      InfixOp '*',
        Ident 'a'
        Apply
          Ident 'foo'
          Ident 'b'
