{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


test 'true', fn:
  ast ƒink:
    true
  | equals ƒink:
    Module
      LitBool true

test 'false', fn:
  ast ƒink:
    false
  | equals ƒink:
    Module
      LitBool false


---
integers
---

test 'integer', fn:
  ast ƒink:
    1_234_567
  | equals ƒink:
    Module
      LitInt '1_234_567'

test 'positive signed', fn:
  ast ƒink:
    +1
  | equals ƒink:
    Module
      LitInt '+1'

test 'negative signed', fn:
  ast ƒink:
    -1
  | equals ƒink:
    Module
      LitInt '-1'

test 'hex', fn:
  ast ƒink:
    0xFFFF_FFFF
  | equals ƒink:
    Module
      LitInt '0xFFFF_FFFF'

test 'positive signed hex', fn:
  ast ƒink:
    +0xFFFF_FFFF
  | equals ƒink:
    Module
      LitInt '+0xFFFF_FFFF'

test 'negative signed hex', fn:
  ast ƒink:
    -0xFFFF_FFFF
  | equals ƒink:
    Module
      LitInt '-0xFFFF_FFFF'

test 'octal', fn:
  ast ƒink:
    0o_1234_5670
  | equals ƒink:
    Module
      LitInt '0o_1234_5670'

test 'positive signed octal', fn:
  ast ƒink:
    +0o_1234_5670
  | equals ƒink:
    Module
      LitInt '+0o_1234_5670'

test 'negative signed octal', fn:
  ast ƒink:
    -0o_1234_5670
  | equals ƒink:
    Module
      LitInt '-0o_1234_5670'

test 'binary', fn:
  ast ƒink:
    0b_0101_1111
  | equals ƒink:
    Module
      LitInt '0b_0101_1111'

test 'positive signed binary', fn:
  ast ƒink:
    +0b_0101_1111
  | equals ƒink:
    Module
      LitInt '+0b_0101_1111'

test 'negative signed binary', fn:
  ast ƒink:
    -0b_0101_1111
  | equals ƒink:
    Module
      LitInt '-0b_0101_1111'

test 'positive signed with underscores', fn:
  ast ƒink:
    +1_234_567
  | equals ƒink:
    Module
      LitInt '+1_234_567'

test 'negative signed with underscores', fn:
  ast ƒink:
    -1_234_567
  | equals ƒink:
    Module
      LitInt '-1_234_567'


---
floats
---

test 'simple float', fn:
  ast ƒink:
    1.0
  | equals ƒink:
    Module
      LitFloat '1.0'

test 'float with exponent', fn:
  ast ƒink:
    1.0e100_000
  | equals ƒink:
    Module
      LitFloat '1.0e100_000'


---
decimals
---

test 'simple decimal', fn:
  ast ƒink:
    1.0d
  | equals ƒink:
    Module
      LitDecimal '1.0d'

test 'decimal with negative exponent', fn:
  ast ƒink:
    1.0d-100
  | equals ƒink:
    Module
      LitDecimal '1.0d-100'


---
strings
---

test 'simple string', fn:
  ast ƒink:
    'hello world'
  | equals ƒink:
    Module
      LitStr 'hello world'

test 'string escape sequences', fn:
  ast ƒink:
    '\n\t\r\\\''
  | equals ƒink:
    Module
      LitStr '\\n\\t\\r\\\\\\\''

test 'string vertical tab backspace formfeed', fn:
  ast ƒink:
    '\v\b\f'
  | equals ƒink:
    Module
      LitStr '\\v\\b\\f'

test 'string hex escape', fn:
  ast ƒink:
    '\x41\x42'
  | equals ƒink:
    Module
      LitStr '\\x41\\x42'

test 'string unicode escape', fn:
  ast ƒink:
    '\u0041\u0042'
  | equals ƒink:
    Module
      LitStr '\\u0041\\u0042'

test 'multiline string', fn:
  ast ƒink:
    '
      hello
      world
    '
  | equals ƒink:
    Module
      LitStr '\nhello\nworld\n'

test 'string interpolation', fn:
  ast ƒink:
    'hello ${1 + 2}'
  | equals ƒink:
    Module
      StrTempl
        LitStr 'hello '
        InfixOp '+',
          LitInt '1'
          LitInt '2'

test 'string interpolation leading expression', fn:
  ast ƒink:
    '${1 + 2} world'
  | equals ƒink:
    Module
      StrTempl
        InfixOp '+',
          LitInt '1'
          LitInt '2'
        LitStr ' world'

test 'tagged template string', fn:
  ast ƒink:
    fmt'hello ${1 + 2}'
  | equals ƒink:
    Module
      Apply
        Ident 'fmt'
        StrRawTempl
          LitStr 'hello '
          InfixOp '+',
            LitInt '1'
            LitInt '2'

test 'tagged template string in argument position', fn:
  ast ƒink:
    store env, id'foo', v
  | equals ƒink:
    Module
      Apply
        Ident 'store'
        Ident 'env'
        Apply
          Ident 'id'
          StrRawTempl
            LitStr 'foo'
        Ident 'v'

test 'tagged template as the sole nested-apply argument', fn:
  ast ƒink:
    foo bar'spam'
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Apply
          Ident 'bar'
          StrRawTempl
            LitStr 'spam'

test 'tagged block-string as the sole nested-apply argument', fn:
  ast ƒink:
    foo bar":
      spam
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Apply
          Ident 'bar'
          StrRawTempl
            LitStr 'spam'

--- A tagged block-string stays raw even when it is the SECOND block-string
    argument in a multi-line arg list. The second one degraded to a plain
    (cooked) LitStr instead of StrRawTempl. ---
test 'second tagged block-string arg stays raw', fn:
  ast ƒink:
    equals
      bar":
        spam
      foo bar":
        spam
  | equals ƒink:
    Module
      Apply
        Ident 'equals'
        Apply
          Ident 'bar'
          StrRawTempl
            LitStr 'spam'
        Apply
          Ident 'foo'
          Apply
            Ident 'bar'
            StrRawTempl
              LitStr 'spam'

test 'rendered template string', fn:
  ast ƒink:
    fmt 'hello ${1 + 2}'
  | equals ƒink:
    Module
      Apply
        Ident 'fmt'
        StrTempl
          LitStr 'hello '
          InfixOp '+',
            LitInt '1'
            LitInt '2'


test 'block string basic', fn:
  ast ƒink:
    ":
      hello world
  | equals ƒink:
    Module
      LitStr 'hello world'

test 'block string multiline', fn:
  ast ƒink:
    ":
      hello
      world
  | equals ƒink:
    Module
      LitStr 'hello\nworld'

test 'block string blank line', fn:
  ast ƒink:
    ":
      foo

      bar
  | equals ƒink:
    Module
      LitStr 'foo\n\nbar'

test 'block string indentation preserved', fn:
  ast ƒink:
    ":
      foo

        bar
  | equals ƒink:
    Module
      LitStr 'foo\n\n  bar'

test 'block string interpolation', fn:
  ast ƒink:
    ":
      hello ${name}
  | equals ƒink:
    Module
      StrTempl
        LitStr 'hello '
        Ident 'name'


test 'block string interpolation nested in block', fn:
  ast ƒink:
    fn:
      fn:
        ":
          hello ${name}
      bar
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        Fn ':',
          Patterns
          StrTempl
            LitStr 'hello '
            Ident 'name'
        Ident 'bar'


---
tuples/list
---

test 'empty sequence', fn:
  ast ƒink:
    []
  | equals ƒink:
    Module
      LitSeq '[..]'

test 'sequence literal', fn:
  ast ƒink:
    [1, 2, 3]
  | equals ƒink:
    Module
      LitSeq '[..]',
        LitInt '1'
        LitInt '2'
        LitInt '3'

test 'sequence constructor', fn:
  ast ƒink:
    seq 1, 2, 3
  | equals ƒink:
    Module
      Apply
        Ident 'seq'
        LitInt '1'
        LitInt '2'
        LitInt '3'

test 'multiline sequence constructor', fn:
  ast ƒink:
    seq
      1
      2
      seq 3, 4
  | equals ƒink:
    Module
      Apply
        Ident 'seq'
        LitInt '1'
        LitInt '2'
        Apply
          Ident 'seq'
          LitInt '3'
          LitInt '4'


---
records/dict syntax
---

test 'empty record', fn:
  ast ƒink:
    {}
  | equals ƒink:
    Module
      LitRec '{..}'

test 'record literal', fn:
  ast ƒink:
    {foo: 1, bar: 2}
  | equals ƒink:
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          LitInt '1'
        Arm ':',
          Ident 'bar'
          LitInt '2'


test 'multiline record', fn:
  ast ƒink:
    {
      foo: 1
      bar: {
        spam: 3
      }
    }
  | equals ƒink:
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          LitInt '1'
        Arm ':',
          Ident 'bar'
          LitRec '{..}',
            Arm ':',
              Ident 'spam'
              LitInt '3'

test 'record shorthand fields', fn:
  ast ƒink:
    {foo, bar}
  | equals ƒink:
    Module
      LitRec '{..}',
        Ident 'foo'
        Ident 'bar'


---
dicts
---
test 'dict with computed key', fn:
  ast ƒink:
    {(a + b): 3}
  | equals ƒink:
    Module
      LitRec '{..}',
        Arm ':',
          Group '(..)',
            InfixOp '+',
              Ident 'a'
              Ident 'b'
          LitInt '3'


# TODO investigate dict type/contructor
test 'dict literal', fn:
  ast ƒink:
    dict {foo: 1, 'bar': 2, (key): 3}
  | equals ƒink:
    Module
      Apply
        Ident 'dict'
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            LitInt '1'
          Arm ':',
            LitStr 'bar'
            LitInt '2'
          Arm ':',
            Group '(..)',
              Ident 'key'
            LitInt '3'


---
tagged literals
---

test 'integer tagged literal', fn:
  ast ƒink:
    10sec
  | equals ƒink:
    Module
      Apply
        Ident 'sec'
        LitInt '10'

test 'float tagged literal', fn:
  ast ƒink:
    10.5min
  | equals ƒink:
    Module
      Apply
        Ident 'min'
        LitFloat '10.5'

test 'grouped tagged literal', fn:
  ast ƒink:
    (foo)min
  | equals ƒink:
    Module
      Apply
        Ident 'min'
        Group '(..)',
          Ident 'foo'

test 'grouped expression tagged literal', fn:
  ast ƒink:
    (1 + 2)foo
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Group '(..)',
          InfixOp '+',
            LitInt '1'
            LitInt '2'

test 'sequence tagged literal', fn:
  ast ƒink:
    [1, 2, 3]foo
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'

test 'record tagged literal', fn:
  ast ƒink:
    {foo: bar}spam
  | equals ƒink:
    Module
      Apply
        Ident 'spam'
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            Ident 'bar'
