
test 'true', fn:
  expect ast fink":
    true
  | equals fink":
    Module
      LitBool true

test 'false', fn:
  expect ast fink":
    false
  | equals fink":
    Module
      LitBool false


---
integers
---

test 'integer', fn:
  expect ast fink":
    1_234_567
  | equals fink":
    Module
      LitInt '1_234_567'

test 'positive signed', fn:
  expect ast fink":
    +1
  | equals fink":
    Module
      LitInt '+1'

test 'negative signed', fn:
  expect ast fink":
    -1
  | equals fink":
    Module
      LitInt '-1'

test 'hex', fn:
  expect ast fink":
    0xFFFF_FFFF
  | equals fink":
    Module
      LitInt '0xFFFF_FFFF'

test 'positive signed hex', fn:
  expect ast fink":
    +0xFFFF_FFFF
  | equals fink":
    Module
      LitInt '+0xFFFF_FFFF'

test 'negative signed hex', fn:
  expect ast fink":
    -0xFFFF_FFFF
  | equals fink":
    Module
      LitInt '-0xFFFF_FFFF'

test 'octal', fn:
  expect ast fink":
    0o_1234_5670
  | equals fink":
    Module
      LitInt '0o_1234_5670'

test 'positive signed octal', fn:
  expect ast fink":
    +0o_1234_5670
  | equals fink":
    Module
      LitInt '+0o_1234_5670'

test 'negative signed octal', fn:
  expect ast fink":
    -0o_1234_5670
  | equals fink":
    Module
      LitInt '-0o_1234_5670'

test 'binary', fn:
  expect ast fink":
    0b_0101_1111
  | equals fink":
    Module
      LitInt '0b_0101_1111'

test 'positive signed binary', fn:
  expect ast fink":
    +0b_0101_1111
  | equals fink":
    Module
      LitInt '+0b_0101_1111'

test 'negative signed binary', fn:
  expect ast fink":
    -0b_0101_1111
  | equals fink":
    Module
      LitInt '-0b_0101_1111'

test 'positive signed with underscores', fn:
  expect ast fink":
    +1_234_567
  | equals fink":
    Module
      LitInt '+1_234_567'

test 'negative signed with underscores', fn:
  expect ast fink":
    -1_234_567
  | equals fink":
    Module
      LitInt '-1_234_567'


---
floats
---

test 'simple float', fn:
  expect ast fink":
    1.0
  | equals fink":
    Module
      LitFloat '1.0'

test 'float with exponent', fn:
  expect ast fink":
    1.0e100_000
  | equals fink":
    Module
      LitFloat '1.0e100_000'


---
decimals
---

test 'simple decimal', fn:
  expect ast fink":
    1.0d
  | equals fink":
    Module
      LitDecimal '1.0d'

test 'decimal with negative exponent', fn:
  expect ast fink":
    1.0d-100
  | equals fink":
    Module
      LitDecimal '1.0d-100'


---
strings
---

test 'simple string', fn:
  expect ast fink":
    'hello world'
  | equals fink":
    Module
      LitStr 'hello world'

test 'string escape sequences', fn:
  expect ast fink":
    '\n\t\r\\\''
  | equals fink":
    Module
      LitStr '\\n\\t\\r\\\\\\\''

test 'string vertical tab backspace formfeed', fn:
  expect ast fink":
    '\v\b\f'
  | equals fink":
    Module
      LitStr '\\v\\b\\f'

test 'string hex escape', fn:
  expect ast fink":
    '\x41\x42'
  | equals fink":
    Module
      LitStr '\\x41\\x42'

test 'string unicode escape', fn:
  expect ast fink":
    '\u0041\u0042'
  | equals fink":
    Module
      LitStr '\\u0041\\u0042'

test 'multiline string', fn:
  expect ast fink":
    '
      hello
      world
    '
  | equals fink":
    Module
      LitStr '\nhello\nworld\n'

test 'string interpolation', fn:
  expect ast fink":
    'hello \${1 + 2}'
  | equals fink":
    Module
      StrTempl
        LitStr 'hello '
        InfixOp '+',
          LitInt '1'
          LitInt '2'

test 'string interpolation leading expression', fn:
  expect ast fink":
    '\${1 + 2} world'
  | equals fink":
    Module
      StrTempl
        InfixOp '+',
          LitInt '1'
          LitInt '2'
        LitStr ' world'

test 'tagged template string', fn:
  expect ast fink":
    fmt'hello \${1 + 2}'
  | equals fink":
    Module
      Apply
        Ident 'fmt'
        StrRawTempl
          LitStr 'hello '
          InfixOp '+',
            LitInt '1'
            LitInt '2'

test 'tagged template string in argument position', fn:
  expect ast fink":
    store env, id'foo', v
  | equals fink":
    Module
      Apply
        Ident 'store'
        Ident 'env'
        Apply
          Ident 'id'
          StrRawTempl
            LitStr 'foo'
        Ident 'v'

test 'rendered template string', fn:
  expect ast fink":
    fmt 'hello \${1 + 2}'
  | equals fink":
    Module
      Apply
        Ident 'fmt'
        StrTempl
          LitStr 'hello '
          InfixOp '+',
            LitInt '1'
            LitInt '2'


test 'block string basic', fn:
  expect ast fink":
    ":
      hello world
  | equals fink":
    Module
      LitStr 'hello world'

test 'block string multiline', fn:
  expect ast fink":
    ":
      hello
      world
  | equals fink":
    Module
      LitStr 'hello\nworld'

test 'block string blank line', fn:
  expect ast fink":
    ":
      foo

      bar
  | equals fink":
    Module
      LitStr 'foo\n\nbar'

test 'block string indentation preserved', fn:
  expect ast fink":
    ":
      foo

        bar
  | equals fink":
    Module
      LitStr 'foo\n\n  bar'

test 'block string interpolation', fn:
  expect ast fink":
    ":
      hello \${name}
  | equals fink":
    Module
      StrTempl
        LitStr 'hello '
        Ident 'name'


---
sequences
---

test 'empty sequence', fn:
  expect ast fink":
    []
  | equals fink":
    Module
      LitSeq '[..]'

test 'sequence literal', fn:
  expect ast fink":
    [1, 2, 3]
  | equals fink":
    Module
      LitSeq '[..]',
        LitInt '1'
        LitInt '2'
        LitInt '3'

test 'sequence constructor', fn:
  expect ast fink":
    seq 1, 2, 3
  | equals fink":
    Module
      Apply
        Ident 'seq'
        LitInt '1'
        LitInt '2'
        LitInt '3'

test 'multiline sequence constructor', fn:
  expect ast fink":
    seq
      1
      2
      seq 3, 4
  | equals fink":
    Module
      Apply
        Ident 'seq'
        LitInt '1'
        LitInt '2'
        Apply
          Ident 'seq'
          LitInt '3'
          LitInt '4'


---
records
---

test 'empty record', fn:
  expect ast fink":
    {}
  | equals fink":
    Module
      LitRec '{..}'

test 'record literal', fn:
  expect ast fink":
    {foo: 1, bar: 2}
  | equals fink":
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          LitInt '1'
        Arm ':',
          Ident 'bar'
          LitInt '2'

test 'record with computed key', fn:
  expect ast fink":
    {(a + b): 3}
  | equals fink":
    Module
      LitRec '{..}',
        Arm ':',
          Group '(..)',
            InfixOp '+',
              Ident 'a'
              Ident 'b'
          LitInt '3'

test 'multiline record', fn:
  expect ast fink":
    {
      foo: 1
      bar: {
        spam: 3
      }
    }
  | equals fink":
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          LitInt '1'
        Arm ':',
          Ident 'bar'
          LitRec '{..}',
            Arm ':',
              Ident 'spam'
              LitInt '3'

test 'record shorthand fields', fn:
  expect ast fink":
    {foo, bar}
  | equals fink":
    Module
      LitRec '{..}',
        Ident 'foo'
        Ident 'bar'


---
dicts
---

test 'dict literal', fn:
  expect ast fink":
    dict {foo: 1, 'bar': 2, (key): 3}
  | equals fink":
    Module
      Apply
        Ident 'dict'
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            LitInt '1'
          Arm ':',
            LitStr 'bar'
            LitInt '2'
          Arm ':',
            Group '(..)',
              Ident 'key'
            LitInt '3'


---
tagged literals
---

test 'integer tagged literal', fn:
  expect ast fink":
    10sec
  | equals fink":
    Module
      Apply
        Ident 'sec'
        LitInt '10'

test 'float tagged literal', fn:
  expect ast fink":
    10.5min
  | equals fink":
    Module
      Apply
        Ident 'min'
        LitFloat '10.5'

# TODO: bug — Group node is stripped by parse_atom postfix tag path (line ~1279 in parser.rs)
# should be: Apply, Ident 'min', Group '(..)', Ident 'foo'
test 'grouped tagged literal', fn:
  expect ast fink":
    (foo)min
  | equals fink":
    Module
      Apply
        Ident 'min'
        Group '(..)',
          Ident 'foo'

test 'grouped expression tagged literal', fn:
  expect ast fink":
    (1 + 2)foo
  | equals fink":
    Module
      Apply
        Ident 'foo'
        Group '(..)',
          InfixOp '+',
            LitInt '1'
            LitInt '2'

test 'sequence tagged literal', fn:
  expect ast fink":
    [1, 2, 3]foo
  | equals fink":
    Module
      Apply
        Ident 'foo'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'

test 'record tagged literal', fn:
  expect ast fink":
    {foo: bar}spam
  | equals fink":
    Module
      Apply
        Ident 'spam'
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            Ident 'bar'


