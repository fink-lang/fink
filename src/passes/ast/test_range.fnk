{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
range
---

test 'ident range', fn:
  expect ast ƒink:
    start..end
  | equals ƒink:
    Module
      InfixOp '..',
        Ident 'start'
        Ident 'end'


test 'ident incl range', fn:
  expect ast ƒink:
    start...end
  | equals ƒink:
    Module
      InfixOp '...',
        Ident 'start'
        Ident 'end'


test 'open range exclusive from ident', fn:
  expect ast ƒink:
    start..
  | equals ƒink:
    Module
      PostfixOp '..',
        Ident 'start'


test 'open range exclusive from int', fn:
  expect ast ƒink:
    0..
  | equals ƒink:
    Module
      PostfixOp '..',
        LitInt '0'

test 'open range in seq literal sole element', fn:
  expect ast ƒink:
    [0..]
  | equals ƒink:
    Module
      LitSeq '[..]',
        PostfixOp '..',
          LitInt '0'


test 'open range in seq literal last element', fn:
  expect ast ƒink:
    [1, 2, 3, 0..]
  | equals ƒink:
    Module
      LitSeq '[..]',
        LitInt '1'
        LitInt '2'
        LitInt '3'
        PostfixOp '..',
          LitInt '0'


test 'open range parenthesised', fn:
  expect ast ƒink:
    (0..)
  | equals ƒink:
    Module
      Group '(..)',
        PostfixOp '..',
          LitInt '0'


test 'open range as fn arg', fn:
  expect ast ƒink:
    foo 0..
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        PostfixOp '..',
          LitInt '0'


test 'open range as first of multiple fn args', fn:
  expect ast ƒink:
    foo 0.., 1
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        PostfixOp '..',
          LitInt '0'
        LitInt '1'


test 'open range as slice index', fn:
  expect ast ƒink:
    xs.(0..)
  | equals ƒink:
    Module
      Member '.',
        Ident 'xs'
        Group '(..)',
          PostfixOp '..',
            LitInt '0'


test 'multiple open ranges in seq literal', fn:
  expect ast ƒink:
    [0.., 1..]
  | equals ƒink:
    Module
      LitSeq '[..]',
        PostfixOp '..',
          LitInt '0'
        PostfixOp '..',
          LitInt '1'


test 'open range in record arm value', fn:
  expect ast ƒink:
    {r: 0..}
  | equals ƒink:
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'r'
          PostfixOp '..',
            LitInt '0'
