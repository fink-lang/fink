{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


---
spread
---

test 'spread into sequence', fn:
  ast ƒink:
    [head, ..tail]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Ident 'head'
        Spread '..',
          Ident 'tail'

test 'spread concat sequences', fn:
  ast ƒink:
    [..seq1, ..seq2]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..',
          Ident 'seq1'
        Spread '..',
          Ident 'seq2'

test 'spread into record', fn:
  ast ƒink:
    {foo: bar, ..rest}
  | equals ƒink:
    Module
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          Ident 'bar'
        Spread '..',
          Ident 'rest'

test 'spread merge records', fn:
  ast ƒink:
    {..rec1, ..rec2}
  | equals ƒink:
    Module
      LitRec '{..}',
        Spread '..',
          Ident 'rec1'
        Spread '..',
          Ident 'rec2'

test 'bare spread in sequence pattern', fn:
  ast ƒink:
    [..]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..'


test 'bare triple spread in sequence pattern', fn:
  ast ƒink:
    [...]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '...'


test 'bare spread in record pattern', fn:
  ast ƒink:
    {..}
  | equals ƒink:
    Module
      LitRec '{..}',
        Spread '..'

test 'spread with range guard', fn:
  ast ƒink:
    [head, ..(0..2), ..rest]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Ident 'head'
        Spread '..',
          Group '(..)',
            InfixOp '..',
              LitInt '0'
              LitInt '2'
        Spread '..',
          Ident 'rest'

test 'spread with function guard', fn:
  ast ƒink:
    [..(is_odd), ..evens]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..',
          Group '(..)',
            Ident 'is_odd'
        Spread '..',
          Ident 'evens'

test 'spread with range expression guard', fn:
  ast ƒink:
    [..(1 + 2)..(3 + 4)]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..',
          InfixOp '..',
            Group '(..)',
              InfixOp '+',
                LitInt '1'
                LitInt '2'
            Group '(..)',
              InfixOp '+',
                LitInt '3'
                LitInt '4'

test 'spread with ident range guard', fn:
  ast ƒink:
    [..foo...bar]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..',
          InfixOp '...',
            Ident 'foo'
            Ident 'bar'

test 'spread with bare range guard', fn:
  ast ƒink:
    [head, ..0..2, ..rest]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Ident 'head'
        Spread '..',
          InfixOp '..',
            LitInt '0'
            LitInt '2'
        Spread '..',
          Ident 'rest'

test 'spread with range to grouped expression', fn:
  ast ƒink:
    [..0..(l)]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Spread '..',
          InfixOp '..',
            LitInt '0'
            Group '(..)',
              Ident 'l'


---
ranges
---

test 'exclusive range', fn:
  ast ƒink:
    0..10
  | equals ƒink:
    Module
      InfixOp '..',
        LitInt '0'
        LitInt '10'

test 'inclusive range', fn:
  ast ƒink:
    0...10
  | equals ƒink:
    Module
      InfixOp '...',
        LitInt '0'
        LitInt '10'

test 'char range', fn:
  ast ƒink:
    'a'...'z'
  | equals ƒink:
    Module
      InfixOp '...',
        LitStr 'a'
        LitStr 'z'

test 'expression range exclusive', fn:
  ast ƒink:
    (1 + 2)..(3 + 4)
  | equals ƒink:
    Module
      InfixOp '..',
        Group '(..)',
          InfixOp '+',
            LitInt '1'
            LitInt '2'
        Group '(..)',
          InfixOp '+',
            LitInt '3'
            LitInt '4'

test 'expression range inclusive', fn:
  ast ƒink:
    (1 + 2)...(3 + 4)
  | equals ƒink:
    Module
      InfixOp '...',
        Group '(..)',
          InfixOp '+',
            LitInt '1'
            LitInt '2'
        Group '(..)',
          InfixOp '+',
            LitInt '3'
            LitInt '4'
