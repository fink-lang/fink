
test 'multiline function', fn:
  expect ast fink":
    fn a, b:
      a + b
  | equals fink":
    Fn ':',
      Patterns
        Ident 'a'
        ',', Ident 'b'
      InfixOp '+',
        Ident 'a'
        Ident 'b'

test 'single line function', fn:
  expect ast fink":
    fn a, b: a + b
  | equals fink":
    Fn ':',
      Patterns
        Ident 'a'
        ',', Ident 'b'
      InfixOp '+',
        Ident 'a'
        Ident 'b'

test 'named function binding', fn:
  expect ast fink":
    add = fn a, b:
      result = a + b
      result
  | equals fink":
    Bind '=',
      Ident 'add'
      Fn ':',
        Patterns
          Ident 'a'
          ',', Ident 'b'
        Bind '=',
          Ident 'result'
          InfixOp '+',
            Ident 'a'
            Ident 'b'
        Ident 'result'

test 'no-arg function', fn:
  expect ast fink":
    greet = fn: 'hello'
  | equals fink":
    Bind '=',
      Ident 'greet'
      Fn ':',
        Patterns
        LitStr 'hello'

test 'inline body comma separates expressions', fn:
  expect ast fink":
    fn: 1, 2
  | equals fink":
    Fn ':',
      Patterns
      LitInt '1'
      LitInt '2'

test 'inline body comma equivalent to multiline block', fn:
  expect ast fink":
    fn a, b: a, b
  | equals fink":
    Fn ':',
      Patterns
        Ident 'a'
        ',', Ident 'b'
      Ident 'a'
      Ident 'b'

test 'function with default arg', fn:
  expect ast fink":
    greet = fn name='world':
      'hello \${name}'
  | equals fink":
    Bind '=',
      Ident 'greet'
      Fn ':',
        Patterns
          Bind '=',
            Ident 'name'
            LitStr 'world'
        StrTempl
          LitStr 'hello '
          Ident 'name'

test 'function with record pattern arg', fn:
  expect ast fink":
    foo = fn {x, y}: x + y
  | equals fink":
    Bind '=',
      Ident 'foo'
      Fn ':',
        Patterns
          LitRec '{..}',
            Ident 'x'
            ',', Ident 'y'
        InfixOp '+',
          Ident 'x'
          Ident 'y'

test 'function with sequence pattern arg', fn:
  expect ast fink":
    bar = fn [head, ..tail]: head
  | equals fink":
    Bind '=',
      Ident 'bar'
      Fn ':',
        Patterns
          LitSeq '[..]',
            Ident 'head'
            ',', Spread '..',
              Ident 'tail'
        Ident 'head'

test 'function with rest args', fn:
  expect ast fink":
    baz = fn arg, ..rest: arg
  | equals fink":
    Bind '=',
      Ident 'baz'
      Fn ':',
        Patterns
          Ident 'arg'
          ',', Spread '..',
            Ident 'rest'
        Ident 'arg'

test 'spread in middle of params', fn:
  expect ast fink":
    baz = fn x, ..ys, z: x
  | equals fink":
    Bind '=',
      Ident 'baz'
      Fn ':',
        Patterns
          Ident 'x'
          ',', Spread '..',
            Ident 'ys'
          ',', Ident 'z'
        Ident 'x'


---
fn match sugar
---

test 'fn match single arg', fn:
  expect ast fink":
    classify = fn match n:
      n > 0: 'positive'
      n < 0: 'negative'
      _: 'zero'
  | equals fink":
    Bind '=',
      Ident 'classify'
      Fn ':',
        Patterns
          Ident 'n'
        Match ':',
          Patterns
            Ident 'n'
          Arm ':',
            InfixOp '>',
              Ident 'n'
              LitInt '0'
            LitStr 'positive'
          Arm ':',
            InfixOp '<',
              Ident 'n'
              LitInt '0'
            LitStr 'negative'
          Arm ':',
            Wildcard
            LitStr 'zero'

test 'fn match multi arg', fn:
  expect ast fink":
    foo = fn match a, ..b:
      1, ..: 1
      2, x, ..y: 2
  | equals fink":
    Bind '=',
      Ident 'foo'
      Fn ':',
        Patterns
          Ident 'a'
          ',', Spread '..',
            Ident 'b'
        Match ':',
          Patterns
            Ident 'a'
            ',', Spread '..',
              Ident 'b'
          Arm ':',
            Patterns
              LitInt '1'
              ',', Spread '..'
            LitInt '1'
          Arm ':',
            Patterns
              LitInt '2'
              ',', Ident 'x'
              ',', Spread '..',
                Ident 'y'
            LitInt '2'


---
higher order
---

test 'returning a function', fn:
  expect ast fink":
    map = fn map_fn: fn match items:
      []: []
      [item, ..rest]:
        [(map_fn item), ..(map map_fn rest)]
  | equals fink":
    Bind '=',
      Ident 'map'
      Fn ':',
        Patterns
          Ident 'map_fn'
        Fn ':',
          Patterns
            Ident 'items'
          Match ':',
            Patterns
              Ident 'items'
            Arm ':',
              LitSeq '[..]'
              LitSeq '[..]'
            Arm ':',
              LitSeq '[..]',
                Ident 'item'
                ',', Spread '..',
                  Ident 'rest'
              LitSeq '[..]',
                Group '(..)',
                  Apply
                    Ident 'map_fn'
                    Ident 'item'
                ',', Spread '..',
                  Apply
                    Ident 'map'
                    Apply
                      Ident 'map_fn'
                      Ident 'rest'


---
application
---

test 'simple application', fn:
  expect ast fink":
    log 'hello'
  | equals fink":
    Apply
      Ident 'log'
      LitStr 'hello'

test 'multi-arg application', fn:
  expect ast fink":
    add 1, 2
  | equals fink":
    Apply
      Ident 'add'
      LitInt '1'
      LitInt '2'

test 'multiline args', fn:
  expect ast fink":
    add
      mul 2, 3
      mul 3, 4
  | equals fink":
    Apply
      Ident 'add'
      Apply
        Ident 'mul'
        LitInt '2'
        ',', LitInt '3'
      Apply
        Ident 'mul'
        LitInt '3'
        ',', LitInt '4'

test 'semicolon grouped args', fn:
  expect ast fink":
    add mul 2, 3; mul 3, 4
  | equals fink":
    Apply
      Ident 'add'
      Apply
        Ident 'mul'
        LitInt '2'
        ',', LitInt '3'
      Apply
        Ident 'mul'
        LitInt '3'
        ',', LitInt '4'

test 'nested right-to-left application', fn:
  expect ast fink":
    foo bar spam ham
  | equals fink":
    Apply
      Ident 'foo'
      Apply
        Ident 'bar'
        Apply
          Ident 'spam'
          Ident 'ham'

test 'postfix tagged application', fn:
  expect ast fink":
    [1, 2, 3]foo
  | equals fink":
    Apply
      Ident 'foo'
      LitSeq '[..]',
        LitInt '1'
        ',', LitInt '2'
        ',', LitInt '3'

test 'partial application placeholder', fn:
  expect ast fink":
    add5 = add 5, ?
  | equals fink":
    Bind '=',
      Ident 'add5'
      Apply
        Ident 'add'
        LitInt '5'
        Partial

test 'partial operator', fn:
  expect ast fink":
    add5 = ? + 5
  | equals fink":
    Bind '=',
      Ident 'add5'
      InfixOp '+',
        Partial
        LitInt '5'


---
pipes
---

test 'simple pipe', fn:
  expect ast fink":
    foo | bar | spam
  | equals fink":
    Pipe
      Ident 'foo'
      Ident 'bar'
      Ident 'spam'

test 'multiline pipe', fn:
  expect ast fink":
    'hello'
    | capitalize
    | log
  | equals fink":
    Pipe
      LitStr 'hello'
      Ident 'capitalize'
      Ident 'log'

test 'pipe with spread partial', fn:
  expect ast fink":
    [1, 2] | add ..?
  | equals fink":
    Pipe
      LitSeq '[..]',
        LitInt '1'
        ',', LitInt '2'
      Apply
        Ident 'add'
        Spread '..',
          Partial

# TODO: Jan, think about | precedence, should it be (foo (bar | (spam ham))?
test 'pipe with apply in each stage', fn:
  expect ast fink":
    foo bar | spam ham
  | equals fink":
    Pipe
      Apply
        Ident 'foo'
        Ident 'bar'
      Apply
        Ident 'spam'
        Ident 'ham'

test 'fn literal as grouped arg', fn:
  expect ast fink":
    map (fn x: x + 1), items
  | equals fink":
    Apply
      Ident 'map'
      Group '(..)',
        Fn ':',
          Patterns
            Ident 'x'
          InfixOp '+',
            Ident 'x'
            LitInt '1'
      Ident 'items'


test 'inline body comma is arg separator inside application', fn:
  expect ast fink":
    fn: foo a, b
  | equals fink":
    Fn ':',
      Patterns
      Apply
        Ident 'foo'
        Ident 'a'
        Ident 'b'

test 'inline body comma after binding starts new expression', fn:
  expect ast fink":
    fn: a = 1, b
  | equals fink":
    Fn ':',
      Patterns
      Bind '=',
        Ident 'a'
        LitInt '1'
      Ident 'b'


test 'fn params multiline continuation', fn:
  expect ast fink":
    fn a,
      b: a + b
  | equals fink":
    Fn ':',
      Patterns
        Ident 'a'
        ',', Ident 'b'
      InfixOp '+',
        Ident 'a'
        Ident 'b'


test 'multiline application', fn:
  expect ast fink":
    ni = foo
      bar
  | equals fink":
    Bind '=',
      Ident 'ni'
      Apply
        Ident 'foo'
        Ident 'bar'
