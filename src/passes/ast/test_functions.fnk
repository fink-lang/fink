test 'block body semicolon separated expressions', fn:
  expect ast ƒink:
    fn:
      1; foo; ni
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        LitInt '1'
        Ident 'foo'
        Ident 'ni'

test 'block body semicolon after non-application', fn:
  expect ast ƒink:
    fn:
      1; 2; 3
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        LitInt '1'
        LitInt '2'
        LitInt '3'


test 'function with default arg', fn:
  expect ast ƒink:
    greet = fn name='world':
      'hello ${name}'
  | equals ƒink:
    Module
      Bind '=',
        Ident 'greet'
        Fn ':',
          Patterns
            Bind '=',
              Ident 'name'
              LitStr 'world'
          StrTempl
            LitStr 'hello '
            Ident 'name'

test 'function with record pattern arg', fn:
  expect ast ƒink:
    foo = fn {x, y}: x + y
  | equals ƒink:
    Module
      Bind '=',
        Ident 'foo'
        Fn ':',
          Patterns
            LitRec '{..}',
              Ident 'x'
              Ident 'y'
          InfixOp '+',
            Ident 'x'
            Ident 'y'

test 'function with sequence pattern arg', fn:
  expect ast ƒink:
    bar = fn [head, ..tail]: head
  | equals ƒink:
    Module
      Bind '=',
        Ident 'bar'
        Fn ':',
          Patterns
            LitSeq '[..]',
              Ident 'head'
              Spread '..',
                Ident 'tail'
          Ident 'head'

test 'function with rest args', fn:
  expect ast ƒink:
    baz = fn arg, ..rest: arg
  | equals ƒink:
    Module
      Bind '=',
        Ident 'baz'
        Fn ':',
          Patterns
            Ident 'arg'
            Spread '..',
              Ident 'rest'
          Ident 'arg'

test 'spread in middle of params', fn:
  expect ast ƒink:
    baz = fn x, ..ys, z: x
  | equals ƒink:
    Module
      Bind '=',
        Ident 'baz'
        Fn ':',
          Patterns
            Ident 'x'
            Spread '..',
              Ident 'ys'
            Ident 'z'
          Ident 'x'


---
fn match sugar
---

test 'fn match single arg', fn:
  expect ast ƒink:
    classify = fn match n:
      n > 0: 'positive'
      n < 0: 'negative'
      _: 'zero'
  | equals ƒink:
    Module
      Bind '=',
        Ident 'classify'
        Fn ':',
          Patterns
            Ident 'n'
          Match ':',
            Ident 'n'
            Arm ':',
              Patterns
                InfixOp '>',
                  Ident 'n'
                  LitInt '0'
              LitStr 'positive'
            Arm ':',
              Patterns
                InfixOp '<',
                  Ident 'n'
                  LitInt '0'
              LitStr 'negative'
            Arm ':',
              Patterns
                Wildcard
              LitStr 'zero'

test 'fn match multi arg', fn:
  expect ast ƒink:
    foo = fn match a, ..b:
      1, ..: 1
      2, x, ..y: 2
  | equals ƒink:
    Module
      Bind '=',
        Ident 'foo'
        Fn ':',
          Patterns
            Ident 'a'
            Spread '..',
              Ident 'b'
          Match ':',
            Ident 'a'
            Spread '..',
              Ident 'b'
            Arm ':',
              Patterns
                LitInt '1'
                Spread '..'
              LitInt '1'
            Arm ':',
              Patterns
                LitInt '2'
                Ident 'x'
                Spread '..',
                  Ident 'y'
              LitInt '2'


---
higher order
---

test 'returning a function', fn:
  expect ast ƒink:
    map = fn map_fn: fn match items:
      []: []
      [item, ..rest]:
        [(map_fn item), ..(map map_fn rest)]
  | equals ƒink:
    Module
      Bind '=',
        Ident 'map'
        Fn ':',
          Patterns
            Ident 'map_fn'
          Fn ':',
            Patterns
              Ident 'items'
            Match ':',
              Ident 'items'
              Arm ':',
                Patterns
                  LitSeq '[..]'
                LitSeq '[..]'
              Arm ':',
                Patterns
                  LitSeq '[..]',
                    Ident 'item'
                    Spread '..',
                      Ident 'rest'
                LitSeq '[..]',
                  Group '(..)',
                    Apply
                      Ident 'map_fn'
                      Ident 'item'
                  Spread '..',
                    Group '(..)',
                      Apply
                        Ident 'map'
                        Apply
                          Ident 'map_fn'
                          Ident 'rest'


---
application
---

test 'simple application', fn:
  expect ast ƒink:
    log 'hello'
  | equals ƒink:
    Module
      Apply
        Ident 'log'
        LitStr 'hello'

test 'multi-arg application', fn:
  expect ast ƒink:
    add 1, 2
  | equals ƒink:
    Module
      Apply
        Ident 'add'
        LitInt '1'
        LitInt '2'

test 'multiline args', fn:
  expect ast ƒink:
    add
      mul 2, 3
      mul 3, 4
  | equals ƒink:
    Module
      Apply
        Ident 'add'
        Apply
          Ident 'mul'
          LitInt '2'
          LitInt '3'
        Apply
          Ident 'mul'
          LitInt '3'
          LitInt '4'

test 'semicolon grouped args', fn:
  expect ast ƒink:
    add mul 2, 3; mul 3, 4
  | equals ƒink:
    Module
      Apply
        Ident 'add'
        Apply
          Ident 'mul'
          LitInt '2'
          LitInt '3'
        Apply
          Ident 'mul'
          LitInt '3'
          LitInt '4'


test 'trailing comma dedent error', fn:
  expect ast ":
    foo
      bar,
    spam
  | equals ":
    ERROR [2:5]: unexpected , followed by dedent


test 'trailing semicolon dedent error', fn:
  expect ast ":
    foo
      bar;
    spam
  | equals ":
    ERROR [2:5]: unexpected ; followed by dedent


test 'nested right-to-left application', fn:
  expect ast ƒink:
    foo bar spam ham
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Apply
          Ident 'bar'
          Apply
            Ident 'spam'
            Ident 'ham'

test 'postfix tagged application', fn:
  expect ast ƒink:
    [1, 2, 3]foo
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'

test 'partial application placeholder', fn:
  expect ast ƒink:
    add5 = add 5, ?
  | equals ƒink:
    Module
      Bind '=',
        Ident 'add5'
        Apply
          Ident 'add'
          LitInt '5'
          Partial

test 'partial operator', fn:
  expect ast ƒink:
    add5 = ? + 5
  | equals ƒink:
    Module
      Bind '=',
        Ident 'add5'
        InfixOp '+',
          Partial
          LitInt '5'


---
pipes
---

test 'simple pipe', fn:
  expect ast ƒink:
    foo | bar | spam
  | equals ƒink:
    Module
      Pipe
        Ident 'foo'
        Ident 'bar'
        Ident 'spam'

test 'multiline pipe', fn:
  expect ast ƒink:
    'hello'
    | capitalize
    | log
  | equals ƒink:
    Module
      Pipe
        LitStr 'hello'
        Ident 'capitalize'
        Ident 'log'

test 'pipe with spread partial', fn:
  expect ast ƒink:
    [1, 2] | add ..?
  | equals ƒink:
    Module
      Pipe
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
        Apply
          Ident 'add'
          Spread '..',
            Partial

# TODO: Jan, think about | precedence, should it be (foo (bar | (spam ham))?
test 'pipe with apply in each stage', fn:
  expect ast ƒink:
    foo bar | spam ham
  | equals ƒink:
    Module
      Pipe
        Apply
          Ident 'foo'
          Ident 'bar'
        Apply
          Ident 'spam'
          Ident 'ham'

test 'fn literal as grouped arg', fn:
  expect ast ƒink:
    map (fn x: x + 1), items
  | equals ƒink:
    Module
      Apply
        Ident 'map'
        Group '(..)',
          Fn ':',
            Patterns
              Ident 'x'
            InfixOp '+',
              Ident 'x'
              LitInt '1'
        Ident 'items'


test 'inline body comma is arg separator inside application', fn:
  expect ast ƒink:
    fn: foo a, b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        Apply
          Ident 'foo'
          Ident 'a'
          Ident 'b'

test 'inline body comma after binding starts new expression', fn:
  expect ast ƒink:
    fn: a = 1, b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        Bind '=',
          Ident 'a'
          LitInt '1'
        Ident 'b'


test 'fn params multiline continuation', fn:
  expect ast ƒink:
    fn a,
      b: a + b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Ident 'a'
          Ident 'b'
        InfixOp '+',
          Ident 'a'
          Ident 'b'


test 'multiline application', fn:
  expect ast ƒink:
    ni = foo
      bar
  | equals ƒink:
    Module
      Bind '=',
        Ident 'ni'
        Apply
          Ident 'foo'
          Ident 'bar'


---
fn as infix operand
---

test 'fn as rhs of ==', fn:
  expect ast ƒink:
    [1, ?] == fn $: [1, $]
  | equals ƒink:
    Module
      InfixOp '==',
        LitSeq '[..]',
          LitInt '1'
          Partial
        Fn ':',
          Patterns
            Ident '$'
          LitSeq '[..]',
            LitInt '1'
            Ident '$'
