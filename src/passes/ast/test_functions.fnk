
{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

test 'multiline function', fn:
  expect ast ƒink:
    fn a, b:
      a + b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Ident 'a'
          Ident 'b'
        InfixOp '+',
          Ident 'a'
          Ident 'b'

test 'fn with params and colon on separate lines', fn:
  expect ast ƒink:
    fn
      foo, bar
      spam
    :
      spam
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Ident 'foo'
          Ident 'bar'
          Ident 'spam'
        Ident 'spam'

test 'single line function', fn:
  expect ast ƒink:
    fn a, b: a + b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Ident 'a'
          Ident 'b'
        InfixOp '+',
          Ident 'a'
          Ident 'b'

test 'named function binding', fn:
  expect ast ƒink:
    add = fn a, b:
      result = a + b
      result
  | equals ƒink:
    Module
      Bind '=',
        Ident 'add'
        Fn ':',
          Patterns
            Ident 'a'
            Ident 'b'
          Bind '=',
            Ident 'result'
            InfixOp '+',
              Ident 'a'
              Ident 'b'
          Ident 'result'

test 'no-arg function', fn:
  expect ast ƒink:
    greet = fn: 'hello'
  | equals ƒink:
    Module
      Bind '=',
        Ident 'greet'
        Fn ':',
          Patterns
          LitStr 'hello'

test 'inline body comma separates expressions', fn:
  expect ast ƒink:
    fn: 1, 2
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        LitInt '1'
        LitInt '2'

test 'inline body comma equivalent to multiline block', fn:
  expect ast ƒink:
    fn a, b: a, b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Ident 'a'
          Ident 'b'
        Ident 'a'
        Ident 'b'

test 'block body comma separated expressions', fn:
  expect ast ƒink:
    fn:
      1, foo, ni
  | equals ƒink:
    Module
      Fn ':',
        Patterns
        LitInt '1'
        Ident 'foo'
        Ident 'ni'

# TODO: semicolon in inline fn body inside application should return to outer
# arg list (strong separator), but parse_inline_exprs greedily consumes it.
# Needs context-aware ; parsing.
