{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


test 'empty module', fn:
  ast ''
  | equals ƒink:
    Module


test 'single expression', fn:
  ast ƒink:
    foo bar
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Ident 'bar'


test 'multiple expressions', fn:
  ast ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    Module
      Bind '=',
        Ident 'foo'
        LitInt '1'
      Bind '=',
        Ident 'bar'
        LitInt '2'
