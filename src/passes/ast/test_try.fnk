{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'try bare', fn:
  expect ast ƒink:
    try foo
  | equals ƒink:
    Module
      Try
        Ident 'foo'

test 'try with application', fn:
  expect ast ƒink:
    try foo bar
  | equals ƒink:
    Module
      Try
        Apply
          Ident 'foo'
          Ident 'bar'

test 'try bound to name', fn:
  expect ast ƒink:
    a = try open 'file.txt'
  | equals ƒink:
    Module
      Bind '=',
        Ident 'a'
        Try
          Apply
            Ident 'open'
            LitStr 'file.txt'

test 'try in pipe', fn:
  expect ast ƒink:
    try foo | bar
  | equals ƒink:
    Module
      Pipe
        Try
          Ident 'foo'
        Ident 'bar'
