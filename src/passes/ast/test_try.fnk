
test 'try bare', fn:
  expect ast fink":
    try foo
  | equals fink":
    Module
      Try
        Ident 'foo'

test 'try with application', fn:
  expect ast fink":
    try foo bar
  | equals fink":
    Module
      Try
        Apply
          Ident 'foo'
          Ident 'bar'

test 'try bound to name', fn:
  expect ast fink":
    a = try open 'file.txt'
  | equals fink":
    Module
      Bind '=',
        Ident 'a'
        Try
          Apply
            Ident 'open'
            LitStr 'file.txt'

test 'try in pipe', fn:
  expect ast fink":
    try foo | bar
  | equals fink":
    Module
      Pipe
        Try
          Ident 'foo'
        Ident 'bar'
