test 'comment', fn:
  expect tokenize ƒink:
    foo # ƒink about it
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    Comment '# ƒink about it', loc [4, 1, 4], [20, 1, 19]
    BlockEnd loc [20, 1, 19], [20, 1, 19]


test 'doc_comment', fn:
  expect tokenize ƒink:
    ---
    ƒink rocks
    ---
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText '\n', loc [3, 1, 3], [4, 2, 0]
    CommentText 'ƒink rocks\n', loc [4, 2, 0], [16, 3, 0]
    CommentEnd '---', loc [16, 3, 0], [19, 3, 3]
    BlockEnd loc [19, 3, 3], [19, 3, 3]


test 'block_comment_inline', fn:
  expect tokenize ƒink:
    ---ƒink---
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText 'ƒink', loc [3, 1, 3], [8, 1, 7]
    CommentEnd '---', loc [8, 1, 7], [11, 1, 10]
    BlockEnd loc [11, 1, 10], [11, 1, 10]


test 'block_comment_empty', fn:
  # ------ is an empty block comment (open immediately followed by close)
  expect tokenize ƒink:
    ------
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentEnd '---', loc [3, 1, 3], [6, 1, 6]
    BlockEnd loc [6, 1, 6], [6, 1, 6]



test 'block_comment_multiline', fn:
  expect tokenize ƒink:
    ---foo
        bar
      spam
    ---
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText 'foo\n', loc [3, 1, 3], [7, 2, 0]
    CommentText '    bar\n', loc [7, 2, 0], [15, 3, 0]
    CommentText '  spam\n', loc [15, 3, 0], [22, 4, 0]
    CommentEnd '---', loc [22, 4, 0], [25, 4, 3]
    BlockEnd loc [25, 4, 3], [25, 4, 3]


test 'block_comment_indent_error', fn:
  expect tokenize ":
    log
      ---foo
    bar
    ---
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'log', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    CommentStart '---', loc [6, 2, 2], [9, 2, 5]
    CommentText 'foo\n', loc [9, 2, 5], [13, 3, 0]
    BlockEnd loc [13, 3, 0], [13, 3, 0]
    Err 'unterminated block comment - unexpected dedent', loc [13, 3, 0], [13, 3, 0]
    Ident 'bar', loc [13, 3, 0], [16, 3, 3]
    BlockCont loc [16, 3, 3], [17, 4, 0]
    CommentStart '---', loc [17, 4, 0], [20, 4, 3]
    Err 'unterminated block comment', loc [20, 4, 3], [20, 4, 3]
    BlockEnd loc [20, 4, 3], [20, 4, 3]


test 'block_comment_closing_indent_error', fn:
  expect tokenize ":
    foo
      ---bar
    ---
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    CommentStart '---', loc [6, 2, 2], [9, 2, 5]
    CommentText 'bar\n', loc [9, 2, 5], [13, 3, 0]
    BlockEnd loc [13, 3, 0], [13, 3, 0]
    Err 'unterminated block comment - unexpected dedent', loc [13, 3, 0], [13, 3, 0]
    CommentStart '---', loc [13, 3, 0], [16, 3, 3]
    Err 'unterminated block comment', loc [16, 3, 3], [16, 3, 3]
    BlockEnd loc [16, 3, 3], [16, 3, 3]


test 'block_trailing_blank_lines', fn:
  expect tokenize ƒink:
    foo
      bar

  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]


test 'err_str_eof', fn:
  expect tokenize '\'hello'
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    StrStart '\'', loc [0, 1, 0], [1, 1, 1]
    StrText 'hello', loc [1, 1, 1], [6, 1, 6]
    Err 'unterminated string', loc [6, 1, 6], [6, 1, 6]
    BlockEnd loc [6, 1, 6], [6, 1, 6]


test 'err_doc_comment_eof', fn:
  expect tokenize ":
    ---
    hello
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText '\n', loc [3, 1, 3], [4, 2, 0]
    CommentText 'hello', loc [4, 2, 0], [9, 2, 5]
    Err 'unterminated block comment', loc [9, 2, 5], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]


test 'err_bracket_eof', fn:
  expect tokenize ":
    [foo
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '[', loc [0, 1, 0], [1, 1, 1]
    Ident 'foo', loc [1, 1, 1], [4, 1, 4]
    Err 'unclosed bracket', loc [4, 1, 4], [4, 1, 4]
    BlockEnd loc [4, 1, 4], [4, 1, 4]


test 'err_bracket_mismatch', fn:
  expect tokenize ":
    {foo]
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
    Ident 'foo', loc [1, 1, 1], [4, 1, 4]
    Err ']', loc [4, 1, 4], [5, 1, 5]
    Err 'unclosed bracket', loc [5, 1, 5], [5, 1, 5]
    BlockEnd loc [5, 1, 5], [5, 1, 5]


test 'err_unexpected_dedent', fn:
  expect tokenize ":
    foo
      bar
        ni
     ham
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockStart loc [9, 2, 5], [14, 3, 4]
    Ident 'ni', loc [14, 3, 4], [16, 3, 6]
    BlockEnd loc [16, 3, 6], [16, 3, 6]
    Err 'unexpected dedent', loc [16, 3, 6], [18, 4, 1]
    Ident 'ham', loc [18, 4, 1], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]


test 'err_unexpected_dedent2', fn:
  expect tokenize 'foo\n  bar\n    ni\n ham'
  | equals ":
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockStart loc [9, 2, 5], [14, 3, 4]
    Ident 'ni', loc [14, 3, 4], [16, 3, 6]
    BlockEnd loc [16, 3, 6], [16, 3, 6]
