    Ident 'ham', loc [18, 4, 1], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]



test 'err_tab', fn:
  expect tokenize 'a\tb'
  | equals ":
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'a', loc [0, 1, 0], [1, 1, 1]
    Err 'tab character not allowed', loc [1, 1, 1], [2, 1, 2]
    Ident 'b', loc [2, 1, 2], [3, 1, 3]
    BlockEnd loc [3, 1, 3], [3, 1, 3]


test 'bracket_multiline_flat', fn:
  expect tokenize ƒink:
    {
      foo: 1
      bar: 2
    }
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
    BlockStart loc [1, 1, 1], [4, 2, 2]
    Ident 'foo', loc [4, 2, 2], [7, 2, 5]
    Colon ':', loc [7, 2, 5], [8, 2, 6]
    Int '1', loc [9, 2, 7], [10, 2, 8]
    BlockCont loc [10, 2, 8], [13, 3, 2]
    Ident 'bar', loc [13, 3, 2], [16, 3, 5]
    Colon ':', loc [16, 3, 5], [17, 3, 6]
    Int '2', loc [18, 3, 7], [19, 3, 8]
    BlockEnd loc [19, 3, 8], [19, 3, 8]
    BracketClose '}', loc [20, 4, 0], [21, 4, 1]
    BlockEnd loc [21, 4, 1], [21, 4, 1]


test 'bracket_multiline_nested', fn:
  expect tokenize ƒink:
    {
      foo: {
        bar: 1
      }
    }
  | equals ƒink:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
