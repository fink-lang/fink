{test, expect, equals, ast} = import '!fake'
{ƒink} = import 'fink/blocks.fnk'


---
Member access followed by application.

Today `ctx.h 42` parses as two statements (a Member then a LitInt).
The expected shape is `Apply(Member(ctx, h), 42)` so that method-style
calls work without intermediate bindings or pipes.
---

test 'member then apply', fn:
  expect ast ƒink:
    ctx.h 42
  | equals ƒink:
    Module
      Apply
        Member '.',
          Ident 'ctx'
          Ident 'h'
        LitInt '42'


test 'member then apply two args', fn:
  expect ast ƒink:
    ctx.h 1, 2
  | equals ƒink:
    Module
      Apply
        Member '.',
          Ident 'ctx'
          Ident 'h'
        LitInt '1'
        LitInt '2'


test 'nested member then apply', fn:
  expect ast ƒink:
    ctx.w.foo 42
  | equals ƒink:
    Module
      Apply
        Member '.',
          Member '.',
            Ident 'ctx'
            Ident 'w'
          Ident 'foo'
        LitInt '42'


--- A member-access head applied in ARGUMENT position is one argument (the
    member application), not two flat args of the outer call. Regression:
    `f g.h 42` must be `Apply(f, Apply(Member(g, h), 42))`, not
    `Apply(f, Member(g, h), 42)`. This is what makes `is_opt Opt.Some {val: 1}`
    pass a single constructed value rather than the bare case type plus a rec. ---
test 'member apply in argument position', fn:
  expect ast ƒink:
    f g.h 42
  | equals ƒink:
    Module
      Apply
        Ident 'f'
        Apply
          Member '.',
            Ident 'g'
            Ident 'h'
          LitInt '42'


test 'member apply with rec literal in argument position', fn:
  expect ast ƒink:
    f g.h {x: 1}
  | equals ƒink:
    Module
      Apply
        Ident 'f'
        Apply
          Member '.',
            Ident 'g'
            Ident 'h'
          LitRec '{..}',
            Arm ':',
              Ident 'x'
              LitInt '1'
