---

test 'try — simple', fn:
  expect fmt ƒink:
    try foo bar

  | equals ƒink:
    try foo bar


---
Group
---

test 'group — parens', fn:
  expect fmt ƒink:
    (a + b) * c

  | equals ƒink:
    (a + b) * c


---
Partial
---

test 'partial — hole', fn:
  expect fmt ƒink:
    add 5, ?

  | equals ƒink:
    add 5, ?


---
Seq and Rec with items
---

test 'seq literal with items', fn:
  expect fmt ƒink:
    [1, 2, 3]

  | equals ƒink:
    [1, 2, 3]

test 'rec literal with items', fn:
  expect fmt ƒink:
    {foo, bar}

  | equals ƒink:
    {foo, bar}


---
Decimal literal
---

test 'decimal literal', fn:
  expect fmt ƒink:
    1.0d

  | equals ƒink:
    1.0d
