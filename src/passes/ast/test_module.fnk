{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'empty module', fn:
  expect module ''
  | equals ƒink:
    Module


test 'single expression', fn:
  expect module ƒink:
    foo bar
  | equals ƒink:
    Module
      Apply
        Ident 'foo'
        Ident 'bar'


test 'multiple expressions', fn:
  expect module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    Module
      Bind '=',
        Ident 'foo'
        LitInt '1'
      Bind '=',
        Ident 'bar'
        LitInt '2'