{test, expect, equals, ast} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
left-hand binding
---

test 'simple binding', fn:
  expect ast ƒink:
    foo = 1
  | equals ƒink:
    Module
      Bind '=',
        Ident 'foo'
        LitInt '1'

test 'sequence destructure', fn:
  expect ast ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Ident 'a'
          Ident 'b'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'

test 'record destructure', fn:
  expect ast ƒink:
    {x, y} = point
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'x'
          Ident 'y'
        Ident 'point'

test 'record destructure with rename', fn:
  expect ast ƒink:
    {x, y: z} = point
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'x'
          Arm ':',
            Ident 'y'
            Ident 'z'
        Ident 'point'

test 'nested record destructure', fn:
  expect ast ƒink:
    {a, b: {c, d}} = foo
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'a'
          Arm ':',
            Ident 'b'
            LitRec '{..}',
              Ident 'c'
              Ident 'd'
        Ident 'foo'

test 'nested destructure', fn:
  expect ast ƒink:
    [a, [b, c]] = [1, [2, 3]]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Ident 'a'
          LitSeq '[..]',
            Ident 'b'
            Ident 'c'
        LitSeq '[..]',
          LitInt '1'
          LitSeq '[..]',
            LitInt '2'
            LitInt '3'

test 'spread head and tail', fn:
  expect ast ƒink:
    [head, ..tail] = [1, 2, 3, 4]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Ident 'head'
          Spread '..',
            Ident 'tail'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'
          LitInt '4'

test 'spread head middle and end', fn:
  expect ast ƒink:
    [head, ..middle, end] = [1, 2, 3, 4]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Ident 'head'
          Spread '..',
            Ident 'middle'
          Ident 'end'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'
          LitInt '3'
          LitInt '4'

test 'spread with guard', fn:
  expect ast ƒink:
    [head > 3, ..tail] = [4, 5, 6]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          InfixOp '>',
            Ident 'head'
            LitInt '3'
          Spread '..',
            Ident 'tail'
        LitSeq '[..]',
          LitInt '4'
          LitInt '5'
          LitInt '6'

test 'guard with function call in pattern', fn:
  expect ast ƒink:
    [(is_odd head), ..tail] = [3, 4, 5]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Group '(..)',
            Apply
              Ident 'is_odd'
              Ident 'head'
          Spread '..',
            Ident 'tail'
        LitSeq '[..]',
          LitInt '3'
          LitInt '4'
          LitInt '5'

test 'record destructure with spread rest', fn:
  expect ast ƒink:
    {x, ..rest} = point
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'x'
          Spread '..',
            Ident 'rest'
        Ident 'point'

test 'record destructure with non-empty rest assertion', fn:
  expect ast ƒink:
    {x, ..} = point
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'x'
          Spread '..'
        Ident 'point'

test 'record destructure exact - empty rest', fn:
  expect ast ƒink:
    {x, ..{}} = point
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'x'
          Spread '..',
            LitRec '{..}'
        Ident 'point'

test 'seq destructure exact - empty rest', fn:
  expect ast ƒink:
    [a, ..[]] = foo
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Ident 'a'
          Spread '..',
            LitSeq '[..]'
        Ident 'foo'

test 'string pattern binding', fn:
  expect ast ƒink:
    'start ${middle} end' = 'foo bar spam'
  | equals ƒink:
    Module
      Bind '=',
        StrTempl
          LitStr 'start '
          Ident 'middle'
          LitStr ' end'
        LitStr 'foo bar spam'


---
right-hand binding
---

test 'simple right-hand binding', fn:
  expect ast ƒink:
    123 |= b
  | equals ƒink:
    Module
      BindRight '|=',
        LitInt '123'
        Ident 'b'

test 'multiline right-hand binding', fn:
  expect ast ƒink:
    foo
      arg1
      arg2
    |= result
  | equals ƒink:
    Module
      BindRight '|=',
        Apply
          Ident 'foo'
          Ident 'arg1'
          Ident 'arg2'
        Ident 'result'

test 'nested right-hand binding', fn:
  expect ast ƒink:
    [a |= [b, 2], [3, 4]] = [[1, 2], [3, 4]]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          BindRight '|=',
            Ident 'a'
            LitSeq '[..]',
              Ident 'b'
              LitInt '2'
          LitSeq '[..]',
            LitInt '3'
            LitInt '4'
        LitSeq '[..]',
          LitSeq '[..]',
            LitInt '1'
            LitInt '2'
          LitSeq '[..]',
            LitInt '3'
            LitInt '4'

test 'right-hand binding with sequence destructure', fn:
  expect ast ƒink:
    get_pair foo |= [a, b]
  | equals ƒink:
    Module
      BindRight '|=',
        Apply
          Ident 'get_pair'
          Ident 'foo'
        LitSeq '[..]',
          Ident 'a'
          Ident 'b'

test 'right-hand binding with record destructure', fn:
  expect ast ƒink:
    get_point foo |= {x, y}
  | equals ƒink:
    Module
      BindRight '|=',
        Apply
          Ident 'get_point'
          Ident 'foo'
        LitRec '{..}',
          Ident 'x'
          Ident 'y'

test 'right-hand binding with nested destructure', fn:
  expect ast ƒink:
    compute foo |= {x, y: [a, b]}
  | equals ƒink:
    Module
      BindRight '|=',
        Apply
          Ident 'compute'
          Ident 'foo'
        LitRec '{..}',
          Ident 'x'
          Arm ':',
            Ident 'y'
            LitSeq '[..]',
              Ident 'a'
              Ident 'b'

test 'nested right-hand binding in record pattern', fn:
  expect ast ƒink:
    {foo: f |= {bar, spam: num ni}} = {foo: {bar: 1, spam: 2}}
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            BindRight '|=',
              Ident 'f'
              LitRec '{..}',
                Ident 'bar'
                Arm ':',
                  Ident 'spam'
                  Apply
                    Ident 'num'
                    Ident 'ni'
        LitRec '{..}',
          Arm ':',
            Ident 'foo'
            LitRec '{..}',
              Arm ':',
                Ident 'bar'
                LitInt '1'
              Arm ':',
                Ident 'spam'
                LitInt '2'

test 'spread guard with right-hand binding', fn:
  expect ast ƒink:
    [..(str) |= strings, ..other] = [1, '2', 3, '4']
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Spread '..',
            BindRight '|=',
              Group '(..)',
                Ident 'str'
              Ident 'strings'
          Spread '..',
            Ident 'other'
        LitSeq '[..]',
          LitInt '1'
          LitStr '2'
          LitInt '3'
          LitStr '4'

test 'import', fn:
  expect ast ƒink:
    {foo, bar} = import './foobar.fnk'
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'foo'
          Ident 'bar'
        Apply
          Ident 'import'
          LitStr './foobar.fnk'


---
wildcard
---

test 'bare wildcard', fn:
  expect ast ƒink:
    _
  | equals ƒink:
    Module
      Wildcard

test 'wildcard in sequence destructure', fn:
  expect ast ƒink:
    [_, x] = [1, 2]
  | equals ƒink:
    Module
      Bind '=',
        LitSeq '[..]',
          Wildcard
          Ident 'x'
        LitSeq '[..]',
          LitInt '1'
          LitInt '2'

test 'wildcard in fn params', fn:
  expect ast ƒink:
    fn _, b: b
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Wildcard
          Ident 'b'
        Ident 'b'

test 'wildcard does not match _foo', fn:
  expect ast ƒink:
    _foo
  | equals ƒink:
    Module
      Ident '_foo'

test 'implicit wildcard - middle slots', fn:
  expect ast ƒink:
    [_, _, n]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Wildcard
        Wildcard
        Ident 'n'

test 'implicit wildcard - leading comma', fn:
  expect ast ƒink:
    [, , n]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Wildcard
        Wildcard
        Ident 'n'

test 'implicit wildcard - mixed explicit and implicit', fn:
  expect ast ƒink:
    [_, , n]
  | equals ƒink:
    Module
      LitSeq '[..]',
        Wildcard
        Wildcard
        Ident 'n'

test 'implicit wildcard in fn params', fn:
  expect ast ƒink:
    fn , , c: c
  | equals ƒink:
    Module
      Fn ':',
        Patterns
          Wildcard
          Wildcard
          Ident 'c'
        Ident 'c'
