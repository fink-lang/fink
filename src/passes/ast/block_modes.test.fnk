{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


test 'ƒink block with no args', fn:
  ast ƒink:
    {ƒink} = import 'fink/blocks.fnk'
    ƒink: 'hello'
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒink'
        Apply
          Ident 'import'
          LitStr 'fink/blocks.fnk'
      Block ':',
        Ident 'ƒink'
        Patterns
        LitStr 'hello'


test 'ƒink block with params and body', fn:
  ast ƒink:
    {ƒink} = import 'fink/blocks.fnk'
    ƒink a, b:
      x = a + b
      x * 2
  | equals ƒink:
    Module
      Bind '=',
        LitRec '{..}',
          Ident 'ƒink'
        Apply
          Ident 'import'
          LitStr 'fink/blocks.fnk'
      Block ':',
        Ident 'ƒink'
        Patterns
          Ident 'a'
          Ident 'b'
        Bind '=',
          Ident 'x'
          InfixOp '+',
            Ident 'a'
            Ident 'b'
        InfixOp '*',
          Ident 'x'
          LitInt '2'

