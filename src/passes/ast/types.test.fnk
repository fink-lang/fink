{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{ast} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


---
type: record (named fields)
---

test 'record type', fn:
  ast ƒink:
    type:
      shrub: u8
  | equals ƒink:
    Module
      Type ':',
        Patterns
        Arm ':',
          Ident 'shrub'
          Ident 'u8'


test 'named record type binding', fn:
  ast ƒink:
    Foo = type:
      shrub: u8
      ni: i8
  | equals ƒink:
    Module
      Bind '=',
        Ident 'Foo'
        Type ':',
          Patterns
          Arm ':',
            Ident 'shrub'
            Ident 'u8'
          Arm ':',
            Ident 'ni'
            Ident 'i8'


---
type: tuple (positional fields)
---

test 'tuple type', fn:
  ast ƒink:
    type: u8, i8
  | equals ƒink:
    Module
      Type ':',
        Patterns
        Ident 'u8'
        Ident 'i8'


---
type: unit
---

test 'unit type', fn:
  ast ƒink:
    type _
  | equals ƒink:
    Module
      Type '_'


---
type: generic params
---

test 'generic type', fn:
  ast ƒink:
    type T:
      ham: T
  | equals ƒink:
    Module
      Type ':',
        Patterns
          Ident 'T'
        Arm ':',
          Ident 'ham'
          Ident 'T'


---
type: function (a `fn A, ...: R` in type position)
---

test 'function type', fn:
  ast ƒink:
    type: fn u8, u8: u8
  | equals ƒink:
    Module
      Type ':',
        Patterns
        Fn ':',
          Patterns
            Ident 'u8'
            Ident 'u8'
          Ident 'u8'


--- constructing a fn-type instance: applying the named fn-type to a fn literal.
    The outer `Fn ':'` is the fn VALUE; it differs from the `Fn ':'` inside a
    `Type` (which is the fn type). ---
test 'function type instance construction', fn:
  ast ƒink:
    add = Foo fn a, b: a
  | equals ƒink:
    Module
      Bind '=',
        Ident 'add'
        Apply
          Ident 'Foo'
          Fn ':',
            Patterns
              Ident 'a'
              Ident 'b'
            Ident 'a'


---
enum: closed sum
---

test 'enum type', fn:
  ast ƒink:
    enum T:
      Some T
      None
  | equals ƒink:
    Module
      Enum ':',
        Patterns
          Ident 'T'
        Apply
          Ident 'Some'
          Ident 'T'
        Ident 'None'


---
type: extension via ..Foo (type-level spread)
---

test 'record type extends', fn:
  ast ƒink:
    Bar = type:
      ..Foo
      ni: u8
  | equals ƒink:
    Module
      Bind '=',
        Ident 'Bar'
        Type ':',
          Patterns
          Spread '..',
            Ident 'Foo'
          Arm ':',
            Ident 'ni'
            Ident 'u8'


test 'extends an applied generic', fn:
  ast ƒink:
    Bar = type:
      ..Foo u8
  | equals ƒink:
    Module
      Bind '=',
        Ident 'Bar'
        Type ':',
          Patterns
          Spread '..',
            Apply
              Ident 'Foo'
              Ident 'u8'


test 'tuple type extends with prepend', fn:
  ast ƒink:
    Nu = type:
      u8
      ..Ni
  | equals ƒink:
    Module
      Bind '=',
        Ident 'Nu'
        Type ':',
          Patterns
          Ident 'u8'
          Spread '..',
            Ident 'Ni'


---
union: open union
---

test 'union block', fn:
  ast ƒink:
    union:
      SignedInt
      UnsignedInt
  | equals ƒink:
    Module
      Union ':',
        Patterns
        Ident 'SignedInt'
        Ident 'UnsignedInt'


---
typed destructure patterns: `Foo a, b` / `Foo a, ..rest` / `Foo ..whole` / `Foo ..`
A type head leads a positional pattern that mirrors construction. `Foo a, b`
and the spread forms parse as `Apply`; guard-only `Foo ..` parses as a
`PostfixOp` (the `..` is postfix on the head, binding nothing).
---

test 'typed destructure positionals', fn:
  ast ƒink:
    Foo a, b = foo
  | equals ƒink:
    Module
      Bind '=',
        Apply
          Ident 'Foo'
          Ident 'a'
          Ident 'b'
        Ident 'foo'

test 'typed destructure head and rest', fn:
  ast ƒink:
    Foo a, ..rest = foo
  | equals ƒink:
    Module
      Bind '=',
        Apply
          Ident 'Foo'
          Ident 'a'
          Spread '..',
            Ident 'rest'
        Ident 'foo'

test 'typed whole-value bind', fn:
  ast ƒink:
    Foo ..whole = foo
  | equals ƒink:
    Module
      Bind '=',
        Apply
          Ident 'Foo'
          Spread '..',
            Ident 'whole'
        Ident 'foo'

test 'typed guard-only pattern in match', fn:
  ast ƒink:
    match foo:
      Foo ..: 1
  | equals ƒink:
    Module
      Match ':',
        Ident 'foo'
        Arm ':',
          Patterns
            Apply
              Ident 'Foo'
              Spread '..'
          LitInt '1'

test 'typed whole-value bind in match arm parses like binding', fn:
  ast ƒink:
    match foo:
      Foo ..w: w
  | equals ƒink:
    Module
      Match ':',
        Ident 'foo'
        Arm ':',
          Patterns
            Apply
              Ident 'Foo'
              Spread '..',
                Ident 'w'
          Ident 'w'
