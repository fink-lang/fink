---
synth ref resolution after lifting
---

# After lifting, Ref::Synth refs must resolve to in-scope bindings.
# name_res resolves synth refs like any other ref, so that capture analysis
# can detect when lifting moves a fn to a scope where its synth refs are
# no longer valid.
#
# Test format:
#   test 'name', fn:
#     expect cps_resolve_synth fink":
#       <fink source>
#
#     | equals fink":
#       <expected classified resolution including synth refs>

{test, equals, expect, fink, cps_resolve_synth} = import 'fake!'

---
simple match — synth refs should resolve as local or captured
---

# After lifting, the match_block fn's captured bindings resolve as `captured`
# and the remaining synth refs (in-scope conts) resolve as `local`.

test 'match — synth refs resolve after lifting', fn:
  expect cps_resolve_synth fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    (ref 30, ?) == unresolved
    (synth 31, ·v_30) == (captured 1, (bind 30))
    (ref 15, ?) == unresolved
    (synth 16, ·v_15) == (local (bind 15))
    (ref 81, ?) == unresolved
    (synth 87, ·v_81) == (captured 1, (bind 81))
    (ref 11, ?) == unresolved
    (synth 83, ·v_11) == (local (bind 11))
    (ref 12, ?) == unresolved
    (synth 85, ·v_12) == (local (bind 12))
    (ref 10, ?) == unresolved
    (synth 13, ·v_10) == (local (bind 10))
    (ref 73, ?) == unresolved
    (synth 77, ·v_73) == (captured 1, (bind 73))
    (ref 7, ?) == unresolved
    (synth 75, ·v_7) == (local (bind 7))
    (ref 23, ?) == unresolved
    (synth 34, ·v_23) == (captured 1, (bind 23))
    (ref 6, ?) == unresolved
    (synth 35, ·v_6) == (local (bind 6))
    (ref 76, ?) == unresolved
    (synth 37, ·v_76) == (local (bind 76))
    (ref 42, ?) == unresolved
    (synth 47, ·v_42) == (captured 1, (bind 42))
    (ref 43, ?) == unresolved
    (synth 48, ·v_43) == (local (bind 43))
    (ref 51, ?) == unresolved
    (synth 53, ·v_51) == (captured 1, (bind 51))
    (ref 1, n) == unresolved
    (synth 5, ·v_1) == (local (bind 1))
    (ref 3, ?) == unresolved
    (synth 62, ·v_3) == (local (bind 3))

