---
synth ref resolution after lifting
---

# After lifting, Ref::Synth refs must resolve to in-scope bindings.
# name_res resolves synth refs like any other ref, so that capture analysis
# can detect when lifting moves a fn to a scope where its synth refs are
# no longer valid.
#
# Test format:
#   test 'name', fn:
#     expect cps_resolve_synth fink":
#       <fink source>
#
#     | equals fink":
#       <expected classified resolution including synth refs>

{test, equals, expect, fink, cps_resolve_synth} = import 'fake!'

---
simple match — synth refs should resolve as local or captured
---

# After lifting, the match_block fn's captured bindings resolve as `captured`
# and the remaining synth refs (in-scope conts) resolve as `local`.

test 'match — synth refs resolve after lifting', fn:
  expect cps_resolve_synth fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    (ref 50, n) == unresolved
    (synth 5, ·v_50) == (local (bind 50))
    (ref 37, ?) == unresolved
    (synth 38, ·v_37) == (local (bind 37))
    (ref 16, ?) == unresolved
    (synth 17, ·v_16) == (local (bind 16))
    (ref 70, ?) == unresolved
    (synth 76, ·v_70) == (captured 1, (bind 70))
    (ref 12, ?) == unresolved
    (synth 72, ·v_12) == (local (bind 12))
    (ref 13, ?) == unresolved
    (synth 74, ·v_13) == (local (bind 13))
    (ref 11, ?) == unresolved
    (synth 14, ·v_11) == (local (bind 11))
    (ref 24, ?) == unresolved
    (synth 31, ·v_24) == (captured 1, (bind 24))
    (ref 9, ?) == unresolved
    (synth 32, ·v_9) == (local (bind 9))
    (ref 49, ?) == unresolved
    (synth 55, ·v_49) == (captured 1, (bind 49))
    (ref 1, n) == unresolved
    (synth 51, ·v_1) == (local (bind 1))
    (ref 4, ?) == unresolved
    (synth 53, ·v_4) == (local (bind 4))
    (ref 3, ?) == unresolved
    (synth 44, ·v_3) == (local (bind 3))

