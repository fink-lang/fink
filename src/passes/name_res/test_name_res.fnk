---
name resolution tests
---

# Name resolution — maps each ref to the binding it resolves to.
#
# Output format: one line per resolved Ref::Name, walk order.
#   (ref <cps_id>, <name>) == (bind <cps_id>, <name>)
#
# Only Ref::Name nodes appear (Ref::Gen are structural, always resolved).
# Unresolved names:  (ref <cps_id>, <name>) == (unresolved <name>)
#
# Test format:
#   test 'name', fn:
#     expect cps_name_res fink":
#       <fink source>
#
#     | equals fink":
#       <expected resolution edges>


---
local bindings
---

test 'ref to binding', fn:
  expect cps_name_res fink":
    x = 1
    y = x
  | equals fink":
    (ref 3, x) == (bind 2, x)
    (ref 5, y) == (bind 4, y)

test 'ref to param', fn:
  expect cps_name_res fink":
    fn a: a
  | equals fink":
    (ref 2, a) == (bind 1, a)

test 'chained bindings', fn:
  expect cps_name_res fink":
    x = 1
    y = x
    z = y
  | equals fink":
    (ref 3, x) == (bind 2, x)
    (ref 5, y) == (bind 4, y)
    (ref 7, z) == (bind 6, z)

test 'multiple refs to same binding', fn:
  expect cps_name_res fink":
    x = 1
    y = x
    z = x
  | equals fink":
    (ref 3, x) == (bind 2, x)
    (ref 5, x) == (bind 2, x)
    (ref 7, z) == (bind 6, z)

test 'fn with two params', fn:
  expect cps_name_res fink":
    fn a, b: a + b
  | equals fink":
    (ref 3, a) == (bind 1, a)
    (ref 4, b) == (bind 2, b)


---
closures
---

test 'capture from outer scope', fn:
  expect cps_name_res fink":
    x = 1
    fn a: x
  | equals fink":
    (ref 5, x) == (bind 2, x)

test 'param not captured', fn:
  expect cps_name_res fink":
    fn a:
      fn b: a
  | equals fink":
    (ref 4, a) == (bind 1, a)


---
application
---

test 'fn application', fn:
  expect cps_name_res fink":
    f = fn a: a
    f 1
  | equals fink":
    (ref 3, a) == (bind 2, a)
    (ref 7, f) == (bind 6, f)


---
unresolved names
---

test 'unresolved ref', fn:
  expect cps_name_res fink":
    x
  | equals fink":
    (ref 0, x) == (unresolved x)

test 'mixed resolved and unresolved', fn:
  expect cps_name_res fink":
    x = 1
    y = x
    z = w
  | equals fink":
    (ref 3, x) == (bind 2, x)
    (ref 5, w) == (unresolved w)
    (ref 7, z) == (bind 6, z)

test 'unresolved in fn body', fn:
  expect cps_name_res fink":
    fn a: b
  | equals fink":
    (ref 2, b) == (unresolved b)


---
shadowing
---

test 'shadow binding', fn:
  expect cps_name_res fink":
    x = 1
    x = 2
    y = x
  | equals fink":
    (ref 5, x) == (bind 4, x)
    (ref 7, y) == (bind 6, y)

test 'param shadows outer binding', fn:
  expect cps_name_res fink":
    a = 1
    fn a:
      a
  | equals fink":
    (ref 5, a) == (bind 4, a)

test 'inner fn shadows outer binding', fn:
  expect cps_name_res fink":
    x = 1
    fn x: x
  | equals fink":
    (ref 5, x) == (bind 4, x)


---
recursion — fn bodies see sibling LetFn names (hoisted),
LetVal right-hand sides see only prior bindings (sequential).
---

test 'self recursion', fn:
  expect cps_name_res fink":
    f = fn a:
      f a
  | equals fink":
    (ref 2, f) == (bind 9, f)
    (ref 3, a) == (bind 1, a)
    (ref 10, f) == (bind 9, f)

test 'mutual recursion', fn:
  expect cps_name_res fink":
    f = fn a:
      g a
    g = fn b:
      f b
  | equals fink":
    (ref 3, g) == (bind 20, g)
    (ref 4, a) == (bind 2, a)
    (ref 13, f) == (bind 10, f)
    (ref 14, b) == (bind 12, b)
    (ref 21, g) == (bind 20, g)

test 'val ref to prior fn resolves', fn:
  expect cps_name_res fink":
    foo = fn a: a
    bar = foo
  | equals fink":
    (ref 3, a) == (bind 2, a)
    (ref 7, foo) == (bind 6, foo)
    (ref 9, bar) == (bind 8, bar)

test 'val forward ref still unresolved even if fn', fn:
  expect cps_name_res fink":
    bar = foo
    foo = fn a: a
    spam = foo
  | equals fink":
    (ref 1, foo) == (unresolved foo)
    (ref 5, a) == (bind 4, a)
    (ref 9, foo) == (bind 8, foo)
    (ref 11, spam) == (bind 10, spam)


---
pattern assignments — LHS destructuring
---

test 'seq destructure', fn:
  expect cps_name_res fink":
    [a, b] = [1, 2]
    a
  | equals fink":
    (ref 15, a) == (bind 10, a)

test 'seq destructure uses both bindings', fn:
  expect cps_name_res fink":
    [a, b] = [1, 2]
    c = a
  | equals fink":
    (ref 15, a) == (bind 10, a)
    (ref 17, c) == (bind 16, c)

test 'rec destructure', fn:
  expect cps_name_res fink":
    {a} = {a: 1}
    a
  | equals fink":
    (ref 10, a) == (bind 7, a)

test 'rec destructure uses binding', fn:
  expect cps_name_res fink":
    {a, b} = {a: 1, b: 2}
    c = a
  | equals fink":
    (ref 17, a) == (bind 11, a)
    (ref 19, c) == (bind 18, c)

test 'nested seq destructure', fn:
  expect cps_name_res fink":
    [a, [b, c]] = [1, [2, 3]]
    b
  | equals fink":
    (ref 27, b) == (bind 21, b)

test 'seq destructure with ref rhs', fn:
  expect cps_name_res fink":
    x = [1, 2]
    [a, b] = x
    a
  | equals fink":
    (ref 9, x) == (bind 8, x)
    (ref 17, a) == (bind 12, a)

test 'rec destructure with ref rhs', fn:
  expect cps_name_res fink":
    x = {a: 1}
    {a} = x
    a
  | equals fink":
    (ref 7, x) == (bind 6, x)
    (ref 12, a) == (bind 9, a)

test 'nested seq destructure with ref rhs', fn:
  expect cps_name_res fink":
    x = [1, [2, 3]]
    [a, [b, c]] = x
    b
  | equals fink":
    (ref 15, x) == (bind 14, x)
    (ref 29, b) == (bind 23, b)


---
match blocks
---

test 'match with literal arms', fn:
  expect cps_name_res fink":
    x = 1
    match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 3, x) == (bind 2, x)

test 'match with outer scope ref in arm', fn:
  expect cps_name_res fink":
    x = 1
    y = 2
    match x:
      1: y
      2: 'two'
  | equals fink":
    (ref 5, x) == (bind 2, x)
    (ref 9, y) == (bind 4, y)

test 'match result binding', fn:
  expect cps_name_res fink":
    x = 1
    result = match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 3, x) == (bind 2, x)
    (ref 20, result) == (bind 19, result)
