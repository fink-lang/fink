---
name resolution tests
---

# Name resolution — classified scope graph.
#
# Output format: one line per resolved Ref::Name, walk order.
#   (ref ID, name) == (local (bind ID, name)) in scope ID
#   (ref ID, name) == (captured DEPTH, (bind ID, name)) in scope ID
#   (ref ID, name) == (recursive (bind ID, name)) in scope ID
#   (ref ID, name) == unresolved
#
# Only Ref::Name nodes appear (Ref::Gen are structural, always resolved).
#
# Test format:
#   test 'name', fn:
#     expect cps_resolve fink":
#       <fink source>
#
#     | equals fink":
#       <expected classified resolution>


---
local bindings
---

test 'ref to binding', fn:
  expect cps_resolve fink":
    x = 1
    y = x
  | equals fink":
    (ref 0, x) == unresolved

test 'ref to param', fn:
  expect cps_resolve fink":
    fn a: a
  | equals fink":
    (ref 0, a) == unresolved

test 'chained bindings', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = y
  | equals fink":
    (ref 0, x) == unresolved
    (ref 1, y) == unresolved

test 'multiple refs to same binding', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = x
  | equals fink":
    (ref 0, x) == unresolved
    (ref 0, x) == unresolved

test 'fn with two params', fn:
  expect cps_resolve fink":
    fn a, b: a + b
  | equals fink":
    (ref 0, a) == unresolved
    (ref 1, b) == unresolved


---
closures
---

test 'capture from outer scope', fn:
  expect cps_resolve fink":
    x = 1
    fn a: x
  | equals fink":
    (ref 0, x) == unresolved

test 'param not captured', fn:
  expect cps_resolve fink":
    fn a:
      fn b: a
  | equals fink":
    (ref 0, a) == unresolved


---
application
---

test 'fn application', fn:
  expect cps_resolve fink":
    f = fn a: a
    f 1
  | equals fink":
    (ref 1, a) == unresolved
    (ref 5, ?) == unresolved
    (ref 0, f) == unresolved


---
unresolved names
---

test 'unresolved ref', fn:
  expect cps_resolve fink":
    x
  | equals fink":
    (ref 0, ?) == unresolved

test 'mixed resolved and unresolved', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = w
  | equals fink":
    (ref 0, x) == unresolved
    (ref 7, x) == (local (bind 0, x)) in scope 4

test 'unresolved in fn body', fn:
  expect cps_resolve fink":
    fn a: b
  | equals fink":
    (ref 3, ?) == unresolved


---
shadowing
---

test 'shadow binding', fn:
  expect cps_resolve fink":
    x = 1
    x = 2
    y = x
  | equals fink":
    (ref 1, x) == unresolved

test 'param shadows outer binding', fn:
  expect cps_resolve fink":
    a = 1
    fn a:
      a
  | equals fink":
    (ref 1, a) == unresolved

test 'inner fn shadows outer binding', fn:
  expect cps_resolve fink":
    x = 1
    fn x: x
  | equals fink":
    (ref 1, x) == unresolved


---
recursion — fn bodies see sibling LetFn names (hoisted),
LetVal right-hand sides see only prior bindings (sequential).
---

test 'self recursion', fn:
  expect cps_resolve fink":
    f = fn a:
      f a
  | equals fink":
    (ref 0, f) == unresolved
    (ref 1, a) == unresolved
    (ref 3, ?) == unresolved

test 'mutual recursion', fn:
  expect cps_resolve fink":
    f = fn a:
      g a
    g = fn b:
      f b
  | equals fink":
    (ref 1, g) == unresolved
    (ref 2, a) == unresolved
    (ref 7, ?) == unresolved
    (ref 0, f) == unresolved
    (ref 3, b) == unresolved
    (ref 15, ?) == unresolved

test 'val ref to prior fn resolves', fn:
  expect cps_resolve fink":
    foo = fn a: a
    bar = foo
  | equals fink":
    (ref 2, a) == unresolved
    (ref 6, ?) == unresolved
    (ref 0, foo) == unresolved

test 'val forward ref still unresolved even if fn', fn:
  expect cps_resolve fink":
    bar = foo
    foo = fn a: a
    spam = foo
  | equals fink":
    (ref 1, foo) == unresolved
    (ref 3, a) == unresolved
    (ref 8, ?) == unresolved
    (ref 1, foo) == unresolved


---
pattern assignments — LHS destructuring
---

test 'seq destructure', fn:
  expect cps_resolve fink":
    [a, b] = [1, 2]
    a
  | equals fink":
    (ref 7, ?) == unresolved
    (ref 10, ?) == unresolved
    (ref 12, ?) == unresolved
    (ref 13, ?) == unresolved
    (ref 14, ?) == unresolved
    (ref 17, ?) == unresolved
    (ref 18, ?) == unresolved

test 'seq destructure uses both bindings', fn:
  expect cps_resolve fink":
    [a, b] = [1, 2]
    c = a
  | equals fink":
    (ref 8, ?) == unresolved
    (ref 11, ?) == unresolved
    (ref 13, ?) == unresolved
    (ref 14, ?) == unresolved
    (ref 15, ?) == unresolved
    (ref 18, ?) == unresolved
    (ref 19, ?) == unresolved
    (ref 0, a) == unresolved

test 'rec destructure', fn:
  expect cps_resolve fink":
    {a} = {a: 1}
    a
  | equals fink":
    (ref 7, ?) == unresolved
    (ref 9, ?) == unresolved
    (ref 10, ?) == unresolved

test 'rec destructure uses binding', fn:
  expect cps_resolve fink":
    {a, b} = {a: 1, b: 2}
    c = a
  | equals fink":
    (ref 9, ?) == unresolved
    (ref 13, ?) == unresolved
    (ref 15, ?) == unresolved
    (ref 16, ?) == unresolved
    (ref 17, ?) == unresolved
    (ref 20, ?) == unresolved
    (ref 0, a) == unresolved

test 'nested seq destructure', fn:
  expect cps_resolve fink":
    [a, [b, c]] = [1, [2, 3]]
    b
  | equals fink":
    (ref 12, ?) == unresolved
    (ref 8, ?) == unresolved
    (ref 15, ?) == unresolved
    (ref 17, ?) == unresolved
    (ref 19, ?) == unresolved
    (ref 20, ?) == unresolved
    (ref 21, ?) == unresolved
    (ref 24, ?) == unresolved
    (ref 28, ?) == unresolved
    (ref 29, ?) == unresolved
    (ref 30, ?) == unresolved
    (ref 33, ?) == unresolved
    (ref 34, ?) == unresolved
    (ref 25, ?) == unresolved

test 'seq destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = [1, 2]
    [a, b] = x
    a
  | equals fink":
    (ref 8, ?) == unresolved
    (ref 11, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 14, ?) == unresolved
    (ref 15, ?) == unresolved
    (ref 16, ?) == unresolved
    (ref 19, ?) == unresolved
    (ref 20, ?) == unresolved

test 'rec destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = {a: 1}
    {a} = x
    a
  | equals fink":
    (ref 8, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 11, ?) == unresolved
    (ref 12, ?) == unresolved

test 'nested seq destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = [1, [2, 3]]
    [a, [b, c]] = x
    b
  | equals fink":
    (ref 13, ?) == unresolved
    (ref 9, ?) == unresolved
    (ref 16, ?) == unresolved
    (ref 18, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 21, ?) == unresolved
    (ref 22, ?) == unresolved
    (ref 23, ?) == unresolved
    (ref 26, ?) == unresolved
    (ref 30, ?) == unresolved
    (ref 31, ?) == unresolved
    (ref 32, ?) == unresolved
    (ref 35, ?) == unresolved
    (ref 36, ?) == unresolved
    (ref 27, ?) == unresolved


---
match blocks
---

test 'match with literal arms', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 9, ?) == unresolved
    (ref 23, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 19, ?) == unresolved
    (ref 33, ?) == unresolved

test 'match with outer scope ref in arm', fn:
  expect cps_resolve fink":
    x = 1
    y = 2
    match x:
      1: y
      2: 'two'
  | equals fink":
    (ref 11, ?) == unresolved
    (ref 1, y) == unresolved
    (ref 25, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 21, ?) == unresolved
    (ref 35, ?) == unresolved

test 'match result binding', fn:
  expect cps_resolve fink":
    x = 1
    result = match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 10, ?) == unresolved
    (ref 24, ?) == unresolved
    (ref 0, x) == unresolved
    (ref 20, ?) == unresolved
    (ref 34, ?) == unresolved
    (ref 36, ?) == unresolved


---
nested captures
---

test 'capture depth 2 — three levels of fn nesting', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      fn b:
        x
  | equals fink":
    (ref 0, x) == unresolved

test 'capture depth 2 with local use too', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      y = x
      fn b:
        x
  | equals fink":
    (ref 0, x) == unresolved
    (ref 0, x) == unresolved

test 'shadow in middle scope breaks capture chain', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      x = 2
      fn b:
        x
  | equals fink":
    (ref 2, x) == unresolved

test 'capture and local in same fn body', fn:
  expect cps_resolve fink":
    x = 1
    f = fn a:
      y = a
      z = x
  | equals fink":
    (ref 2, a) == unresolved
    (ref 0, x) == unresolved
    (ref 9, ?) == unresolved

test 'match arm binding used in arm body', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a: a
      b: b + a
  | equals fink":
    (ref 11, ?) == unresolved
    (ref 1, a) == unresolved
    (ref 22, ?) == unresolved
    (ref 2, b) == unresolved
    (ref 14, a) == (local (bind 1, a)) in scope 4
    (ref 0, x) == unresolved
    (ref 18, ?) == unresolved
    (ref 31, ?) == unresolved

test 'binding inside match arm body', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a:
        y = a
        y
  | equals fink":
    (ref 11, ?) == unresolved
    (ref 1, a) == unresolved
    (ref 0, x) == unresolved
    (ref 18, ?) == unresolved

test 'fn in match arm captures outer', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a: fn b: a
  | equals fink":
    (ref 11, ?) == unresolved
    (ref 1, a) == unresolved
    (ref 0, x) == unresolved
    (ref 22, ?) == unresolved

test 'spread param resolves locally', fn:
  expect cps_resolve fink":
    fn a, ..b: b
  | equals fink":
    (ref 1, b) == unresolved

test 'wildcard not in scope', fn:
  expect cps_resolve fink":
    _ = 1
    _
  | equals fink":
    (ref 3, ?) == unresolved
