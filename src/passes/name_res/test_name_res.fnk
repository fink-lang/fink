---
name resolution tests
---

# Name resolution — classified scope graph.
#
# Output format: one line per resolved Ref::Name, walk order.
#   (ref ID, name) == (local (bind ID, name)) in scope ID
#   (ref ID, name) == (captured DEPTH, (bind ID, name)) in scope ID
#   (ref ID, name) == (recursive (bind ID, name)) in scope ID
#   (ref ID, name) == unresolved
#
# Only Ref::Name nodes appear (Ref::Gen are structural, always resolved).
#
# Test format:
#   test 'name', fn:
#     expect cps_resolve fink":
#       <fink source>
#
#     | equals fink":
#       <expected classified resolution>


---
local bindings
---

test 'ref to binding', fn:
  expect cps_resolve fink":
    x = 1
    y = x
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 7, y) == (local (bind 6, y)) in scope 1

test 'ref to param', fn:
  expect cps_resolve fink":
    fn a: a
  | equals fink":
    (ref 4, a) == (local (bind 2, a)) in scope 1

test 'chained bindings', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = y
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 7, y) == (local (bind 6, y)) in scope 1
    (ref 9, z) == (local (bind 8, z)) in scope 1

test 'multiple refs to same binding', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = x
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 7, x) == (local (bind 4, x)) in scope 1
    (ref 9, z) == (local (bind 8, z)) in scope 1

test 'fn with two params', fn:
  expect cps_resolve fink":
    fn a, b: a + b
  | equals fink":
    (ref 5, a) == (local (bind 2, a)) in scope 1
    (ref 6, b) == (local (bind 3, b)) in scope 1


---
closures
---

test 'capture from outer scope', fn:
  expect cps_resolve fink":
    x = 1
    fn a: x
  | equals fink":
    (ref 8, x) == (captured 1, (bind 4, x)) in scope 1

test 'param not captured', fn:
  expect cps_resolve fink":
    fn a:
      fn b: a
  | equals fink":
    (ref 7, a) == (captured 1, (bind 2, a)) in scope 1


---
application
---

test 'fn application', fn:
  expect cps_resolve fink":
    f = fn a: a
    f 1
  | equals fink":
    (ref 6, a) == (local (bind 4, a)) in scope 3
    (ref 10, f) == (local (bind 9, f)) in scope 1


---
unresolved names
---

test 'unresolved ref', fn:
  expect cps_resolve fink":
    x
  | equals fink":
    (ref 1, x) == unresolved

test 'mixed resolved and unresolved', fn:
  expect cps_resolve fink":
    x = 1
    y = x
    z = w
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 7, w) == unresolved
    (ref 9, z) == (local (bind 8, z)) in scope 1

test 'unresolved in fn body', fn:
  expect cps_resolve fink":
    fn a: b
  | equals fink":
    (ref 4, b) == unresolved


---
shadowing
---

test 'shadow binding', fn:
  expect cps_resolve fink":
    x = 1
    x = 2
    y = x
  | equals fink":
    (ref 7, x) == (local (bind 6, x)) in scope 1
    (ref 9, y) == (local (bind 8, y)) in scope 1

test 'param shadows outer binding', fn:
  expect cps_resolve fink":
    a = 1
    fn a:
      a
  | equals fink":
    (ref 8, a) == (local (bind 6, a)) in scope 5

test 'inner fn shadows outer binding', fn:
  expect cps_resolve fink":
    x = 1
    fn x: x
  | equals fink":
    (ref 8, x) == (local (bind 6, x)) in scope 5


---
recursion — fn bodies see sibling LetFn names (hoisted),
LetVal right-hand sides see only prior bindings (sequential).
---

test 'self recursion', fn:
  expect cps_resolve fink":
    f = fn a:
      f a
  | equals fink":
    (ref 4, f) == (recursive (bind 11, f)) in scope 16
    (ref 5, a) == (local (bind 2, a)) in scope 1
    (ref 12, f) == (local (bind 11, f)) in scope 16

test 'mutual recursion', fn:
  expect cps_resolve fink":
    f = fn a:
      g a
    g = fn b:
      f b
  | equals fink":
    (ref 6, g) == (captured 1, (bind 24, g)) in scope 1
    (ref 7, a) == (local (bind 4, a)) in scope 3
    (ref 17, f) == (captured 1, (bind 13, f)) in scope 1
    (ref 18, b) == (local (bind 15, b)) in scope 14
    (ref 25, g) == (local (bind 24, g)) in scope 1

test 'val ref to prior fn resolves', fn:
  expect cps_resolve fink":
    foo = fn a: a
    bar = foo
  | equals fink":
    (ref 6, a) == (local (bind 4, a)) in scope 3
    (ref 10, foo) == (local (bind 9, foo)) in scope 1
    (ref 12, bar) == (local (bind 11, bar)) in scope 1

test 'val forward ref still unresolved even if fn', fn:
  expect cps_resolve fink":
    bar = foo
    foo = fn a: a
    spam = foo
  | equals fink":
    (ref 3, foo) == unresolved
    (ref 8, a) == (local (bind 6, a)) in scope 5
    (ref 12, foo) == (local (bind 11, foo)) in scope 1
    (ref 14, spam) == (local (bind 13, spam)) in scope 1


---
pattern assignments — LHS destructuring
---

test 'seq destructure', fn:
  expect cps_resolve fink":
    [a, b] = [1, 2]
    a
  | equals fink":
    (ref 17, a) == (local (bind 12, a)) in scope 1

test 'seq destructure uses both bindings', fn:
  expect cps_resolve fink":
    [a, b] = [1, 2]
    c = a
  | equals fink":
    (ref 17, a) == (local (bind 12, a)) in scope 1
    (ref 19, c) == (local (bind 18, c)) in scope 1

test 'rec destructure', fn:
  expect cps_resolve fink":
    {a} = {a: 1}
    a
  | equals fink":
    (ref 12, a) == (local (bind 9, a)) in scope 1

test 'rec destructure uses binding', fn:
  expect cps_resolve fink":
    {a, b} = {a: 1, b: 2}
    c = a
  | equals fink":
    (ref 19, a) == (local (bind 13, a)) in scope 1
    (ref 21, c) == (local (bind 20, c)) in scope 1

test 'nested seq destructure', fn:
  expect cps_resolve fink":
    [a, [b, c]] = [1, [2, 3]]
    b
  | equals fink":
    (ref 29, b) == (local (bind 23, b)) in scope 1

test 'seq destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = [1, 2]
    [a, b] = x
    a
  | equals fink":
    (ref 11, x) == (local (bind 10, x)) in scope 1
    (ref 19, a) == (local (bind 14, a)) in scope 1

test 'rec destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = {a: 1}
    {a} = x
    a
  | equals fink":
    (ref 9, x) == (local (bind 8, x)) in scope 1
    (ref 14, a) == (local (bind 11, a)) in scope 1

test 'nested seq destructure with ref rhs', fn:
  expect cps_resolve fink":
    x = [1, [2, 3]]
    [a, [b, c]] = x
    b
  | equals fink":
    (ref 17, x) == (local (bind 16, x)) in scope 1
    (ref 31, b) == (local (bind 25, b)) in scope 1


---
match blocks
---

test 'match with literal arms', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1

test 'match with outer scope ref in arm', fn:
  expect cps_resolve fink":
    x = 1
    y = 2
    match x:
      1: y
      2: 'two'
  | equals fink":
    (ref 7, x) == (local (bind 4, x)) in scope 1
    (ref 11, y) == (local (bind 6, y)) in scope 1

test 'match result binding', fn:
  expect cps_resolve fink":
    x = 1
    result = match x:
      1: 'one'
      2: 'two'
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 22, result) == (local (bind 21, result)) in scope 1


---
nested captures
---

test 'capture depth 2 — three levels of fn nesting', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      fn b:
        x
  | equals fink":
    (ref 11, x) == (captured 2, (bind 4, x)) in scope 1

test 'capture depth 2 with local use too', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      y = x
      fn b:
        x
  | equals fink":
    (ref 8, x) == (captured 1, (bind 4, x)) in scope 1
    (ref 13, x) == (captured 2, (bind 4, x)) in scope 1

test 'shadow in middle scope breaks capture chain', fn:
  expect cps_resolve fink":
    x = 1
    fn a:
      x = 2
      fn b:
        x
  | equals fink":
    (ref 13, x) == (captured 1, (bind 9, x)) in scope 5

test 'capture and local in same fn body', fn:
  expect cps_resolve fink":
    x = 1
    f = fn a:
      y = a
      z = x
  | equals fink":
    (ref 8, a) == (local (bind 6, a)) in scope 5
    (ref 10, x) == (captured 1, (bind 4, x)) in scope 1
    (ref 12, z) == (local (bind 11, z)) in scope 5
    (ref 20, f) == (local (bind 19, f)) in scope 1

test 'match arm binding used in arm body', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a: a
      b: b + a
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 9, a) == (local (bind 8, a)) in scope 12
    (ref 15, b) == (local (bind 14, b)) in scope 22
    (ref 16, a) == unresolved

test 'binding inside match arm body', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a:
        y = a
        y
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 9, a) == (local (bind 8, a)) in scope 16
    (ref 11, y) == (local (bind 10, y)) in scope 16

test 'fn in match arm captures outer', fn:
  expect cps_resolve fink":
    x = 1
    match x:
      a: fn b: a
  | equals fink":
    (ref 5, x) == (local (bind 4, x)) in scope 1
    (ref 12, a) == (captured 1, (bind 8, a)) in scope 18

test 'spread param resolves locally', fn:
  expect cps_resolve fink":
    fn a, ..b: b
  | equals fink":
    (ref 5, b) == (local (bind 3, b)) in scope 1

test 'wildcard not in scope', fn:
  expect cps_resolve fink":
    _ = 1
    _
  | equals fink":
    (ref 4, ?) == unresolved
