# --- recursion ---

test 'simple recursion', fn:
  expect gen_wat fink":
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5
  | equals wat":
    TODO

test 'recursive countdown', fn:
  expect gen_wat fink":
    count = fn a, n:
      match n:
        0: a
        _: count a + 1, n - 1
    main = fn:
      count 0, 10
  | equals wat":
    TODO

test 'mutual recursion', fn:
  expect gen_wat fink":
    is-even = fn n:
      match n:
        0: 1
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: 0
        _: is-even n - 1

    main = fn:
      is-even 10
  | equals wat":
    TODO

