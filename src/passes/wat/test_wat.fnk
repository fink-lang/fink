test 'chained fn calls', fn:
  expect gen_wat fink":
    double = fn x:
      x * 2
    inc = fn x:
      x + 1
    main = fn:
      x = double 5
      inc x
  | equals wat":
    TODO

test 'pipe unary', fn:
  expect gen_wat fink":
    double = fn x:
      x * 2
    inc = fn x:
      x + 1
    main = fn:
      5 | double | inc
  | equals wat":
    TODO

# --- match ---

test 'match literal first arm', fn:
