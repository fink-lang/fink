{test, expect, equals, fink, gen_wat, wat} = import '!fake'



test 'literal int', fn:
  expect gen_wat fink":
    main = fn:
      42
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))

      (func $v_4 (type $Fn1) (param $v_5 (ref $Any))
        (return_call_ref $Fn1 (local.get $v_5) (struct.new $Num (f64.const 42)))
      )
      (export "main" (func $v_4))
    )
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICA0MiJdLAogICJtYXBwaW5ncyI6ICI7Ozs7O0FBQU87QUFDTCwyQ0FBQTs7QUFERiIKfQ==


test 'let binding', fn:
  expect gen_wat fink":
    main = fn:
      x = 42
      x
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))

      (func $v_5 (type $Fn1) (param $v_6 (ref $Any))
        (local $x_1 (ref $Any))
        (local.set $x_1 (struct.new $Num (f64.const 42)))
        (return_call_ref $Fn1 (local.get $v_6) (local.get $x_1))
      )
      (export "main" (func $v_5))
    )
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICB4ID0gNDJcbiAgeCJdLAogICJtYXBwaW5ncyI6ICI7Ozs7O0FBQU87O0lBQ0gsV0FBRixLQUFJO0FBQ0osMkNBQUE7O0FBRkYiCn0=


test 'add two literals', fn:
  expect gen_wat fink":
    main = fn:
      2 + 3
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))

      (func $v_4 (type $Fn1) (param $v_5 (ref $Any))
        (return_call $op_plus (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_5))
      )
      (export "main" (func $v_4))
    )
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICAyICsgMyJdLAogICJtYXBwaW5ncyI6ICI7Ozs7O0FBQU87QUFDSCwwQkFBRixnQ0FBSTs7QUFETiIKfQ==


test 'chained arithmetic', fn:
  expect gen_wat fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))
      (type $Fn2 (func (param (ref $Any) (ref $Any))))

      (func $v_25 (type $Fn2) (param $v_26 (ref $Any)) (param $v_9 (ref $Any))
        (local $x_1 (ref $Any))
        (local.set $x_1 (local.get $v_9))
        (return_call $op_plus (local.get $x_1) (struct.new $Num (f64.const 4)) (local.get $v_26))
      )
      (func $v_5 (type $Fn1) (param $v_6 (ref $Any))
        (local $v_30 (ref $Any))
        (local.set $v_30 (call $closure_2 (local.get $v_25) (local.get $v_6)))
        (return_call $op_mul (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_30))
      )
      (export "main" (func $v_5))
    )
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICB4ID0gMiAqIDNcbiAgeCArIDQiXSwKICAibWFwcGluZ3MiOiAiOzs7Ozs7OztJQUNJLFdBQUYsS0FBSTtBQUNGLDBCQUFGLGlCQUFJOztBQUZDOzt3REFBQTtBQUNDLHlCQUFGLGdDQUFJOztBQURWIgp9


