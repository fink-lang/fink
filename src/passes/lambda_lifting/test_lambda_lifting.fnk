---
lambda lifting tests
---

# Lambda lifting — eliminates closures by threading captured bindings as extra
# parameters through the entire call chain.
#
# After lifting, no fn should contain ·closure nodes — all captured values are
# passed explicitly as params at every call site.
#
# Extra (forwarded) args trail after the cont, preserving the original builtin
# interface: `builtin operands..., cont, forwarded...`
#
# Test format:
#   test 'name', fn:
#     expect lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected lifted CPS — no ·closure anywhere>

{test, equals, expect, fink, lift} = import 'fake!'


---
pure functions — no captures, unchanged (same as closure lifting)
---

test 'pure fn is unchanged', fn:
  expect lift fink":
    f = fn x: x

  | equals fink":
    ·f_0 = ·v_5 = fn ·x_1, ·v_6:
      ·v_6 ·x_1

    ·export ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·v_8 = fn ·b_2, ·v_9:
      ·v_9 ·b_2

    ·foo_0 = ·v_6 = fn ·a_1, ·v_7:
      ·v_7 ·v_8

    ·export ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted, no closure', fn:
  expect lift fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_25 = fn ·v_9, ·v_26:
      ·x_1 = ·v_9
      ·op_plus ·x_1, 4, ·v_26

    ·main_0 = ·v_5 = fn ·v_6:
      ·op_mul 2, 3, ·v_25, ·v_6

    ·export ·main_0


---
depth-1 captures — single level, extra params instead of ·closure
---

test 'captured binding — escaping value needs closure', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_22 = fn ·b_2, ·v_9, ·a_23:
      ·op_plus ·a_23, ·b_2, ·v_9

    ·foo_0 = ·v_6 = fn ·a_1, ·v_7:
      ·closure ·v_22, ·a_1, ·v_7

    ·export ·foo_0


test 'escaping fn value — closure needed for bind-then-call', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

    main = fn:
      bar = foo 2
      bar

  | equals fink":
    ·v_47 = fn ·b_3, ·v_12, ·a_48:
      ·op_plus ·a_48, ·b_3, ·v_12

    ·foo_0 = ·v_9 = fn ·a_2, ·v_10:
      ·closure ·v_47, ·a_2, ·v_10

    ·v_42 = fn ·v_25, ·v_43:
      ·bar_4 = ·v_25
      ·v_43 ·bar_4

    ·main_1 = ·v_21 = fn ·v_22:
      ·foo_0 2, ·v_42, ·v_22

    ·export ·foo_0, ·main_1


test 'two module-level bindings — capture threaded as param', fn:
  expect lift fink":
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·f_0 = ·v_9 = fn ·x_2, ·v_10:
      ·v_10 ·x_2

    ·v_35 = fn ·b_4, ·v_18, ·a_36:
      ·op_plus ·a_36, ·b_4, ·v_18

    ·g_1 = ·v_15 = fn ·a_3, ·v_16:
      ·closure ·v_35, ·a_3, ·v_16

    ·export ·f_0, ·g_1


---
depth-2 captures — multi-level nesting, all closures eliminated
---

test 'depth-2 capture — all values threaded as params', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_48 = fn ·v_15, ·c_49, ·v_51:
      ·op_plus ·v_15, ·c_49, ·v_51

    ·v_39 = fn ·c_3, ·v_12, ·a_40, ·b_42:
      ·op_plus ·a_40, ·b_42, ·v_48, ·c_3, ·v_12

    ·v_32 = fn ·b_2, ·v_10, ·a_33:
      ·closure ·v_39, ·a_33, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn ·a_1, ·v_8:
      ·closure ·v_32, ·a_1, ·v_8

    ·export ·foo_0


test 'multiple captures at depth-2 — escaping values need closures', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_34 = fn ·c_3, ·v_12, ·a_35, ·b_37:
      ·op_plus ·a_35, ·b_37, ·v_12

    ·v_27 = fn ·b_2, ·v_10, ·a_28:
      ·closure ·v_34, ·a_28, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn ·a_1, ·v_8:
      ·closure ·v_27, ·a_1, ·v_8

    ·export ·foo_0


---
yield
---

test 'yield — cont body lifted, no closure', fn:
  expect lift fink":
    main = fn:
      q = yield 42
      1 + q

  | equals fink":
    ·v_24 = fn ·v_8, ·v_25:
      ·q_1 = ·v_8
      ·op_plus 1, ·q_1, ·v_25

    ·main_0 = ·v_5 = fn ·v_6:
      ·yield 42, ·v_24, ·v_6

    ·export ·main_0


---
module-level calls
---

test 'multi-fn module — add and main', fn:
  expect lift fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    ·add_0 = ·v_8 = fn ·a_2, ·b_3, ·v_9:
      ·op_plus ·a_2, ·b_3, ·v_9

    ·main_1 = ·v_16 = fn ·v_17:
      ·add_0 3, 4, ·v_17

    ·export ·add_0, ·main_1


test 'chained module-fn calls — cont params threaded, no closure', fn:
  expect lift fink":
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals fink":
    ·double_0 = ·v_11 = fn ·x_3, ·v_12:
      ·op_mul ·x_3, 2, ·v_12

    ·inc_1 = ·v_19 = fn ·x_4, ·v_20:
      ·op_plus ·x_4, 1, ·v_20

    ·v_55 = fn ·v_31, ·v_56:
      ·x_5 = ·v_31
      ·inc_1 ·x_5, ·v_56

    ·main_2 = ·v_27 = fn ·v_28:
      ·double_0 5, ·v_55, ·v_28

    ·export ·double_0, ·inc_1, ·main_2


---
pattern matching
---

test 'match with guard — no closures', fn:
  expect lift fink":
    main = fn foo:
      a > 0 = foo
      a + 1

  | equals fink":
    ·v_27 = fn ·v_16, ·a_28, ·v_30:
      ·op_plus ·a_28, 1, ·v_30

    ·main_0 = ·v_6 = fn ·foo_1, ·v_7:
      ·a_2 = ·foo_1
      ·match_if ·op_gt, ·a_2, 0, panic, ·v_27, ·a_2, ·v_7

    ·export ·main_0


test 'seq destructure — no closures', fn:
  expect lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_47 = fn ·v_14, ·a_48, ·v_50:
      ·op_plus ·a_48, 1, ·v_50

    ·v_42 = fn ·v_10, ·v_11, ·v_43:
      ·a_2 = ·v_10
      ·match_done ·v_11, panic, ·v_47, ·a_2, ·v_43

    ·v_37 = fn ·v_9, ·v_38:
      ·match_next ·v_9, panic, ·v_42, ·v_38

    ·main_0 = ·v_6 = fn ·foo_1, ·v_7:
      ·match_seq ·foo_1, panic, ·v_37, ·v_7

    ·export ·main_0


test 'record destructure — no closures', fn:
  expect lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_39 = fn ·v_10, ·v_11, ·v_40:
      ·x_2 = ·v_10
      ·op_plus ·x_2, 1, ·v_40

    ·v_34 = fn ·v_9, ·v_35:
      ·match_field ·v_9, 'x', panic, ·v_39, ·v_35

    ·main_0 = ·v_6 = fn ·foo_1, ·v_7:
      ·match_rec ·foo_1, panic, ·v_34, ·v_7

    ·export ·main_0


test 'match — no closures, no forward refs', fn:
  expect lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·v_33 = fn ·v_21, ·n_34, ·v_36:
      ·match_block ·n_34, ·v_21, ·v_36

    ·v_40 = fn ·v_14:
      ·v_14 42

    ·v_43 = fn ·v_11, ·v_9, ·v_10:
      ·match_value ·v_11, 0, ·v_9, ·v_10

    ·foo_0 = ·v_5 = fn ·n_1, ·v_6:
      ·match_arm ·v_43, ·v_40, ·v_33, ·n_1, ·v_6

    ·export ·foo_0


test 'match with binding — no closures', fn:
  expect lift fink":
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals fink":
    ·v_53 = fn ·v_26, ·v_54:
      ·r_2 = ·v_26
      ·v_54 ·r_2

    ·v_41 = fn ·v_24, ·n_42, ·v_44:
      ·match_block ·n_42, ·v_24, ·v_53, ·v_44

    ·v_48 = fn ·v_15, ·n_49:
      ·op_plus ·n_49, 1, ·v_15

    ·v_58 = fn ·v_12, ·v_10, ·v_11:
      ·match_value ·v_12, 0, ·v_10, ·v_11

    ·foo_0 = ·v_6 = fn ·n_1, ·v_7:
      ·match_arm ·v_58, ·v_41, ·n_1, ·v_7, ·v_48, ·n_1

    ·export ·foo_0


test 'recursive fn in match — no closures', fn:
  expect lift fink":
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals fink":
    ·v_87 = fn ·v_43, ·v_88:
      ·r_2 = ·v_43
      ·v_88 ·r_2

    ·v_70 = fn ·v_41, ·n_71, ·v_73, ·v_75:
      ·match_block ·n_71, ·v_73, ·v_41, ·v_87, ·v_75

    ·v_95 = fn ·v_32, ·v_96:
      ·fib_0 ·v_32, ·v_96

    ·v_82 = fn ·v_28, ·n_83:
      ·op_plus ·n_83, 1, ·v_95, ·v_28

    ·v_92 = fn ·v_26, ·v_24, ·v_25:
      ·v_25 _

    ·v_60 = fn ·v_22, ·n_61, ·v_63:
      ·match_arm ·v_92, ·v_70, ·n_61, ·v_22, ·v_63, ·v_82, ·n_61

    ·v_67 = fn ·v_15:
      ·v_15 1

    ·v_79 = fn ·v_12, ·v_10, ·v_11:
      ·match_value ·v_12, 0, ·v_10, ·v_11

    ·fib_0 = ·v_6 = fn ·n_1, ·v_7:
      ·match_arm ·v_79, ·v_67, ·v_60, ·n_1, ·v_7

    ·export ·fib_0


---
mutual recursion
---

test 'mutual recursion — ping pong', fn:
  expect lift fink":
    ping = fn x: pong x
    pong = fn x: ping x

  | equals fink":
    ·ping_0 = ·v_8 = fn ·x_2, ·v_9:
      ·pong_1 ·x_2, ·v_9

    ·pong_1 = ·v_16 = fn ·x_3, ·v_17:
      ·ping_0 ·x_3, ·v_17

    ·export ·ping_0, ·pong_1

test 'mutual recursion with shared cont', fn:
  expect lift fink":
    is-even = fn n:
      match n:
        0: 1
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: 0
        _: is-even n - 1

  | equals fink":
    ·v_135 = fn ·v_43, ·n_136, ·v_138, ·v_140:
      ·match_block ·n_136, ·v_138, ·v_43, ·v_140

    ·v_171 = fn ·v_34, ·v_172:
      ·is-odd_1 ·v_34, ·v_172

    ·v_155 = fn ·v_30, ·n_156:
      ·op_minus ·n_156, 1, ·v_171, ·v_30

    ·v_168 = fn ·v_28, ·v_26, ·v_27:
      ·v_27 _

    ·v_113 = fn ·v_24, ·n_114, ·v_116:
      ·match_arm ·v_168, ·v_135, ·n_114, ·v_24, ·v_116, ·v_155, ·n_114

    ·v_132 = fn ·v_17:
      ·v_17 1

    ·v_152 = fn ·v_14, ·v_12, ·v_13:
      ·match_value ·v_14, 0, ·v_12, ·v_13

    ·is-even_0 = ·v_8 = fn ·n_2, ·v_9:
      ·match_arm ·v_152, ·v_132, ·v_113, ·n_2, ·v_9

    ·v_123 = fn ·v_88, ·n_124, ·v_126, ·v_128:
      ·match_block ·n_124, ·v_126, ·v_88, ·v_128

    ·v_163 = fn ·v_79, ·v_164:
      ·is-even_0 ·v_79, ·v_164

    ·v_147 = fn ·v_75, ·n_148:
      ·op_minus ·n_148, 1, ·v_163, ·v_75

    ·v_160 = fn ·v_73, ·v_71, ·v_72:
      ·v_72 _

    ·v_106 = fn ·v_69, ·n_107, ·v_109:
      ·match_arm ·v_160, ·v_123, ·n_107, ·v_69, ·v_109, ·v_147, ·n_107

    ·v_120 = fn ·v_62:
      ·v_62 0

    ·v_144 = fn ·v_59, ·v_57, ·v_58:
      ·match_value ·v_59, 0, ·v_57, ·v_58

    ·is-odd_1 = ·v_53 = fn ·n_3, ·v_54:
      ·match_arm ·v_144, ·v_120, ·v_106, ·n_3, ·v_54

    ·export ·is-even_0, ·is-odd_1
