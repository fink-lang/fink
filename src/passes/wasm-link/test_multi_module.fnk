---
Multi-module linker snapshot tests.

These tests drive the wasm-link pass: parse a multi-file fink source
(`#= ./path` delimiters mark file boundaries; the last file is the
entry), compile each module, link everything into a single self-contained
WASM binary, and snapshot the linked WAT.

The goal is to pin the linker's multi-module output — cross-fragment
global imports should resolve to the provider's defined globals, and
dependency fragments should appear in the output with `<url>:fink_module`
exports so the runner can initialize them in order.
---

{test, expect, equals, gen_wat_pkg, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'two file package — entry imports foo from foobar/spam', fn:
  expect gen_wat_pkg ƒink:
    {foo} = import './test_modules/entry.fnk'

    foo 2, 3
  | equals wat":
