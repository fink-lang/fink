      fn ·v_49, ·ƒctx_40, ·ƒret_10, ·c_3:
        ·letcaps ·v_49, fn {·a_47, ·b_48}:
          ·op_plus ·ƒctx_40, ·a_47, ·b_48, fn ·ƒctx_42, ·v_13:
            ·op_plus ·ƒctx_42, ·v_13, ·c_3, ·ƒret_10
      fn ·v_54:
        ·fn
          fn ·v_60, ·ƒctx_39, ·ƒret_8, ·b_2:
            ·letcaps ·v_60, fn {·a_59}:
              ·closure ·v_54, {·a_47: ·a_59, ·b_48: ·b_2}, fn ·v_9:
                ·ƒret_8 _
          fn ·v_64:
            ·fn
              fn ·v_69, ·ƒctx_38, ·ƒret_6, ·a_1:
                ·closure ·v_64, {·a_59: ·a_1}, fn ·v_7:
                  ·ƒret_6 _
              fn ·v_72:
                ·ƒink_module fn ·ƒctx_36, ·ƒret_4:
                  ·letrec fn ·foo_0:
                    ·closure ·v_72, {}, fn ·v_5:
                      ·set ·foo_0, ·v_5, fn:
                        ·ƒpub ·ƒctx_36, ·foo_0, fn ·ƒctx_45:
                          ·ƒret_4 ·ƒctx_45, ·foo_0
    # sm:


