  expect cps_hoisted ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals ƒink:
    ·fn
      fn ·v_45, ·ƒctx_36, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_36, ·a_2, ·b_3, ·ƒret_6
      fn ·v_48:
        ·ƒink_module fn ·ƒctx_34, ·ƒret_4:
          ·letrec fn ·add_0, ·x_1:
            ·closure ·v_48, {}, fn ·v_5:
              ·set ·add_0, ·v_5, fn:
                ·ƒpub ·ƒctx_34, ·add_0, fn ·ƒctx_39:
                  ·add_0
                    ·ƒctx_39
                    fn ·ƒctx_41, ·v_16:
                      ·set ·x_1, ·v_16, fn:
                        ·ƒpub ·ƒctx_41, ·x_1, fn ·ƒctx_43:
                          ·ƒret_4 ·ƒctx_43, ·x_1
                    i8 1
                    i8 2
    # sm:


