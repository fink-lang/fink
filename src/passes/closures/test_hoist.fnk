                    ·ƒv_24 ·ƒctx_42, ·ƒv_30, ·panic, ·ƒv_5
    # sm:


---
Regression test for the fooobar lifting bug — module with multiple
top-level fns where the results of calls are bound to names. Previously
downstream wasm emit panicked with `unknown local: add_0` because capture
analysis didn't track LetVal names that aliased hoisted fn references
(`add_0 = v_14` where v_14 is the hoisted add-fn). Nested inline conts
referencing `add_0` couldn't see it in scope_binds and therefore didn't
capture it. Fixed by always adding LetVal names to scope_binds during
extraction, regardless of whether the val aliases a hoisted fn.
---

test 'multiple top-level fns with bound call results', fn:
  expect cps_hoisted ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3

  | equals ƒink:
    ·fn
      fn ·ƒcaps_118, ·ƒctx_65, ·ƒret_10, ·a_4, ·b_5: ·op_plus ·ƒctx_65, ·a_4, ·b_5, ·ƒret_10
      fn ·ƒv_121:
        ·fn
          fn ·ƒcaps_98, ·ƒctx_73, ·ƒret_23, ·a_6, ·b_7: ·op_mul ·ƒctx_73, ·a_6, ·b_7, ·ƒret_23
          fn ·ƒv_101:
            ·fn
              fn ·ƒcaps_90, ·ƒctx_78, ·ƒv_33:
                ·letcaps ·ƒcaps_90, fn {·ƒslot_88, ·ƒret_89}:
                  ·set ·ƒslot_88, ·ƒv_33, fn:
                    ·ƒpub ·ƒctx_78, ·p_3, fn ·ƒctx_80:
                      ·ƒret_89 ·ƒctx_80, ·ƒslot_88
              fn ·ƒv_95:
                ·fn
                  fn ·ƒcaps_108, ·ƒctx_70, ·ƒv_20:
                    ·letcaps ·ƒcaps_108, fn {·ƒslot_104, ·ƒslot_105, ·ƒslot_106, ·ƒret_107}:
                      ·set ·ƒslot_104, ·ƒv_20, fn:
                        ·ƒpub ·ƒctx_70, ·s_1, fn ·ƒctx_72:
                          ·closure ·ƒv_101, {}, fn ·ƒv_22:
                            ·set ·ƒslot_105, ·ƒv_22, fn:
                              ·ƒpub ·ƒctx_72, ·mul_2, fn ·ƒctx_76:
                                ·closure ·ƒv_95, {·ƒslot_88: ·ƒslot_106, ·ƒret_89: ·ƒret_107}, fn ·ƒv_82:
                                  ·ƒslot_105 ·ƒctx_76, ·ƒv_82, ·ƒslot_104, (i8 3)
                  fn ·ƒv_115:
                    ·ƒink_module fn ·ƒctx_63, ·ƒret_8:
                      ·letrec fn ·add_0, ·s_1, ·mul_2, ·p_3:
                        ·closure ·ƒv_121, {}, fn ·ƒv_9:
                          ·set ·add_0, ·ƒv_9, fn:
                            ·ƒpub ·ƒctx_63, ·add_0, fn ·ƒctx_68:
                              ·closure ·ƒv_115, {·ƒslot_104: ·s_1, ·ƒslot_105: ·mul_2, ·ƒslot_106: ·p_3, ·ƒret_107: ·ƒret_8}, fn ·ƒv_85:
                                ·add_0 ·ƒctx_68, ·ƒv_85, (i8 1), (i8 2)
    # sm:-
