      fn ·ƒcaps_58, ·ƒctx_36, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_36, ·a_2, ·b_3, ·ƒret_6
      fn ·ƒv_61:
        ·fn
          fn ·ƒcaps_50, ·ƒctx_41, ·ƒv_16:
            ·letcaps ·ƒcaps_50, fn {·ƒslot_48, ·ƒret_49}:
              ·set ·ƒslot_48, ·ƒv_16, fn:
                ·ƒpub ·ƒctx_41, ·x_1, fn ·ƒctx_43:
                  ·ƒret_49 ·ƒctx_43, ·ƒslot_48
          fn ·ƒv_55:
            ·ƒink_module fn ·ƒctx_34, ·ƒret_4:
              ·letrec fn ·add_0, ·x_1:
                ·closure ·ƒv_61, {}, fn ·ƒv_5:
                  ·set ·add_0, ·ƒv_5, fn:
                    ·ƒpub ·ƒctx_34, ·add_0, fn ·ƒctx_39:
