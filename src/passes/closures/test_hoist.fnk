              ·op_plus ·ƒctx_47, ·a_52, ·b_4, ·ƒret_15
          fn ·ƒv_57:
            ·fn
              fn ·ƒcaps_64, ·ƒctx_46, ·ƒret_13, ·a_3:
                ·closure ·ƒv_57, {·a_52: ·a_3}, fn ·ƒv_14:
                  ·ƒret_13 ·ƒctx_46, ·ƒv_14
              fn ·ƒv_67:
                ·ƒink_module fn ·ƒctx_40, ·ƒret_5:
                  ·letrec fn ·f_0, ·g_1:
                    ·closure ·ƒv_73, {}, fn ·ƒv_6:
                      ·set ·f_0, ·ƒv_6, fn:
                        ·ƒpub ·ƒctx_40, ·f_0, fn ·ƒctx_45:
