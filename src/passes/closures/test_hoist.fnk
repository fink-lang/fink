---
Hoist tests — full regression set for the closures pipeline.

Runs each fink source through convert + hoist. The expected output is
the post-hoist shape: top-level lifted fns (`·fn` chain at the
outermost level), no nested `·fn` inside the module body, all closure
construction explicit via `·closure { ... }` nodes.

Source inputs inherited from the legacy lifting test suite — they
cover module exports, nested fns, destructures, match arms, mutual
recursion, strings, and the historically tricky standalone-destructure
non-convergence case.

For the curated happy-path showing the convert pass output in
isolation (without hoisting), see `test_convert.fnk`.
---

{test, skip, equals, expect, cps_hoisted} = import 'fake!'
{ƒink} = import 'fink/blocks.fnk'
{·ƒink_module,·import,·ƒpub, ·closure, ·if, ·panic
  ·op_plus, ·op_mul, ·op_eq, ·op_minus
  ·fn, ·letrec, ·let, ·set, ·letcaps
  ·empty, ·is_seq_like, ·is_rec_like
  ·seq_pop, ·seq_prepend
  ·rec_put, ·rec_pop, i8, i16
} = import '@fink/compile/builtins'




test 'single module expr', fn:
  expect cps_hoisted ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, (i8 42)
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABgEAAgABAAIGAQAC


test 'single binding export', fn:
  expect cps_hoisted ƒink:
    foo = fn: 123
  | equals ƒink:
    ·fn
      fn ·ƒcaps_25, ·ƒctx_20, ·ƒret_3: ·ƒret_3 ·ƒctx_20, (i8 123)
      fn ·ƒv_28:
        ·ƒink_module fn ·ƒctx_18, ·ƒret_1:
          ·letrec fn ·foo_0:
            ·closure ·ƒv_28, {}, fn ·ƒv_2:
              ·set ·foo_0, ·ƒv_2, fn:
                ·ƒpub ·ƒctx_18, ·foo_0, fn ·ƒctx_23:
                  ·ƒret_1 ·ƒctx_23, ·foo_0
    # sm:PgABDAcAAQAHCAAMABoAGAEIAxIABAEAAwABAAMUABQABgEAAwABAAMGAQADCAAMAQcHEAACAAoBCw0AAQANJAEADRgBAA0SAAIADgEADQABAA0YAQADDgACABIBDAcAAQAHFAEABxAABAEABwABAAcCAQAHAgAKAQAHDgACABYBCw0AAQANDAEAAw4ABAEMBw4ACAACABoBCwMAAQADEAAUAAQBAAMOAAoAFAACAB4BAAMAAQADFAAUAAQBAAM

