pattern matching
---

test 'seq destructure', fn:
  expect cps_hoisted ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·fn
      fn ·v_87, ·ƒctx_63, ·v_10:
        ·letcaps ·v_87, fn {·v_86}:
          ·let ·v_10, fn ·a_2:
            ·op_plus ·ƒctx_63, ·a_2, (i8 1), ·v_86
      fn ·v_91:
        ·fn
          fn ·v_80, ·ƒctx_65, ·ƒsucc_8, ·ƒfail_9, ·v_7:
            ·is_seq_like ·ƒctx_65, ·v_7,
              fn ·ƒctx_67, ·v_22:
                ·seq_pop ·ƒctx_67, ·v_22, ·ƒfail_9, fn ·ƒctx_69, ·v_10, ·v_14:
                  ·empty ·ƒctx_69, ·v_14, fn ·ƒctx_71, ·v_17:
                    ·if ·v_17,
                      fn: ·ƒsucc_8 ·ƒctx_71, ·v_10
                      fn: ·ƒfail_9 ·ƒctx_71
              fn ·ƒctx_74: ·ƒfail_9 ·ƒctx_74
          fn ·v_83:
            ·fn
              fn ·v_94, ·ƒctx_62, ·ƒret_5, ·foo_1:
                ·letrec fn ·a_2:
                  ·closure ·v_91, {·v_86: ·ƒret_5}, fn ·v_41:
                    ·closure ·v_83, {}, fn ·v_30:
                      ·v_30 ·ƒctx_62, ·v_41, ·panic, ·foo_1
              fn ·v_97:
                ·ƒink_module fn ·ƒctx_60, ·ƒret_3:
                  ·letrec fn ·spam_0:
                    ·closure ·v_97, {}, fn ·v_4:
                      ·set ·spam_0, ·v_4, fn:
                        ·ƒpub ·ƒctx_60, ·spam_0, fn ·ƒctx_78:
                          ·ƒret_3 ·ƒctx_78, ·spam_0
    # sm:


test 'record destructure', fn:
  expect cps_hoisted ƒink:
    ham = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·fn
      fn ·v_78, ·ƒctx_57, ·v_10:
        ·letcaps ·v_78, fn {·v_77}:
          ·let ·v_10, fn ·x_2:
            ·op_plus ·ƒctx_57, ·x_2, (i8 1), ·v_77
      fn ·v_82:
        ·fn
          fn ·v_71, ·ƒctx_59, ·ƒsucc_8, ·ƒfail_9, ·v_7:
            ·is_rec_like ·ƒctx_59, ·v_7,
              fn ·ƒctx_61, ·v_15:
                ·rec_pop ·ƒctx_61, ·v_15, 'x', ·ƒfail_9, fn ·ƒctx_63, ·v_10, ·v_14:
                  ·ƒsucc_8 ·ƒctx_63, ·v_10
              fn ·ƒctx_65: ·ƒfail_9 ·ƒctx_65
          fn ·v_74:
            ·fn
              fn ·v_85, ·ƒctx_56, ·ƒret_5, ·foo_1:
                ·letrec fn ·x_2:
