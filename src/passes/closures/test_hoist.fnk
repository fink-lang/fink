test 'captured binding becomes leading param', fn:
  expect cps_hoisted ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·fn
      fn ·v_35, ·ƒctx_29, ·ƒret_7, ·b_2:
        ·letcaps ·v_35, fn {·a_34}:
          ·op_plus ·ƒctx_29, ·a_34, ·b_2, ·ƒret_7
      fn ·v_39:
        ·fn
          fn ·v_44, ·ƒctx_28, ·ƒret_5, ·a_1:
            ·closure ·v_39, {·a_34: ·a_1}, fn ·v_6:
              ·ƒret_5 _
          fn ·v_47:
            ·ƒink_module fn ·ƒctx_26, ·ƒret_3:
              ·letrec fn ·foo_0:
                ·closure ·v_47, {}, fn ·v_4:
                  ·set ·foo_0, ·v_4, fn:
                    ·ƒpub ·ƒctx_26, ·foo_0, fn ·ƒctx_32:
                      ·ƒret_3 ·ƒctx_32, ·foo_0
    # sm:


