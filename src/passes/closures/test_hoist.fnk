      fn ·v_71:
        ·fn
          fn ·v_53, ·ƒctx_47, ·ƒret_15, ·b_4:
            ·letcaps ·v_53, fn {·a_52}:
              ·op_plus ·ƒctx_47, ·a_52, ·b_4, ·ƒret_15
          fn ·v_57:
            ·fn
              fn ·v_62, ·ƒctx_46, ·ƒret_13, ·a_3:
                ·closure ·v_57, {·a_52: ·a_3}, fn ·v_14:
                  ·ƒret_13 _
              fn ·v_65:
                ·ƒink_module fn ·ƒctx_40, ·ƒret_5:
                  ·letrec fn ·f_0, ·g_1:
                    ·closure ·v_71, {}, fn ·v_6:
                      ·set ·f_0, ·v_6, fn:
                        ·ƒpub ·ƒctx_40, ·f_0, fn ·ƒctx_45:
                          ·closure ·v_65, {}, fn ·v_12:
                            ·set ·g_1, ·v_12, fn:
                              ·ƒpub ·ƒctx_45, ·g_1, fn ·ƒctx_50:
                                ·ƒret_5 ·ƒctx_50, ·g_1
    # sm:

