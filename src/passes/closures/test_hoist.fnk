test 'top-level destructure with import rhs — lift non-convergence', fn:
  expect cps_hoisted ƒink:
    {foo} = import './bar.fnk'

  | equals ƒink:
    ·fn
      fn ·ƒcaps_60, ·ƒctx_43, ·ƒv_10:
        ·letcaps ·ƒcaps_60, fn {·ƒret_59}:
          ·let ·ƒv_10, fn ·foo_0:
            ·ƒret_59 ·foo_0
      fn ·ƒv_64:
        ·fn
          fn ·ƒcaps_53, ·ƒctx_44, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
            ·is_rec_like ·ƒctx_44, ·ƒv_7,
              fn ·ƒctx_46, ·ƒv_15:
                ·rec_pop ·ƒctx_46, ·ƒv_15, 'foo', ·ƒfail_9, fn ·ƒctx_48, ·ƒv_10, ·ƒv_14:
                  ·ƒsucc_8 ·ƒctx_48, ·ƒv_10
              fn ·ƒctx_50: ·ƒfail_9 ·ƒctx_50
          fn ·ƒv_56:
            ·ƒink_module fn ·ƒctx_39, ·ƒret_2:
              ·import ·ƒctx_39, './bar.fnk', fn ·ƒctx_42, ·ƒv_5:
                ·closure ·ƒv_64, {·ƒret_59: ·ƒret_2}, fn ·ƒv_30:
