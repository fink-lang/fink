              ·ƒret_5 _
          fn ·v_47:
            ·ƒink_module fn ·ƒctx_26, ·ƒret_3:
              ·letrec fn ·foo_0:
                ·closure ·v_47, {}, fn ·v_4:
                  ·set ·foo_0, ·v_4, fn:
                    ·ƒpub ·ƒctx_26, ·foo_0, fn ·ƒctx_32:
                      ·ƒret_3 ·ƒctx_32, ·foo_0
    # sm:


