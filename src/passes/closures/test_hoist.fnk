test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect cps_hoisted ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·fn
      fn ·ƒcaps_110, ·ƒctx_64, ·ƒret_8, ·x_3: ·op_mul ·ƒctx_64, ·x_3, (i8 2), ·ƒret_8
      fn ·ƒv_113:
        ·fn
          fn ·ƒcaps_104, ·ƒctx_68, ·ƒret_16, ·x_4: ·op_plus ·ƒctx_68, ·x_4, (i8 1), ·ƒret_16
          fn ·ƒv_107:
            ·fn
              fn ·ƒcaps_85, ·ƒctx_74, ·ƒv_27:
                ·letcaps ·ƒcaps_85, fn {·ƒslot_82, ·ƒret_83, ·ƒslot_84}:
                  ·set ·ƒslot_84, ·ƒv_27, fn:
                    ·ƒslot_82 ·ƒctx_74, ·ƒret_83, ·ƒslot_84
              fn ·ƒv_91:
                ·fn
                  fn ·ƒcaps_96, ·ƒctx_72, ·ƒret_24:
                    ·letcaps ·ƒcaps_96, fn {·ƒslot_94, ·ƒslot_95}:
                      ·letrec fn ·x_5:
                        ·closure ·ƒv_91, {·ƒslot_82: ·ƒslot_94, ·ƒret_83: ·ƒret_24, ·ƒslot_84: ·x_5}, fn ·ƒv_79:
                          ·ƒslot_95 ·ƒctx_72, ·ƒv_79, (i8 5)
                  fn ·ƒv_101:
                    ·ƒink_module fn ·ƒctx_62, ·ƒret_6:
                      ·letrec fn ·double_0, ·inc_1, ·foo_2:
                        ·closure ·ƒv_113, {}, fn ·ƒv_7:
                          ·set ·double_0, ·ƒv_7, fn:
                            ·ƒpub ·ƒctx_62, ·double_0, fn ·ƒctx_67:
                              ·closure ·ƒv_107, {}, fn ·ƒv_15:
                                ·set ·inc_1, ·ƒv_15, fn:
                                  ·ƒpub ·ƒctx_67, ·inc_1, fn ·ƒctx_71:
                                    ·closure ·ƒv_101, {·ƒslot_94: ·inc_1, ·ƒslot_95: ·double_0}, fn ·ƒv_23:
                                      ·set ·foo_2, ·ƒv_23, fn:
                                        ·ƒpub ·ƒctx_71, ·foo_2, fn ·ƒctx_77:
                                          ·ƒret_6 ·ƒctx_77, ·foo_2
    # sm:-AQsDAAEAAxAAFAAEAQADDgAKABQAAgBCATYaAAEAGhQBABoSAAQBABoAAQAaAgE1AwABAAMWAAQBAAMOAAQBLQYAAQAGFgAEAQAGFAAAAWQaAgAKAQAaEAACAEYBCyAAAQAgDAEAAw4ABAEMGhAACAACAEoBCwMAAQADEAAUAAQBAAMOAAoAFAACAE4BAAMAAQADFAAUAAQBAAM

---
pattern matching
---

test 'seq destructure', fn:
  expect cps_hoisted ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·fn
      fn ·ƒcaps_87, ·ƒctx_63, ·ƒv_10:
        ·letcaps ·ƒcaps_87, fn {·ƒret_86}:
          ·let ·ƒv_10, fn ·a_2:
            ·op_plus ·ƒctx_63, ·a_2, (i8 1), ·ƒret_86
      fn ·ƒv_91:
