                          ·ƒpub ·ƒctx_43, ·foo_1, fn ·ƒctx_47:
                            ·ƒret_4 ·ƒctx_47, ·foo_1
    # sm:

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect cps_hoisted ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·fn
      fn ·ƒcaps_110, ·ƒctx_64, ·ƒret_8, ·x_3: ·op_mul ·ƒctx_64, ·x_3, (i8 2), ·ƒret_8
      fn ·v_113:
        ·fn
          fn ·ƒcaps_104, ·ƒctx_68, ·ƒret_16, ·x_4: ·op_plus ·ƒctx_68, ·x_4, (i8 1), ·ƒret_16
          fn ·v_107:
            ·fn
              fn ·ƒcaps_85, ·ƒctx_74, ·v_27:
                ·letcaps ·ƒcaps_85, fn {·inc_82, ·ƒret_83, ·x_84}:
                  ·set ·x_84, ·v_27, fn:
                    ·inc_82 ·ƒctx_74, ·ƒret_83, ·x_84
              fn ·v_91:
                ·fn
                  fn ·ƒcaps_96, ·ƒctx_72, ·ƒret_24:
                    ·letcaps ·ƒcaps_96, fn {·inc_94, ·double_95}:
                      ·letrec fn ·x_5:
                        ·closure ·v_91, {·inc_82: ·inc_94, ·ƒret_83: ·ƒret_24, ·x_84: ·x_5}, fn ·v_79:
                          ·double_95 ·ƒctx_72, ·v_79, (i8 5)
                  fn ·v_101:
                    ·ƒink_module fn ·ƒctx_62, ·ƒret_6:
                      ·letrec fn ·double_0, ·inc_1, ·foo_2:
                        ·closure ·v_113, {}, fn ·v_7:
                          ·set ·double_0, ·v_7, fn:
                            ·ƒpub ·ƒctx_62, ·double_0, fn ·ƒctx_67:
                              ·closure ·v_107, {}, fn ·v_15:
                                ·set ·inc_1, ·v_15, fn:
                                  ·ƒpub ·ƒctx_67, ·inc_1, fn ·ƒctx_71:
                                    ·closure ·v_101, {·inc_94: ·inc_1, ·double_95: ·double_0}, fn ·v_23:
                                      ·set ·foo_2, ·v_23, fn:
                                        ·ƒpub ·ƒctx_71, ·foo_2, fn ·ƒctx_77:
                                          ·ƒret_6 ·ƒctx_77, ·foo_2
    # sm:-AQsDAAEAAxAAFAAEAQADDgAKABQAAgBCATYaAAEAGhQBABoOAAQBABoAAQAaAgE1AwABAAMQAAQBAAMOAAQBLQYAAQAGFgAEAQAGFAAAAWQaAgAKAQAaDAACAEYBCyAAAQAgDAEAAw4ABAEMGgwACAACAEoBCwMAAQADEAAUAAQBAAMOAAoAFAACAE4BAAMAAQADFAAUAAQBAAM

---
pattern matching
---

test 'seq destructure', fn:
  expect cps_hoisted ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·fn
      fn ·ƒcaps_87, ·ƒctx_63, ·v_10:
        ·letcaps ·ƒcaps_87, fn {·ƒret_86}:
          ·let ·v_10, fn ·a_2:
            ·op_plus ·ƒctx_63, ·a_2, (i8 1), ·ƒret_86
      fn ·v_91:
        ·fn
          fn ·ƒcaps_80, ·ƒctx_65, ·ƒsucc_8, ·ƒfail_9, ·v_7:
            ·is_seq_like ·ƒctx_65, ·v_7,
              fn ·ƒctx_67, ·v_22:
                ·seq_pop ·ƒctx_67, ·v_22, ·ƒfail_9, fn ·ƒctx_69, ·v_10, ·v_14:
                  ·empty ·ƒctx_69, ·v_14, fn ·ƒctx_71, ·v_17:
                    ·if ·v_17,
                      fn: ·ƒsucc_8 ·ƒctx_71, ·v_10
                      fn: ·ƒfail_9 ·ƒctx_71
              fn ·ƒctx_74: ·ƒfail_9 ·ƒctx_74
          fn ·v_83:
            ·fn
              fn ·ƒcaps_94, ·ƒctx_62, ·ƒret_5, ·foo_1:
                ·letrec fn ·a_2:
                  ·closure ·v_91, {·ƒret_86: ·ƒret_5}, fn ·v_41:
                    ·closure ·v_83, {}, fn ·v_30:
                      ·v_30 ·ƒctx_62, ·v_41, ·panic, ·foo_1
              fn ·v_97:
                ·ƒink_module fn ·ƒctx_60, ·ƒret_3:
                  ·letrec fn ·spam_0:
                    ·closure ·v_97, {}, fn ·v_4:
