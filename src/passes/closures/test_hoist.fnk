      fn ·v_28:
        ·ƒink_module fn ·ƒctx_18, ·ƒret_1:
          ·letrec fn ·foo_0:
            ·closure ·v_28, {}, fn ·v_2:
              ·set ·foo_0, ·v_2, fn:
                ·ƒpub ·ƒctx_18, ·foo_0, fn ·ƒctx_23:
                  ·ƒret_1 ·ƒctx_23, ·foo_0
    # sm:PgABDAcAAQAHCAAMAQAHEAAYAQgDEgAEAQADAAEAAxQAFAAGAQADAAEAAwYBAAMIAAwBBwcMAAIACgELDQABAA0kAQANGAEADRIAAgAOAQANAAEADRgBAAMOAAIAEgEMBwABAAcUAQAHDAAEAQAHAAEABwIBAAcCAAoBAAcKAAIAFgELDQABAA0MAQADDgAEAQwHCgAIAAIAGgELAwABAAMQABQABAEAAw4ACgAUAAIAHgEAAwABAAMUABQABAEAAw

