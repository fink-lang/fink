test 'multi-fn module — add and main', fn:
  expect cps_hoisted ƒink:
    add = fn a, b:
      a + b

    foo = fn:
      add 3, 4

  | equals ƒink:
    ·fn
      fn ·v_57, ·ƒctx_40, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_40, ·a_2, ·b_3, ·ƒret_6
      fn ·v_60:
        ·fn
          fn ·v_50, ·ƒctx_44, ·ƒret_14:
            ·letcaps ·v_50, fn {·add_49}:
              ·add_49 ·ƒctx_44, ·ƒret_14, (i8 3), (i8 4)
          fn ·v_54:
            ·ƒink_module fn ·ƒctx_38, ·ƒret_4:
              ·letrec fn ·add_0, ·foo_1:
                ·closure ·v_60, {}, fn ·v_5:
                  ·set ·add_0, ·v_5, fn:
                    ·ƒpub ·ƒctx_38, ·add_0, fn ·ƒctx_43:
                      ·closure ·v_54, {·add_49: ·add_0}, fn ·v_13:
                        ·set ·foo_1, ·v_13, fn:
                          ·ƒpub ·ƒctx_43, ·foo_1, fn ·ƒctx_47:
                            ·ƒret_4 ·ƒctx_47, ·foo_1
    # sm:

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect cps_hoisted ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·fn
      fn ·v_95, ·ƒctx_64, ·ƒret_8, ·x_3: ·op_mul ·ƒctx_64, ·x_3, (i8 2), ·ƒret_8
      fn ·v_98:
        ·fn
          fn ·v_89, ·ƒctx_68, ·ƒret_16, ·x_4: ·op_plus ·ƒctx_68, ·x_4, (i8 1), ·ƒret_16
          fn ·v_92:
            ·fn
              fn ·v_81, ·ƒctx_72, ·ƒret_24:
                ·letcaps ·v_81, fn {·double_79, ·inc_80}:
                  ·letrec fn ·x_5:
                    ·double_79
                      ·ƒctx_72
                      fn ·ƒctx_74, ·v_27:
                        ·set ·x_5, ·v_27, fn:
                          ·inc_80 ·ƒctx_74, ·ƒret_24, ·x_5
                      i8 5
              fn ·v_86:
                ·ƒink_module fn ·ƒctx_62, ·ƒret_6:
                  ·letrec fn ·double_0, ·inc_1, ·foo_2:
                    ·closure ·v_98, {}, fn ·v_7:
                      ·set ·double_0, ·v_7, fn:
                        ·ƒpub ·ƒctx_62, ·double_0, fn ·ƒctx_67:
                          ·closure ·v_92, {}, fn ·v_15:
                            ·set ·inc_1, ·v_15, fn:
                              ·ƒpub ·ƒctx_67, ·inc_1, fn ·ƒctx_71:
                                ·closure ·v_86, {·double_79: ·double_0, ·inc_80: ·inc_1}, fn ·v_23:
                                  ·set ·foo_2, ·v_23, fn:
                                    ·ƒpub ·ƒctx_71, ·foo_2, fn ·ƒctx_77:
                                      ·ƒret_6 ·ƒctx_77, ·foo_2
    # sm:-AQsgAAEAIAwBAAMOAAQBDBoMAAgAAgBCAQsDAAEAAxAAFAAEAQADDgAKABQAAgBGAQADAAEAAxQAFAAEAQAD

