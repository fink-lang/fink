---
cps_c IR — pretty-printer tests
---

# Input is a Fink expression; output is the synthesized CPS Fink source.
# First-pass CPS — no ·load/·store/·scope synthesis (all names in scope by construction).
#
# Rendering conventions:
#   ·let val, fn name:              — LetVal
#   ·fn fn params: fn_body, fn name: — LetFn
#   ·apply func, args, fn result: — App
#   ·v_cont val             — Ret
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module} = import '@fink/compile/builtins'

---
literals — tail position, no synthesis needed
---

test 'int literal', fn:
  expect cps_module ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (u8 42)
    # sm:CgABAAIAAQACJAEAAhIAAgAGAQACAAEAAhYBAAIAAQACBgEAAg

test 'int literal with underscores', fn:
  expect cps_module ƒink:
    1_000_000
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (u32 1000000)
    # sm:CgABAAkAAQAJJAEACRIAAgAGAQAJAAEACRYBAAkAAQAJCAEACQ

test 'negative int literal', fn:
  expect cps_module ƒink:
    -1_000
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (i16 -1000)
    # sm:CgABAAYAAQAGJAEABhIAAgAGAQAGAAEABhYBAAYAAQAGCAEABg

test 'negative zero literal', fn:
  expect cps_module ƒink:
    -0
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (i8 0)
    # sm:CgABAAIAAQACJAEAAhIAAgAGAQACAAEAAhYBAAIAAQACBgEAAg

test 'hex int literal', fn:
  expect cps_module ƒink:
    0xFF_FF
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (u16 65535)
    # sm:CgABAAcAAQAHJAEABxIAAgAGAQAHAAEABxYBAAcAAQAHCAEABw

test 'octal int literal', fn:
  expect cps_module ƒink:
    0o7_7
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (u8 63)
    # sm:CgABAAUAAQAFJAEABRIAAgAGAQAFAAEABRYBAAUAAQAFBgEABQ

test 'binary int literal', fn:
  expect cps_module ƒink:
    0b_1010_1111
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (u8 175)
    # sm:CgABAAwAAQAMJAEADBIAAgAGAQAMAAEADBYBAAwAAQAMBgEADA

test 'float literal with exponent', fn:
  expect cps_module ƒink:
    1.5e1_0
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 (f64 1.5e10)
    # sm:CgABAAcAAQAHJAEABxIAAgAGAQAHAAEABxYBAAcAAQAHCAEABw

test 'decimal literal', fn:
  expect cps_module ƒink:
    1.5_0d
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 1.50d
    # sm:CAABAAYAAQAGJAEABhIAAgAGAQAGAAEABhQBAAY


test 'bool literal', fn:
  expect cps_module ƒink:
    true
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 true
    # sm:CAABAAQAAQAEJAEABBIAAgAGAQAEAAEABBQBAAQ


test 'string literal', fn:
  expect cps_module ƒink:
    'hello'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 'hello'
    # sm:CwABAAcAAQAHJAEABxIAAgAGAQAHAAEABxQBAAcAAQAHAgEABwoBAAc

