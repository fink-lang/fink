---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·v_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
single binding
---

test 'single binding export', fn:
  expect cps_module ƒink:
    foo = 1
  | equals ƒink:
    ·let 1, fn ·foo_0:
      ·export ·foo_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMSJdLAogICJtYXBwaW5ncyI6ICJBQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtFLEEsUUFBQSIKfQ==


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·let 1, fn ·foo_0:
      ·let 2, fn ·bar_1:
        ·export ·foo_0, ·bar_1
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuYmFyID0gMiJdLAogICJtYXBwaW5ncyI6ICJBQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtFQUNJLEFBQUEsS0FBRSxDLEtBQU4sTTtJLEEsUUFEQSxNLEVBQ0EiCn0=


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·fn
      fn ·ƒret_9, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_9
      fn ·v_8:
        ·let ·v_8, fn ·add_0:
          ·fn
            fn ·ƒret_17: ·add_0 ·ƒret_17, 3, 4
            fn ·v_16:
              ·let ·v_16, fn ·main_1:
                ·export ·add_0, ·main_1
    #sourcemaps:


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn: foo 1
  | equals ƒink:
    ·import fn ·v_8:
      ·fn
        fn ·v_13:
          ·let ·v_13, fn ·foo_0:
            ·fn
              fn ·ƒret_31: ·foo_0 ·ƒret_31, 1
              fn ·v_30:
                ·let ·v_30, fn ·main_1:
                  ·export ·main_1
        fn ·v_45:
          ·fn
            fn ·ƒsucc_11, ·ƒfail_12, ·v_10:
              ·is_rec_like ·v_10,
                fn ·v_18:
                  ·rec_pop ·v_18, 'foo', ·ƒfail_12, fn ·v_13, ·v_17:
                    ·ƒsucc_11 ·v_13
                fn: ·ƒfail_12 _
            fn ·v_27: ·v_27 ·v_45, ·panic, ·v_8, './bar.fnk'
    #sourcemaps:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·seq_prepend 2, [], fn ·v_8:
      ·seq_prepend 1, ·v_8, fn ·v_11:
        ·fn
          fn ·v_16, ·v_17:
            ·let ·v_16, fn ·a_0:
              ·let ·v_17, fn ·b_1:
                ·fn
                  fn ·ƒret_47: ·ƒret_47 ·a_0
                  fn ·v_46:
                    ·let ·v_46, fn ·foo_2:
                      ·export ·foo_2
          fn ·v_61:
            ·fn
              fn ·ƒsucc_14, ·ƒfail_15, ·v_13:
                ·is_seq_like ·v_13,
                  fn ·v_30:
                    ·seq_pop ·v_30, ·ƒfail_15, fn ·v_16, ·v_31:
                      ·seq_pop ·v_31, ·ƒfail_15, fn ·v_17, ·v_22:
                        ·empty ·v_22, fn ·v_25:
                          ·if ·v_25,
                            fn: ·ƒsucc_14 ·v_16, ·v_17
                            fn: ·ƒfail_15 _
                  fn: ·ƒfail_15 _
              fn ·v_42: ·v_42 ·v_61, ·panic, ·v_11
    #sourcemaps:
