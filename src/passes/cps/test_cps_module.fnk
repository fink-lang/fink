---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·v_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
single binding
---

test 'single binding export', fn:
  expect cps_module ƒink:
    foo = 1
  | equals ƒink:
    ·let 1, fn ·foo_0:
      ·export ·foo_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMSJdLAogICJtYXBwaW5ncyI6ICJBQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtFLEEsUUFBQSIKfQ==


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·let 1, fn ·foo_0:
      ·let 2, fn ·bar_1:
        ·export ·foo_0, ·bar_1
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuYmFyID0gMiJdLAogICJtYXBwaW5ncyI6ICJBQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtFQUNJLEFBQUEsS0FBRSxDLEtBQU4sTTtJLEEsUUFEQSxNLEVBQ0EiCn0=


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·fn
      fn ·a_2, ·b_3, ·ret_9: ·op_plus ·a_2, ·b_3, ·v_9
      fn ·v_8:
        ·let ·v_8, fn ·add_0:
          ·fn
            fn ·ret_17: ·add_0 3, 4, ·v_17
            fn ·v_16:
              ·let ·v_16, fn ·main_1:
                ·export ·add_0, ·main_1
    #sourcemaps:


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn: foo 1
  | equals ƒink:
    ·import './bar.fnk', fn ·v_8:
      ·fn
        fn ·v_13:
          ·let ·v_13, fn ·foo_0:
            ·fn
              fn ·ret_26: ·foo_0 1, ·v_26
              fn ·v_25:
                ·let ·v_25, fn ·main_1:
                  ·export ·main_1
        fn ·v_40:
          ·fn
            fn ·v_10, ·succ_11, ·fail_12:
              ·rec_pop ·v_10, 'foo', ·v_12, fn ·v_13, ·v_17:
                ·v_11 ·v_13
            fn ·v_22: ·v_22 ·v_8, ·v_40, ·panic
    #sourcemaps:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·seq_prepend 2, [], fn ·v_8:
      ·seq_prepend 1, ·v_8, fn ·v_11:
        ·fn
          fn ·v_16, ·v_17:
            ·let ·v_16, fn ·a_0:
              ·let ·v_17, fn ·b_1:
                ·fn
                  fn ·ret_42: ·v_42 ·a_0
                  fn ·v_41:
                    ·let ·v_41, fn ·foo_2:
                      ·export ·foo_2
          fn ·v_56:
            ·fn
              fn ·v_13, ·succ_14, ·fail_15:
                ·seq_pop ·v_13, ·v_15, fn ·v_16, ·v_30:
                  ·seq_pop ·v_30, ·v_15, fn ·v_17, ·v_22:
                    ·empty ·v_22, fn ·v_25:
                      ·if ·v_25,
                        fn: ·v_14 ·v_16, ·v_17
                        fn: ·v_15 _
              fn ·v_37: ·v_37 ·v_11, ·v_56, ·panic
    #sourcemaps:
