---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·ƒ_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module fink":
#       <fink source>
#     | equals fink":
#       <expected cps output>

{test, expect, equals, fink, cps_module} = import '!fake'


---
single binding
---

test 'single binding export', fn:
  expect cps_module fink":
    foo = 1
  | equals fink":
    ·let 1, fn ·foo_0:
      ·export ·foo_0


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module fink":
    foo = 1
    bar = 2
  | equals fink":
    ·let 1, fn ·foo_0:
      ·let 2, fn ·bar_1:
        ·export ·foo_0, ·bar_1


test 'two fns export', fn:
  expect cps_module fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals fink":
    ·fn
      fn ·a_2, ·b_3, ·ƒ_9:
        ·op_plus ·a_2, ·b_3, ·ƒ_9
      fn ·v_8:
        ·let ·v_8, fn ·add_0:
          ·fn
            fn ·ƒ_17:
              ·add_0 3, 4, ·ƒ_17
            fn ·v_16:
              ·let ·v_16, fn ·main_1:
                ·export ·add_0, ·main_1


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module fink":
    {foo} = import './bar.fnk'
    main = fn: foo 1
  | equals fink":
    ·∅import './bar.fnk', fn ·v_7:
      ·match_rec ·v_7, ·panic, fn ·v_9:
        ·match_field ·v_9, 'foo', ·panic, fn ·v_10, ·v_11:
          ·let ·v_10, fn ·foo_0:
            ·fn
              fn ·ƒ_16:
                ·foo_0 1, ·ƒ_16
              fn ·v_15:
                ·let ·v_15, fn ·main_1:
                  ·export ·main_1


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module fink":
    [a, b] = [1, 2]
    foo = fn: a
  | equals fink":
    ·seq_append [], 1, fn ·v_8:
      ·seq_append ·v_8, 2, fn ·v_11:
        ·match_seq ·v_11, ·panic, fn ·v_13:
          ·match_next ·v_13, ·panic, fn ·v_14, ·v_15:
            ·let ·v_14, fn ·a_0:
              ·match_next ·v_15, ·panic, fn ·v_18, ·v_19:
                ·let ·v_18, fn ·b_1:
                  ·match_done ·v_19, ·panic, fn ·v_22:
                    ·fn
                      fn ·ƒ_25:
                        ·ƒ_25 ·a_0
                      fn ·v_24:
                        ·let ·v_24, fn ·foo_2:
                          ·export ·foo_2
