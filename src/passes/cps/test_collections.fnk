{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_module ƒink:
    [1, 2, 3]
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_prepend 3, [], fn ·v_3:
        ·seq_prepend 2, ·v_3, fn ·v_6:
          ·seq_prepend 1, ·v_6, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWzEsIDIsIDNdIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxhQUFPLEMsRUFBUCxBLEMsQyxLQUFBLEk7SUFBQSxBQUFBLGFBQUksQyxFQUFKLEksS0FBQSxJO01BQUEsQUFBQSxhQUFDLEMsRUFBRCxJLEUiCn0=


test 'empty seq literal', fn:
  expect cps_module ƒink:
    []
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 []
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiW10iXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RSxBLFFBQUEsQSxDIgp9


test 'rec literal', fn:
  expect cps_module ƒink:
    {x: 1, y: 2}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·rec_put {}, 'x', 1, fn ·v_4:
        ·rec_put ·v_4, 'y', 2, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie3g6IDEsIHk6IDJ9Il0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxTQUFBLEEsQyxDLEVBQUMsQSxDQUFBLEMsQyxFQUFHLEMsS0FBSixJO0lBQUEsQUFBQSxTQUFBLEksRUFBTyxBLENBQUEsQyxDLEVBQUcsQyxFIgp9


test 'empty rec literal', fn:
  expect cps_module ƒink:
    {}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 {}
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie30iXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RSxBLFFBQUEsQSxDIgp9


test 'rec shorthand', fn:
  expect cps_module ƒink:
    {x, y}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·rec_put {}, 'x', ·∅x, fn ·v_4:
        ·rec_put ·v_4, 'y', ·∅y, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie3gsIHl9Il0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxTQUFBLEEsQyxDLEVBQUMsQSxDQUFBLEMsQyxFQUFBLEcsS0FBRCxJO0lBQUEsQUFBQSxTQUFBLEksRUFBSSxBLENBQUEsQyxDLEVBQUEsRyxFIgp9



---
member access
---

test 'member static', fn:
  expect cps_module ƒink:
    foo.bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_dot ·∅foo, 'bar', ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLmJhciJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsUUFBQSxLLEVBQUksQSxDQUFBLEcsQyxFIgp9


test 'member dynamic', fn:
  expect cps_module ƒink:
    foo.(key)
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_dot ·∅foo, ·∅key, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLihrZXkpIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxRQUFBLEssRUFBSyxLLEUiCn0=


test 'member string key shorthand', fn:
  expect cps_module ƒink:
    foo.'bar baz'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_dot ·∅foo, 'bar baz', ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLidiYXIgYmF6JyJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsUUFBQSxLLEVBQUksQSxDQUFBLE8sQyxFIgp9



---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_module ƒink:
    [..xs, 1]
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_prepend 1, [], fn ·v_3:
        ·seq_concat ·∅xs, ·v_3, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWy4ueHMsIDFdIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxhQUFPLEMsRUFBUCxBLEMsQyxLQUFBLEk7SUFBQSxBQUFBLFlBQUcsSSxFQUFILEksRSIKfQ==


test 'rec spread', fn:
  expect cps_module ƒink:
    {..base, x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·rec_merge {}, ·∅base, fn ·v_3:
        ·rec_put ·v_3, 'x', 1, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiey4uYmFzZSwgeDogMX0iXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFBLFdBQUEsQSxDLEMsRUFBRyxNLEtBQUgsSTtJQUFBLEFBQUEsU0FBQSxJLEVBQVMsQSxDQUFBLEMsQyxFQUFHLEMsRSIKfQ==



---
tagged literals
---

test 'tagged literal', fn:
  expect cps_module ƒink:
    10sec
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅sec ·ƒret_0, 10
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiMTBzZWMiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFFLE0sTyxFQUFGIgp9



---
seq/rec literals with spreads
---

# NOTE: ·seq_prepend/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_module ƒink:
    [1, ..a, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_prepend 2, [], fn ·v_3:
        ·seq_concat ·∅a, ·v_3, fn ·v_6:
          ·seq_prepend 1, ·v_6, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWzEsIC4uYSwgMl0iXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFBLGFBQVMsQyxFQUFULEEsQyxDLEtBQUEsSTtJQUFBLEFBQUEsWUFBTSxHLEVBQU4sSSxLQUFBLEk7TUFBQSxBQUFBLGFBQUMsQyxFQUFELEksRSIKfQ==

test 'seq literal leading spread', fn:
  expect cps_module ƒink:
    [..a, ..b]
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_concat ·∅b, [], fn ·v_3:
        ·seq_concat ·∅a, ·v_3, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWy4uYSwgLi5iXSJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsWUFBUSxHLEVBQVIsQSxDLEMsS0FBQSxJO0lBQUEsQUFBQSxZQUFHLEcsRUFBSCxJLEUiCn0=

test 'rec literal with spread', fn:
  expect cps_module ƒink:
    {foo: a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·rec_put {}, 'foo', ·∅a, fn ·v_4:
        ·rec_merge ·v_4, ·∅b, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie2ZvbzogYSwgLi5ifSJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsU0FBQSxBLEMsQyxFQUFDLEEsQ0FBQSxHLEMsRUFBSyxHLEtBQU4sSTtJQUFBLEFBQUEsV0FBQSxJLEVBQVcsRyxFIgp9

test 'rec literal leading spread', fn:
  expect cps_module ƒink:
    {..a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·rec_merge {}, ·∅a, fn ·v_3:
        ·rec_merge ·v_3, ·∅b, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiey4uYSwgLi5ifSJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsV0FBQSxBLEMsQyxFQUFHLEcsS0FBSCxJO0lBQUEsQUFBQSxXQUFBLEksRUFBUSxHLEUiCn0=


