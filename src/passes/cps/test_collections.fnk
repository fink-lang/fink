{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import 'fink/blocks.fnk'

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_module ƒink:
    [1, 2, 3]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend ·ƒctx_16, (i8 3), [], fn ·ƒctx_19, ·ƒv_5:
        ·seq_prepend ·ƒctx_19, (i8 2), ·ƒv_5, fn ·ƒctx_21, ·ƒv_7:
          ·seq_prepend ·ƒctx_21, (i8 1), ·ƒv_7, ·ƒret_0
    # sm:LwABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEcABQABgEAAQABAAEGAQABBAAEAQ0JAAEACQIBAAkCAAoAGAEOAQ4AAgAKAQUBAAEAARwAFAAGAQABAAEAAQYBAAEEAAQBBgEOAAoAGAEFAQ4AAgAOAQUBAAEAARwAFAAGAQABAAEAAQYBAAEEAAQBBgEOAAQBBQE


test 'empty seq literal', fn:
  expect cps_module ƒink:
    []
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, []
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec literal', fn:
  expect cps_module ƒink:
    {x: 1, y: 2}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put ·ƒctx_13, {}, ƒ'x', (i8 1), fn ·ƒctx_16, ·ƒv_4:
        ·rec_put ·ƒctx_16, ·ƒv_4, ƒ'y', (i8 2), ·ƒret_0
    # sm:JQABAAwAAQAMJAEADBgBAAwSAAIABgECBAABAAQUABQABAEBDAABAAwCAQAMAgAEAQIBCgAGAQYBAAEAAQYBAAEEAAoAGAEFBA4AAgAKAQwEAAEABBQAFAAEAQsEDgAEAQwBCgAGAQYBAAEAAQYBAAEEAAQBBQQ


test 'empty rec literal', fn:
  expect cps_module ƒink:
    {}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, {}
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec shorthand', fn:
  expect cps_module ƒink:
    {x, y}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put ·ƒctx_13, {}, ƒ'x', ·∅x, fn ·ƒctx_16, ·ƒv_4:
        ·rec_put ·ƒctx_16, ·ƒv_4, ƒ'y', ·∅y, ·ƒret_0
    # sm:IQABAAYAAQAGJAEABhgBAAYSAAIABgECAQABAAEUABQABAEBBgABAAYCAQAGAgAEAQIBCgAEAQABDAAKABgBAAEOAAIACgEGAQABAAEUABQABAEFAQ4ABAEGAQoABAEAAQwABAEAAQ



---
member access
---

test 'member static', fn:
  expect cps_module ƒink:
    foo.bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, ƒ'bar', ·ƒret_0
    # sm:DwABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcSABIABAEAAxAABAEIAw4ABAEHBw


test 'member dynamic get', fn:
  expect cps_module ƒink:
    foo.(key)
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, ·∅key, ·ƒret_0
    # sm:DwABAAkAAQAJJAEACRYBAAkSAAIABgEACQABAAkSABIABAEAAxAABAEKAxAABAEJCQ


test 'member dynamic key', fn:
  expect cps_module ƒink:
    key = 'foo'
    {(key): 42}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_14, ·ƒret_1:
      ·letrec fn ·key_0:
        ·set ·key_0, 'foo', fn:
          ·ƒpub ·ƒctx_14, ·key_0, fn ·ƒctx_17:
            ·rec_put ·ƒctx_17, {}, ·key_0, (i8 42), ·ƒret_1
    # sm:LgABABcAAQAXJAEAFxgBGAsSAAIABgEXFwABABcYAQADDgACAAoBAAsAAQALDAEAAw4ABAEMBQABAAUCAQAFBgEABQIACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBGgkAAQAJFAAUAAQBAQsAAQALAgEACwIABAEEAw4ABgEMAgABAAIGAQACBgAEAQ0J


test 'member string key shorthand', fn:
  expect cps_module ƒink:
    foo.'bar baz'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, 'bar baz', ·ƒret_0
    # sm:EgABAA0AAQANJAEADRYBAA0SAAIABgEADQABAA0SABIABAEAAxAABAEICQABAAkCAQAJDgEACQIABAEHDQ



---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_module ƒink:
    [..xs, 1]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_prepend ·ƒctx_11, (i8 1), [], fn ·ƒctx_14, ·ƒv_4:
        ·seq_concat ·ƒctx_14, ·∅xs, ·ƒv_4, ·ƒret_0
    # sm:HwABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEcABQABgEAAQABAAEGAQABBAAEAQ0JAAEACQIBAAkCAAoAGAEOAQ4AAgAKAQsEAAEABBoAFAAEAQQCDgAEAQgBDgAEAQsE


test 'rec spread', fn:
  expect cps_module ƒink:
    {..base, x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_merge ·ƒctx_12, {}, ·∅base, fn ·ƒctx_15, ·ƒv_3:
        ·rec_put ·ƒctx_15, ·ƒv_3, ƒ'x', (i8 1), ·ƒret_0
    # sm:IQABAA4AAQAOJAEADhgBAA4SAAIABgECBgABAAYYABQABAEBDgABAA4CAQAOAgAEAQYEEgAKABgBAwYOAAIACgEQBAABAAQUABQABAEPBg4ABAEQAQoABgEGAQABAAEGAQABBAAEAQUE



---
tagged literals
---

test 'tagged literal', fn:
  expect cps_module ƒink:
    10sec
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅sec ·ƒctx_6, ·ƒret_0, (i8 10)
    # sm:DwABAAUAAQAFJAEABRYBAAUSAAIABgEABQABBAMSABIABAEDBRIABgEAAgABAAIGAQAC



---
seq/rec literals with spreads
---

# NOTE: ·seq_prepend/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_module ƒink:
    [1, ..a, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend ·ƒctx_16, (i8 2), [], fn ·ƒctx_19, ·ƒv_5:
        ·seq_concat ·ƒctx_19, ·∅a, ·ƒv_5, fn ·ƒctx_21, ·ƒv_7:
          ·seq_prepend ·ƒctx_21, (i8 1), ·ƒv_7, ·ƒret_0
    # sm:LQABAAsAAQALJAEACxgBAAsSAAIABgESAQABAAEcABQABgEAAQABAAEGAQABBAAEARELAAEACwIBAAsCAAoAGAESAQ4AAgAKAQkDAAEAAxoAFAAEAQQBDAAEAQYBDgAKABgBCQMOAAIADgEFAQABAAEcABQABgEAAQABAAEGAQABBAAEAQYDDgAEAQUB

test 'seq literal leading spread', fn:
  expect cps_module ƒink:
    [..a, ..b]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_concat ·ƒctx_11, ·∅b, [], fn ·ƒctx_14, ·ƒv_4:
        ·seq_concat ·ƒctx_14, ·∅a, ·ƒv_4, ·ƒret_0
    # sm:HQABAAoAAQAKJAEAChgBAAoSAAIABgEMAwABAAMaABQABAEEAQwABAEPCgABAAoCAQAKAgAKABgBDAMOAAIACgEJAwABAAMaABQABAEEAQwABAEGAw4ABAEJAw

test 'rec literal with spread', fn:
  expect cps_module ƒink:
    {foo: a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_put ·ƒctx_12, {}, ƒ'foo', ·∅a, fn ·ƒctx_15, ·ƒv_4:
        ·rec_merge ·ƒctx_15, ·ƒv_4, ·∅b, ·ƒret_0
    # sm:HwABAA0AAQANJAEADRgBAA0SAAIABgECBgABAAYUABQABAEBDQABAA0CAQANAgAEAQIDDgAEAQoBDAAKABgBCQYOAAIACgEQAwABAAMYABQABAEPBg4ABAEUAQwABAEDAw

test 'rec literal leading spread', fn:
  expect cps_module ƒink:
    {..a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·rec_merge ·ƒctx_11, {}, ·∅a, fn ·ƒctx_14, ·ƒv_3:
        ·rec_merge ·ƒctx_14, ·ƒv_3, ·∅b, ·ƒret_0
    # sm:HQABAAoAAQAKJAEAChgBAAoSAAIABgECAwABAAMYABQABAEBCgABAAoCAQAKAgAEAQYBDAAKABgBAwMOAAIACgEKAwABAAMYABQABAEJAw4ABAEOAQwABAEDAw


