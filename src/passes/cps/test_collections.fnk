{test, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_expr ƒink:
    [1, 2, 3]
  | equals ƒink:
    ·seq_prepend 3, [], fn ·v_3:
      ·seq_prepend 2, ·v_3, fn ·v_6:
        ·seq_prepend 1, ·v_6, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWzEsIDIsIDNdIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxhQUFPLEMsRUFBUCxBLEMsQyxLQUFBLEk7RUFBQSxBQUFBLGFBQUksQyxFQUFKLEksS0FBQSxJO0lBQUEsQUFBQSxhQUFDLEMsRUFBRCxJLEUiCn0=


test 'empty seq literal', fn:
  expect cps_expr ƒink:
    []
  | equals ƒink:
    ·v_0 []
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiW10iXSwKICAibWFwcGluZ3MiOiAiQSxBLEtBQUEsQSxDIgp9


test 'rec literal', fn:
  expect cps_expr ƒink:
    {x: 1, y: 2}
  | equals ƒink:
    ·rec_put {}, 'x', 1, fn ·v_4:
      ·rec_put ·v_4, 'y', 2, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie3g6IDEsIHk6IDJ9Il0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxTQUFBLEEsQyxDLEVBQUMsQSxDQUFBLEMsQyxFQUFHLEMsS0FBSixJO0VBQUEsQUFBQSxTQUFBLEksRUFBTyxBLENBQUEsQyxDLEVBQUcsQyxFIgp9


test 'empty rec literal', fn:
  expect cps_expr ƒink:
    {}
  | equals ƒink:
    ·v_0 {}
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie30iXSwKICAibWFwcGluZ3MiOiAiQSxBLEtBQUEsQSxDIgp9


test 'rec shorthand', fn:
  expect cps_expr ƒink:
    {x, y}
  | equals ƒink:
    ·rec_put {}, 'x', ·∅x, fn ·v_4:
      ·rec_put ·v_4, 'y', ·∅y, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie3gsIHl9Il0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxTQUFBLEEsQyxDLEVBQUMsQSxDQUFBLEMsQyxFQUFBLEcsS0FBRCxJO0VBQUEsQUFBQSxTQUFBLEksRUFBSSxBLENBQUEsQyxDLEVBQUEsRyxFIgp9



---
member access
---

test 'member static', fn:
  expect cps_expr ƒink:
    foo.bar
  | equals ƒink:
    ·op_dot ·∅foo, 'bar', ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLmJhciJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsUUFBQSxLLEVBQUksQSxDQUFBLEcsQyxFIgp9


test 'member dynamic', fn:
  expect cps_expr ƒink:
    foo.(key)
  | equals ƒink:
    ·op_dot ·∅foo, ·∅key, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLihrZXkpIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxRQUFBLEssRUFBSyxLLEUiCn0=


test 'member string key shorthand', fn:
  expect cps_expr ƒink:
    foo.'bar baz'
  | equals ƒink:
    ·op_dot ·∅foo, 'bar baz', ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vLidiYXIgYmF6JyJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsUUFBQSxLLEVBQUksQSxDQUFBLE8sQyxFIgp9



---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_expr ƒink:
    [..xs, 1]
  | equals ƒink:
    ·seq_prepend 1, [], fn ·v_3:
      ·seq_concat ·∅xs, ·v_3, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWy4ueHMsIDFdIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxhQUFPLEMsRUFBUCxBLEMsQyxLQUFBLEk7RUFBQSxBQUFBLFlBQUcsSSxFQUFILEksRSIKfQ==


test 'rec spread', fn:
  expect cps_expr ƒink:
    {..base, x: 1}
  | equals ƒink:
    ·rec_merge {}, ·∅base, fn ·v_3:
      ·rec_put ·v_3, 'x', 1, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiey4uYmFzZSwgeDogMX0iXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBLFdBQUEsQSxDLEMsRUFBRyxNLEtBQUgsSTtFQUFBLEFBQUEsU0FBQSxJLEVBQVMsQSxDQUFBLEMsQyxFQUFHLEMsRSIKfQ==



---
tagged literals
---

test 'tagged literal', fn:
  expect cps_expr ƒink:
    10sec
  | equals ƒink:
    ·∅sec ·v_0, 10
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiMTBzZWMiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFFLE0sSSxFQUFGIgp9



---
seq/rec literals with spreads
---

# NOTE: ·seq_prepend/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_expr ƒink:
    [1, ..a, 2]
  | equals ƒink:
    ·seq_prepend 2, [], fn ·v_3:
      ·seq_concat ·∅a, ·v_3, fn ·v_6:
        ·seq_prepend 1, ·v_6, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWzEsIC4uYSwgMl0iXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBLGFBQVMsQyxFQUFULEEsQyxDLEtBQUEsSTtFQUFBLEFBQUEsWUFBTSxHLEVBQU4sSSxLQUFBLEk7SUFBQSxBQUFBLGFBQUMsQyxFQUFELEksRSIKfQ==

test 'seq literal leading spread', fn:
  expect cps_expr ƒink:
    [..a, ..b]
  | equals ƒink:
    ·seq_concat ·∅b, [], fn ·v_3:
      ·seq_concat ·∅a, ·v_3, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiWy4uYSwgLi5iXSJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsWUFBUSxHLEVBQVIsQSxDLEMsS0FBQSxJO0VBQUEsQUFBQSxZQUFHLEcsRUFBSCxJLEUiCn0=

test 'rec literal with spread', fn:
  expect cps_expr ƒink:
    {foo: a, ..b}
  | equals ƒink:
    ·rec_put {}, 'foo', ·∅a, fn ·v_4:
      ·rec_merge ·v_4, ·∅b, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsie2ZvbzogYSwgLi5ifSJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsU0FBQSxBLEMsQyxFQUFDLEEsQ0FBQSxHLEMsRUFBSyxHLEtBQU4sSTtFQUFBLEFBQUEsV0FBQSxJLEVBQVcsRyxFIgp9

test 'rec literal leading spread', fn:
  expect cps_expr ƒink:
    {..a, ..b}
  | equals ƒink:
    ·rec_merge {}, ·∅a, fn ·v_3:
      ·rec_merge ·v_3, ·∅b, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiey4uYSwgLi5ifSJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsV0FBQSxBLEMsQyxFQUFHLEcsS0FBSCxJO0VBQUEsQUFBQSxXQUFBLEksRUFBUSxHLEUiCn0=


