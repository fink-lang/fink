{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_module ƒink:
    [1, 2, 3]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend ·ƒctx_16, (i8 3), [], fn ·ƒctx_19, ·v_3:
        ·seq_prepend ·ƒctx_19, (i8 2), ·v_3, fn ·ƒctx_21, ·v_6:
          ·seq_prepend ·ƒctx_21, (i8 1), ·v_6, ·ƒret_0
    # sm:LwABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEcABQABgEAAQABAAEGAQABBAAEAQ0JAAEACQIBAAkCAAoAGAEOAQoAAgAKAQUBAAEAARwAFAAGAQABAAEAAQYBAAEEAAQBBgEKAAoAGAEFAQoAAgAOAQUBAAEAARwAFAAGAQABAAEAAQYBAAEEAAQBBgEKAAQBBQE


test 'empty seq literal', fn:
  expect cps_module ƒink:
    []
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, []
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec literal', fn:
  expect cps_module ƒink:
    {x: 1, y: 2}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put ·ƒctx_13, {}, 'x', (i8 1), fn ·ƒctx_16, ·v_4:
        ·rec_put ·ƒctx_16, ·v_4, 'y', (i8 2), ·ƒret_0
    # sm:KwABAAwAAQAMJAEADBgBAAwSAAIABgECBAABAAQUABQABAEBDAABAAwCAQAMAgAEAQIBAAEAAQIBAAECAQABAgAGAQYBAAEAAQYBAAEEAAoAGAEFBAoAAgAKAQwEAAEABBQAFAAEAQsECgAEAQwBAAEAAQIBAAECAQABAgAGAQYBAAEAAQYBAAEEAAQBBQQ


test 'empty rec literal', fn:
  expect cps_module ƒink:
    {}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, {}
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec shorthand', fn:
  expect cps_module ƒink:
    {x, y}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put ·ƒctx_13, {}, 'x', ·∅x, fn ·ƒctx_16, ·v_4:
        ·rec_put ·ƒctx_16, ·x_4, 'y', ·∅y, ·ƒret_0
    # sm:JwABAAYAAQAGJAEABhgBAAYSAAIABgECAQABAAEUABQABAEBBgABAAYCAQAGAgAEAQIBAAEAAQIBAAECAQABAgAEAQABDAAKABgBAAEKAAIACgEGAQABAAEUABQABAEFAQoABAEGAQABAAECAQABAgEAAQIABAEAAQwABAEAAQ



---
member access
---

test 'member static', fn:
  expect cps_module ƒink:
    foo.bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, 'bar', ·ƒret_0
    # sm:EgABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcSABIABAEAAxAABAEIAwABAAMCAQADBgEAAwIABAEHBw


test 'member dynamic get', fn:
  expect cps_module ƒink:
    foo.(key)
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, ·∅key, ·ƒret_0
    # sm:DwABAAkAAQAJJAEACRYBAAkSAAIABgEACQABAAkSABIABAEAAxAABAEKAxAABAEJCQ


test 'member dynamic key', fn:
  expect cps_module ƒink:
    key = 'foo'
    {(key): 42}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_14, ·ƒret_1:
      ·letrec fn ·key_0:
        ·set ·key_0, 'foo', fn:
          ·ƒpub ·ƒctx_14, ·key_0, fn ·ƒctx_17:
            ·rec_put ·ƒctx_17, {}, ·key_0, (i8 42), ·ƒret_1
    # sm:LgABABcAAQAXJAEAFxgBGAsSAAIABgEXFwABABcYAQADDgACAAoBAAsAAQALDAEAAw4ABAEMBQABAAUCAQAFBgEABQIACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBGgkAAQAJFAAUAAQBAQsAAQALAgEACwIABAEEAw4ABgEMAgABAAIGAQACBgAEAQ0J


test 'member string key shorthand', fn:
  expect cps_module ƒink:
    foo.'bar baz'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·ƒctx_6, ·∅foo, 'bar baz', ·ƒret_0
    # sm:EgABAA0AAQANJAEADRYBAA0SAAIABgEADQABAA0SABIABAEAAxAABAEICQABAAkCAQAJDgEACQIABAEHDQ



---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_module ƒink:
    [..xs, 1]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_prepend ·ƒctx_11, (i8 1), [], fn ·ƒctx_14, ·v_3:
        ·seq_concat ·ƒctx_14, ·∅xs, ·v_3, ·ƒret_0
    # sm:HwABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEcABQABgEAAQABAAEGAQABBAAEAQ0JAAEACQIBAAkCAAoAGAEOAQoAAgAKAQsEAAEABBoAFAAEAQQCDgAEAQgBCgAEAQsE


test 'rec spread', fn:
  expect cps_module ƒink:
    {..base, x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_merge ·ƒctx_12, {}, ·∅base, fn ·ƒctx_15, ·v_3:
        ·rec_put ·ƒctx_15, ·v_3, 'x', (i8 1), ·ƒret_0
    # sm:JAABAA4AAQAOJAEADhgBAA4SAAIABgECBgABAAYYABQABAEBDgABAA4CAQAOAgAEAQYEEgAKABgBAwYKAAIACgEQBAABAAQUABQABAEPBgoABAEQAQABAAECAQABAgEAAQIABgEGAQABAAEGAQABBAAEAQUE



---
tagged literals
---

test 'tagged literal', fn:
  expect cps_module ƒink:
    10sec
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅sec ·ƒctx_6, ·ƒret_0, (i8 10)
    # sm:DwABAAUAAQAFJAEABRYBAAUSAAIABgEABQABBAMSABIABAEDBRIABgEAAgABAAIGAQAC



---
seq/rec literals with spreads
---

# NOTE: ·seq_prepend/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_module ƒink:
    [1, ..a, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend ·ƒctx_16, (i8 2), [], fn ·ƒctx_19, ·v_3:
        ·seq_concat ·ƒctx_19, ·∅a, ·v_3, fn ·ƒctx_21, ·v_6:
          ·seq_prepend ·ƒctx_21, (i8 1), ·v_6, ·ƒret_0
    # sm:LQABAAsAAQALJAEACxgBAAsSAAIABgESAQABAAEcABQABgEAAQABAAEGAQABBAAEARELAAEACwIBAAsCAAoAGAESAQoAAgAKAQkDAAEAAxoAFAAEAQQBDAAEAQYBCgAKABgBCQMKAAIADgEFAQABAAEcABQABgEAAQABAAEGAQABBAAEAQYDCgAEAQUB

test 'seq literal leading spread', fn:
  expect cps_module ƒink:
    [..a, ..b]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_concat ·ƒctx_11, ·∅b, [], fn ·ƒctx_14, ·v_3:
        ·seq_concat ·ƒctx_14, ·∅a, ·v_3, ·ƒret_0
    # sm:HQABAAoAAQAKJAEAChgBAAoSAAIABgEMAwABAAMaABQABAEEAQwABAEPCgABAAoCAQAKAgAKABgBDAMKAAIACgEJAwABAAMaABQABAEEAQwABAEGAwoABAEJAw

test 'rec literal with spread', fn:
  expect cps_module ƒink:
    {foo: a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_put ·ƒctx_12, {}, 'foo', ·∅a, fn ·ƒctx_15, ·v_4:
        ·rec_merge ·ƒctx_15, ·v_4, ·∅b, ·ƒret_0
    # sm:IgABAA0AAQANJAEADRgBAA0SAAIABgECBgABAAYUABQABAEBDQABAA0CAQANAgAEAQIDAAEAAwIBAAMGAQADAgAEAQoBDAAKABgBCQYKAAIACgEQAwABAAMYABQABAEPBgoABAEUAQwABAEDAw

test 'rec literal leading spread', fn:
  expect cps_module ƒink:
    {..a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·rec_merge ·ƒctx_11, {}, ·∅a, fn ·ƒctx_14, ·v_3:
        ·rec_merge ·ƒctx_14, ·v_3, ·∅b, ·ƒret_0
    # sm:HQABAAoAAQAKJAEAChgBAAoSAAIABgECAwABAAMYABQABAEBCgABAAoCAQAKAgAEAQYBDAAKABgBAwMKAAIACgEKAwABAAMYABQABAEJAwoABAEOAQwABAEDAw


