{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_module ƒink:
    [1, 2, 3]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend (i8 3), [], fn ·ƒctx_18, ·v_3:
        ·seq_prepend (i8 2), ·v_3, fn ·ƒctx_19, ·v_6:
          ·seq_prepend (i8 1), ·v_6, ·ƒret_0
    # sm:KQABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEeAQABAAEAAQYBAAEEAAQBDQkAAQAJAgEACQIACgAYAQ4BCgACAAoBBQEAAQABHgEAAQABAAEGAQABBAAEAQYBCgAKABgBBQEKAAIADgEFAQABAAEeAQABAAEAAQYBAAEEAAQBBgEKAAQBBQE


test 'empty seq literal', fn:
  expect cps_module ƒink:
    []
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, []
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec literal', fn:
  expect cps_module ƒink:
    {x: 1, y: 2}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put {}, 'x', (i8 1), fn ·ƒctx_15, ·v_4:
        ·rec_put ·v_4, 'y', (i8 2), ·ƒret_0
    # sm:JwABAAwAAQAMJAEADBgBAAwSAAIABgECBAABAAQUAQEMAAEADAIBAAwCAAQBAgEAAQABAgEAAQIBAAECAAYBBgEAAQABBgEAAQQACgAYAQUECgACAAoBDAQAAQAEFAELBAoABAEMAQABAAECAQABAgEAAQIABgEGAQABAAEGAQABBAAEAQUE


test 'empty rec literal', fn:
  expect cps_module ƒink:
    {}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, {}
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABAEAAgABAAICAQAC


test 'rec shorthand', fn:
  expect cps_module ƒink:
    {x, y}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·rec_put {}, 'x', ·∅x, fn ·ƒctx_15, ·v_4:
        ·rec_put ·x_4, 'y', ·∅y, ·ƒret_0
    # sm:IwABAAYAAQAGJAEABhgBAAYSAAIABgECAQABAAEUAQEGAAEABgIBAAYCAAQBAgEAAQABAgEAAQIBAAECAAQBAAEMAAoAGAEAAQoAAgAKAQYBAAEAARQBBQEKAAQBBgEAAQABAgEAAQIBAAECAAQBAAEMAAQBAAE



---
member access
---

test 'member static', fn:
  expect cps_module ƒink:
    foo.bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·∅foo, 'bar', ·ƒret_0
    # sm:EAABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcSAQADEAAEAQgDAAEAAwIBAAMGAQADAgAEAQcH


test 'member dynamic', fn:
  expect cps_module ƒink:
    foo.(key)
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·∅foo, ·∅key, ·ƒret_0
    # sm:DQABAAkAAQAJJAEACRYBAAkSAAIABgEACQABAAkSAQADEAAEAQoDEAAEAQkJ


test 'member string key shorthand', fn:
  expect cps_module ƒink:
    foo.'bar baz'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_dot ·∅foo, 'bar baz', ·ƒret_0
    # sm:EAABAA0AAQANJAEADRYBAA0SAAIABgEADQABAA0SAQADEAAEAQgJAAEACQIBAAkOAQAJAgAEAQcN



---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_module ƒink:
    [..xs, 1]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_prepend (i8 1), [], fn ·ƒctx_13, ·v_3:
        ·seq_concat ·∅xs, ·v_3, ·ƒret_0
    # sm:GwABAAkAAQAJJAEACRgBAAkSAAIABgEOAQABAAEeAQABAAEAAQYBAAEEAAQBDQkAAQAJAgEACQIACgAYAQ4BCgACAAoBCwQAAQAEGgEEAg4ABAEIAQoABAELBA


test 'rec spread', fn:
  expect cps_module ƒink:
    {..base, x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_merge {}, ·∅base, fn ·ƒctx_14, ·v_3:
        ·rec_put ·v_3, 'x', (i8 1), ·ƒret_0
    # sm:IAABAA4AAQAOJAEADhgBAA4SAAIABgECBgABAAYYAQEOAAEADgIBAA4CAAQBBgQSAAoAGAEDBgoAAgAKARAEAAEABBQBDwYKAAQBEAEAAQABAgEAAQIBAAECAAYBBgEAAQABBgEAAQQABAEFBA



---
tagged literals
---

test 'tagged literal', fn:
  expect cps_module ƒink:
    10sec
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅sec ·ƒctx_6, ·ƒret_0, (i8 10)
    # sm:DwABAAUAAQAFJAEABRYBAAUSAAIABgEABQABBAMSABIABAEDBRIABgEAAgABAAIGAQAC



---
seq/rec literals with spreads
---

# NOTE: ·seq_prepend/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_module ƒink:
    [1, ..a, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_0:
      ·seq_prepend (i8 2), [], fn ·ƒctx_18, ·v_3:
        ·seq_concat ·∅a, ·v_3, fn ·ƒctx_19, ·v_6:
          ·seq_prepend (i8 1), ·v_6, ·ƒret_0
    # sm:JwABAAsAAQALJAEACxgBAAsSAAIABgESAQABAAEeAQABAAEAAQYBAAEEAAQBEQsAAQALAgEACwIACgAYARIBCgACAAoBCQMAAQADGgEEAQwABAEGAQoACgAYAQkDCgACAA4BBQEAAQABHgEAAQABAAEGAQABBAAEAQYDCgAEAQUB

test 'seq literal leading spread', fn:
  expect cps_module ƒink:
    [..a, ..b]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·seq_concat ·∅b, [], fn ·ƒctx_13, ·v_3:
        ·seq_concat ·∅a, ·v_3, ·ƒret_0
    # sm:GQABAAoAAQAKJAEAChgBAAoSAAIABgEMAwABAAMaAQQBDAAEAQ8KAAEACgIBAAoCAAoAGAEMAwoAAgAKAQkDAAEAAxoBBAEMAAQBBgMKAAQBCQM

test 'rec literal with spread', fn:
  expect cps_module ƒink:
    {foo: a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·rec_put {}, 'foo', ·∅a, fn ·ƒctx_14, ·v_4:
        ·rec_merge ·v_4, ·∅b, ·ƒret_0
    # sm:HgABAA0AAQANJAEADRgBAA0SAAIABgECBgABAAYUAQENAAEADQIBAA0CAAQBAgMAAQADAgEAAwYBAAMCAAQBCgEMAAoAGAEJBgoAAgAKARADAAEAAxgBDwYKAAQBFAEMAAQBAwM

test 'rec literal leading spread', fn:
  expect cps_module ƒink:
    {..a, ..b}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·rec_merge {}, ·∅a, fn ·ƒctx_13, ·v_3:
        ·rec_merge ·v_3, ·∅b, ·ƒret_0
    # sm:GQABAAoAAQAKJAEAChgBAAoSAAIABgECAwABAAMYAQEKAAEACgIBAAoCAAQBBgEMAAoAGAEDAwoAAgAKAQoDAAEAAxgBCQMKAAQBDgEMAAQBAwM


