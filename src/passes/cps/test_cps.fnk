---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_expr ƒink:
    fn a: a
  | equals ƒink:
    ·fn
      fn ·ƒret_3, ·a_0: ·ƒret_3 ·a_0
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4gYTogYSJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUE7S0FBQSxTQUFHLEksRSxBQUFILFFBQU07S0FBTixJLEUsQSxLQUFBIgp9


test 'fn two params', fn:
  expect cps_expr ƒink:
    fn a, b: a
  | equals ƒink:
    ·fn
      fn ·ƒret_4, ·a_0, ·b_1: ·ƒret_4 ·a_0
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4gYSwgYjogYSJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUE7S0FBQSxTQUFHLE1BQUcsSSxFLEFBQU4sUUFBUztLQUFULEksRSxBLEtBQUEiCn0=


test 'named fn', fn:
  expect cps_expr ƒink:
    double = fn a: a
  | equals ƒink:
    ·fn
      fn ·ƒret_4, ·a_1: ·ƒret_4 ·a_1
      fn ·v_3:
        ·let ·v_3, fn ·double_0:
          ·v_2 ·double_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZG91YmxlID0gZm4gYTogYSJdLAogICJtYXBwaW5ncyI6ICJBQUFTLEFBQUE7S0FBQSxTQUFHLEksRSxBQUFILFFBQU07S0FBTixJO0lBQUYsQUFBQSxLQUFFLEksS0FBVCxTO00sQSxLQUFBIgp9


