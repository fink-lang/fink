test 'str tagged template', fn:
  expect cps_expr ƒink:
    foo'1\n2
      3'
  | equals ƒink:
    ·seq_prepend '1⧵n2␊3', [], fn ·v_4:
      ·∅foo ·v_0, ..·v_4
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vJzFcXG4yXG4gIDMnIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxhQUFJLEEsQ0FBQSxNLEMsRUFBSixBLEMsQyxLQUFBLEk7RUFBQSxBQUFBLE0sSSxFQUFBLEEsRUFBQSIKfQ==


test 'str tagged template escape handling', fn:
  expect cps_expr ƒink:
    foo'\n\r\t\f${bar}\b\v\$\'\\\xE9\u{8A_9E}'
  | equals ƒink:
    ·seq_prepend '⧵b⧵v⧵＄⧵′⧵⧵⧵xE9⧵u{8A_9E}', [], fn ·v_4:
