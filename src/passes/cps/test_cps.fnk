---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_expr ƒink:
    foo 1, ..items
  | equals ƒink:
    ·∅foo ·v_0, 1, ..·∅items
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIDEsIC4uaXRlbXMiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBLE0sSSxFQUFJLEMsRUFBSyxBLEVBQUEiCn0=


test 'call with spread — trailing iterable', fn:
  expect cps_expr ƒink:
    foo a, ..rest
  | equals ƒink:
    ·∅foo ·v_0, ·∅a, ..·∅rest
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIGEsIC4ucmVzdCJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUEsTSxJLEVBQUksRyxFQUFLLEEsRUFBQSIKfQ==


test 'call with spread — spread only', fn:
  expect cps_expr ƒink:
    foo ..items
  | equals ƒink:
    ·∅foo ·v_0, ..·∅items
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIC4uaXRlbXMiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBLE0sSSxFQUFNLEEsRUFBQSIKfQ==


test 'call with spread — passes through from varargs fn', fn:
