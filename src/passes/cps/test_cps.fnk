---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_expr ƒink:
    a < b < c
  | equals ƒink:
    ·op_lt ·∅a, ·∅b, fn ·v_4:
      ·op_lt ·∅b, ·∅c, fn ·v_6:
        ·op_and ·v_4, ·v_6, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSA8IGIgPCBjIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxPQUFBLEcsRUFBSSxHLEtBQUosSTtFQUFBLEFBQUEsT0FBSSxHLEVBQUksRyxLQUFSLEk7SUFBQSxBQUFBLFFBQUEsSSxFQUFBLEksRSIKfQ==

