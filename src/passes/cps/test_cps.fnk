---
cps_c IR — pretty-printer tests
---

# Input is a Fink expression; output is the synthesized CPS Fink source.
# First-pass CPS — no ·load/·store/·scope synthesis (all names in scope by construction).
#
# Rendering conventions:
#   ·let val, fn name:              — LetVal
#   ·fn fn params: fn_body, fn name: — LetFn
#   ·apply func, args, fn result: — App
#   ·ƒ_cont val             — Ret
#
# Test format:
#   test 'name', fn:
#     expect cps_expr fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps output>

{test, expect, equals, fink, cps_expr} = import '!fake'

---
literals — tail position, no synthesis needed
---

test 'int literal', fn:
  expect cps_expr fink":
    42
  | equals fink":
    ·ƒ_0 42


test 'bool literal', fn:
  expect cps_expr fink":
    true
  | equals fink":
    ·ƒ_0 true


test 'string literal', fn:
  expect cps_expr fink":
    'hello'
  | equals fink":
    ·ƒ_0 'hello'


---
binding — ·match_store synthesis
---

test 'bind literal', fn:
  expect cps_expr fink":
    x = 42
  | equals fink":
    ·let 42, fn ·x_0:
      ·ƒ_1 ·x_0


test 'bind ident', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let ·∅foo, fn ·x_0:
      ·ƒ_1 ·x_0


---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  expect cps_expr fink":
    foo 42
  | equals fink":
    ·∅foo 42, ·ƒ_0


test '·apply ident to ident', fn:
  expect cps_expr fink":
    foo bar
  | equals fink":
    ·∅foo ·∅bar, ·ƒ_0


---
identifier reference — synthesize ·load
---

test 'ident ref', fn:
  expect cps_expr fink":
    foo
  | equals fink":
    ·ƒ_0 ·∅foo


---
block — statement sequences
---

test 'block two stmts', fn:
  expect cps_expr fink":
    x = 1
    x
  | equals fink":
    ·fn
      fn ·ƒ_3:
        ·let 1, fn ·x_0:
          ·ƒ_3 ·x_0
      fn ·v_2:
        ·ƒ_1 ·v_2


test 'block bind then ·apply', fn:
  expect cps_expr fink":
    x = 42
    foo x
  | equals fink":
    ·fn
      fn ·ƒ_3:
        ·let 42, fn ·x_0:
          ·∅foo ·x_0, ·ƒ_3
      fn ·v_2:
        ·ƒ_1 ·v_2


test 'fn body with bind', fn:
  expect cps_expr fink":
    fn a:
      x = a + 1
      x
  | equals fink":
    ·fn
      fn ·a_0, ·ƒ_4:
        ·op_plus ·a_0, 1, fn ·v_7:
          ·let ·v_7, fn ·x_1:
            ·ƒ_4 ·x_1
      fn ·v_3:
        ·ƒ_2 ·v_3


---
pipe — lowered as application
---

test 'pipe two stages', fn:
  expect cps_expr fink":
    a | foo
  | equals fink":
    ·∅foo ·∅a, ·ƒ_0


test 'pipe three stages', fn:
  expect cps_expr fink":
    a | foo | bar
  | equals fink":
    ·∅foo ·∅a, fn ·v_3:
      ·∅bar ·v_3, ·ƒ_0


---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_expr fink":
    a + b
  | equals fink":
    ·op_plus ·∅a, ·∅b, ·ƒ_0


test 'infix literal', fn:
  expect cps_expr fink":
    a + 1
  | equals fink":
    ·op_plus ·∅a, 1, ·ƒ_0


---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_expr fink":
    fn a: a
  | equals fink":
    ·fn
      fn ·a_0, ·ƒ_3:
        ·ƒ_3 ·a_0
      fn ·v_2:
        ·ƒ_1 ·v_2


test 'fn two params', fn:
  expect cps_expr fink":
    fn a, b: a
  | equals fink":
    ·fn
      fn ·a_0, ·b_1, ·ƒ_4:
        ·ƒ_4 ·a_0
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'named fn', fn:
  expect cps_expr fink":
    double = fn a: a
  | equals fink":
    ·fn
      fn ·a_1, ·ƒ_4:
        ·ƒ_4 ·a_1
      fn ·v_3:
        ·let ·v_3, fn ·double_0:
          ·ƒ_2 ·double_0


---
unary ops
---

test 'unary not', fn:
  expect cps_expr fink":
    not x
  | equals fink":
    ·op_not ·∅x, ·ƒ_0


test 'unary minus', fn:
  expect cps_expr fink":
    -x
  | equals fink":
    ·op_minus ·∅x, ·ƒ_0

---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_expr fink":
    a < b < c
  | equals fink":
    ·op_lt ·∅a, ·∅b, fn ·v_4:
      ·op_lt ·∅b, ·∅c, fn ·v_6:
        ·op_and ·v_4, ·v_6, ·ƒ_0

---
range
---

test 'range excl', fn:
  expect cps_expr fink":
    0..10
  | equals fink":
    ·op_rngex 0, 10, ·ƒ_0


test 'range incl', fn:
  expect cps_expr fink":
    0...10
  | equals fink":
    ·op_rngin 0, 10, ·ƒ_0

---
string templates
---

test 'str templ', fn:
  expect cps_expr fink":
    'hello \${name}'
  | equals fink":
    ·str_fmt 'hello ', ·∅name, ·ƒ_0


test 'str templ two exprs', fn:
  expect cps_expr fink":
    '\${a} and \${b}'
  | equals fink":
    ·str_fmt ·∅a, ' and ', ·∅b, ·ƒ_0

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_expr fink":
    [1, 2, 3]
  | equals fink":
    ·seq_append [], 1, fn ·v_3:
      ·seq_append ·v_3, 2, fn ·v_6:
        ·seq_append ·v_6, 3, ·ƒ_0


test 'empty seq literal', fn:
  expect cps_expr fink":
    []
  | equals fink":
    ·ƒ_0 []


test 'rec literal', fn:
  expect cps_expr fink":
    {x: 1, y: 2}
  | equals fink":
    ·rec_put {}, 'x', 1, fn ·v_4:
      ·rec_put ·v_4, 'y', 2, ·ƒ_0


test 'empty rec literal', fn:
  expect cps_expr fink":
    {}
  | equals fink":
    ·ƒ_0 {}


test 'rec shorthand', fn:
  expect cps_expr fink":
    {x, y}
  | equals fink":
    ·rec_put {}, 'x', ·∅x, fn ·v_4:
      ·rec_put ·v_4, 'y', ·∅y, ·ƒ_0


---
member access
---

test 'member static', fn:
  expect cps_expr fink":
    foo.bar
  | equals fink":
    ·op_dot ·∅foo, ·∅bar, ·ƒ_0


test 'member dynamic', fn:
  expect cps_expr fink":
    foo.(key)
  | equals fink":
    ·op_dot ·∅foo, ·∅key, ·ƒ_0


---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_expr fink":
    [..xs, 1]
  | equals fink":
    ·seq_concat [], ·∅xs, fn ·v_3:
      ·seq_append ·v_3, 1, ·ƒ_0


test 'rec spread', fn:
  expect cps_expr fink":
    {..base, x: 1}
  | equals fink":
    ·rec_merge {}, ·∅base, fn ·v_3:
      ·rec_put ·v_3, 'x', 1, ·ƒ_0


---
try expression
---

test 'try', fn:
  expect cps_expr fink":
    try foo
  | equals fink":
    ·ƒ_0 ·∅foo


---
tagged literals
---

test 'tagged literal', fn:
  expect cps_expr fink":
    10sec
  | equals fink":
    ·∅sec 10, ·ƒ_0


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_expr fink":
    foo = 1
    bar = foo + 1
  | equals fink":
    ·fn
      fn ·ƒ_4:
        ·let 1, fn ·foo_0:
          ·op_plus ·foo_0, 1, fn ·v_8:
            ·let ·v_8, fn ·bar_1:
              ·ƒ_4 ·bar_1
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'binding rhs is a call', fn:
  expect cps_expr fink":
    foo = add 1, 2
  | equals fink":
    ·∅add 1, 2, fn ·v_5:
      ·let ·v_5, fn ·foo_0:
        ·ƒ_1 ·foo_0


test 'expression result discarded', fn:
  expect cps_expr fink":
    foo 1
    bar
  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·∅foo 1, fn ·v_5:
          ·let ·v_5, fn ·v_7:
            ·ƒ_2 ·v_7
      fn ·v_1:
        ·ƒ_0 ·v_1


test 'chained member access', fn:
  expect cps_expr fink":
    foo.bar.baz
  | equals fink":
    ·op_dot ·∅foo, ·∅bar, fn ·v_3:
      ·op_dot ·v_3, ·∅baz, ·ƒ_0


---
ported from test_cps — calls and application
---

test 'simple call', fn:
  expect cps_expr fink":
    add 1, 2
  | equals fink":
    ·∅add 1, 2, ·ƒ_0


test 'nested call', fn:
  expect cps_expr fink":
    add (mul 2, 3), 1
  | equals fink":
    ·∅mul 2, 3, fn ·v_5:
      ·∅add ·v_5, 1, ·ƒ_0


test 'postfix tag', fn:
  expect cps_expr fink":
    (foo bar)tag
  | equals fink":
    ·∅foo ·∅bar, fn ·v_4:
      ·∅tag ·v_4, ·ƒ_0


test 'call with spread', fn:
  expect cps_expr fink":
    foo a, ..rest
  | equals fink":
    ·∅foo ·∅a, ..·∅rest, ·ƒ_0


test 'simple pipe', fn:
  expect cps_expr fink":
    x | f
  | equals fink":
    ·∅f ·∅x, ·ƒ_0


test 'pipe chain', fn:
  expect cps_expr fink":
    x | f | g
  | equals fink":
    ·∅f ·∅x, fn ·v_3:
      ·∅g ·v_3, ·ƒ_0


---
ported from test_cps — functions and closures
---

test 'function binding', fn:
  expect cps_expr fink":
    inc = fn x: x + 1
  | equals fink":
    ·fn
      fn ·x_1, ·ƒ_4:
        ·op_plus ·x_1, 1, ·ƒ_4
      fn ·v_3:
        ·let ·v_3, fn ·inc_0:
          ·ƒ_2 ·inc_0


test '·closure over outer variable', fn:
  expect cps_expr fink":
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals fink":
    ·fn
      fn ·a_1, ·ƒ_6:
        ·fn
          fn ·b_2, ·ƒ_8:
            ·op_plus ·a_1, ·b_2, ·ƒ_8
          fn ·v_7:
            ·let ·v_7, fn ·ni_3:
              ·ƒ_6 ·ni_3
      fn ·v_5:
        ·let ·v_5, fn ·foo_0:
          ·ƒ_4 ·foo_0


test 'three sequential bindings', fn:
  expect cps_expr fink":
    a = 1
    b = 2
    c = a + b
  | equals fink":
    ·fn
      fn ·ƒ_5:
        ·let 1, fn ·a_0:
          ·let 2, fn ·b_1:
            ·op_plus ·a_0, ·b_1, fn ·v_10:
              ·let ·v_10, fn ·c_2:
                ·ƒ_5 ·c_2
      fn ·v_4:
        ·ƒ_3 ·v_4


---
ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_expr fink":
    foo = fn a: foo a + 1
    foo 1
  | equals fink":
    ·fn
      fn ·ƒ_4:
        ·fn
          fn ·a_1, ·ƒ_6:
            ·op_plus ·a_1, 1, fn ·v_10:
              ·foo_0 ·v_10, ·ƒ_6
          fn ·v_5:
            ·let ·v_5, fn ·foo_0:
              ·foo_0 1, ·ƒ_4
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'mutual recursion', fn:
  expect cps_expr fink":
    ping = fn x: pong x
    pong = fn x: ping x
  | equals fink":
    ·fn
      fn ·ƒ_6:
        ·fn
          fn ·x_2, ·ƒ_8:
            ·pong_1 ·x_2, ·ƒ_8
          fn ·v_7:
            ·let ·v_7, fn ·ping_0:
              ·fn
                fn ·x_3, ·ƒ_16:
                  ·ping_0 ·x_3, ·ƒ_16
                fn ·v_15:
                  ·let ·v_15, fn ·pong_1:
                    ·ƒ_6 ·pong_1
      fn ·v_5:
        ·ƒ_4 ·v_5


---
pattern bindings (bind-right)
---

test 'bind right — simple ·id', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let ·∅foo, fn ·x_0:
      ·ƒ_1 ·x_0


---
varargs functions
---

test 'multi-param function', fn:
  expect cps_expr fink":
    fn x, y: x + y
  | equals fink":
    ·fn
      fn ·x_0, ·y_1, ·ƒ_4:
        ·op_plus ·x_0, ·y_1, ·ƒ_4
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'varargs — collect rest', fn:
  expect cps_expr fink":
    fn a, ..rest: rest
  | equals fink":
    ·fn
      fn ·a_0, ..·rest_1, ·ƒ_4:
        ·ƒ_4 ·rest_1
      fn ·v_3:
        ·ƒ_2 ·v_3


---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_expr fink":
    inc = fn x: x + 1
    inc 5
  | equals fink":
    ·fn
      fn ·ƒ_4:
        ·fn
          fn ·x_1, ·ƒ_6:
            ·op_plus ·x_1, 1, ·ƒ_6
          fn ·v_5:
            ·let ·v_5, fn ·inc_0:
              ·inc_0 5, ·ƒ_4
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'chained binding is sequential ·match_store', fn:
  expect cps_expr fink":
    foo = spam = 1
  | equals fink":
    ·let 1, fn ·spam_1:
      ·let ·spam_1, fn ·foo_0:
        ·ƒ_2 ·foo_0


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_expr fink":
    spam = (
      ni = ham 1
      ni
    )
  | equals fink":
    ·fn
      fn ·ƒ_4:
        ·∅ham 1, fn ·v_7:
          ·let ·v_7, fn ·ni_1:
            ·ƒ_4 ·ni_1
      fn ·v_3:
        ·v_3 fn ·v_13:
          ·let ·v_13, fn ·spam_0:
            ·ƒ_2 ·spam_0

---
functions — additional
---

test 'identity function', fn:
  expect cps_expr fink":
    fn x: x
  | equals fink":
    ·fn
      fn ·x_0, ·ƒ_3:
        ·ƒ_3 ·x_0
      fn ·v_2:
        ·ƒ_1 ·v_2

test 'function with operator in body', fn:
  expect cps_expr fink":
    fn x: x + 1
  | equals fink":
    ·fn
      fn ·x_0, ·ƒ_3:
        ·op_plus ·x_0, 1, ·ƒ_3
      fn ·v_2:
        ·ƒ_1 ·v_2

test 'try — result bound, code continues', fn:
  expect cps_expr fink":
    ni = try foo bar
    ni + 1
  | equals fink":
    ·fn
      fn ·ƒ_3:
        ·∅foo ·∅bar, fn ·v_6:
          ·let ·v_6, fn ·ni_0:
            ·op_plus ·ni_0, 1, ·ƒ_3
      fn ·v_2:
        ·ƒ_1 ·v_2


---
seq/rec literals with spreads
---

# NOTE: ·seq_append/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_expr fink":
    [1, ..a, 2]
  | equals fink":
    ·seq_append [], 1, fn ·v_3:
      ·seq_concat ·v_3, ·∅a, fn ·v_6:
        ·seq_append ·v_6, 2, ·ƒ_0

test 'seq literal leading spread', fn:
  expect cps_expr fink":
    [..a, ..b]
  | equals fink":
    ·seq_concat [], ·∅a, fn ·v_3:
      ·seq_concat ·v_3, ·∅b, ·ƒ_0

test 'rec literal with spread', fn:
  expect cps_expr fink":
    {foo: a, ..b}
  | equals fink":
    ·rec_put {}, 'foo', ·∅a, fn ·v_4:
      ·rec_merge ·v_4, ·∅b, ·ƒ_0

test 'rec literal leading spread', fn:
  expect cps_expr fink":
    {..a, ..b}
  | equals fink":
    ·rec_merge {}, ·∅a, fn ·v_3:
      ·rec_merge ·v_3, ·∅b, ·ƒ_0


---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_expr fink":
    foo 1, ..items
  | equals fink":
    ·∅foo 1, ..·∅items, ·ƒ_0


test 'call with spread — trailing iterable', fn:
  expect cps_expr fink":
    foo a, ..rest
  | equals fink":
    ·∅foo ·∅a, ..·∅rest, ·ƒ_0


test 'call with spread — spread only', fn:
  expect cps_expr fink":
    foo ..items
  | equals fink":
    ·∅foo ..·∅items, ·ƒ_0


test 'call with spread — passes through from varargs fn', fn:
  expect cps_expr fink":
    fn ..args: foo ..args
  | equals fink":
    ·fn
      fn ..·args_0, ·ƒ_3:
        ·∅foo ..·args_0, ·ƒ_3
      fn ·v_2:
        ·ƒ_1 ·v_2


---
module level
---

test 'two bindings at module level', fn:
  expect cps_expr fink":
    foo = 1
    bar = 2
  | equals fink":
    ·fn
      fn ·ƒ_4:
        ·let 1, fn ·foo_0:
          ·let 2, fn ·bar_1:
            ·ƒ_4 ·bar_1
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'two fns at module level — main calls add', fn:
  expect cps_expr fink":
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals fink":
    ·fn
      fn ·ƒ_6:
        ·fn
          fn ·a_2, ·b_3, ·ƒ_8:
            ·op_plus ·a_2, ·b_3, ·ƒ_8
          fn ·v_7:
            ·let ·v_7, fn ·add_0:
              ·fn
                fn ·ƒ_16:
                  ·add_0 3, 4, ·ƒ_16
                fn ·v_15:
                  ·let ·v_15, fn ·main_1:
                    ·ƒ_6 ·main_1
      fn ·v_5:
        ·ƒ_4 ·v_5

# TODO bug in AST parsing `a - add b` wrong, need to re-review once fixed
test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_expr fink":
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals fink":
    ·fn
      fn ·ƒ_11:
        ·fn
          fn ·a_3, ·b_4, ·ƒ_13:
            ·op_plus ·a_3, ·b_4, ·ƒ_13
          fn ·v_12:
            ·let ·v_12, fn ·add_0:
              ·fn
                fn ·a_5, ·b_6, ·ƒ_21:
                  ·fn
                    fn ·foo_7, ·ƒ_23:
                      ·ƒ_23 ·foo_7
                    fn ·v_22:
                      ·let ·v_22, fn ·add_8:
                        ·op_minus ·a_5, ·add_8, fn ·v_30:
                          ·let ·v_30, fn ·v_32:
                            ·ƒ_21 ·v_32
                fn ·v_20:
                  ·let ·v_20, fn ·sub_1:
                    ·fn
                      fn ·ƒ_43:
                        ·add_0 3, 4, ·ƒ_43
                      fn ·v_42:
                        ·let ·v_42, fn ·main_2:
                          ·ƒ_11 ·main_2
      fn ·v_10:
        ·ƒ_9 ·v_10
