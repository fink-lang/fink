test 'two bindings at module level', fn:
  expect cps_expr ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·fn
      fn ·ƒret_4:
        ·let 1, fn ·foo_0:
          ·let 2, fn ·bar_1:
            ·ƒret_4 ·bar_1
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuYmFyID0gMiJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUE7S0FBQSxPO0lBQUksQUFBQSxLQUFFLEMsS0FBTixNO01BQ0ksQUFBQSxLQUFFLEMsS0FBTixNO1FBREEsQUFBQSxRQUNBO0tBREEsSSxFLEEsS0FBQSIKfQ==


test 'two fns at module level — main calls add', fn:
  expect cps_expr ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·fn
      fn ·ƒret_6:
        ·fn
          fn ·ƒret_8, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_8
          fn ·v_7:
            ·let ·v_7, fn ·add_0:
              ·fn
                fn ·ƒret_16: ·add_0 ·ƒret_16, 3, 4
                fn ·v_15:
                  ·let ·v_15, fn ·main_1:
                    ·ƒret_6 ·main_1
      fn ·v_5: ·v_4 ·v_5
    #sourcemaps:

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_expr ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·fn
      fn ·ƒret_11:
        ·fn
          fn ·ƒret_13, ·a_3, ·b_4: ·op_plus ·a_3, ·b_4, ·ƒret_13
          fn ·v_12:
            ·let ·v_12, fn ·add_0:
              ·fn
                fn ·ƒret_21, ·a_5, ·b_6:
                  ·fn
                    fn ·ƒret_23, ·foo_7: ·ƒret_23 ·foo_7
                    fn ·v_22:
                      ·let ·v_22, fn ·add_8:
                        ·add_8 fn ·v_31: ·op_minus ·a_5, ·v_31, ·ƒret_21, ·b_6
                fn ·v_20:
                  ·let ·v_20, fn ·sub_1:
                    ·fn
                      fn ·ƒret_44: ·add_0 ·ƒret_44, 3, 4
                      fn ·v_43:
                        ·let ·v_43, fn ·main_2:
                          ·ƒret_11 ·main_2
      fn ·v_10: ·v_9 ·v_10
