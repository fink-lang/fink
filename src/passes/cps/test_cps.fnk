---
cps_c IR — pretty-printer tests
---

# Input is a Fink expression; output is the synthesized CPS Fink source.
# First-pass CPS — no ·load/·store/·scope synthesis (all names in scope by construction).
#
# Rendering conventions:
#   ·let val, fn name:              — LetVal
#   ·fn fn params: fn_body, fn name: — LetFn
#   ·apply func, args, fn result: — App
#   ·ƒ_cont val             — Ret
#
# Test format:
#   test 'name', fn:
#     expect cps_expr fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps output>

{test, expect, equals_fink, cps_expr} = import '!fake'
{·let, ·fn, ·ƒ_cont, ·apply} = import '!fake'

---
literals — tail position, no synthesis needed
---

test 'int literal', fn:
  expect cps_expr fink":
    42
  | equals fink":
    ·ƒ_cont 42


test 'bool literal', fn:
  expect cps_expr fink":
    true
  | equals fink":
    ·ƒ_cont true


test 'string literal', fn:
  expect cps_expr fink":
    'hello'
  | equals fink":
    ·ƒ_cont 'hello'


---
binding — ·match_store synthesis
---

test 'bind literal', fn:
  expect cps_expr fink":
    x = 42
  | equals fink":
    ·let 42, fn x:
      ·ƒ_cont x


test 'bind ident', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let foo, fn x:
      ·ƒ_cont x


---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  expect cps_expr fink":
    foo 42
  | equals fink":
    ·apply foo, 42, fn ·v_2:
      ·ƒ_cont ·v_2


test '·apply ident to ident', fn:
  expect cps_expr fink":
    foo bar
  | equals fink":
    ·apply foo, bar, fn ·v_2:
      ·ƒ_cont ·v_2


---
identifier reference — synthesize ·load
---

test 'ident ref', fn:
  expect cps_expr fink":
    foo
  | equals fink":
    ·ƒ_cont foo


---
block — statement sequences
---

test 'block two stmts', fn:
  expect cps_expr fink":
    x = 1
    x
  | equals fink":
    ·fn
      fn:
        ·let 1, fn x:
          ·ƒ_cont x
      fn ·v_0: ·ƒ_cont ·v_0


test 'block bind then ·apply', fn:
  expect cps_expr fink":
    x = 42
    foo x
  | equals fink":
    ·fn
      fn:
        ·let 42, fn x:
          ·apply foo, x, fn ·v_5:
            ·ƒ_cont ·v_5
      fn ·v_0: ·ƒ_cont ·v_0


test 'fn body with bind', fn:
  expect cps_expr fink":
    fn a:
      x = a + 1
      x
  | equals fink":
    ·fn
      fn a:
        ·apply ·op_plus, a, 1, fn ·v_4:
          ·let ·v_4, fn x:
            ·ƒ_cont x
      fn ·v_0: ·ƒ_cont ·v_0


---
pipe — lowered as application
---

test 'pipe two stages', fn:
  expect cps_expr fink":
    a | foo
  | equals fink":
    ·apply foo, a, fn ·v_2:
      ·ƒ_cont ·v_2


test 'pipe three stages', fn:
  expect cps_expr fink":
    a | foo | bar
  | equals fink":
    ·apply foo, a, fn ·v_2:
      ·apply bar, ·v_2, fn ·v_5:
        ·ƒ_cont ·v_5


---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_expr fink":
    a + b
  | equals fink":
    ·apply ·op_plus, a, b, fn ·v_2:
      ·ƒ_cont ·v_2


test 'infix literal', fn:
  expect cps_expr fink":
    a + 1
  | equals fink":
    ·apply ·op_plus, a, 1, fn ·v_2:
      ·ƒ_cont ·v_2


---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_expr fink":
    fn a: a
  | equals fink":
    ·fn
      fn a: ·ƒ_cont a
      fn ·v_0: ·ƒ_cont ·v_0


test 'fn two params', fn:
  expect cps_expr fink":
    fn a, b: a
  | equals fink":
    ·fn
      fn a, b: ·ƒ_cont a
      fn ·v_0: ·ƒ_cont ·v_0


test 'named fn', fn:
  expect cps_expr fink":
    double = fn a: a
  | equals fink":
    ·fn
      fn a: ·ƒ_cont a
      fn ·v_0:
        ·let ·v_0, fn double:
          ·ƒ_cont double


---
unary ops
---

test 'unary not', fn:
  expect cps_expr fink":
    not x
  | equals fink":
    ·apply ·op_not, x, fn ·v_1:
      ·ƒ_cont ·v_1


test 'unary minus', fn:
  expect cps_expr fink":
    -x
  | equals fink":
    ·apply ·op_minus, x, fn ·v_1:
      ·ƒ_cont ·v_1

---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_expr fink":
    a < b < c
  | equals fink":
    ·apply ·op_lt, a, b, fn ·v_3:
      ·apply ·op_lt, b, c, fn ·v_5:
        ·apply ·op_and, ·v_3, ·v_5, fn ·v_7:
          ·ƒ_cont ·v_7

---
range
---

test 'range excl', fn:
  expect cps_expr fink":
    0..10
  | equals fink":
    ·apply ·op_rngex, 0, 10, fn ·v_2:
      ·ƒ_cont ·v_2


test 'range incl', fn:
  expect cps_expr fink":
    0...10
  | equals fink":
    ·apply ·op_rngin, 0, 10, fn ·v_2:
      ·ƒ_cont ·v_2

---
string templates
---

test 'str templ', fn:
  expect cps_expr fink":
    'hello \${name}'
  | equals fink":
    ·apply ·str_fmt, 'hello ', name, fn ·v_2:
      ·ƒ_cont ·v_2


test 'str templ two exprs', fn:
  expect cps_expr fink":
    '\${a} and \${b}'
  | equals fink":
    ·apply ·str_fmt, a, ' and ', b, fn ·v_3:
      ·ƒ_cont ·v_3

---
sequence and record literals
---

test 'seq literal', fn:
  expect cps_expr fink":
    [1, 2, 3]
  | equals fink":
    ·apply ·seq_append, [], 1, fn ·v_2:
      ·apply ·seq_append, ·v_2, 2, fn ·v_5:
        ·apply ·seq_append, ·v_5, 3, fn ·v_8:
          ·ƒ_cont ·v_8


test 'empty seq literal', fn:
  expect cps_expr fink":
    []
  | equals fink":
    ·ƒ_cont []


test 'rec literal', fn:
  expect cps_expr fink":
    {x: 1, y: 2}
  | equals fink":
    ·apply ·rec_put, {}, 'x', 1, fn ·v_3:
      ·apply ·rec_put, ·v_3, 'y', 2, fn ·v_7:
        ·ƒ_cont ·v_7


test 'empty rec literal', fn:
  expect cps_expr fink":
    {}
  | equals fink":
    ·ƒ_cont {}


test 'rec shorthand', fn:
  expect cps_expr fink":
    {x, y}
  | equals fink":
    ·apply ·rec_put, {}, 'x', x, fn ·v_3:
      ·apply ·rec_put, ·v_3, 'y', y, fn ·v_7:
        ·ƒ_cont ·v_7


---
member access
---

test 'member static', fn:
  expect cps_expr fink":
    foo.bar
  | equals fink":
    ·apply ·op_dot, foo, bar, fn ·v_2:
      ·ƒ_cont ·v_2


test 'member dynamic', fn:
  expect cps_expr fink":
    foo.(key)
  | equals fink":
    ·apply ·op_dot, foo, key, fn ·v_2:
      ·ƒ_cont ·v_2


---
spreads in seq and rec literals
---

test 'seq spread', fn:
  expect cps_expr fink":
    [..xs, 1]
  | equals fink":
    ·apply ·seq_concat, [], xs, fn ·v_2:
      ·apply ·seq_append, ·v_2, 1, fn ·v_5:
        ·ƒ_cont ·v_5


test 'rec spread', fn:
  expect cps_expr fink":
    {..base, x: 1}
  | equals fink":
    ·apply ·rec_merge, {}, base, fn ·v_2:
      ·apply ·rec_put, ·v_2, 'x', 1, fn ·v_6:
        ·ƒ_cont ·v_6


---
try expression
---

test 'try', fn:
  expect cps_expr fink":
    try foo
  | equals fink":
    ·ƒ_cont foo


---
tagged literals
---

test 'tagged literal', fn:
  expect cps_expr fink":
    10sec
  | equals fink":
    ·apply sec, 10, fn ·v_2:
      ·ƒ_cont ·v_2


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_expr fink":
    foo = 1
    bar = foo + 1
  | equals fink":
    ·fn
      fn:
        ·let 1, fn foo:
          ·apply ·op_plus, foo, 1, fn ·v_5:
            ·let ·v_5, fn bar:
              ·ƒ_cont bar
      fn ·v_0: ·ƒ_cont ·v_0


test 'binding rhs is a call', fn:
  expect cps_expr fink":
    foo = add 1, 2
  | equals fink":
    ·apply add, 1, 2, fn ·v_3:
      ·let ·v_3, fn foo:
        ·ƒ_cont foo


test 'expression result discarded', fn:
  expect cps_expr fink":
    foo 1
    bar
  | equals fink":
    ·fn
      fn:
        ·apply foo, 1, fn ·v_3:
          ·let ·v_3, fn ·v_5:
            ·ƒ_cont bar
      fn ·v_0: ·ƒ_cont ·v_0


test 'chained member access', fn:
  expect cps_expr fink":
    foo.bar.baz
  | equals fink":
    ·apply ·op_dot, foo, bar, fn ·v_2:
      ·apply ·op_dot, ·v_2, baz, fn ·v_5:
        ·ƒ_cont ·v_5


---
ported from test_cps — calls and application
---

test 'simple call', fn:
  expect cps_expr fink":
    add 1, 2
  | equals fink":
    ·apply add, 1, 2, fn ·v_3:
      ·ƒ_cont ·v_3


test 'nested call', fn:
  expect cps_expr fink":
    add (mul 2, 3), 1
  | equals fink":
    ·apply mul, 2, 3, fn ·v_4:
      ·apply add, ·v_4, 1, fn ·v_7:
        ·ƒ_cont ·v_7


test 'postfix tag', fn:
  expect cps_expr fink":
    (foo bar)tag
  | equals fink":
    ·apply foo, bar, fn ·v_3:
      ·apply tag, ·v_3, fn ·v_5:
        ·ƒ_cont ·v_5


test 'call with spread', fn:
  expect cps_expr fink":
    foo a, ..rest
  | equals fink":
    ·apply foo, a, ..rest, fn ·v_3:
      ·ƒ_cont ·v_3


test 'simple pipe', fn:
  expect cps_expr fink":
    x | f
  | equals fink":
    ·apply f, x, fn ·v_2:
      ·ƒ_cont ·v_2


test 'pipe chain', fn:
  expect cps_expr fink":
    x | f | g
  | equals fink":
    ·apply f, x, fn ·v_2:
      ·apply g, ·v_2, fn ·v_5:
        ·ƒ_cont ·v_5


---
ported from test_cps — functions and closures
---

test 'function binding', fn:
  expect cps_expr fink":
    inc = fn x: x + 1
  | equals fink":
    ·fn
      fn x:
        ·apply ·op_plus, x, 1, fn ·v_4:
          ·ƒ_cont ·v_4
      fn ·v_0:
        ·let ·v_0, fn inc:
          ·ƒ_cont inc


test '·closure over outer variable', fn:
  expect cps_expr fink":
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals fink":
    ·fn
      fn a:
        ·fn
          fn b:
            ·apply ·op_plus, a, b, fn ·v_6:
              ·ƒ_cont ·v_6
          fn ·v_2:
            ·let ·v_2, fn ni:
              ·ƒ_cont ni
      fn ·v_0:
        ·let ·v_0, fn foo:
          ·ƒ_cont foo


test 'three sequential bindings', fn:
  expect cps_expr fink":
    a = 1
    b = 2
    c = a + b
  | equals fink":
    ·fn
      fn:
        ·let 1, fn a:
          ·let 2, fn b:
            ·apply ·op_plus, a, b, fn ·v_7:
              ·let ·v_7, fn c:
                ·ƒ_cont c
      fn ·v_0: ·ƒ_cont ·v_0


---
ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_expr fink":
    foo = fn a: foo a + 1
    foo 1
  | equals fink":
    ·fn
      fn:
        ·fn
          fn a:
            ·apply ·op_plus, a, 1, fn ·v_6:
              ·apply foo, ·v_6, fn ·v_8:
                ·ƒ_cont ·v_8
          fn ·v_1:
            ·let ·v_1, fn foo:
              ·apply foo, 1, fn ·v_17:
                ·ƒ_cont ·v_17
      fn ·v_0: ·ƒ_cont ·v_0


test 'mutual recursion', fn:
  expect cps_expr fink":
    ping = fn x: pong x
    pong = fn x: ping x
  | equals fink":
    ·fn
      fn:
        ·fn
          fn x:
            ·apply pong, x, fn ·v_5:
              ·ƒ_cont ·v_5
          fn ·v_1:
            ·let ·v_1, fn ping:
              ·fn
                fn x:
                  ·apply ping, x, fn ·v_15:
                    ·ƒ_cont ·v_15
                fn ·v_11:
                  ·let ·v_11, fn pong:
                    ·ƒ_cont pong
      fn ·v_0: ·ƒ_cont ·v_0


---
pattern bindings (bind-right)
---

test 'bind right — simple ·id', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let foo, fn x:
      ·ƒ_cont x


---
varargs functions
---

test 'multi-param function', fn:
  expect cps_expr fink":
    fn x, y: x + y
  | equals fink":
    ·fn
      fn x, y:
        ·apply ·op_plus, x, y, fn ·v_5:
          ·ƒ_cont ·v_5
      fn ·v_0: ·ƒ_cont ·v_0


test 'varargs — collect rest', fn:
  expect cps_expr fink":
    fn a, ..rest: rest
  | equals fink":
    ·fn
      fn a, ..rest: ·ƒ_cont rest
      fn ·v_0: ·ƒ_cont ·v_0


---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_expr fink":
    inc = fn x: x + 1
    inc 5
  | equals fink":
    ·fn
      fn:
        ·fn
          fn x:
            ·apply ·op_plus, x, 1, fn ·v_5:
              ·ƒ_cont ·v_5
          fn ·v_1:
            ·let ·v_1, fn inc:
              ·apply inc, 5, fn ·v_13:
                ·ƒ_cont ·v_13
      fn ·v_0: ·ƒ_cont ·v_0


test 'chained binding is sequential ·match_store', fn:
  expect cps_expr fink":
    foo = spam = 1
  | equals fink":
    ·let 1, fn spam:
      ·let spam, fn foo:
        ·ƒ_cont foo


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_expr fink":
    spam = (
      ni = ham 1
      ni
    )
  | equals fink":
    ·fn
      fn:
        ·apply ham, 1, fn ·v_3:
          ·let ·v_3, fn ni:
            ·ƒ_cont ni
      fn ·v_0:
        ·apply ·v_0, fn ·v_11:
          ·let ·v_11, fn spam:
            ·ƒ_cont spam

---
functions — additional
---

test 'identity function', fn:
  expect cps_expr fink":
    fn x: x
  | equals fink":
    ·fn
      fn x: ·ƒ_cont x
      fn ·v_0: ·ƒ_cont ·v_0

test 'function with operator in body', fn:
  expect cps_expr fink":
    fn x: x + 1
  | equals fink":
    ·fn
      fn x:
        ·apply ·op_plus, x, 1, fn ·v_4:
          ·ƒ_cont ·v_4
      fn ·v_0: ·ƒ_cont ·v_0

test 'try — result bound, code continues', fn:
  expect cps_expr fink":
    ni = try foo bar
    ni + 1
  | equals fink":
    ·fn
      fn:
        ·apply foo, bar, fn ·v_3:
          ·let ·v_3, fn ni:
            ·apply ·op_plus, ni, 1, fn ·v_8:
              ·ƒ_cont ·v_8
      fn ·v_0: ·ƒ_cont ·v_0


---
seq/rec literals with spreads
---

# NOTE: ·seq_append/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_expr fink":
    [1, ..a, 2]
  | equals fink":
    ·apply ·seq_append, [], 1, fn ·v_2:
      ·apply ·seq_concat, ·v_2, a, fn ·v_5:
        ·apply ·seq_append, ·v_5, 2, fn ·v_8:
          ·ƒ_cont ·v_8

test 'seq literal leading spread', fn:
  expect cps_expr fink":
    [..a, ..b]
  | equals fink":
    ·apply ·seq_concat, [], a, fn ·v_2:
      ·apply ·seq_concat, ·v_2, b, fn ·v_5:
        ·ƒ_cont ·v_5

test 'rec literal with spread', fn:
  expect cps_expr fink":
    {foo: a, ..b}
  | equals fink":
    ·apply ·rec_put, {}, 'foo', a, fn ·v_3:
      ·apply ·rec_merge, ·v_3, b, fn ·v_6:
        ·ƒ_cont ·v_6

test 'rec literal leading spread', fn:
  expect cps_expr fink":
    {..a, ..b}
  | equals fink":
    ·apply ·rec_merge, {}, a, fn ·v_2:
      ·apply ·rec_merge, ·v_2, b, fn ·v_5:
        ·ƒ_cont ·v_5


---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_expr fink":
    foo 1, ..items
  | equals fink":
    ·apply foo, 1, ..items, fn ·v_3:
      ·ƒ_cont ·v_3


test 'call with spread — trailing iterable', fn:
  expect cps_expr fink":
    foo a, ..rest
  | equals fink":
    ·apply foo, a, ..rest, fn ·v_3:
      ·ƒ_cont ·v_3


test 'call with spread — spread only', fn:
  expect cps_expr fink":
    foo ..items
  | equals fink":
    ·apply foo, ..items, fn ·v_2:
      ·ƒ_cont ·v_2


test 'call with spread — passes through from varargs fn', fn:
  expect cps_expr fink":
    fn ..args: foo ..args
  | equals fink":
    ·fn
      fn ..args:
        ·apply foo, ..args, fn ·v_4:
          ·ƒ_cont ·v_4
      fn ·v_0: ·ƒ_cont ·v_0


---
module level
---

test 'two bindings at module level', fn:
  expect cps_expr fink":
    foo = 1
    bar = 2
  | equals fink":
    ·fn
      fn:
        ·let 1, fn foo:
          ·let 2, fn bar:
            ·ƒ_cont bar
      fn ·v_0: ·ƒ_cont ·v_0
