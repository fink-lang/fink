---
cps_c IR — pretty-printer tests
---

# Input is a Fink expression; output is the synthesized CPS Fink source.
# First-pass CPS — no ·load/·store/·scope synthesis (all names in scope by construction).
#
# Rendering conventions:
#   ·let val, fn name:              — LetVal
#   ·fn fn params: fn_body, fn name: — LetFn
#   ·apply func, args, fn result: — App
#   ·v_cont val             — Ret
#
# Test format:
#   test 'name', fn:
#     expect cps_expr ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
literals — tail position, no synthesis needed
---

test 'int literal', fn:
  expect cps_expr ƒink:
    42
  | equals ƒink:
    ·v_0 42
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiNDIiXSwKICAibWFwcGluZ3MiOiAiQSxBLEtBQUEiCn0=

test 'int literal with underscores', fn:
  expect cps_expr ƒink:
    1_000_000
  | equals ƒink:
    ·v_0 1000000
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiMV8wMDBfMDAwIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxLQUFBIgp9

