---
block — statement sequences
---

test 'block two stmts', fn:
  expect cps_expr ƒink:
    x = 1
    x
  | equals ƒink:
    ·fn
      fn ·ƒret_3:
        ·let 1, fn ·x_0:
          ·ƒret_3 ·x_0
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieCA9IDFcbngiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBO0tBQUEsTztJQUFFLEFBQUEsS0FBRSxDLEtBQUosSTtNLEFBQUEsUUFDQTtLQURBLEksRSxBLEtBQUEiCn0=


test 'block bind then ·apply', fn:
  expect cps_expr ƒink:
    x = 42
    foo x
  | equals ƒink:
    ·fn
      fn ·ƒret_3:
        ·let 42, fn ·x_0:
          ·∅foo ·ƒret_3, ·x_0
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieCA9IDQyXG5mb28geCJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUE7S0FBQSxPO0lBQUUsQUFBQSxLQUFFLEUsS0FBSixJO01BQ0EsQUFBQSxNQURBLE8sRUFDSTtLQURKLEksRSxBLEtBQUEiCn0=


test 'fn body with bind', fn:
  expect cps_expr ƒink:
    fn a:
      x = a + 1
      x
  | equals ƒink:
    ·fn
      fn ·ƒret_4, ·a_0:
        ·op_plus ·a_0, 1, fn ·v_7:
          ·let ·v_7, fn ·x_1:
            ·ƒret_4 ·x_1
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4gYTpcbiAgeCA9IGEgKyAxXG4gIHgiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBO0tBQUEsU0FBRyxJO0lBQ0ssQUFBQSxTQUFGLEksRUFBSSxDLEtBQUosSTtNQUFGLEFBQUEsS0FBRSxJLEtBQUosSTtRLEFBREYsUUFFRTtLQUZGLEksRSxBLEtBQUEiCn0=


