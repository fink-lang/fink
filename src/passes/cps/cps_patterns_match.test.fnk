                    ·ƒctx_40
                    ·ƒret_17
                    fn ·ƒctx_42: ·panic ·ƒctx_42
                    ·ƒv_16
                fn ·ƒv_23: ·ƒv_23 ·ƒctx_34, ·ƒret_0, ·∅foo
    # sm:RAABABIAAQASJAEAEhgBABISAAIABgEaBQABAAUIABAAGAASAAQBBgIAAQACFAAUAAYBAAIAAQACBgEAAgYAEAEFBRAAAgAOAQAFAAEABQgAGAAYABgAGAAOAAQBAAUAAQAFEgAUAAQBAAUUABgBAAUQAAIAFgEZEgABABIIACAAGAAYAQASEAACAB4BABIAAQASMgA2AQASPAAUAAQBABIAAQASEAA2AQASEAAgAQASEAAEAQASAAEAEhIAFAAEAQASEgAEAQwD


