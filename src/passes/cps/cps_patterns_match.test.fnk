      ·fn
        fn ·ƒctx_104, ·ƒret_21: ·op_plus ·ƒctx_104, ·∅y, (i8 1), ·ƒret_21
        fn ·ƒv_27:
          ·fn
            fn ·ƒctx_106, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·fn
                fn ·ƒctx_107: ·ƒv_27 ·ƒctx_107, ·ƒsucc_3
                fn ·ƒv_33:
                  ·fn
                    fn ·ƒctx_109, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                      ·op_eq ·ƒctx_109, ·ƒv_6, true, fn ·ƒctx_111, ·ƒv_11:
                        ·if ·ƒv_11,
                          fn: ·ƒsucc_7 ·ƒctx_111
                          fn: ·ƒfail_8 ·ƒctx_111
                    fn ·ƒv_19: ·ƒv_19 ·ƒctx_106, ·ƒv_33, ·ƒfail_4, ·ƒv_2
            fn ·ƒv_39:
              ·fn
                fn ·ƒctx_115, ·ƒret_59: ·ƒret_59 ·ƒctx_115, ·∅y
                fn ·ƒv_63:
                  ·fn
                    fn ·ƒctx_117, ·ƒsucc_41, ·ƒfail_42, ·ƒv_40:
                      ·fn
                        fn ·ƒctx_118: ·ƒv_63 ·ƒctx_118, ·ƒsucc_41
                        fn ·ƒv_69:
                          ·fn
                            fn ·ƒctx_120, ·ƒsucc_45, ·ƒfail_46, ·ƒv_44:
                              ·op_eq ·ƒctx_120, ·ƒv_44, false, fn ·ƒctx_122, ·ƒv_49:
                                ·if ·ƒv_49,
                                  fn: ·ƒsucc_45 ·ƒctx_122
                                  fn: ·ƒfail_46 ·ƒctx_122
                            fn ·ƒv_57: ·ƒv_57 ·ƒctx_117, ·ƒv_69, ·ƒfail_42, ·ƒv_40
                    fn ·ƒv_75:
                      ·fn
                        fn ·ƒctx_126, ·ƒret_77, ·ƒv_76:
                          ·ƒv_39
                            ·ƒctx_126
                            ·ƒret_77
                            fn ·ƒctx_128:
                              ·ƒv_75
                                ·ƒctx_128
                                ·ƒret_77
                                fn ·ƒctx_130: ·panic ·ƒctx_130
                                ·ƒv_76
                            ·ƒv_76
                        fn ·ƒv_87: ·ƒv_87 ·ƒctx_102, ·ƒret_0, ·∅x
    # sm:


test 'match child ·scope — binding in arm body', fn:
  cps_module ƒink:
    match n:
      a > 1:
        ni = a
        ni
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_62, ·ƒret_2:
      ·fn
        fn ·ƒctx_64, ·ƒret_22, ·a_0:
          ·let ·a_0, fn ·ni_1:
            ·ƒret_22 ·ƒctx_64, ·ni_1
        fn ·ƒv_28:
          ·fn
            fn ·ƒctx_66, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
              ·let ·ƒv_4, fn ·a_0:
                ·fn
                  fn ·ƒctx_67, ·a_0: ·ƒv_28 ·ƒctx_67, ·ƒsucc_5, ·ƒv_4
                  fn ·ƒv_33:
                    ·fn
                      fn ·ƒctx_69, ·ƒsucc_9, ·ƒfail_10, ·ƒv_8:
                        ·op_gt ·ƒctx_69, ·ƒv_8, (i8 1), fn ·ƒctx_71, ·ƒv_13:
                          ·if ·ƒv_13,
                            fn: ·ƒsucc_9 ·ƒctx_71, ·ƒv_8
                            fn: ·ƒfail_10 ·ƒctx_71
                      fn ·ƒv_21: ·ƒv_21 ·ƒctx_66, ·ƒv_33, ·ƒfail_6, ·ƒv_4
            fn ·ƒv_43:
              ·fn
                fn ·ƒctx_75, ·ƒret_45, ·ƒv_44:
                  ·ƒv_43
                    ·ƒctx_75
                    ·ƒret_45
                    fn ·ƒctx_77: ·panic ·ƒctx_77
                    ·ƒv_44
                fn ·ƒv_51: ·ƒv_51 ·ƒctx_62, ·ƒret_2, ·∅n
    # sm:


