{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{cps_module} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected

test 'match block bind', fn:
  cps_module ƒink:
    match foo:
      1: 2
      x: x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_79, ·ƒret_1:
      ·fn
        fn ·ƒctx_81, ·ƒret_22: ·ƒret_22 ·ƒctx_81, (i8 2)
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_83, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·fn
                fn ·ƒctx_84: ·ƒv_26 ·ƒctx_84, ·ƒsucc_4
                fn ·ƒv_32:
                  ·fn
                    fn ·ƒctx_86, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                      ·op_eq ·ƒctx_86, ·ƒv_7, (i8 1), fn ·ƒctx_88, ·ƒv_12:
                        ·if ·ƒv_12,
                          fn: ·ƒsucc_8 ·ƒctx_88
                          fn: ·ƒfail_9 ·ƒctx_88
                    fn ·ƒv_20: ·ƒv_20 ·ƒctx_83, ·ƒv_32, ·ƒfail_5, ·ƒv_3
            fn ·ƒv_38:
              ·fn
                fn ·ƒctx_92, ·ƒret_43, ·x_0: ·ƒret_43 ·ƒctx_92, ·x_0
                fn ·ƒv_47:
                  ·fn
                    fn ·ƒctx_94, ·ƒsucc_40, ·ƒfail_41, ·ƒv_39: ·ƒv_47 ·ƒctx_94, ·ƒsucc_40, ·ƒv_39
                    fn ·ƒv_52:
                      ·fn
                        fn ·ƒctx_96, ·ƒret_54, ·ƒv_53:
                          ·ƒv_38
                            ·ƒctx_96
                            ·ƒret_54
                            fn ·ƒctx_98:
                              ·ƒv_52
                                ·ƒctx_98
                                ·ƒret_54
                                fn ·ƒctx_100: ·panic ·ƒctx_100
                                ·ƒv_53
                            ·ƒv_53
                        fn ·ƒv_64: ·ƒv_64 ·ƒctx_79, ·ƒret_1, ·∅foo
    # sm:


