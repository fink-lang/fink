test 'str templ two exprs', fn:
  expect cps_module ƒink:
    '${a} and ${b}'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·str_fmt ·∅a, ' and ', ·∅b, ·ƒret_0
