test 'str tagged template', fn:
  expect cps_module ƒink:
    foo'1\n2
      3'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_prepend '1⧵n2␊3', [], fn ·v_4:
        ·∅foo ·ƒret_0, ..·v_4
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vJzFcXG4yXG4gIDMnIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxhQUFJLEEsQ0FBQSxNLEMsRUFBSixBLEMsQyxLQUFBLEk7SUFBQSxBQUFBLE0sTyxFQUFBLEEsRUFBQSIKfQ==


test 'str tagged template escape handling', fn:
  expect cps_module ƒink:
    foo'\n\r\t\f${bar}\b\v\$\'\\\xC3\xA9\u{8A_9E}'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·seq_prepend '⧵b⧵v⧵＄⧵′⧵⧵⧵xC3⧵xA9⧵u{8A_9E}', [], fn ·v_4:
        ·seq_prepend ·∅bar, ·v_4, fn ·v_7:
          ·seq_prepend '⧵n⧵r⧵t⧵f', ·v_7, fn ·v_10:
            ·∅foo ·ƒret_0, ..·v_10
    #sourcemaps:


test 'str implicit formatting handling', fn:
  expect cps_module ƒink:
    '1\n2
      3'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 '1␊2␊3'
