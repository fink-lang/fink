{test, skip, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
string templates
---

test 'str templ', fn:
  expect cps_expr ƒink:
    'hello ${name}'
  | equals ƒink:
    ·str_fmt 'hello ', ·∅name, ·v_0
