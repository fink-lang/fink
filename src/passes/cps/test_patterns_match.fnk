test 'match child ·scope — binding in arm body', fn:
  expect cps_module ƒink:
    match n:
      a > 1:
        ni = a
        ni
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_22:
          ·let ·a_0, fn ·ni_1:
            ·ƒret_22 ·ni_1
        fn ·v_28:
          ·fn
            fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·fn
                fn: ·v_28 ·ƒsucc_5
                fn ·v_34:
                  ·fn
                    fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                      ·op_gt ·v_8, 1, fn ·v_13:
                        ·if ·v_13,
                          fn: ·ƒsucc_9 ·v_8
                          fn: ·ƒfail_10 _
                    fn ·v_21: ·v_21 ·v_34, ·ƒfail_6, ·v_4
            fn ·v_40:
              ·fn
                fn ·ƒret_42, ·v_41:
                  ·v_40
                    ·ƒret_42
                    fn: ·panic _
                    ·v_41
                fn ·v_48: ·v_48 ·ƒret_2, ·∅n
    # sm:


