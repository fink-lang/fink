test 'match literal arms', fn:
  expect cps_expr ƒink:
    match foo:
      1: 'one'
      2: 'two'
      _: 'other'
  | equals ƒink:
    ·fn
      fn ·ƒret_21: ·ƒret_21 'one'
      fn ·v_25:
        ·fn
          fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
            ·fn
              fn: ·v_25 ·ƒsucc_3
              fn ·v_31:
                ·fn
                  fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                    ·op_eq ·v_6, 1, fn ·v_11:
                      ·if ·v_11,
                        fn: ·ƒsucc_7 _
                        fn: ·ƒfail_8 _
                  fn ·v_19: ·v_19 ·v_31, ·ƒfail_4, ·v_2
          fn ·v_37:
            ·fn
              fn ·ƒret_57: ·ƒret_57 'two'
              fn ·v_61:
                ·fn
                  fn ·ƒsucc_39, ·ƒfail_40, ·v_38:
                    ·fn
                      fn: ·v_61 ·ƒsucc_39
                      fn ·v_67:
                        ·fn
                          fn ·ƒsucc_43, ·ƒfail_44, ·v_42:
                            ·op_eq ·v_42, 2, fn ·v_47:
                              ·if ·v_47,
                                fn: ·ƒsucc_43 _
                                fn: ·ƒfail_44 _
                          fn ·v_55: ·v_55 ·v_67, ·ƒfail_40, ·v_38
                  fn ·v_73:
                    ·fn
                      fn ·ƒret_78: ·ƒret_78 'other'
                      fn ·v_82:
                        ·fn
                          fn ·ƒsucc_75, ·ƒfail_76, ·v_74: ·v_82 ·ƒsucc_75
                          fn ·v_87:
                            ·fn
                              fn ·ƒret_89, ·v_88:
                                ·v_37 ·ƒret_89, fn:
                                  ·v_73 ·ƒret_89, fn:
                                    ·v_87 ·ƒret_89, fn: ·panic _, ·v_88, ·v_88, ·v_88
                              fn ·v_104: ·v_104 ·v_0, ·∅foo
    #sourcemaps:


test 'match — expression in arm', fn:
  expect cps_expr ƒink:
    match x:
      true: y + 1
      false: y
  | equals ƒink:
    ·fn
      fn ·ƒret_21: ·op_plus ·∅y, 1, ·ƒret_21
      fn ·v_27:
        ·fn
          fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
            ·fn
              fn: ·v_27 ·ƒsucc_3
              fn ·v_33:
                ·fn
                  fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                    ·op_eq ·v_6, true, fn ·v_11:
                      ·if ·v_11,
                        fn: ·ƒsucc_7 _
                        fn: ·ƒfail_8 _
                  fn ·v_19: ·v_19 ·v_33, ·ƒfail_4, ·v_2
          fn ·v_39:
            ·fn
              fn ·ƒret_59: ·ƒret_59 ·∅y
              fn ·v_63:
                ·fn
                  fn ·ƒsucc_41, ·ƒfail_42, ·v_40:
                    ·fn
                      fn: ·v_63 ·ƒsucc_41
                      fn ·v_69:
                        ·fn
                          fn ·ƒsucc_45, ·ƒfail_46, ·v_44:
                            ·op_eq ·v_44, false, fn ·v_49:
                              ·if ·v_49,
                                fn: ·ƒsucc_45 _
                                fn: ·ƒfail_46 _
                          fn ·v_57: ·v_57 ·v_69, ·ƒfail_42, ·v_40
                  fn ·v_75:
                    ·fn
                      fn ·ƒret_77, ·v_76:
                        ·v_39 ·ƒret_77, fn:
                          ·v_75 ·ƒret_77, fn: ·panic _, ·v_76, ·v_76
                      fn ·v_88: ·v_88 ·v_0, ·∅x
    #sourcemaps:


test 'match child ·scope — binding in arm body', fn:
  expect cps_expr ƒink:
    match n:
      a > 1:
        ni = a
        ni
  | equals ƒink:
    ·fn
      fn ·ƒret_22:
        ·let ·a_0, fn ·ni_1:
          ·ƒret_22 ·ni_1
      fn ·v_28:
        ·fn
          fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
            ·fn
              fn: ·v_28 ·ƒsucc_5
              fn ·v_34:
                ·fn
                  fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                    ·op_gt ·v_8, 1, fn ·v_13:
                      ·if ·v_13,
                        fn: ·ƒsucc_9 ·v_8
                        fn: ·ƒfail_10 _
                  fn ·v_21: ·v_21 ·v_34, ·ƒfail_6, ·v_4
          fn ·v_40:
            ·fn
              fn ·ƒret_42, ·v_41:
                ·v_40 ·ƒret_42, fn: ·panic _, ·v_41
              fn ·v_49: ·v_49 ·v_2, ·∅n
    #sourcemaps:


