              ·fn
                fn: ·v_27 ·ƒsucc_3
                fn ·v_33:
                  ·fn
                    fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                      ·op_eq ·v_6, true, fn ·v_11:
                        ·if ·v_11,
                          fn: ·ƒsucc_7 _
                          fn: ·ƒfail_8 _
                    fn ·v_19: ·v_19 ·v_33, ·ƒfail_4, ·v_2
            fn ·v_39:
              ·fn
                fn ·ƒret_59: ·ƒret_59 ·∅y
                fn ·v_63:
                  ·fn
                    fn ·ƒsucc_41, ·ƒfail_42, ·v_40:
                      ·fn
                        fn: ·v_63 ·ƒsucc_41
                        fn ·v_69:
                          ·fn
                            fn ·ƒsucc_45, ·ƒfail_46, ·v_44:
                              ·op_eq ·v_44, false, fn ·v_49:
                                ·if ·v_49,
                                  fn: ·ƒsucc_45 _
                                  fn: ·ƒfail_46 _
                            fn ·v_57: ·v_57 ·v_69, ·ƒfail_42, ·v_40
                    fn ·v_75:
                      ·fn
                        fn ·ƒret_77, ·v_76:
                          ·v_39
                            ·ƒret_77
                            fn:
