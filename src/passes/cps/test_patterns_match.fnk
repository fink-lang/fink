      [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_41, ·a_0, ·b_1: ·ƒret_41 ·a_0
        fn ·v_45:
          ·fn
            fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·fn
                fn ·v_11, ·v_12:
                  ·let ·v_11, fn ·a_0:
                    ·let ·v_12, fn ·b_1:
                      ·v_45 ·ƒsucc_5, ·v_11, ·v_12
                fn ·v_54:
                  ·fn
                    fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                      ·is_seq_like ·v_8,
                        fn ·v_25:
                          ·seq_pop ·v_25, ·ƒfail_10, fn ·v_11, ·v_26:
                            ·seq_pop ·v_26, ·ƒfail_10, fn ·v_12, ·v_17:
                              ·empty ·v_17, fn ·v_20:
                                ·if ·v_20,
                                  fn: ·ƒsucc_9 ·v_11, ·v_12
                                  fn: ·ƒfail_10 _
                        fn: ·ƒfail_10 _
                    fn ·v_37: ·v_37 ·v_54, ·ƒfail_6, ·v_4
            fn ·v_61:
              ·fn
                fn ·ƒret_63, ·v_62:
                  ·v_61
                    ·ƒret_63
                    fn: ·panic _
                    ·v_62
                fn ·v_69: ·v_69 ·ƒret_2, ·∅foo
    # sm:

