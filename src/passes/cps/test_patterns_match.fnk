{test, equals, expect, cps_expr} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

test 'match block bind', fn:
  expect cps_expr ƒink:
    match foo:
      1: 2
      x: x
  | equals ƒink:
    ·fn
      fn ·ƒret_22: ·ƒret_22 2
      fn ·v_26:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·fn
              fn: ·v_26 ·ƒsucc_4
              fn ·v_32:
                ·fn
                  fn ·ƒsucc_8, ·ƒfail_9, ·v_7:
                    ·op_eq ·v_7, 1, fn ·v_12:
                      ·if ·v_12,
                        fn: ·ƒsucc_8 _
                        fn: ·ƒfail_9 _
                  fn ·v_20: ·v_20 ·v_32, ·ƒfail_5, ·v_3
          fn ·v_38:
            ·fn
              fn ·ƒret_43, ·x_0: ·ƒret_43 ·x_0
              fn ·v_47:
                ·fn
                  fn ·ƒsucc_40, ·ƒfail_41, ·v_39: ·v_47 ·ƒsucc_40, ·v_39
                  fn ·v_52:
                    ·fn
                      fn ·ƒret_54, ·v_53:
                        ·v_38 ·ƒret_54, fn:
                          ·v_52 ·ƒret_54, fn: ·panic _, ·v_53, ·v_53
                      fn ·v_65: ·v_65 ·v_1, ·∅foo
    #sourcemaps:


