              ·fn
                fn: ·v_25 ·ƒsucc_3
                fn ·v_31:
                  ·fn
                    fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                      ·op_eq ·v_6, 1, fn ·v_11:
                        ·if ·v_11,
                          fn: ·ƒsucc_7 _
                          fn: ·ƒfail_8 _
                    fn ·v_19: ·v_19 ·v_31, ·ƒfail_4, ·v_2
            fn ·v_37:
              ·fn
                fn ·ƒret_57: ·ƒret_57 'two'
                fn ·v_61:
                  ·fn
                    fn ·ƒsucc_39, ·ƒfail_40, ·v_38:
                      ·fn
                        fn: ·v_61 ·ƒsucc_39
                        fn ·v_67:
                          ·fn
                            fn ·ƒsucc_43, ·ƒfail_44, ·v_42:
                              ·op_eq ·v_42, 2, fn ·v_47:
                                ·if ·v_47,
                                  fn: ·ƒsucc_43 _
                                  fn: ·ƒfail_44 _
                            fn ·v_55: ·v_55 ·v_67, ·ƒfail_40, ·v_38
                    fn ·v_73:
                      ·fn
                        fn ·ƒret_78: ·ƒret_78 'other'
                        fn ·v_82:
                          ·fn
                            fn ·ƒsucc_75, ·ƒfail_76, ·v_74: ·v_82 ·ƒsucc_75
                            fn ·v_87:
                              ·fn
                                fn ·ƒret_89, ·v_88:
                                  ·v_37
                                    ·ƒret_89
                                    fn:
                                      ·v_73
                                        ·ƒret_89
                                        fn:
                                          ·v_87
                                            ·ƒret_89
                                            fn: ·panic _
                                            ·v_88
                                        ·v_88
                                    ·v_88
                                fn ·v_103: ·v_103 ·ƒret_0, ·∅foo
    # sm:


test 'match — expression in arm', fn:
