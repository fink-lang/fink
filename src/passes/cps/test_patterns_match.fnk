          fn ·ƒsucc_7, ·ƒfail_8, ·v_5, ·v_6: ·v_15 ·ƒsucc_7, ·v_5, ·v_6
          fn ·v_20:
            ·fn
              fn ·ƒret_23, ·v_21, ·v_22:
                ·v_20 ·ƒret_23, fn: ·panic _, ·v_21, ·v_22
              fn ·v_31: ·v_31 ·v_2, ·∅a, ·∅b
