{test, equals, expect, cps_expr} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  expect cps_expr ƒink:
    x > 2 = foo
  | equals ƒink:
    ·fn
      fn ·x_0: ·v_1 ·x_0
      fn ·v_18:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·op_gt ·v_3, 2, fn ·v_8:
              ·if ·v_8,
                fn: ·ƒsucc_4 ·v_3
                fn: ·ƒfail_5 _
          fn ·v_16: ·v_16 ·v_18, ·panic, ·∅foo
    #sourcemaps:


test 'bind right — seq pattern', fn:
  expect cps_expr ƒink:
    [a, b] = foo
  | equals ƒink:
    ·fn
      fn ·v_7, ·v_8:
        ·let ·v_7, fn ·a_0:
          ·let ·v_8, fn ·b_1:
            ·v_2 ·b_1
      fn ·v_42:
        ·fn
          fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
            ·is_seq_like ·v_4,
              fn ·v_21:
                ·seq_pop ·v_21, ·ƒfail_6, fn ·v_7, ·v_22:
                  ·seq_pop ·v_22, ·ƒfail_6, fn ·v_8, ·v_13:
                    ·empty ·v_13, fn ·v_16:
                      ·if ·v_16,
                        fn: ·ƒsucc_5 ·v_7, ·v_8
                        fn: ·ƒfail_6 _
              fn: ·ƒfail_6 _
          fn ·v_33: ·v_33 ·v_42, ·panic, ·∅foo
    #sourcemaps:


test 'bind right — rec pattern', fn:
  expect cps_expr ƒink:
    {bar} = foo
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·bar_0:
          ·v_1 ·bar_0
      fn ·v_26:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·is_rec_like ·v_3,
              fn ·v_11:
                ·rec_pop ·v_11, 'bar', ·ƒfail_5, fn ·v_6, ·v_10:
                  ·ƒsucc_4 ·v_6
              fn: ·ƒfail_5 _
          fn ·v_20: ·v_20 ·v_26, ·panic, ·∅foo
    #sourcemaps:


test 'seq pattern', fn:
  expect cps_expr ƒink:
    [a, 1] = foo
  | equals ƒink:
    ·fn
      fn ·v_6, ·v_7:
        ·let ·v_6, fn ·a_0:
          ·fn
            fn: ·v_1 ·panic
            fn ·v_52:
              ·fn
                fn ·ƒsucc_36, ·ƒfail_37, ·v_35:
                  ·op_eq ·v_35, 1, fn ·v_40:
                    ·if ·v_40,
                      fn: ·ƒsucc_36 _
                      fn: ·ƒfail_37 _
                fn ·v_48: ·v_48 ·v_52, ·panic, ·v_7
      fn ·v_65:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·is_seq_like ·v_3,
              fn ·v_20:
                ·seq_pop ·v_20, ·ƒfail_5, fn ·v_6, ·v_21:
                  ·seq_pop ·v_21, ·ƒfail_5, fn ·v_7, ·v_12:
                    ·empty ·v_12, fn ·v_15:
                      ·if ·v_15,
                        fn: ·ƒsucc_4 ·v_6, ·v_7
                        fn: ·ƒfail_5 _
              fn: ·ƒfail_5 _
          fn ·v_32: ·v_32 ·v_65, ·panic, ·∅foo
    #sourcemaps:

