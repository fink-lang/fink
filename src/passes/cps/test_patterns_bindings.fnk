              fn ·v_52:
                ·fn
                  fn ·ƒctx_79, ·ƒsucc_36, ·ƒfail_37, ·v_35:
                    ·op_eq ·v_35, (i8 1), fn ·ƒctx_80, ·v_40:
                      ·if ·v_40,
                        fn: ·ƒsucc_36 ·ƒctx_80
