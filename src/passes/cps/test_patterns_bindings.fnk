test 'range — exclusive in match arm', fn:
  expect cps_module ƒink:
    match x:
      0..10: 'low'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_61, ·ƒret_0:
      ·fn
        fn ·ƒctx_63, ·ƒret_26: ·ƒret_26 ·ƒctx_63, 'low'
        fn ·v_30:
          ·fn
            fn ·ƒctx_66, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·fn
                fn ·ƒctx_67: ·v_30 ·ƒctx_67, ·ƒsucc_3
                fn ·v_36:
                  ·fn
                    fn ·ƒctx_70, ·ƒsucc_7, ·ƒfail_8, ·v_6:
                      ·op_rngex (i8 0), (i8 10), fn ·ƒctx_71, ·v_19:
                        ·op_in ·v_6, ·v_19, fn ·ƒctx_72, ·v_14:
                          ·if ·v_14,
                            fn: ·ƒsucc_7 ·ƒctx_72
                            fn: ·ƒfail_8 ·ƒctx_72
                    fn ·v_23: ·v_23 ·ƒctx_75, ·v_36, ·ƒfail_4, ·v_2
            fn ·v_42:
              ·fn
                fn ·ƒctx_78, ·ƒret_44, ·v_43:
                  ·v_42
                    ·ƒctx_78
                    ·ƒret_44
                    fn ·ƒctx_80: ·panic _
                    ·v_43
                fn ·v_50: ·v_50 ·ƒctx_81, ·ƒret_0, ·∅x
    # sm:


