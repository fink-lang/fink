test 'range — exclusive in match arm', fn:
  expect cps_module ƒink:
    match x:
      0..10: 'low'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_61, ·ƒret_0:
      ·fn
        fn ·ƒctx_63, ·ƒret_26: ·ƒret_26 ·ƒctx_63, 'low'
        fn ·ƒv_30:
          ·fn
            fn ·ƒctx_65, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·fn
                fn ·ƒctx_66: ·ƒv_30 ·ƒctx_66, ·ƒsucc_3
                fn ·ƒv_36:
                  ·fn
                    fn ·ƒctx_68, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                      ·op_rngex ·ƒctx_68, (i8 0), (i8 10), fn ·ƒctx_70, ·ƒv_19:
                        ·op_in ·ƒctx_70, ·ƒv_6, ·ƒv_19, fn ·ƒctx_72, ·ƒv_14:
                          ·if ·ƒv_14,
                            fn: ·ƒsucc_7 ·ƒctx_72
                            fn: ·ƒfail_8 ·ƒctx_72
                    fn ·ƒv_23: ·ƒv_23 ·ƒctx_65, ·ƒv_36, ·ƒfail_4, ·ƒv_2
            fn ·ƒv_42:
              ·fn
                fn ·ƒctx_76, ·ƒret_44, ·ƒv_43:
                  ·ƒv_42
                    ·ƒctx_76
                    ·ƒret_44
                    fn ·ƒctx_78: ·panic ·ƒctx_78
                    ·ƒv_43
                fn ·ƒv_50: ·ƒv_50 ·ƒctx_61, ·ƒret_0, ·∅x
    # sm:


