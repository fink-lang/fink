    #sourcemaps:


test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps_module ƒink:
    fn a, [1, ..b]: b
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_45, ·a_0, ·v_4:
          ·fn
            fn ·v_9, ·v_10:
              ·fn
                fn:
                  ·let ·v_10, fn ·b_1:
                    ·ƒret_45 ·b_1
                fn ·v_52:
                  ·fn
                    fn ·ƒsucc_29, ·ƒfail_30, ·v_28:
                      ·op_eq ·v_28, 1, fn ·v_33:
                        ·if ·v_33,
                          fn: ·ƒsucc_29 _
                          fn: ·ƒfail_30 _
                    fn ·v_41: ·v_41 ·v_52, ·panic, ·v_9
            fn ·v_60:
              ·fn
                fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                  ·is_seq_like ·v_6,
                    fn ·v_18:
                      ·seq_pop ·v_18, ·ƒfail_8, fn ·v_9, ·v_15:
                        ·let ·v_15, fn ·v_10:
                          ·ƒsucc_7 ·v_9, ·v_10
                    fn: ·ƒfail_8 _
                fn ·v_26: ·v_26 ·v_60, ·panic, ·v_4
        fn ·v_3: ·ƒret_2 ·v_3
    #sourcemaps:
