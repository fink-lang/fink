                  fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                    ·op_rngin 0, 10, fn ·v_19:
                      ·op_in ·v_6, ·v_19, fn ·v_14:
                        ·if ·v_14,
                          fn: ·ƒsucc_7 _
                          fn: ·ƒfail_8 _
                  fn ·v_23: ·v_23 ·v_36, ·ƒfail_4, ·v_2
          fn ·v_42:
            ·fn
              fn ·ƒret_44, ·v_43:
                ·v_42
                  ·ƒret_44
                  fn: ·panic _
                  ·v_43
              fn ·v_51: ·v_51 ·v_0, ·∅x
    #sourcemaps:


test 'range — bind-lhs check', fn:
  expect cps_expr ƒink:
    0..10 = foo
  | equals ƒink:
    ·fn
      fn ·v_20: ·v_0 ·v_20
      fn ·v_23:
        ·fn
          fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
            ·op_rngex 0, 10, fn ·v_15:
              ·op_in ·v_2, ·v_15, fn ·v_10:
                ·if ·v_10,
                  fn: ·ƒsucc_3 _
                  fn: ·ƒfail_4 _
          fn ·v_19: ·v_19 ·v_23, ·panic, ·∅foo
    #sourcemaps:


---
fn params (·v_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  expect cps_expr ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·fn
      fn ·ƒret_39, ·v_4:
        ·fn
          fn ·v_9, ·v_10:
            ·let ·v_9, fn ·a_0:
              ·let ·v_10, fn ·b_1:
                ·ƒret_39 ·a_0
          fn ·v_48:
            ·fn
              fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                ·is_seq_like ·v_6,
                  fn ·v_23:
                    ·seq_pop ·v_23, ·ƒfail_8, fn ·v_9, ·v_24:
                      ·seq_pop ·v_24, ·ƒfail_8, fn ·v_10, ·v_15:
                        ·empty ·v_15, fn ·v_18:
                          ·if ·v_18,
                            fn: ·ƒsucc_7 ·v_9, ·v_10
                            fn: ·ƒfail_8 _
                  fn: ·ƒfail_8 _
              fn ·v_35: ·v_35 ·v_48, ·panic, ·v_4
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:

