---
range patterns
---

test 'range — exclusive in match arm', fn:
  expect cps_module ƒink:
    match x:
      0..10: 'low'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·fn
        fn ·ƒret_26: ·ƒret_26 'low'
        fn ·v_30:
          ·fn
            fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·fn
                fn: ·v_30 ·ƒsucc_3
                fn ·v_36:
                  ·fn
                    fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                      ·op_rngex 0, 10, fn ·v_19:
                        ·op_in ·v_6, ·v_19, fn ·v_14:
                          ·if ·v_14,
                            fn: ·ƒsucc_7 _
                            fn: ·ƒfail_8 _
                    fn ·v_23: ·v_23 ·v_36, ·ƒfail_4, ·v_2
            fn ·v_42:
              ·fn
                fn ·ƒret_44, ·v_43:
                  ·v_42
                    ·ƒret_44
                    fn: ·panic _
                    ·v_43
                fn ·v_50: ·v_50 ·ƒret_0, ·∅x
    #sourcemaps:


