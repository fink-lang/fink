              fn ·v_11:
                ·rec_pop ·v_11, 4, ·ƒfail_5, fn ·v_6, ·v_10:
                  ·ƒsucc_4 ·v_6
              fn: ·ƒfail_5 _
          fn ·v_20: ·v_20 ·v_26, ·panic, ·∅rec
