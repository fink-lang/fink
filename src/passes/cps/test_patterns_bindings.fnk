              ·let ·ƒv_9, fn ·a_0:
                ·let ·ƒv_10, fn ·b_1:
                  ·ƒret_39 ·ƒctx_63, ·a_0
            fn ·ƒv_48:
              ·fn
                fn ·ƒctx_65, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                  ·is_seq_like ·ƒctx_65, ·ƒv_6,
                    fn ·ƒctx_67, ·ƒv_23:
                      ·seq_pop ·ƒctx_67, ·ƒv_23, ·ƒfail_8, fn ·ƒctx_69, ·ƒv_9, ·ƒv_24:
                        ·seq_pop ·ƒctx_69, ·ƒv_24, ·ƒfail_8, fn ·ƒctx_71, ·ƒv_10, ·ƒv_15:
                          ·empty ·ƒctx_71, ·ƒv_15, fn ·ƒctx_73, ·ƒv_18:
