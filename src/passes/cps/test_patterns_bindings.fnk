---
fn params (·v_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  expect cps_module ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_57, ·ƒret_2:
      ·fn
        fn ·ƒctx_59, ·ƒret_39, ·ƒv_4:
          ·fn
            fn ·ƒctx_60, ·ƒv_9, ·ƒv_10:
              ·let ·ƒv_9, fn ·a_0:
                ·let ·ƒv_10, fn ·b_1:
                  ·ƒret_39 ·ƒctx_60, ·a_0
            fn ·ƒv_48:
              ·fn
                fn ·ƒctx_62, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                  ·is_seq_like ·ƒctx_62, ·ƒv_6,
                    fn ·ƒctx_64, ·ƒv_23:
                      ·seq_pop ·ƒctx_64, ·ƒv_23, ·ƒfail_8, fn ·ƒctx_66, ·ƒv_9, ·ƒv_24:
                        ·seq_pop ·ƒctx_66, ·ƒv_24, ·ƒfail_8, fn ·ƒctx_68, ·ƒv_10, ·ƒv_15:
                          ·empty ·ƒctx_68, ·ƒv_15, fn ·ƒctx_70, ·ƒv_18:
                            ·if ·ƒv_18,
                              fn: ·ƒsucc_7 ·ƒctx_70, ·ƒv_9, ·ƒv_10
                              fn: ·ƒfail_8 ·ƒctx_70
                    fn ·ƒctx_73: ·ƒfail_8 ·ƒctx_73
                fn ·ƒv_35: ·ƒv_35 ·ƒctx_59, ·ƒv_48, ·panic, ·ƒv_4
        fn ·ƒv_3: ·ƒret_2 ·ƒctx_57, ·ƒv_3
    # sm:

