---
fn params (·v_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  expect cps_module ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_39, ·v_4:
          ·fn
            fn ·v_9, ·v_10:
              ·let ·v_9, fn ·a_0:
                ·let ·v_10, fn ·b_1:
                  ·ƒret_39 ·a_0
            fn ·v_48:
              ·fn
                fn ·ƒsucc_7, ·ƒfail_8, ·v_6:
                  ·is_seq_like ·v_6,
                    fn ·v_23:
                      ·seq_pop ·v_23, ·ƒfail_8, fn ·v_9, ·v_24:
                        ·seq_pop ·v_24, ·ƒfail_8, fn ·v_10, ·v_15:
                          ·empty ·v_15, fn ·v_18:
                            ·if ·v_18,
                              fn: ·ƒsucc_7 ·v_9, ·v_10
                              fn: ·ƒfail_8 _
                    fn: ·ƒfail_8 _
                fn ·v_35: ·v_35 ·v_48, ·panic, ·v_4
        fn ·v_3: ·ƒret_2 ·v_3
    #sourcemaps:

