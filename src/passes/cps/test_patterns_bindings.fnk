        fn ·v_20: ·ƒret_0 ·v_20
        fn ·v_23:
          ·fn
            fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·op_rngex 0, 10, fn ·v_15:
                ·op_in ·v_2, ·v_15, fn ·v_10:
                  ·if ·v_10,
                    fn: ·ƒsucc_3 _
                    fn: ·ƒfail_4 _
            fn ·v_19: ·v_19 ·v_23, ·panic, ·∅foo
