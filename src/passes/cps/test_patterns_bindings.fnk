            ·let ·ƒv_6, fn ·a_0:
              ·fn
                fn ·ƒctx_76: ·ƒret_1 ·ƒctx_76, ·panic
                fn ·ƒv_52:
                  ·fn
                    fn ·ƒctx_78, ·ƒsucc_36, ·ƒfail_37, ·ƒv_35:
                      ·op_eq ·ƒctx_78, ·ƒv_35, (i8 1), fn ·ƒctx_80, ·ƒv_40:
                        ·if ·ƒv_40,
                          fn: ·ƒsucc_36 ·ƒctx_80
                          fn: ·ƒfail_37 ·ƒctx_80
                    fn ·ƒv_48: ·ƒv_48 ·ƒctx_75, ·ƒv_52, ·panic, ·ƒv_7
          fn ·ƒv_65:
            ·fn
              fn ·ƒctx_84, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·is_seq_like ·ƒctx_84, ·ƒv_3,
                  fn ·ƒctx_86, ·ƒv_20:
