---
fn params (·v_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  expect cps_module ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_57, ·ƒret_2:
      ·fn
        fn ·ƒctx_59, ·ƒret_39, ·v_4:
          ·fn
            fn ·ƒctx_60, ·v_9, ·v_10:
              ·let ·v_9, fn ·a_0:
                ·let ·v_10, fn ·b_1:
                  ·ƒret_39 ·ƒctx_62, ·a_0
            fn ·v_48:
              ·fn
                fn ·ƒctx_65, ·ƒsucc_7, ·ƒfail_8, ·v_6:
                  ·is_seq_like ·v_6,
                    fn ·ƒctx_66, ·v_23:
                      ·seq_pop ·v_23, ·ƒfail_8, fn ·ƒctx_67, ·v_9, ·v_24:
                        ·seq_pop ·v_24, ·ƒfail_8, fn ·ƒctx_68, ·v_10, ·v_15:
                          ·empty ·v_15, fn ·ƒctx_69, ·v_18:
                            ·if ·v_18,
                              fn: ·ƒsucc_7 ·ƒctx_69, ·v_9, ·v_10
                              fn: ·ƒfail_8 ·ƒctx_69
                    fn ·ƒctx_72: ·ƒfail_8 ·ƒctx_72
                fn ·v_35: ·v_35 ·ƒctx_74, ·v_48, ·panic, ·v_4
        fn ·v_3: ·ƒret_2 ·v_3
    # sm:

