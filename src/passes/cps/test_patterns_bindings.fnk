{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  expect cps_module ƒink:
    x > 2 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_31, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·x_0, ·∅foo, fn:
          ·fn
            fn ·ƒctx_33, ·x_0: ·ƒret_1 ·ƒctx_33, ·x_0
            fn ·ƒv_18:
              ·fn
                fn ·ƒctx_35, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                  ·op_gt ·ƒctx_35, ·ƒv_3, (i8 2), fn ·ƒctx_37, ·ƒv_8:
                    ·if ·ƒv_8,
                      fn: ·ƒsucc_4 ·ƒctx_37, ·ƒv_3
                      fn: ·ƒfail_5 ·ƒctx_37
                fn ·ƒv_16: ·ƒv_16 ·ƒctx_31, ·ƒv_18, ·panic, ·∅foo
    # sm:


test 'bind right — seq pattern', fn:
  expect cps_module ƒink:
    [a, b] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_50, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·fn
          fn ·ƒctx_52, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·a_0:
              ·let ·ƒv_8, fn ·b_1:
                ·ƒret_2 ·ƒctx_52, ·b_1
          fn ·ƒv_42:
            ·fn
              fn ·ƒctx_53, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·is_seq_like ·ƒctx_53, ·ƒv_4,
                  fn ·ƒctx_55, ·ƒv_21:
                    ·seq_pop ·ƒctx_55, ·ƒv_21, ·ƒfail_6, fn ·ƒctx_57, ·ƒv_7, ·ƒv_22:
                      ·seq_pop ·ƒctx_57, ·ƒv_22, ·ƒfail_6, fn ·ƒctx_59, ·ƒv_8, ·ƒv_13:
                        ·empty ·ƒctx_59, ·ƒv_13, fn ·ƒctx_61, ·ƒv_16:
                          ·if ·ƒv_16,
                            fn: ·ƒsucc_5 ·ƒctx_61, ·ƒv_7, ·ƒv_8
                            fn: ·ƒfail_6 ·ƒctx_61
                  fn ·ƒctx_64: ·ƒfail_6 ·ƒctx_64
              fn ·ƒv_33: ·ƒv_33 ·ƒctx_50, ·ƒv_42, ·panic, ·∅foo
    # sm:


