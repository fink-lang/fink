test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps_module ƒink:
    fn a, [1, ..b]: b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_69, ·ƒret_2:
      ·fn
        fn ·ƒctx_71, ·ƒret_45, ·a_0, ·ƒv_4:
          ·fn
            fn ·ƒctx_72, ·ƒv_9, ·ƒv_10:
              ·fn
                fn ·ƒctx_73:
                  ·let ·ƒv_10, fn ·b_1:
                    ·ƒret_45 ·ƒctx_73, ·b_1
                fn ·ƒv_52:
                  ·fn
                    fn ·ƒctx_75, ·ƒsucc_29, ·ƒfail_30, ·ƒv_28:
                      ·op_eq ·ƒctx_75, ·ƒv_28, (i8 1), fn ·ƒctx_77, ·ƒv_33:
                        ·if ·ƒv_33,
