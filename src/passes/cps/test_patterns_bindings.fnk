                      ·seq_pop ·ƒctx_88, ·ƒv_21, ·ƒfail_5, fn ·ƒctx_90, ·ƒv_7, ·ƒv_12:
                        ·empty ·ƒctx_90, ·ƒv_12, fn ·ƒctx_92, ·ƒv_15:
                          ·if ·ƒv_15,
                            fn: ·ƒsucc_4 ·ƒctx_92, ·ƒv_6, ·ƒv_7
