test 'seq pattern', fn:
  expect cps_module ƒink:
    [a, 1] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_73, ·ƒret_1:
      ·letrec fn ·a_0:
        ·fn
          fn ·ƒctx_75, ·v_6, ·v_7:
            ·let ·v_6, fn ·a_0:
              ·fn
                fn ·ƒctx_76: ·ƒret_1 ·ƒctx_76, ·panic
                fn ·v_52:
                  ·fn
                    fn ·ƒctx_78, ·ƒsucc_36, ·ƒfail_37, ·v_35:
                      ·op_eq ·ƒctx_78, ·v_35, (i8 1), fn ·ƒctx_80, ·v_40:
                        ·if ·v_40,
                          fn: ·ƒsucc_36 ·ƒctx_80
                          fn: ·ƒfail_37 ·ƒctx_80
                    fn ·v_48: ·v_48 ·ƒctx_75, ·v_52, ·panic, ·v_7
          fn ·v_65:
            ·fn
              fn ·ƒctx_84, ·ƒsucc_4, ·ƒfail_5, ·v_3:
                ·is_seq_like ·ƒctx_84, ·v_3,
                  fn ·ƒctx_86, ·v_20:
                    ·seq_pop ·ƒctx_86, ·v_20, ·ƒfail_5, fn ·ƒctx_88, ·v_6, ·v_21:
                      ·seq_pop ·ƒctx_88, ·v_21, ·ƒfail_5, fn ·ƒctx_90, ·v_7, ·v_12:
                        ·empty ·ƒctx_90, ·v_12, fn ·ƒctx_92, ·v_15:
                          ·if ·v_15,
                            fn: ·ƒsucc_4 ·ƒctx_92, ·v_6, ·v_7
                            fn: ·ƒfail_5 ·ƒctx_92
                  fn ·ƒctx_95: ·ƒfail_5 ·ƒctx_95
              fn ·v_32: ·v_32 ·ƒctx_73, ·v_65, ·panic, ·∅foo
    # sm:

