{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  expect cps_module ƒink:
    x > 2 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_28, ·ƒret_1:
      ·fn
        fn ·ƒctx_30, ·x_0: ·ƒret_1 ·ƒctx_30, ·x_0
        fn ·v_18:
          ·fn
            fn ·ƒctx_33, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·op_gt ·v_3, (i8 2), fn ·ƒctx_34, ·v_8:
                ·if ·v_8,
                  fn: ·ƒsucc_4 ·ƒctx_34, ·v_3
                  fn: ·ƒfail_5 ·ƒctx_34
            fn ·v_16: ·v_16 ·ƒctx_37, ·v_18, ·panic, ·∅foo
    # sm:RgABAAsAAQALJAEACxgBAAsSAAIABgEACwABAAsIABAAGAEAAQoABAEACwABAAsUABQABAEACwoAEAEACwwAAgAOAQALAAEACwgAGAAYABgAGAEACwoAAgAWAQAFAAEABRABAAsKAAYBCAEAAQABBgEAAQQACgAYAQcFCgACABoBAAUAAQAFCgEABQoAAgAiAAQBAAsAAQALFgAUAAQBAAsKACIABAEACwABAAsWABQAGAEACwwABAEACwABAAsOABQABAEACwwABAEACw4ABAEQAw


test 'bind right — seq pattern', fn:
  expect cps_module ƒink:
    [a, b] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_49, ·ƒret_2:
      ·fn
        fn ·ƒctx_51, ·v_7, ·v_8:
          ·let ·v_7, fn ·a_0:
            ·let ·v_8, fn ·b_1:
              ·ƒret_2 ·b_1
        fn ·v_42:
          ·fn
            fn ·ƒctx_54, ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·is_seq_like ·v_4,
                fn ·ƒctx_55, ·v_21:
                  ·seq_pop ·v_21, ·ƒfail_6, fn ·ƒctx_56, ·v_7, ·v_22:
                    ·seq_pop ·v_22, ·ƒfail_6, fn ·ƒctx_57, ·v_8, ·v_13:
                      ·empty ·v_13, fn ·ƒctx_58, ·v_16:
                        ·if ·v_16,
                          fn: ·ƒsucc_5 ·ƒctx_58, ·v_7, ·v_8
                          fn: ·ƒfail_6 ·ƒctx_58
                fn ·ƒctx_61: ·ƒfail_6 ·ƒctx_61
            fn ·v_33: ·v_33 ·ƒctx_63, ·v_42, ·panic, ·∅foo
    # sm:


