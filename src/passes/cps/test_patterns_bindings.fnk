test 'range — exclusive in match arm', fn:
  expect cps_module ƒink:
    match x:
      0..10: 'low'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_61, ·ƒret_0:
      ·fn
        fn ·ƒctx_63, ·ƒret_26: ·ƒret_26 ·ƒctx_63, 'low'
        fn ·v_30:
          ·fn
            fn ·ƒctx_65, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·fn
                fn ·ƒctx_66: ·v_30 ·ƒctx_66, ·ƒsucc_3
                fn ·v_36:
                  ·fn
                    fn ·ƒctx_68, ·ƒsucc_7, ·ƒfail_8, ·v_6:
                      ·op_rngex ·ƒctx_68, (i8 0), (i8 10), fn ·ƒctx_70, ·v_19:
                        ·op_in ·ƒctx_70, ·v_6, ·v_19, fn ·ƒctx_72, ·v_14:
                          ·if ·v_14,
                            fn: ·ƒsucc_7 ·ƒctx_72
                            fn: ·ƒfail_8 ·ƒctx_72
                    fn ·v_23: ·v_23 ·ƒctx_65, ·v_36, ·ƒfail_4, ·v_2
            fn ·v_42:
              ·fn
                fn ·ƒctx_76, ·ƒret_44, ·v_43:
                  ·v_42
                    ·ƒctx_76
                    ·ƒret_44
                    fn ·ƒctx_78: ·panic ·ƒctx_78
                    ·v_43
                fn ·v_50: ·v_50 ·ƒctx_61, ·ƒret_0, ·∅x
    # sm:


