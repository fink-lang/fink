{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  expect cps_module ƒink:
    x > 2 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_32, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·ƒctx_32, ·x_0, ·∅foo, fn ·ƒctx_35:
          ·fn
            fn ·ƒctx_36, ·x_0: ·ƒret_1 ·ƒctx_36, ·x_0
            fn ·v_18:
              ·fn
                fn ·ƒctx_38, ·ƒsucc_4, ·ƒfail_5, ·v_3:
                  ·op_gt ·ƒctx_38, ·v_3, (i8 2), fn ·ƒctx_40, ·v_8:
                    ·if ·v_8,
                      fn: ·ƒsucc_4 ·ƒctx_40, ·v_3
                      fn: ·ƒfail_5 ·ƒctx_40
                fn ·v_16: ·v_16 ·ƒctx_35, ·v_18, ·panic, ·∅foo
    # sm:


test 'bind right — seq pattern', fn:
  expect cps_module ƒink:
    [a, b] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_50, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·fn
          fn ·ƒctx_52, ·v_7, ·v_8:
            ·let ·v_7, fn ·a_0:
              ·let ·v_8, fn ·b_1:
                ·ƒret_2 ·ƒctx_52, ·b_1
          fn ·v_42:
            ·fn
              fn ·ƒctx_53, ·ƒsucc_5, ·ƒfail_6, ·v_4:
                ·is_seq_like ·ƒctx_53, ·v_4,
                  fn ·ƒctx_55, ·v_21:
                    ·seq_pop ·ƒctx_55, ·v_21, ·ƒfail_6, fn ·ƒctx_57, ·v_7, ·v_22:
                      ·seq_pop ·ƒctx_57, ·v_22, ·ƒfail_6, fn ·ƒctx_59, ·v_8, ·v_13:
                        ·empty ·ƒctx_59, ·v_13, fn ·ƒctx_61, ·v_16:
                          ·if ·v_16,
                            fn: ·ƒsucc_5 ·ƒctx_61, ·v_7, ·v_8
                            fn: ·ƒfail_6 ·ƒctx_61
                  fn ·ƒctx_64: ·ƒfail_6 ·ƒctx_64
              fn ·v_33: ·v_33 ·ƒctx_50, ·v_42, ·panic, ·∅foo
    # sm:


