test 'fn — seq destructuring param', fn:
  expect cps_module ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_57, ·ƒret_2:
      ·fn
        fn ·ƒctx_59, ·ƒret_39, ·v_4:
          ·fn
            fn ·ƒctx_60, ·v_9, ·v_10:
              ·let ·v_9, fn ·a_0:
                ·let ·v_10, fn ·b_1:
                  ·ƒret_39 ·ƒctx_60, ·a_0
            fn ·v_48:
              ·fn
                fn ·ƒctx_62, ·ƒsucc_7, ·ƒfail_8, ·v_6:
                  ·is_seq_like ·ƒctx_62, ·v_6,
                    fn ·ƒctx_64, ·v_23:
                      ·seq_pop ·ƒctx_64, ·v_23, ·ƒfail_8, fn ·ƒctx_66, ·v_9, ·v_24:
                        ·seq_pop ·ƒctx_66, ·v_24, ·ƒfail_8, fn ·ƒctx_68, ·v_10, ·v_15:
                          ·empty ·ƒctx_68, ·v_15, fn ·ƒctx_70, ·v_18:
                            ·if ·v_18,
                              fn: ·ƒsucc_7 ·ƒctx_70, ·v_9, ·v_10
                              fn: ·ƒfail_8 ·ƒctx_70
                    fn ·ƒctx_73: ·ƒfail_8 ·ƒctx_73
                fn ·v_35: ·v_35 ·ƒctx_59, ·v_48, ·panic, ·v_4
        fn ·v_3: ·ƒret_2 ·ƒctx_57, ·v_3
    # sm:

