---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·v_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module, ·import, ·fn,·let, ·export, ·op_plus, ·op_mul, ·is_rec_like, ·rec_pop,
 ·ƒsucc_11, ·ƒfail_12, ·panic, ·ƒpub, i8, ·seq_pop, ·is_seq_like, ·seq_prepend, ·empty, ·if,
 ·rec_put
} = import '@fink/compile/builtins'



test 'single module expr', fn:
  expect cps_module ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, (i8 42)
    # sm:DQABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIUABIABgEAAgABAAIGAQAC


---
single binding
---

test 'single binding export', fn:
  expect cps_module ƒink:
    foo = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_10, ·ƒret_1:
      ·let (i8 1), fn ·foo_0:
        ·ƒpub ·ƒctx_10, ·foo_0, fn ·ƒctx_13:
          ·ƒret_1 ·ƒctx_13, ·foo_0
    # sm:HQABAAcAAQAHJAEABxgBAAcSAAIABgEIAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIACgEAAwABAAMQABQABAEAAw4ACgAUAAIADgEAAwABAAMUABQABAEAAw


test 'single binding export with trailing expr', fn:
  expect cps_module ƒink:
    foo = 1
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_9, ·ƒret_1:
      ·let (i8 1), fn ·foo_0:
        ·ƒpub ·ƒctx_9, ·foo_0, fn ·ƒctx_12:
          ·ƒret_1 ·ƒctx_12, (i8 42)
    # sm:HwABAAoAAQAKJAEAChYBEAISAAIABgEHAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIACgEAAwABAAMQABIABAEAAw4ACgAUAAIADgEQAgABAAIUABQABgEAAgABAAIGAQAC


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·let (i8 1), fn ·foo_0:
        ·ƒpub ·ƒctx_16, ·foo_0, fn ·ƒctx_19:
          ·let (i8 2), fn ·bar_1:
            ·ƒpub ·ƒctx_19, ·bar_1, fn ·ƒctx_21:
              ·ƒret_2 ·ƒctx_21, ·bar_1
    # sm:LwABAA8AAQAPJAEADxgBEAcSAAIABgEHAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIACgEAAwABAAMQABQABAEAAw4ACgAUAAIADgEYAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIAEgEAAwABAAMQABQABAEAAw4ACgAUAAIAFgEAAwABAAMUABQABAEAAw


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·fn
        fn ·ƒctx_39, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_39, ·a_2, ·b_3, ·ƒret_6
        fn ·v_5:
          ·let ·v_5, fn ·add_0:
            ·ƒpub ·ƒctx_37, ·add_0, fn ·ƒctx_42:
              ·fn
                fn ·ƒctx_43, ·ƒret_14: ·add_0 ·ƒctx_43, ·ƒret_14, (i8 3), (i8 4)
                fn ·v_13:
                  ·let ·v_13, fn ·main_1:
                    ·ƒpub ·ƒctx_42, ·main_1, fn ·ƒctx_46:
                      ·ƒret_4 ·ƒctx_46, ·main_1
    # sm:


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn:
      foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_57, ·ƒret_3:
      ·import ·ƒctx_57, './bar.fnk', fn ·ƒctx_60, ·v_6:
        ·fn
          fn ·ƒctx_61, ·v_11:
            ·let ·v_11, fn ·foo_0:
              ·fn
                fn ·ƒctx_62, ·ƒret_29: ·foo_0 ·ƒctx_62, ·ƒret_29, (i8 1)
                fn ·v_28:
                  ·let ·v_28, fn ·main_1:
                    ·ƒpub ·ƒctx_61, ·main_1, fn ·ƒctx_65:
                      ·ƒret_3 ·ƒctx_65, ·main_1
          fn ·v_43:
            ·fn
              fn ·ƒctx_67, ·ƒsucc_9, ·ƒfail_10, ·v_8:
                ·is_rec_like ·ƒctx_67, ·v_8,
                  fn ·ƒctx_69, ·v_16:
                    ·rec_pop ·ƒctx_69, ·v_16, 'foo', ·ƒfail_10, fn ·ƒctx_71, ·v_11, ·v_15:
                      ·ƒsucc_9 ·ƒctx_71, ·v_11
                  fn ·ƒctx_73: ·ƒfail_10 ·ƒctx_73
              fn ·v_25: ·v_25 ·ƒctx_60, ·v_43, ·panic, ·v_6
    # sm:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_75, ·ƒret_3:
      ·seq_prepend ·ƒctx_75, (i8 2), [], fn ·ƒctx_78, ·v_6:
        ·seq_prepend ·ƒctx_78, (i8 1), ·v_6, fn ·ƒctx_80, ·v_9:
          ·fn
            fn ·ƒctx_81, ·v_14, ·v_15:
              ·let ·v_14, fn ·a_0:
                ·let ·v_15, fn ·b_1:
                  ·fn
                    fn ·ƒctx_82, ·ƒret_45: ·ƒret_45 ·ƒctx_82, ·a_0
                    fn ·v_44:
                      ·let ·v_44, fn ·foo_2:
                        ·ƒpub ·ƒctx_81, ·foo_2, fn ·ƒctx_85:
                          ·ƒret_3 ·ƒctx_85, ·foo_2
            fn ·v_59:
              ·fn
                fn ·ƒctx_87, ·ƒsucc_12, ·ƒfail_13, ·v_11:
                  ·is_seq_like ·ƒctx_87, ·v_11,
                    fn ·ƒctx_89, ·v_28:
                      ·seq_pop ·ƒctx_89, ·v_28, ·ƒfail_13, fn ·ƒctx_91, ·v_14, ·v_29:
                        ·seq_pop ·ƒctx_91, ·v_29, ·ƒfail_13, fn ·ƒctx_93, ·v_15, ·v_20:
                          ·empty ·ƒctx_93, ·v_20, fn ·ƒctx_95, ·v_23:
                            ·if ·v_23,
                              fn: ·ƒsucc_12 ·ƒctx_95, ·v_14, ·v_15
                              fn: ·ƒfail_13 ·ƒctx_95
                    fn ·ƒctx_98: ·ƒfail_13 ·ƒctx_98
                fn ·v_40: ·v_40 ·ƒctx_80, ·v_59, ·panic, ·v_9
    # sm:


---
standalone top-level destructures — no trailing binding
---

# These pin the exact CPS shape that lifting fails to converge on.
# Mirrors the 4 failing repros in lifting/test_lifting.fnk.

test 'standalone top-level seq destructure with literal rhs', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_59, ·ƒret_2:
      ·seq_prepend ·ƒctx_59, (i8 2), [], fn ·ƒctx_62, ·v_5:
        ·seq_prepend ·ƒctx_62, (i8 1), ·v_5, fn ·ƒctx_64, ·v_8:
          ·fn
            fn ·ƒctx_65, ·v_13, ·v_14:
              ·let ·v_13, fn ·a_0:
                ·let ·v_14, fn ·b_1:
                  ·ƒret_2 ·ƒctx_65, ·b_1
            fn ·v_48:
              ·fn
                fn ·ƒctx_66, ·ƒsucc_11, ·ƒfail_12, ·v_10:
                  ·is_seq_like ·ƒctx_66, ·v_10,
                    fn ·ƒctx_68, ·v_27:
                      ·seq_pop ·ƒctx_68, ·v_27, ·ƒfail_12, fn ·ƒctx_70, ·v_13, ·v_28:
                        ·seq_pop ·ƒctx_70, ·v_28, ·ƒfail_12, fn ·ƒctx_72, ·v_14, ·v_19:
                          ·empty ·ƒctx_72, ·v_19, fn ·ƒctx_74, ·v_22:
                            ·if ·v_22,
                              fn: ·ƒsucc_11 ·ƒctx_74, ·v_13, ·v_14
                              fn: ·ƒfail_12 ·ƒctx_74
                    fn ·ƒctx_77: ·ƒfail_12 ·ƒctx_77
                fn ·v_39: ·v_39 ·ƒctx_64, ·v_48, ·panic, ·v_8
    # sm:


test 'standalone top-level rec destructure with literal rhs', fn:
  expect cps_module ƒink:
    {x} = {x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_1:
      ·rec_put ·ƒctx_39, {}, 'x', (i8 1), fn ·ƒctx_42, ·v_5:
        ·fn
          fn ·ƒctx_43, ·v_10:
            ·let ·v_10, fn ·x_0:
              ·ƒret_1 ·ƒctx_43, ·x_0
          fn ·v_30:
            ·fn
              fn ·ƒctx_44, ·ƒsucc_8, ·ƒfail_9, ·v_7:
                ·is_rec_like ·ƒctx_44, ·v_7,
                  fn ·ƒctx_46, ·v_15:
                    ·rec_pop ·ƒctx_46, ·v_15, 'x', ·ƒfail_9, fn ·ƒctx_48, ·v_10, ·v_14:
                      ·ƒsucc_8 ·ƒctx_48, ·v_10
                  fn ·ƒctx_50: ·ƒfail_9 ·ƒctx_50
              fn ·v_24: ·v_24 ·ƒctx_42, ·v_30, ·panic, ·v_5
    # sm:


test 'standalone top-level destructure with call rhs', fn:
  expect cps_module ƒink:
    [a, b] = some_call x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_54, ·ƒret_2:
      ·∅some_call
        ·ƒctx_54
        fn ·ƒctx_57, ·v_5:
          ·fn
            fn ·ƒctx_58, ·v_10, ·v_11:
              ·let ·v_10, fn ·a_0:
                ·let ·v_11, fn ·b_1:
                  ·ƒret_2 ·ƒctx_58, ·b_1
            fn ·v_45:
              ·fn
                fn ·ƒctx_59, ·ƒsucc_8, ·ƒfail_9, ·v_7:
                  ·is_seq_like ·ƒctx_59, ·v_7,
                    fn ·ƒctx_61, ·v_24:
                      ·seq_pop ·ƒctx_61, ·v_24, ·ƒfail_9, fn ·ƒctx_63, ·v_10, ·v_25:
                        ·seq_pop ·ƒctx_63, ·v_25, ·ƒfail_9, fn ·ƒctx_65, ·v_11, ·v_16:
                          ·empty ·ƒctx_65, ·v_16, fn ·ƒctx_67, ·v_19:
                            ·if ·v_19,
                              fn: ·ƒsucc_8 ·ƒctx_67, ·v_10, ·v_11
                              fn: ·ƒfail_9 ·ƒctx_67
                    fn ·ƒctx_70: ·ƒfail_9 ·ƒctx_70
                fn ·v_36: ·v_36 ·ƒctx_57, ·v_45, ·panic, ·v_5
        ·∅x
    # sm:


test 'standalone top-level destructure with import rhs', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_2:
      ·import ·ƒctx_39, './bar.fnk', fn ·ƒctx_42, ·v_5:
        ·fn
          fn ·ƒctx_43, ·v_10:
            ·let ·v_10, fn ·foo_0:
              ·ƒret_2 ·ƒctx_43, ·foo_0
          fn ·v_30:
            ·fn
              fn ·ƒctx_44, ·ƒsucc_8, ·ƒfail_9, ·v_7:
                ·is_rec_like ·ƒctx_44, ·v_7,
                  fn ·ƒctx_46, ·v_15:
                    ·rec_pop ·ƒctx_46, ·v_15, 'foo', ·ƒfail_9, fn ·ƒctx_48, ·v_10, ·v_14:
                      ·ƒsucc_8 ·ƒctx_48, ·v_10
                  fn ·ƒctx_50: ·ƒfail_9 ·ƒctx_50
              fn ·v_24: ·v_24 ·ƒctx_42, ·v_30, ·panic, ·v_5
    # sm:


---
·export should only carry binding names — call args must not leak in.
Repro for the fooobar bug: module with multiple top-level fns + calls
whose results are bound to names. Yesterday the ·export terminal was
rendered as `·export ·add_0, ·s_1, ·mul_2, ·p_3, ·s_1, 3, 1, 2` — the
trailing `·s_1, 3, 1, 2` are args from the two call sites leaking in.
---

test 'export args do not leak call args', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      ni = a * b
      ni

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_68, ·ƒret_9:
      ·fn
        fn ·ƒctx_70, ·ƒret_11, ·a_4, ·b_5: ·op_plus ·ƒctx_70, ·a_4, ·b_5, ·ƒret_11
        fn ·v_10:
          ·let ·v_10, fn ·add_0:
            ·ƒpub ·ƒctx_68, ·add_0, fn ·ƒctx_73:
              ·add_0
                ·ƒctx_73
                fn ·ƒctx_75, ·v_21:
                  ·let ·v_21, fn ·s_1:
                    ·ƒpub ·ƒctx_75, ·s_1, fn ·ƒctx_77:
                      ·fn
                        fn ·ƒctx_78, ·ƒret_24, ·a_6, ·b_7:
                          ·op_mul ·ƒctx_78, ·a_6, ·b_7, fn ·ƒctx_80, ·v_27:
                            ·let ·v_27, fn ·ni_8:
                              ·ƒret_24 ·ƒctx_80, ·ni_8
                        fn ·v_23:
                          ·let ·v_23, fn ·mul_2:
                            ·ƒpub ·ƒctx_77, ·mul_2, fn ·ƒctx_83:
                              ·mul_2
                                ·ƒctx_83
                                fn ·ƒctx_85, ·v_39:
                                  ·let ·v_39, fn ·p_3:
                                    ·ƒpub ·ƒctx_85, ·p_3, fn ·ƒctx_87:
                                      ·ƒret_9 ·ƒctx_87, ·p_3
                                ·s_1
                                i8 3
                i8 1
                i8 2
    # sm:


