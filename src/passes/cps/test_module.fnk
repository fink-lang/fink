---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·v_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'
{·module_init, ·import, ·fn,·let, ·export, ·op_plus, ·is_rec_like, ·rec_pop,
 ·ƒsucc_11, ·ƒfail_12, ·panic
} = import '@fink/compile/builtins'

---
single binding
---

test 'single binding export', fn:
  expect cps_module ƒink:
    foo = 1
  | equals ƒink:
    ·fn
      fn:
        ·let 1, fn ·foo_0:
          ·export ·foo_0
      fn ·v_7: ·module_init ·v_7
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMSJdLAogICJtYXBwaW5ncyI6ICJBLEE7STtJQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtNLEEsUUFBQTtLLEksRSxBLGEiCn0=


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·fn
      fn:
        ·let 1, fn ·foo_0:
          ·let 2, fn ·bar_1:
            ·export ·foo_0, ·bar_1
      fn ·v_12: ·module_init ·v_12
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuYmFyID0gMiJdLAogICJtYXBwaW5ncyI6ICJBLEE7STtJQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtNQUNJLEFBQUEsS0FBRSxDLEtBQU4sTTtRLEEsUUFEQSxNLEVBQ0E7SyxLLEUsQSxhIgp9


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·fn
      fn:
        ·fn
          fn ·ƒret_9, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_9
          fn ·v_8:
            ·let ·v_8, fn ·add_0:
              ·fn
                fn ·ƒret_17: ·add_0 ·ƒret_17, 3, 4
                fn ·v_16:
                  ·let ·v_16, fn ·main_1:
                    ·export ·add_0, ·main_1
      fn ·v_33: ·module_init ·v_33
    #sourcemaps:


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn: foo 1
  | equals ƒink:
    ·fn
      fn:
        ·import './bar.fnk', fn ·v_8:
          ·fn
            fn ·v_13:
              ·let ·v_13, fn ·foo_0:
                ·fn
                  fn ·ƒret_31: ·foo_0 ·ƒret_31, 1
                  fn ·v_30:
                    ·let ·v_30, fn ·main_1:
                      ·export ·main_1
            fn ·v_45:
              ·fn
                fn ·ƒsucc_11, ·ƒfail_12, ·v_10:
                  ·is_rec_like ·v_10,
                    fn ·v_18:
                      ·rec_pop ·v_18, 'foo', ·ƒfail_12, fn ·v_13, ·v_17:
                        ·ƒsucc_11 ·v_13
                    fn: ·ƒfail_12 _
                fn ·v_27: ·v_27 ·v_45, ·panic, ·v_8
      fn ·v_54: ·module_init ·v_54
    #sourcemaps:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·fn
      fn:
        ·seq_prepend 2, [], fn ·v_8:
          ·seq_prepend 1, ·v_8, fn ·v_11:
            ·fn
              fn ·v_16, ·v_17:
                ·let ·v_16, fn ·a_0:
                  ·let ·v_17, fn ·b_1:
                    ·fn
                      fn ·ƒret_47: ·ƒret_47 ·a_0
                      fn ·v_46:
                        ·let ·v_46, fn ·foo_2:
                          ·export ·foo_2
              fn ·v_61:
                ·fn
                  fn ·ƒsucc_14, ·ƒfail_15, ·v_13:
                    ·is_seq_like ·v_13,
                      fn ·v_30:
                        ·seq_pop ·v_30, ·ƒfail_15, fn ·v_16, ·v_31:
                          ·seq_pop ·v_31, ·ƒfail_15, fn ·v_17, ·v_22:
                            ·empty ·v_22, fn ·v_25:
                              ·if ·v_25,
                                fn: ·ƒsucc_14 ·v_16, ·v_17
                                fn: ·ƒfail_15 _
                      fn: ·ƒfail_15 _
                  fn ·v_42: ·v_42 ·v_61, ·panic, ·v_11
      fn ·v_72: ·module_init ·v_72
    #sourcemaps:


---
standalone top-level destructures — no trailing binding
---

# These pin the exact CPS shape that lifting fails to converge on.
# Mirrors the 4 failing repros in lifting/test_lifting.fnk.

test 'standalone top-level seq destructure with literal rhs', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·fn
      fn:
        ·seq_prepend 2, [], fn ·v_6:
          ·seq_prepend 1, ·v_6, fn ·v_9:
            ·fn
              fn ·v_14, ·v_15:
                ·let ·v_14, fn ·a_0:
                  ·let ·v_15, fn ·b_1:
                    ·export _
              fn ·v_49:
                ·fn
                  fn ·ƒsucc_12, ·ƒfail_13, ·v_11:
                    ·is_seq_like ·v_11,
                      fn ·v_28:
                        ·seq_pop ·v_28, ·ƒfail_13, fn ·v_14, ·v_29:
                          ·seq_pop ·v_29, ·ƒfail_13, fn ·v_15, ·v_20:
                            ·empty ·v_20, fn ·v_23:
                              ·if ·v_23,
                                fn: ·ƒsucc_12 ·v_14, ·v_15
                                fn: ·ƒfail_13 _
                      fn: ·ƒfail_13 _
                  fn ·v_40: ·v_40 ·v_49, ·panic, ·v_9
      fn ·v_60: ·module_init ·v_60
    #sourcemaps:


test 'standalone top-level rec destructure with literal rhs', fn:
  expect cps_module ƒink:
    {x} = {x: 1}
  | equals ƒink:
    ·fn
      fn:
        ·rec_put {}, 'x', 1, fn ·v_6:
          ·fn
            fn ·v_11:
              ·let ·v_11, fn ·x_0:
                ·export _
            fn ·v_31:
              ·fn
                fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                  ·is_rec_like ·v_8,
                    fn ·v_16:
                      ·rec_pop ·v_16, 'x', ·ƒfail_10, fn ·v_11, ·v_15:
                        ·ƒsucc_9 ·v_11
                    fn: ·ƒfail_10 _
                fn ·v_25: ·v_25 ·v_31, ·panic, ·v_6
      fn ·v_40: ·module_init ·v_40
    #sourcemaps:


test 'standalone top-level destructure with call rhs', fn:
  expect cps_module ƒink:
    [a, b] = some_call x
  | equals ƒink:
    ·fn
      fn:
        ·∅some_call fn ·v_6:
          ·fn
            fn ·v_11, ·v_12:
              ·let ·v_11, fn ·a_0:
                ·let ·v_12, fn ·b_1:
                  ·export _
            fn ·v_46:
              ·fn
                fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                  ·is_seq_like ·v_8,
                    fn ·v_25:
                      ·seq_pop ·v_25, ·ƒfail_10, fn ·v_11, ·v_26:
                        ·seq_pop ·v_26, ·ƒfail_10, fn ·v_12, ·v_17:
                          ·empty ·v_17, fn ·v_20:
                            ·if ·v_20,
                              fn: ·ƒsucc_9 ·v_11, ·v_12
                              fn: ·ƒfail_10 _
                    fn: ·ƒfail_10 _
                fn ·v_37: ·v_37 ·v_46, ·panic, ·v_6, ·∅x
      fn ·v_55: ·module_init ·v_55
    #sourcemaps:


test 'standalone top-level destructure with import rhs', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
  | equals ƒink:
    ·fn
      fn:
        ·import './bar.fnk', fn ·v_6:
          ·fn
            fn ·v_11:
              ·let ·v_11, fn ·foo_0:
                ·export _
            fn ·v_31:
              ·fn
                fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                  ·is_rec_like ·v_8,
                    fn ·v_16:
                      ·rec_pop ·v_16, 'foo', ·ƒfail_10, fn ·v_11, ·v_15:
                        ·ƒsucc_9 ·v_11
                    fn: ·ƒfail_10 _
                fn ·v_25: ·v_25 ·v_31, ·panic, ·v_6
      fn ·v_40: ·module_init ·v_40
    #sourcemaps:

