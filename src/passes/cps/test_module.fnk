test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·foo_0, (i8 1), fn:
          ·ƒpub ·ƒctx_17, ·foo_0, fn ·ƒctx_20:
            ·set ·bar_1, (i8 2), fn:
              ·ƒpub ·ƒctx_20, ·bar_1, fn ·ƒctx_22:
                ·ƒret_2 ·ƒctx_22, ·bar_1
    # sm:NwABAA8AAQAPJAEADxgBEAcSAAIABgEPDwABAA8YAQADEgEQAw4AAgAKAQ8HAAEABwwBAAMOAAYBDAEAAQABBgEAAQQACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBEAcAAQAHDAEAAw4ABgEMAQABAAEGAQABBAAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEAAwABAAMUABQABAEAAw


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_38, ·ƒret_4:
      ·letrec fn ·add_0, ·main_1:
        ·fn
          fn ·ƒctx_40, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_40, ·a_2, ·b_3, ·ƒret_6
          fn ·v_5:
            ·set ·add_0, ·v_5, fn:
              ·ƒpub ·ƒctx_38, ·add_0, fn ·ƒctx_43:
                ·fn
                  fn ·ƒctx_44, ·ƒret_14: ·add_0 ·ƒctx_44, ·ƒret_14, (i8 3), (i8 4)
                  fn ·v_13:
                    ·set ·main_1, ·v_13, fn:
                      ·ƒpub ·ƒctx_43, ·main_1, fn ·ƒctx_47:
                        ·ƒret_4 ·ƒctx_47, ·main_1
    # sm:XwABAC0AAQAtJAEALRgBMBUSAAIABgEvLQABAC0YAQADEgEwBBAAAgAKASMQAAEAEAgAFAAYARYFFgEPAQ4BBgEKAAQBCgUAAQAFFAAUAAQBAAEKAAQBCAEKAAQBBwUSABQBFRAKAAIAEgELFgABABYMAQADDgAEAQwQCgAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgE-DgABAA4IACQAGAEMCBQABAEACAABAAMQABQABAEACBQABgEIAQABAAEGAQABBAAGAQYBAAEAAQYBAAEEACQBGQ4MAAIAIgENFQABABUMAQAEEAAEAQ4ODAAIAAIAJgENBAABAAQQABQABAEABBAACgAUAAIAKgEABAABAAQUABQABAEABA


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn:
      foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_3:
      ·letrec fn ·main_1:
        ·import ·ƒctx_58, './bar.fnk', fn ·ƒctx_61, ·v_6:
          ·fn
            fn ·ƒctx_62, ·v_11:
              ·let ·v_11, fn ·foo_0:
                ·fn
                  fn ·ƒctx_63, ·ƒret_29: ·foo_0 ·ƒctx_63, ·ƒret_29, (i8 1)
                  fn ·v_28:
                    ·let ·v_28, fn ·main_1:
                      ·ƒpub ·ƒctx_62, ·main_1, fn ·ƒctx_66:
                        ·ƒret_3 ·ƒctx_66, ·main_1
            fn ·v_43:
              ·fn
                fn ·ƒctx_68, ·ƒsucc_9, ·ƒfail_10, ·v_8:
                  ·is_rec_like ·ƒctx_68, ·v_8,
                    fn ·ƒctx_70, ·v_16:
                      ·rec_pop ·ƒctx_70, ·v_16, 'foo', ·ƒfail_10, fn ·ƒctx_72, ·v_11, ·v_15:
                        ·ƒsucc_9 ·ƒctx_72, ·v_11
                    fn ·ƒctx_74: ·ƒfail_10 ·ƒctx_74
                fn ·v_25: ·v_25 ·ƒctx_61, ·v_43, ·panic, ·v_6
    # sm:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_76, ·ƒret_3:
      ·letrec fn ·a_0, ·b_1, ·foo_2:
        ·seq_prepend ·ƒctx_76, (i8 2), [], fn ·ƒctx_79, ·v_6:
          ·seq_prepend ·ƒctx_79, (i8 1), ·v_6, fn ·ƒctx_81, ·v_9:
            ·fn
              fn ·ƒctx_82, ·v_14, ·v_15:
                ·let ·v_14, fn ·a_0:
                  ·let ·v_15, fn ·b_1:
                    ·fn
                      fn ·ƒctx_83, ·ƒret_45: ·ƒret_45 ·ƒctx_83, ·a_0
                      fn ·v_44:
                        ·let ·v_44, fn ·foo_2:
                          ·ƒpub ·ƒctx_82, ·foo_2, fn ·ƒctx_86:
                            ·ƒret_3 ·ƒctx_86, ·foo_2
              fn ·v_59:
                ·fn
                  fn ·ƒctx_88, ·ƒsucc_12, ·ƒfail_13, ·v_11:
                    ·is_seq_like ·ƒctx_88, ·v_11,
                      fn ·ƒctx_90, ·v_28:
                        ·seq_pop ·ƒctx_90, ·v_28, ·ƒfail_13, fn ·ƒctx_92, ·v_14, ·v_29:
                          ·seq_pop ·ƒctx_92, ·v_29, ·ƒfail_13, fn ·ƒctx_94, ·v_15, ·v_20:
                            ·empty ·ƒctx_94, ·v_20, fn ·ƒctx_96, ·v_23:
                              ·if ·v_23,
                                fn: ·ƒsucc_12 ·ƒctx_96, ·v_14, ·v_15
                                fn: ·ƒfail_13 ·ƒctx_96
                      fn ·ƒctx_99: ·ƒfail_13 ·ƒctx_99
                  fn ·v_40: ·v_40 ·ƒctx_81, ·v_59, ·panic, ·v_9
    # sm:


---
standalone top-level destructures — no trailing binding
---

# These pin the exact CPS shape that lifting fails to converge on.
# Mirrors the 4 failing repros in lifting/test_lifting.fnk.

test 'standalone top-level seq destructure with literal rhs', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_60, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·seq_prepend ·ƒctx_60, (i8 2), [], fn ·ƒctx_63, ·v_5:
          ·seq_prepend ·ƒctx_63, (i8 1), ·v_5, fn ·ƒctx_65, ·v_8:
            ·fn
              fn ·ƒctx_66, ·v_13, ·v_14:
                ·let ·v_13, fn ·a_0:
                  ·let ·v_14, fn ·b_1:
                    ·ƒret_2 ·ƒctx_66, ·b_1
              fn ·v_48:
                ·fn
                  fn ·ƒctx_67, ·ƒsucc_11, ·ƒfail_12, ·v_10:
                    ·is_seq_like ·ƒctx_67, ·v_10,
                      fn ·ƒctx_69, ·v_27:
                        ·seq_pop ·ƒctx_69, ·v_27, ·ƒfail_12, fn ·ƒctx_71, ·v_13, ·v_28:
                          ·seq_pop ·ƒctx_71, ·v_28, ·ƒfail_12, fn ·ƒctx_73, ·v_14, ·v_19:
                            ·empty ·ƒctx_73, ·v_19, fn ·ƒctx_75, ·v_22:
                              ·if ·v_22,
                                fn: ·ƒsucc_11 ·ƒctx_75, ·v_13, ·v_14
                                fn: ·ƒfail_12 ·ƒctx_75
                      fn ·ƒctx_78: ·ƒfail_12 ·ƒctx_78
                  fn ·v_39: ·v_39 ·ƒctx_65, ·v_48, ·panic, ·v_8
    # sm:-AAQBAA8AAQAPGAAUAAQBAA8MAAQBAA8MAD4ABAEADwABAA8YABQALAAUAAQBAA8AAQAPGAAUACQBAA8MAAQBAA8AAQAPDgAUAAQBAA8MAAQBAA8OAAQBFAE


