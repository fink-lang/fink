test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·foo_0, (i8 1), fn:
          ·ƒpub ·ƒctx_17, ·foo_0, fn ·ƒctx_20:
            ·set ·bar_1, (i8 2), fn:
              ·ƒpub ·ƒctx_20, ·bar_1, fn ·ƒctx_22:
                ·ƒret_2 ·ƒctx_22, ·bar_1
    # sm:NwABAA8AAQAPJAEADxgBEAcSAAIABgEPDwABAA8YAQADEgEQAw4AAgAKAQ8HAAEABwwBAAMOAAYBDAEAAQABBgEAAQQACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBEAcAAQAHDAEAAw4ABgEMAQABAAEGAQABBAAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEAAwABAAMUABQABAEAAw


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_38, ·ƒret_4:
      ·letrec fn ·add_0, ·main_1:
        ·fn
          fn ·ƒctx_40, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_40, ·a_2, ·b_3, ·ƒret_6
          fn ·ƒv_5:
            ·set ·add_0, ·ƒv_5, fn:
              ·ƒpub ·ƒctx_38, ·add_0, fn ·ƒctx_43:
                ·fn
                  fn ·ƒctx_44, ·ƒret_14: ·add_0 ·ƒctx_44, ·ƒret_14, (i8 3), (i8 4)
                  fn ·ƒv_13:
                    ·set ·main_1, ·ƒv_13, fn:
                      ·ƒpub ·ƒctx_43, ·main_1, fn ·ƒctx_47:
                        ·ƒret_4 ·ƒctx_47, ·main_1
    # sm:XwABAC0AAQAtJAEALRgBMBUSAAIABgEvLQABAC0YAQADEgEwBBAAAgAKASMQAAEAEAgAFAAYARYFFgEPAQ4BBgEKAAQBCgUAAQAFFAAUAAQBAAEKAAQBCAEKAAQBBwUSABQBFRAOAAIAEgELFgABABYMAQADDgAEAQwQDgAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgE-DgABAA4IACQAGAEMCBQABAEACAABAAMQABQABAEACBQABgEIAQABAAEGAQABBAAGAQYBAAEAAQYBAAEEACQBGQ4QAAIAIgENFQABABUMAQAEEAAEAQ4OEAAIAAIAJgENBAABAAQQABQABAEABBAACgAUAAIAKgEABAABAAQUABQABAEABA


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn:
      foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_62, ·ƒret_3:
      ·letrec fn ·main_1:
        ·import ·ƒctx_62, './bar.fnk', fn ·ƒctx_65, ·ƒv_6:
          ·fn
            fn ·ƒctx_66, ·ƒv_11:
              ·let ·ƒv_11, fn ·foo_0:
                ·fn
                  fn ·ƒctx_67, ·ƒret_30: ·foo_0 ·ƒctx_67, ·ƒret_30, (i8 1)
                  fn ·ƒv_29:
                    ·let ·ƒv_29, fn ·main_1:
                      ·ƒpub ·ƒctx_66, ·main_1, fn ·ƒctx_70:
                        ·ƒret_3 ·ƒctx_70, ·main_1
            fn ·ƒv_44:
              ·fn
                fn ·ƒctx_72, ·ƒsucc_9, ·ƒfail_10, ·ƒv_8:
                  ·guard_apply ·ƒctx_72, ·rec_protocol, ·ƒv_8,
                    fn ·ƒctx_74, ·ƒv_16:
                      ·rec_pop ·ƒctx_74, ·ƒv_16, 'foo', ·ƒfail_10, fn ·ƒctx_76, ·ƒv_11, ·ƒv_15:
                        ·ƒsucc_9 ·ƒctx_76, ·ƒv_11
                    fn ·ƒctx_78: ·ƒfail_10 ·ƒctx_78
                fn ·ƒv_26:
                  ·fn
                    fn ·ƒctx_80: ·panic ·ƒctx_80
                    fn ·ƒv_47: ·ƒv_26 ·ƒctx_65, ·ƒv_44, ·ƒv_47, ·ƒv_6
    # sm:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_80, ·ƒret_3:
      ·letrec fn ·a_0, ·b_1, ·foo_2:
        ·seq_prepend ·ƒctx_80, (i8 2), [], fn ·ƒctx_83, ·ƒv_7:
          ·seq_prepend ·ƒctx_83, (i8 1), ·ƒv_7, fn ·ƒctx_85, ·ƒv_9:
            ·fn
              fn ·ƒctx_86, ·ƒv_14, ·ƒv_15:
                ·let ·ƒv_14, fn ·a_0:
                  ·let ·ƒv_15, fn ·b_1:
                    ·fn
                      fn ·ƒctx_87, ·ƒret_46: ·ƒret_46 ·ƒctx_87, ·a_0
                      fn ·ƒv_45:
                        ·let ·ƒv_45, fn ·foo_2:
                          ·ƒpub ·ƒctx_86, ·foo_2, fn ·ƒctx_90:
                            ·ƒret_3 ·ƒctx_90, ·foo_2
              fn ·ƒv_60:
                ·fn
                  fn ·ƒctx_92, ·ƒsucc_12, ·ƒfail_13, ·ƒv_11:
                    ·guard_apply ·ƒctx_92, ·tuple_protocol, ·ƒv_11,
                      fn ·ƒctx_94, ·ƒv_28:
                        ·seq_pop ·ƒctx_94, ·ƒv_28, ·ƒfail_13, fn ·ƒctx_96, ·ƒv_14, ·ƒv_29:
                          ·seq_pop ·ƒctx_96, ·ƒv_29, ·ƒfail_13, fn ·ƒctx_98, ·ƒv_15, ·ƒv_20:
                            ·empty ·ƒctx_98, ·ƒv_20, fn ·ƒctx_100, ·ƒv_23:
                              ·if ·ƒv_23,
                                fn: ·ƒsucc_12 ·ƒctx_100, ·ƒv_14, ·ƒv_15
                                fn: ·ƒfail_13 ·ƒctx_100
                      fn ·ƒctx_103: ·ƒfail_13 ·ƒctx_103
                  fn ·ƒv_41:
                    ·fn
                      fn ·ƒctx_105: ·panic ·ƒctx_105
                      fn ·ƒv_63: ·ƒv_41 ·ƒctx_85, ·ƒv_60, ·ƒv_63, ·ƒv_9
    # sm:


---
standalone top-level destructures — no trailing binding
---

# These pin the exact CPS shape that lifting fails to converge on.
# Mirrors the 4 failing repros in lifting/test_lifting.fnk.

test 'standalone top-level seq destructure with literal rhs', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_64, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·seq_prepend ·ƒctx_64, (i8 2), [], fn ·ƒctx_67, ·ƒv_6:
          ·seq_prepend ·ƒctx_67, (i8 1), ·ƒv_6, fn ·ƒctx_69, ·ƒv_8:
            ·fn
              fn ·ƒctx_70, ·ƒv_13, ·ƒv_14:
                ·let ·ƒv_13, fn ·a_0:
                  ·let ·ƒv_14, fn ·b_1:
                    ·ƒret_2 ·ƒctx_70, ·b_1
              fn ·ƒv_49:
                ·fn
                  fn ·ƒctx_71, ·ƒsucc_11, ·ƒfail_12, ·ƒv_10:
                    ·guard_apply ·ƒctx_71, ·tuple_protocol, ·ƒv_10,
                      fn ·ƒctx_73, ·ƒv_27:
                        ·seq_pop ·ƒctx_73, ·ƒv_27, ·ƒfail_12, fn ·ƒctx_75, ·ƒv_13, ·ƒv_28:
                          ·seq_pop ·ƒctx_75, ·ƒv_28, ·ƒfail_12, fn ·ƒctx_77, ·ƒv_14, ·ƒv_19:
                            ·empty ·ƒctx_77, ·ƒv_19, fn ·ƒctx_79, ·ƒv_22:
                              ·if ·ƒv_22,
                                fn: ·ƒsucc_11 ·ƒctx_79, ·ƒv_13, ·ƒv_14
                                fn: ·ƒfail_12 ·ƒctx_79
                      fn ·ƒctx_82: ·ƒfail_12 ·ƒctx_82
                  fn ·ƒv_40:
                    ·fn
                      fn ·ƒctx_84: ·panic ·ƒctx_84
                      fn ·ƒv_52: ·ƒv_40 ·ƒctx_69, ·ƒv_49, ·ƒv_52, ·ƒv_8
    # sm:-AAQBAA8AAQAPGAAUAAQBAA8QAAQBAA8QAD4ABAEADwABAA8YABQALAAUAAQBAA8AAQAPGAAUACQBAA8QAAIAIgEADwABAA8IACwAFAAEAQAPAAEADxAAFAAsAQAPEAAEAQAPAAEADxIAFAAEAQAPEAAEAQAPEAAEARQB


