    {x} = {x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_40, ·ƒret_1:
      ·letrec fn ·x_0:
        ·rec_put ·ƒctx_40, {}, 'x', (i8 1), fn ·ƒctx_43, ·v_5:
          ·fn
            fn ·ƒctx_44, ·v_10:
              ·let ·v_10, fn ·x_0:
                ·ƒret_1 ·ƒctx_44, ·x_0
            fn ·v_30:
              ·fn
                fn ·ƒctx_45, ·ƒsucc_8, ·ƒfail_9, ·v_7:
                  ·is_rec_like ·ƒctx_45, ·v_7,
                    fn ·ƒctx_47, ·v_15:
                      ·rec_pop ·ƒctx_47, ·v_15, 'x', ·ƒfail_9, fn ·ƒctx_49, ·v_10, ·v_14:
                        ·ƒsucc_8 ·ƒctx_49, ·v_10
                    fn ·ƒctx_51: ·ƒfail_9 ·ƒctx_51
                fn ·v_24: ·v_24 ·ƒctx_43, ·v_30, ·panic, ·v_5
    # sm:


