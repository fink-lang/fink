              ·fn
                fn ·ƒctx_49, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                  ·guard_apply ·ƒctx_49, ·rec_protocol, ·ƒv_7,
                    fn ·ƒctx_51, ·ƒv_15:
                      ·rec_pop ·ƒctx_51, ·ƒv_15, 'x', ·ƒfail_9, fn ·ƒctx_53, ·ƒv_10, ·ƒv_14:
                        ·ƒsucc_8 ·ƒctx_53, ·ƒv_10
                    fn ·ƒctx_55: ·ƒfail_9 ·ƒctx_55
                fn ·ƒv_25:
                  ·fn
                    fn ·ƒctx_57: ·panic ·ƒctx_57
                    fn ·ƒv_34: ·ƒv_25 ·ƒctx_47, ·ƒv_31, ·ƒv_34, ·ƒv_5
    # sm:


