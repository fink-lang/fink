---
module-level CPS — lower_module produces flat chain + export terminal
---

# Module CPS: flat LetFn/LetVal chain ending with ·v_0 ·export_0, ·export_1, ...
# No outer ·fn wrapper. Only simple name = expr bindings are exported.
# Pattern destructures and imports are excluded from exports.
#
# Test format:
#   test 'name', fn:
#     expect cps_module ƒink:
#       <fink source>
#     | equals ƒink:
#       <expected cps output>

{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module, ·import, ·fn,·let, ·export, ·op_plus, ·op_mul, ·is_rec_like, ·rec_pop,
 ·ƒsucc_11, ·ƒfail_12, ·panic
} = import '@fink/compile/builtins'



test 'single module expr', fn:
  expect cps_module ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 42
    # sm:CAABAAIAAQACJAEAAhIAAgAGAQACAAEAAhQBAAI


---
single binding
---

test 'single binding export', fn:
  expect cps_module ƒink:
    foo = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·ƒret_1 ·foo_0
    # sm:FQABAAcAAQAHJAEABxIAAgAGAQgBAAEAAQwBBAECAAoBCwMOAAIACgEAAwABAAMQAQADDgAIAAIADgEAAwABAAMUAQAD


test 'single binding export with trailing expr', fn:
  expect cps_module ƒink:
    foo = 1
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·ƒret_1 42
    # sm:FQABAAoAAQAKJAEQAhIAAgAGAQcBAAEAAQwBBAECAAoBCwMOAAIACgEAAwABAAMQAQADDgAIAAIADgEQAgABAAIUAQAC


---
multiple bindings
---

test 'two bindings export', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·let 2, fn ·bar_1:
            ·ƒpub ·bar_1, fn:
              ·ƒret_2 ·bar_1
    # sm:IgABAA8AAQAPJAEQBxIAAgAGAQcBAAEAAQwBBAECAAoBCwMOAAIACgEAAwABAAMQAQADDgAIAAIADgEYAQABAAEMAQQBAgAKAQsDDgACABIBAAMAAQADEAEAAw4ACAACABYBAAMAAQADFAEAAw


test 'two fns export', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·fn
        fn ·ƒret_6, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_6
        fn ·v_5:
          ·let ·v_5, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·fn
                fn ·ƒret_14: ·add_0 ·ƒret_14, 3, 4
                fn ·v_13:
                  ·let ·v_13, fn ·main_1:
                    ·ƒpub ·main_1, fn:
                      ·ƒret_4 ·main_1
    # sm:RAABAC0AAQAtJAEwFRIAAgAGASMQAAEAEAgAEAEWBRYBDwEOAQYBCgAEAQoFAAEABRQBAAEKAAQBCAEKAAQBBwUSABABFRAKAAIADgEDAQABAAEMAQQQCgAKAQsDDgACABIBAAMAAQADEAEAAw4ACAACABYBPg4AAQAOCAAgAQwIFAAEAQAIAAEAAxABAAgUAAQBCAECAAQBBgECACABGQ4MAAIAHgEDAQABAAEMAQQODAAKAQ0EEAACACIBAAQAAQAEEAEABBAACAACACYBAAQAAQAEFAEABA


---
imports excluded from exports
---

test 'import not in exports', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn: foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·import './bar.fnk', fn ·v_6:
        ·fn
          fn ·v_11:
            ·let ·v_11, fn ·foo_0:
              ·fn
                fn ·ƒret_29: ·foo_0 ·ƒret_29, 1
                fn ·v_28:
                  ·let ·v_28, fn ·main_1:
                    ·ƒpub ·main_1, fn:
                      ·ƒret_3 ·main_1
          fn ·v_43:
            ·fn
              fn ·ƒsucc_9, ·ƒfail_10, ·v_8:
                ·is_rec_like ·v_8,
                  fn ·v_16:
                    ·rec_pop ·v_16, 'foo', ·ƒfail_10, fn ·v_11, ·v_15:
                      ·ƒsucc_9 ·v_11
                  fn: ·ƒfail_10 _
              fn ·v_25: ·v_25 ·v_43, ·panic, ·v_6
    # sm:


---
pattern bindings excluded from exports
---

test 'destructure not in exports', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
    foo = fn: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·seq_prepend 2, [], fn ·v_6:
        ·seq_prepend 1, ·v_6, fn ·v_9:
          ·fn
            fn ·v_14, ·v_15:
              ·let ·v_14, fn ·a_0:
                ·let ·v_15, fn ·b_1:
                  ·fn
                    fn ·ƒret_45: ·ƒret_45 ·a_0
                    fn ·v_44:
                      ·let ·v_44, fn ·foo_2:
                        ·ƒpub ·foo_2, fn:
                          ·ƒret_3 ·foo_2
            fn ·v_59:
              ·fn
                fn ·ƒsucc_12, ·ƒfail_13, ·v_11:
                  ·is_seq_like ·v_11,
                    fn ·v_28:
                      ·seq_pop ·v_28, ·ƒfail_13, fn ·v_14, ·v_29:
                        ·seq_pop ·v_29, ·ƒfail_13, fn ·v_15, ·v_20:
                          ·empty ·v_20, fn ·v_23:
                            ·if ·v_23,
                              fn: ·ƒsucc_12 ·v_14, ·v_15
                              fn: ·ƒfail_13 _
                    fn: ·ƒfail_13 _
                fn ·v_40: ·v_40 ·v_59, ·panic, ·v_9
    # sm:


---
standalone top-level destructures — no trailing binding
---

# These pin the exact CPS shape that lifting fails to converge on.
# Mirrors the 4 failing repros in lifting/test_lifting.fnk.

test 'standalone top-level seq destructure with literal rhs', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·seq_prepend 2, [], fn ·v_5:
        ·seq_prepend 1, ·v_5, fn ·v_8:
          ·fn
            fn ·v_13, ·v_14:
              ·let ·v_13, fn ·a_0:
                ·let ·v_14, fn ·b_1:
                  ·ƒret_2 ·b_1
            fn ·v_48:
              ·fn
                fn ·ƒsucc_11, ·ƒfail_12, ·v_10:
                  ·is_seq_like ·v_10,
                    fn ·v_27:
                      ·seq_pop ·v_27, ·ƒfail_12, fn ·v_13, ·v_28:
                        ·seq_pop ·v_28, ·ƒfail_12, fn ·v_14, ·v_19:
                          ·empty ·v_19, fn ·v_22:
                            ·if ·v_22,
                              fn: ·ƒsucc_11 ·v_13, ·v_14
                              fn: ·ƒfail_12 _
                    fn: ·ƒfail_12 _
                fn ·v_39: ·v_39 ·v_48, ·panic, ·v_8
    # sm:


test 'standalone top-level rec destructure with literal rhs', fn:
  expect cps_module ƒink:
    {x} = {x: 1}
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·rec_put {}, 'x', 1, fn ·v_5:
        ·fn
          fn ·v_10:
            ·let ·v_10, fn ·x_0:
              ·ƒret_1 ·x_0
          fn ·v_30:
            ·fn
              fn ·ƒsucc_8, ·ƒfail_9, ·v_7:
                ·is_rec_like ·v_7,
                  fn ·v_15:
                    ·rec_pop ·v_15, 'x', ·ƒfail_9, fn ·v_10, ·v_14:
                      ·ƒsucc_8 ·v_10
                  fn: ·ƒfail_9 _
              fn ·v_24: ·v_24 ·v_30, ·panic, ·v_5
    # sm:


test 'standalone top-level destructure with call rhs', fn:
  expect cps_module ƒink:
    [a, b] = some_call x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·∅some_call
        fn ·v_5:
          ·fn
            fn ·v_10, ·v_11:
              ·let ·v_10, fn ·a_0:
                ·let ·v_11, fn ·b_1:
                  ·ƒret_2 ·b_1
            fn ·v_45:
              ·fn
                fn ·ƒsucc_8, ·ƒfail_9, ·v_7:
                  ·is_seq_like ·v_7,
                    fn ·v_24:
                      ·seq_pop ·v_24, ·ƒfail_9, fn ·v_10, ·v_25:
                        ·seq_pop ·v_25, ·ƒfail_9, fn ·v_11, ·v_16:
                          ·empty ·v_16, fn ·v_19:
                            ·if ·v_19,
                              fn: ·ƒsucc_8 ·v_10, ·v_11
                              fn: ·ƒfail_9 _
                    fn: ·ƒfail_9 _
                fn ·v_36: ·v_36 ·v_45, ·panic, ·v_5
        ·∅x
    # sm:


test 'standalone top-level destructure with import rhs', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·import './bar.fnk', fn ·v_5:
        ·fn
          fn ·v_10:
            ·let ·v_10, fn ·foo_0:
              ·ƒret_2 ·foo_0
          fn ·v_30:
            ·fn
              fn ·ƒsucc_8, ·ƒfail_9, ·v_7:
                ·is_rec_like ·v_7,
                  fn ·v_15:
                    ·rec_pop ·v_15, 'foo', ·ƒfail_9, fn ·v_10, ·v_14:
                      ·ƒsucc_8 ·v_10
                  fn: ·ƒfail_9 _
              fn ·v_24: ·v_24 ·v_30, ·panic, ·v_5
    # sm:


---
·export should only carry binding names — call args must not leak in.
Repro for the fooobar bug: module with multiple top-level fns + calls
whose results are bound to names. Yesterday the ·export terminal was
rendered as `·export ·add_0, ·s_1, ·mul_2, ·p_3, ·s_1, 3, 1, 2` — the
trailing `·s_1, 3, 1, 2` are args from the two call sites leaking in.
---

test 'export args do not leak call args', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      ni = a * b
      ni

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒret_9:
      ·fn
        fn ·ƒret_11, ·a_4, ·b_5: ·op_plus ·a_4, ·b_5, ·ƒret_11
        fn ·v_10:
          ·let ·v_10, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·add_0
                fn ·v_21:
                  ·let ·v_21, fn ·s_1:
                    ·ƒpub ·s_1, fn:
                      ·fn
                        fn ·ƒret_24, ·a_6, ·b_7:
                          ·op_mul ·a_6, ·b_7, fn ·v_27:
                            ·let ·v_27, fn ·ni_8:
                              ·ƒret_24 ·ni_8
                        fn ·v_23:
                          ·let ·v_23, fn ·mul_2:
                            ·ƒpub ·mul_2, fn:
                              ·mul_2
                                fn ·v_39:
                                  ·let ·v_39, fn ·p_3:
                                    ·ƒpub ·p_3, fn:
                                      ·ƒret_9 ·p_3
                                ·s_1
                                3
                1
                2
    # sm:

GAQ

