---
·export should only carry binding names — call args must not leak in.
Repro for the fooobar bug: module with multiple top-level fns + calls
whose results are bound to names. Yesterday the ·export terminal was
rendered as `·export ·add_0, ·s_1, ·mul_2, ·p_3, ·s_1, 3, 1, 2` — the
trailing `·s_1, 3, 1, 2` are args from the two call sites leaking in.
---

test 'export args do not leak call args', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      ni = a * b
      ni

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_70, ·ƒret_9:
      ·letrec fn ·add_0, ·s_1, ·mul_2, ·p_3:
        ·fn
          fn ·ƒctx_72, ·ƒret_11, ·a_4, ·b_5: ·op_plus ·ƒctx_72, ·a_4, ·b_5, ·ƒret_11
          fn ·ƒv_10:
            ·set ·add_0, ·ƒv_10, fn:
              ·ƒpub ·ƒctx_70, ·add_0, fn ·ƒctx_75:
                ·add_0
                  ·ƒctx_75
                  fn ·ƒctx_77, ·ƒv_21:
                    ·set ·s_1, ·ƒv_21, fn:
                      ·ƒpub ·ƒctx_77, ·s_1, fn ·ƒctx_79:
                        ·fn
                          fn ·ƒctx_80, ·ƒret_24, ·a_6, ·b_7:
                            ·letrec fn ·ni_8:
                              ·op_mul ·ƒctx_80, ·a_6, ·b_7, fn ·ƒctx_82, ·ƒv_27:
                                ·set ·ni_8, ·ƒv_27, fn:
                                  ·ƒret_24 ·ƒctx_82, ·ni_8
                          fn ·ƒv_23:
                            ·set ·mul_2, ·ƒv_23, fn:
                              ·ƒpub ·ƒctx_79, ·mul_2, fn ·ƒctx_85:
                                ·mul_2
                                  ·ƒctx_85
                                  fn ·ƒctx_87, ·ƒv_40:
                                    ·set ·p_3, ·ƒv_40, fn:
                                      ·ƒpub ·ƒctx_87, ·p_3, fn ·ƒctx_89:
                                        ·ƒret_9 ·ƒctx_89, ·p_3
                                  ·s_1
                                  i8 3
                  i8 1
                  i8 2
    # sm:-ARACAAEAAhYAFAAEAQACDAA0AS8aEAACADIBCyAAAQAgDAEAAw4ABAEMGhAACAACADYBCwMAAQADEAAUAAQBAAMOAAoAFAACADoBTAgAAQADTABYABgBAAgQAAIAQgEHDAABAAwMAQABCgAEAQgIEAAIAAIARgEHAQABAAEQABQABAEAAQoACgAUAAIASgEAAQABAAEUABQABAEAAUgBEAFIAQYBAAEAAQYBAAEgAWUBAAEAAQYBAAEgAQYBAAEAAQYBAAE


