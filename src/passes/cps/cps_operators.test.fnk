  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_pow ·ƒctx_6, ·∅a, ·∅b, ·ƒret_0
    # sm:DwABAAYAAQAGJAEABhYBAAYSAAIABgEABgABAAYSABIABAEAAQwABAEKAQwABAEJBg


