    a <<< b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_rotl ·ƒctx_6, ·∅a, ·∅b, ·ƒret_0
    # sm:DwABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcUABIABAEAAQwABAEMAQwABAELBw


test 'infix rotr', fn:
  cps_module ƒink:
    a >>> b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_rotr ·ƒctx_6, ·∅a, ·∅b, ·ƒret_0
    # sm:DwABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcUABIABAEAAQwABAEMAQwABAELBw

