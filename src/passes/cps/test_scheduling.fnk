test 'spawn bound to name', fn:
  expect cps_expr ƒink:
    future = spawn task

  | equals ƒink:
    ·spawn fn ·v_5:
      ·let ·v_5, fn ·future_0:
        ·v_2 ·future_0, ·∅task
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZnV0dXJlID0gc3Bhd24gdGFzayJdLAogICJtYXBwaW5ncyI6ICJBQUFTLEFBQUEsT0FBQSxHQUFBLEk7RUFBRixBQUFBLEtBQUUsSSxLQUFULFM7SSxBLEtBQUEsUyxFQUFlIgp9


