test 'spawn bound to name', fn:
  expect cps_expr ƒink:
    future = spawn task

  | equals ƒink:
    ·spawn ·∅task, fn ·v_5:
      ·let ·v_5, fn ·future_0:
        ·v_2 ·future_0
