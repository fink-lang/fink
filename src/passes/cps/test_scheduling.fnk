test 'channel bound to name', fn:
  expect cps_module ƒink:
    ch = channel 0

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·channel (i8 0), fn ·ƒctx_18, ·v_5:
        ·let ·v_5, fn ·ch_0:
          ·ƒpub ·ch_0, fn ·ƒctx_20:
            ·ƒret_2 ·ƒctx_20, ·ch_0
    # sm:IwABAA4AAQAOJAEADhgBAA4SAAIABgEKCQABAAkWARABAAEAAQYBAAEEAAoAGAEPCQoAAgAKAQMBAAEAAQwBBAkKAAoBCQIMAAIADgEAAgABAAIQAQACDAAKABQAAgASAQACAAEAAhQAFAAEAQAC


test 'receive bound to name', fn:
  expect cps_module ƒink:
    msg = receive ch

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·receive ·∅ch, fn ·ƒctx_18, ·v_5:
        ·let ·v_5, fn ·msg_0:
          ·ƒpub ·msg_0, fn ·ƒctx_20:
            ·ƒret_2 ·ƒctx_20, ·msg_0
    # sm:IQABABAAAQAQJAEAEBgBABASAAIABgEMCgABAAoUARACDgAKABgBDwoKAAIACgEDAQABAAEMAQQKCgAKAQsDDgACAA4BAAMAAQADEAEAAw4ACgAUAAIAEgEAAwABAAMUABQABAEAAw

