      ·spawn ·∅task_fn, ·ƒret_1
    # sm:CwABAA0AAQANJAEADRYBAA0SAAIABgEADQABAA0QAQwHGAAEAQsN


test 'await ident', fn:
  expect cps_module ƒink:
    await fut

  | equals ƒink:
