test 'spawn bound to name', fn:
  expect cps_module ƒink:
    future = spawn task

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·spawn ·∅task, fn ·v_5:
        ·let ·v_5, fn ·future_0:
          ·ƒpub ·future_0, fn:
            ·ƒret_2 ·future_0
