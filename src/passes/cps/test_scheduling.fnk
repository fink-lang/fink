{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
scheduling builtins — yield, spawn, await, channel, send, receive
---

test 'yield literal', fn:
  expect cps_module ƒink:
    yield 42

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_1:
      ·yield (i8 42), ·ƒret_1
    # sm:DQABAAgAAQAIJAEACBYBAAgSAAIABgEACAABAAgSAQwCAAEAAgYBAAIGAAQBCwg


test 'yield ident', fn:
  expect cps_module ƒink:
    yield foo

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_1:
      ·yield ·∅foo, ·ƒret_1
    # sm:CwABAAkAAQAJJAEACRYBAAkSAAIABgEACQABAAkQAQwDEAAEAQsJ


test 'spawn ident', fn:
  expect cps_module ƒink:
    spawn task_fn

  | equals ƒink:
