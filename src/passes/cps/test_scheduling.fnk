      ·await ·∅fut, ·ƒret_1
    # sm:CwABAAkAAQAJJAEACRYBAAkSAAIABgEACQABAAkQAQwDEAAEAQsJ


test 'spawn bound to name', fn:
  expect cps_module ƒink:
    future = spawn task

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·spawn ·∅task, fn ·ƒctx_18, ·v_5:
        ·let ·v_5, fn ·future_0:
          ·ƒpub ·future_0, fn ·ƒctx_20:
            ·ƒret_2 ·ƒctx_20, ·future_0
    # sm:IQABABMAAQATJAEAExgBABMSAAIABgESCgABAAoQAQwEEgAKABgBCwoKAAIACgEDAQABAAEMAQQKCgAKAREGFAACAA4BAAYAAQAGEAEABhQACgAUAAIAEgEABgABAAYUABQABAEABg


test 'await bound to name', fn:
  expect cps_module ƒink:
    result = await fut

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·await ·∅fut, fn ·ƒctx_18, ·v_5:
        ·let ·v_5, fn ·result_0:
          ·ƒpub ·result_0, fn ·ƒctx_20:
            ·ƒret_2 ·ƒctx_20, ·result_0
    # sm:IQABABIAAQASJAEAEhgBABISAAIABgESCQABAAkQAQwDEAAKABgBCwkKAAIACgEDAQABAAEMAQQJCgAKAREGFAACAA4BAAYAAQAGEAEABhQACgAUAAIAEgEABgABAAYUABQABAEABg


