{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
scheduling builtins — yield, spawn, await, channel, send, receive
---

test 'yield literal', fn:
  expect cps_module ƒink:
    yield 42

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·yield 42, ·ƒret_1
    # sm:CQAAAAAkABIACAEACAABAAgQAQwCBAAEAA


test 'yield ident', fn:
  expect cps_module ƒink:
    yield foo

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·yield ·∅foo, ·ƒret_1
    # sm:CQAAAAAkABIACAEACQABAAkQAQwDEAAEAA


test 'spawn ident', fn:
  expect cps_module ƒink:
    spawn task_fn

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·spawn ·∅task_fn, ·ƒret_1
    # sm:CQAAAAAkABIACAEADQABAA0QAQwHGAAEAA


test 'await ident', fn:
  expect cps_module ƒink:
    await fut

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·await ·∅fut, ·ƒret_1
    # sm:CQAAAAAkABIACAEACQABAAkQAQwDEAAEAA


test 'spawn bound to name', fn:
  expect cps_module ƒink:
    future = spawn task

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·spawn ·∅task, fn ·v_5:
        ·let ·v_5, fn ·future_0:
          ·ƒpub ·future_0, fn:
            ·ƒret_2 ·future_0
    # sm:GAAAAAAkABIACAESCgABAAoQAQwEEgAKAQsKCgAMAQMBAAEAAQwBBAoKAAoBEQYUABABAAYAAQAGEAEABhQACAAUAAAAFAEABg


test 'await bound to name', fn:
  expect cps_module ƒink:
    result = await fut

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·await ·∅fut, fn ·v_5:
        ·let ·v_5, fn ·result_0:
          ·ƒpub ·result_0, fn:
            ·ƒret_2 ·result_0
    # sm:GAAAAAAkABIACAESCQABAAkQAQwDEAAKAQsJCgAMAQMBAAEAAQwBBAkKAAoBEQYUABABAAYAAQAGEAEABhQACAAUAAAAFAEABg


test 'channel creation', fn:
  expect cps_module ƒink:
    channel 0

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·channel 0, ·ƒret_1
    # sm:CQAAAAAkABIACAEACQABAAkUARABAgAEAA



test 'receive from channel', fn:
  expect cps_module ƒink:
    receive ch

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·receive ·∅ch, ·ƒret_1
    # sm:CQAAAAAkABIACAEACgABAAoUARACDgAEAA


test 'channel bound to name', fn:
  expect cps_module ƒink:
    ch = channel 0

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·channel 0, fn ·v_5:
        ·let ·v_5, fn ·ch_0:
          ·ƒpub ·ch_0, fn:
            ·ƒret_2 ·ch_0
    # sm:GAAAAAAkABIACAEKCQABAAkUARABAgAKAQ8JCgAMAQMBAAEAAQwBBAkKAAoBCQIMABABAAIAAQACEAEAAgwACAAUAAAAFAEAAg


test 'receive bound to name', fn:
  expect cps_module ƒink:
    msg = receive ch

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·receive ·∅ch, fn ·v_5:
        ·let ·v_5, fn ·msg_0:
          ·ƒpub ·msg_0, fn:
            ·ƒret_2 ·msg_0
    # sm:GAAAAAAkABIACAEMCgABAAoUARACDgAKAQ8KCgAMAQMBAAEAAQwBBAoKAAoBCwMOABABAAMAAQADEAEAAw4ACAAUAAAAFAEAAw
