{test, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
scheduling builtins — yield, spawn, await, channel, send, receive
---

test 'yield literal', fn:
  expect cps_expr ƒink:
    yield 42

  | equals ƒink:
