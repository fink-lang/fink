---
cps_c IR — free variable analysis tests
---

# Free var pass — annotates ·fn with captured names from enclosing scope.
#
# Convention:
#   ·fn fn params: fn_body, fn name:  — no captures
#   ·fn [x, y] fn params: fn_body, fn name:  — captures listed
#     (user names plain; params excluded; builtins are Callable::BuiltIn, not captures)
#
# Analysis stops at nested ·fn boundaries (direct captures only).
# Params are excluded (they arrive as arguments, not from scope).
# Names bound within the fn body are also excluded from captures.
#
# Test format:
#   test 'name', fn:
#     expect cps_free_vars fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps output>


---
free variable analysis
---

test 'free vars — fn with no captures', fn:
  expect cps_free_vars fink":
    fn a, b:
      a + b
  | equals fink":
    ·fn
      fn a, b:
        ·apply ·op_plus, a, b, ·state, fn ·v_5, ·state:
          ·ƒ_cont ·v_5, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — fn with only literals', fn:
  expect cps_free_vars fink":
    fn x:
      42
  | equals fink":
    ·fn
      fn x: ·ƒ_cont 42, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures one outer var', fn:
  expect cps_free_vars fink":
    fn x:
      fn y:
        x + y
  | equals fink":
    ·fn
      fn x:
        ·fn
          fn y:
            ·apply ·op_plus, x, y, ·state, fn ·v_6, ·state:
              ·ƒ_cont ·v_6, ·state
          fn ·v_2: ·ƒ_cont ·v_2, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures local binding', fn:
  expect cps_free_vars fink":
    fn x:
      z = x + 1
      fn y:
        z + y
  | equals fink":
    ·fn
      fn x:
        ·apply ·op_plus, x, 1, ·state, fn ·v_4, ·state:
          ·let ·v_4, fn z:
            ·fn
              fn y:
                ·apply ·op_plus, z, y, ·state, fn ·v_11, ·state:
                  ·ƒ_cont ·v_11, ·state
              fn ·v_7: ·ƒ_cont ·v_7, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — named outer, inner captures param', fn:
  expect cps_free_vars fink":
    add = fn x:
      fn y:
        x + y
  | equals fink":
    ·fn
      fn x:
        ·fn
          fn y:
            ·apply ·op_plus, x, y, ·state, fn ·v_6, ·state:
              ·ƒ_cont ·v_6, ·state
          fn ·v_2: ·ƒ_cont ·v_2, ·state
      fn ·v_0:
        ·let ·v_0, fn add:
          ·ƒ_cont add, ·state


test 'free vars — two named fns no captures', fn:
  expect cps_free_vars fink":
    double = fn x: x + x
    triple = fn x: x + x + x
  | equals fink":
    ·fn
      fn:
        ·fn
          fn x:
            ·apply ·op_plus, x, x, ·state, fn ·v_5, ·state:
              ·ƒ_cont ·v_5, ·state
          fn ·v_1:
            ·let ·v_1, fn double:
              ·fn
                fn x:
                  ·apply ·op_plus, x, x, ·state, fn ·v_15, ·state:
                    ·apply ·op_plus, ·v_15, x, ·state, fn ·v_18, ·state:
                      ·ƒ_cont ·v_18, ·state
                fn ·v_11:
                  ·let ·v_11, fn triple:
                    ·ƒ_cont triple, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — three levels of nesting', fn:
  expect cps_free_vars fink":
    fn a:
      fn b:
        fn c:
          a + b + c
  | equals fink":
    ·fn
      fn a:
        ·fn
          fn b:
            ·fn
              fn c:
                ·apply ·op_plus, a, b, ·state, fn ·v_8, ·state:
                  ·apply ·op_plus, ·v_8, c, ·state, fn ·v_11, ·state:
                    ·ƒ_cont ·v_11, ·state
              fn ·v_4: ·ƒ_cont ·v_4, ·state
          fn ·v_2: ·ƒ_cont ·v_2, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


---
free vars — match arms
---

test 'free vars — match arm bindings are local', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        1: 'one'
        n: n
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·match_value ·v_3, 1, ·ƒ_fail, fn ·state:
              ·ƒ_cont 'one', ·state
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·let ·v_3, fn n:
              ·ƒ_cont n, ·state
          fn ·v_16, ·state: ·ƒ_cont ·v_16, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — closure inside match arm captures arm binding', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        [head, ..tail]:
          fn x: head + x
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·match_seq ·v_3, ·ƒ_fail, fn ·m_0, ·state:
              ·match_next ·m_0, ·ƒ_fail, fn ·v_5, ·m_1, ·state:
                ·let ·v_5, fn head:
                  ·match_rest ·m_1, ·ƒ_fail, fn ·v_8, ·state:
                    ·let ·v_8, fn tail:
                      ·fn
                        fn x:
                          ·apply ·op_plus, head, x, ·state, fn ·v_16, ·state:
                            ·ƒ_cont ·v_16, ·state
                        fn ·v_12: ·ƒ_cont ·v_12, ·state
          fn ·v_33, ·state: ·ƒ_cont ·v_33, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state

test 'free vars — range pattern loads operators as free vars', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        0..10: 'low'
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·apply ·op_rngex, 0, 10, ·state, fn ·v_7, ·state:
              ·match_if ·op_in, ·v_3, ·v_7, ·ƒ_fail, fn ·state:
                ·ƒ_cont 'low', ·state
          fn ·v_14, ·state: ·ƒ_cont ·v_14, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — guard pattern loads operator as free var', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        n > 0: n
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·let ·v_3, fn n:
              ·match_if ·op_gt, n, 0, ·ƒ_fail, fn ·state:
                ·ƒ_cont n, ·state
          fn ·v_14, ·state: ·ƒ_cont ·v_14, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — rec pattern bindings are local', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        {a, b}: a
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·match_rec ·v_3, ·ƒ_fail, fn ·m_0, ·state:
              ·match_field ·m_0, 'a', ·ƒ_fail, fn ·v_5, ·m_1, ·state:
                ·let ·v_5, fn a:
                  ·match_field ·m_1, 'b', ·ƒ_fail, fn ·v_8, ·m_2, ·state:
                    ·let ·v_8, fn b:
                      ·ƒ_cont a, ·state
          fn ·v_24, ·state: ·ƒ_cont ·v_24, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


test 'free vars — closure inside rec pattern arm captures field binding', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        {x}: fn y: x + y
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·match_rec ·v_3, ·ƒ_fail, fn ·m_0, ·state:
              ·match_field ·m_0, 'x', ·ƒ_fail, fn ·v_5, ·m_1, ·state:
                ·let ·v_5, fn x:
                  ·fn
                    fn y:
                      ·apply ·op_plus, x, y, ·state, fn ·v_13, ·state:
                        ·ƒ_cont ·v_13, ·state
                    fn ·v_9: ·ƒ_cont ·v_9, ·state
          fn ·v_26, ·state: ·ƒ_cont ·v_26, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state

test 'free vars — rec pattern arm body captures outer var', fn:
  expect cps_free_vars fink":
    fn val:
      match val:
        {x}: x + y
  | equals fink":
    ·fn
      fn val:
        ·match_block val, ·panic, ·state,
          ·match_branch fn ·v_3, ·state, ·ƒ_cont, ·ƒ_fail:
            ·match_rec ·v_3, ·ƒ_fail, fn ·m_0, ·state:
              ·match_field ·m_0, 'x', ·ƒ_fail, fn ·v_5, ·m_1, ·state:
                ·let ·v_5, fn x:
                  ·apply ·op_plus, x, y, ·state, fn ·v_11, ·state:
                    ·ƒ_cont ·v_11, ·state
          fn ·v_21, ·state: ·ƒ_cont ·v_21, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state
