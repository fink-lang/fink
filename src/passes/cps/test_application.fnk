{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  expect cps_module ƒink:
    foo 42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, (i8 42)
    # sm:DwABAAYAAQAGJAEABhYBAAYSAAIABgEABgABAAMSABIABAEABhIABgEIAgABAAIGAQAC


test '·apply ident to ident', fn:
  expect cps_module ƒink:
    foo bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ·∅bar
    # sm:DQABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAMSABIABAEABxIABAEIAw



---
pipe — lowered as application
---

test 'pipe two stages', fn:
  expect cps_module ƒink:
    a | foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ·∅a
    # sm:DQABAAcAAQAHJAEABxYBAAcSAAIABgEEAQABBAMSABIABAEHBxIABAEAAQ


test 'pipe three stages', fn:
  expect cps_module ƒink:
    a | foo | bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅foo
        ·ƒctx_11
        fn ·ƒctx_14, ·v_3: ·∅bar ·ƒctx_14, ·ƒret_0, ·v_3
        ·∅a
    # sm:FAABAA0AAQANJAEADRgBAA0SAAIABgEEAQABBAMaACQAGAEHDQoABAEQAQABBAMSABQABAETDRIABAEADRQBAAE



---
try expression
---

test 'try', fn:
  expect cps_module ƒink:
    try foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, ·∅foo
    # sm:CwABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcUABIABAEIAw



---
ported from test_cps — calls and application
---

test 'simple call', fn:
  expect cps_module ƒink:
    add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅add ·ƒctx_7, ·ƒret_0, (i8 1), (i8 2)
    # sm:EwABAAgAAQAIJAEACBYBAAgSAAIABgEACAABAAMSABIABAEACBIABgEIAQABAAEGAQABBAAGAQYBAAEAAQYBAAE


test 'nested call', fn:
  expect cps_module ƒink:
    add (mul 2, 3), 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·∅mul
        ·ƒctx_13
        fn ·ƒctx_16, ·v_5: ·∅add ·ƒctx_16, ·ƒret_0, ·v_5, (i8 1)
        i8 2
        i8 3
    # sm:HQABABEAAQARJAEAERgBABESAAIABgEKCAABAAMaACQAGAEACAoABAEJEQABAAMSABQABAEAERIABAEKCAoABgEWAQABAAEGAQABDgENAQABAAEGAQABDAEGAQABAAEGAQAB


test 'postfix tag', fn:
  expect cps_module ƒink:
    (foo bar)tag
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅foo
        ·ƒctx_11
        fn ·ƒctx_14, ·v_4: ·∅tag ·ƒctx_14, ·ƒret_0, ·v_4
        ·∅bar
    # sm:FAABAAwAAQAMJAEADBgBAAwSAAIABgECBwABAAMaACQAGAEABwoABAEBDAABEgMSABQABAERDBIABAECBxQBCAM


test 'call with spread', fn:
  expect cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, ·∅a, ..·∅rest
    # sm:EQABAA0AAQANJAEADRYBAA0SAAIABgEADQABAAMSABIABAEADRIABAEIAQwABAEKBAABAAQEAQAE


test 'simple pipe', fn:
  expect cps_module ƒink:
    x | f
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅f ·ƒctx_6, ·ƒret_0, ·∅x
    # sm:DQABAAUAAQAFJAEABRYBAAUSAAIABgEEAQABBAEOABIABAEHBRIABAEAAQ


test 'pipe chain', fn:
  expect cps_module ƒink:
    x | f | g
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅f
        ·ƒctx_11
        fn ·ƒctx_14, ·v_3: ·∅g ·ƒctx_14, ·ƒret_0, ·v_3
        ·∅x
    # sm:FAABAAkAAQAJJAEACRgBAAkSAAIABgEEAQABBAEWACQAGAEHCQoABAEMAQABBAEOABQABAEPCRIABAEACRQBAAE


test 'partial apply', fn:
  expect cps_module ƒink:
    add 3, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_1:
      ·fn
        fn ·ƒctx_14, ·ƒret_3, ·v_0: ·∅add ·ƒctx_14, ·ƒret_3, (i8 3), ·v_0
        fn ·v_2: ·ƒret_1 ·ƒctx_12, ·v_2
    # sm:IAABAAgAAQAIJAEACBgBAAgSAAIABgEACAABAAgIABAAGAEACBYBAAgKAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQoAEAENCAoABAEACAABAAgUAQAIFAAEAQAI


test 'pipe with lambda — literal head', fn:
  expect cps_module ƒink:
    3 | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·fn
        fn ·ƒctx_18, ·ƒret_4, ·a_0: ·op_plus ·ƒctx_18, ·a_0, (i8 2), ·ƒret_4
        fn ·v_3: ·v_3 ·ƒctx_16, ·ƒret_1, (i8 3)
    # sm:JAABAA8AAQAPJAEADxgBAA8SAAIABgEICwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQABAEHBRIAEAELCwoABAEDAQABBAsMABQABAEHDxIABgEAAQABAAEGAQAB


test 'pipe with lambda — ident head', fn:
  expect cps_module ƒink:
    x | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·fn
        fn ·ƒctx_18, ·ƒret_4, ·a_0: ·op_plus ·ƒctx_18, ·a_0, (i8 2), ·ƒret_4
        fn ·v_3: ·v_3 ·ƒctx_16, ·ƒret_1, ·∅x
    # sm:IgABAA8AAQAPJAEADxgBAA8SAAIABgEICwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQABAEHBRIAEAELCwoABAEDAQABBAsMABQABAEHDxIABAEAAQ


test 'pipe with partial', fn:
  expect cps_module ƒink:
    3 | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·fn
        fn ·ƒctx_19, ·ƒret_4, ·v_0: ·∅add ·ƒctx_19, ·ƒret_4, (i8 2), ·v_0
        fn ·v_3: ·v_3 ·ƒctx_17, ·ƒret_1, (i8 3)
    # sm:JAABAAwAAQAMJAEADBgBAAwSAAIABgEICAABAAgIABAAGAEACBYBAAgKAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQoAEAENCAoABAEDAQABBAgMABQABAEHDBIABgEAAQABAAEGAQAB


test 'pipe with partial — ident head', fn:
  expect cps_module ƒink:
    x | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·fn
        fn ·ƒctx_19, ·ƒret_4, ·v_0: ·∅add ·ƒctx_19, ·ƒret_4, (i8 2), ·v_0
        fn ·v_3: ·v_3 ·ƒctx_17, ·ƒret_1, ·∅x
    # sm:IgABAAwAAQAMJAEADBgBAAwSAAIABgEICAABAAgIABAAGAEACBYBAAgKAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQoAEAENCAoABAEDAQABBAgMABQABAEHDBIABAEAAQ



---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_module ƒink:
    foo 1, ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, (i8 1), ..·∅items
    # sm:EwABAA4AAQAOJAEADhYBAA4SAAIABgEADgABAAMSABIABAEADhIABgEIAQABAAEGAQABBAAEAQoFAAEABQQBAAU


test 'call with spread — trailing iterable', fn:
  expect cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, ·∅a, ..·∅rest
    # sm:EQABAA0AAQANJAEADRYBAA0SAAIABgEADQABAAMSABIABAEADRIABAEIAQwABAEKBAABAAQEAQAE


test 'call with spread — spread only', fn:
  expect cps_module ƒink:
    foo ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ..·∅items
    # sm:DwABAAsAAQALJAEACxYBAAsSAAIABgEACwABAAMSABIABAEACxIABAEMBQABAAUEAQAF


test 'call with spread — passes through from varargs fn', fn:
  expect cps_module ƒink:
    fn ..args: foo ..args
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_1:
      ·fn
        fn ·ƒctx_13, ·ƒret_3, ..·args_0: ·∅foo ·ƒctx_13, ·ƒret_3, ..·args_0
        fn ·v_2: ·ƒret_1 ·ƒctx_11, ·v_2
    # sm:IAABABUAAQAVJAEAFRgBABUSAAIABgEAFQABABUIABAAGAEWChYBCwQAAQAEBAEABBAABAEMCgABAAMSABQABAEAChIABAEMBAABAAQEAQAEEAAQASEVCgAEAQAVAAEAFRQBABUUAAQBABU
