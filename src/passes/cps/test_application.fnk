{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  expect cps_module ƒink:
    foo 42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, 42
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIDQyIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxNLE8sRUFBSSIKfQ==


test '·apply ident to ident', fn:
  expect cps_module ƒink:
    foo bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅bar
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIGJhciJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsTSxPLEVBQUkiCn0=



---
pipe — lowered as application
---

test 'pipe two stages', fn:
  expect cps_module ƒink:
    a | foo
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅a
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSB8IGZvbyJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFFLEFBQUUsTSxPLEVBQUoiCn0=


test 'pipe three stages', fn:
  expect cps_module ƒink:
    a | foo | bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo
        fn ·v_3: ·∅bar ·ƒret_0, ·v_3
        ·∅a
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSB8IGZvbyB8IGJhciJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFFLEFBQUU7T0FBSixJLEVBQVEsQUFBRSxNLE8sRUFBVjtJQUFBIgp9



