{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  expect cps_module ƒink:
    foo 42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, 42
    # sm:CgABAAYAAQAGJAEABhIAAgAGAQAGAAEAAxIBAAYSAAQBCAI


test '·apply ident to ident', fn:
  expect cps_module ƒink:
    foo bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅bar
    # sm:CgABAAcAAQAHJAEABxIAAgAGAQAHAAEAAxIBAAcSAAQBCAM



---
pipe — lowered as application
---

test 'pipe two stages', fn:
  expect cps_module ƒink:
    a | foo
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅a
    # sm:CgABAAcAAQAHJAEABxIAAgAGAQQBAAEEAxIBBwcSAAQBAAE


test 'pipe three stages', fn:
  expect cps_module ƒink:
    a | foo | bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo
        fn ·v_3: ·∅bar ·ƒret_0, ·v_3
        ·∅a
    # sm:DwABAA0AAQANJAEADRIAAgAGAQQBAAEEAyABBw0KAAQBEAEAAQQDEgETDRIABAEADRQBAAE



---
try expression
---

test 'try', fn:
  expect cps_module ƒink:
    try foo
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 ·∅foo
    # sm:CAABAAcAAQAHJAEABxIAAgAGAQAHAAEABxQBCAM



---
ported from test_cps — calls and application
---

test 'simple call', fn:
  expect cps_module ƒink:
    add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅add ·ƒret_0, 1, 2
    # sm:DAABAAgAAQAIJAEACBIAAgAGAQAIAAEAAxIBAAgSAAQBCAECAAQBBgE


test 'nested call', fn:
  expect cps_module ƒink:
    add (mul 2, 3), 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅mul
        fn ·v_5: ·∅add ·ƒret_0, ·v_5, 1
        2
        3
    # sm:EgABABEAAQARJAEAERIAAgAGAQoIAAEAAyABAAgKAAQBCREAAQADEgEAERIABAEKCAoABAEWAQwBDQEMAQYB


test 'postfix tag', fn:
  expect cps_module ƒink:
    (foo bar)tag
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo
        fn ·v_4: ·∅tag ·ƒret_0, ·v_4
        ·∅bar
    # sm:DwABAAwAAQAMJAEADBIAAgAGAQIHAAEAAyABAAcKAAQBAQwAARIDEgERDBIABAECBxQBCAM


test 'call with spread', fn:
  expect cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅a, ..·∅rest
    # sm:DgABAA0AAQANJAEADRIAAgAGAQANAAEAAxIBAA0SAAQBCAEMAAQBCgQAAQAEBAEABA


test 'simple pipe', fn:
  expect cps_module ƒink:
    x | f
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅f ·ƒret_0, ·∅x
    # sm:CgABAAUAAQAFJAEABRIAAgAGAQQBAAEEAQ4BBwUSAAQBAAE


test 'pipe chain', fn:
  expect cps_module ƒink:
    x | f | g
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅f
        fn ·v_3: ·∅g ·ƒret_0, ·v_3
        ·∅x
    # sm:DwABAAkAAQAJJAEACRIAAgAGAQQBAAEEARwBBwkKAAQBDAEAAQQBDgEPCRIABAEACRQBAAE


test 'partial apply', fn:
  expect cps_module ƒink:
    add 3, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ·v_0: ·∅add ·ƒret_3, 3, ·v_0
        fn ·v_2: ·ƒret_1 ·v_2
    # sm:GAABAAgAAQAIJAEACBIAAgAGAQAIAAEACAgAEAEACBYBAAgKAAQBAAgAAQADEgEACBIABAEIAQIABAEGAQoAEAENCAoABAEACAABAAgUAQAI


test 'pipe with lambda — literal head', fn:
  expect cps_module ƒink:
    3 | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_4, ·a_0: ·op_plus ·a_0, 2, ·ƒret_4
        fn ·v_3: ·v_3 ·ƒret_1, 3
    # sm:GgABAA8AAQAPJAEADxIAAgAGAQgLAAEACwgAEAEMBRYBBQEKAAQBBgUAAQAFFAEAAQoABAEIAQIABAEHBRIAEAELCwoABAEDAQABBAsMAQcPEgAEAQAB


test 'pipe with lambda — ident head', fn:
  expect cps_module ƒink:
    x | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_4, ·a_0: ·op_plus ·a_0, 2, ·ƒret_4
        fn ·v_3: ·v_3 ·ƒret_1, ·∅x
    # sm:GgABAA8AAQAPJAEADxIAAgAGAQgLAAEACwgAEAEMBRYBBQEKAAQBBgUAAQAFFAEAAQoABAEIAQIABAEHBRIAEAELCwoABAEDAQABBAsMAQcPEgAEAQAB


test 'pipe with partial', fn:
  expect cps_module ƒink:
    3 | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_4, ·v_0: ·∅add ·ƒret_4, 2, ·v_0
        fn ·v_3: ·v_3 ·ƒret_1, 3
    # sm:GgABAAwAAQAMJAEADBIAAgAGAQgIAAEACAgAEAEACBYBAAgKAAQBAAgAAQADEgEACBIABAEIAQIABAEGAQoAEAENCAoABAEDAQABBAgMAQcMEgAEAQAB


test 'pipe with partial — ident head', fn:
  expect cps_module ƒink:
    x | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_4, ·v_0: ·∅add ·ƒret_4, 2, ·v_0
        fn ·v_3: ·v_3 ·ƒret_1, ·∅x
    # sm:GgABAAwAAQAMJAEADBIAAgAGAQgIAAEACAgAEAEACBYBAAgKAAQBAAgAAQADEgEACBIABAEIAQIABAEGAQoAEAENCAoABAEDAQABBAgMAQcMEgAEAQAB



---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_module ƒink:
    foo 1, ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, 1, ..·∅items
    # sm:DgABAA4AAQAOJAEADhIAAgAGAQAOAAEAAxIBAA4SAAQBCAECAAQBCgUAAQAFBAEABQ


test 'call with spread — trailing iterable', fn:
  expect cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅a, ..·∅rest
    # sm:DgABAA0AAQANJAEADRIAAgAGAQANAAEAAxIBAA0SAAQBCAEMAAQBCgQAAQAEBAEABA


test 'call with spread — spread only', fn:
  expect cps_module ƒink:
    foo ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ..·∅items
    # sm:DAABAAsAAQALJAEACxIAAgAGAQALAAEAAxIBAAsSAAQBDAUAAQAFBAEABQ


test 'call with spread — passes through from varargs fn', fn:
  expect cps_module ƒink:
    fn ..args: foo ..args
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ..·args_0: ·∅foo ·ƒret_3, ..·args_0
        fn ·v_2: ·ƒret_1 ·v_2
    # sm:GgABABUAAQAVJAEAFRIAAgAGAQAVAAEAFQgAEAEWChYBCwQAAQAEBAEABBAABAEMCgABAAMSAQAKEgAEAQwEAAEABAQBAAQQABABIRUKAAQBABUAAQAVFAEAFQ





