---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_module ƒink:
    foo 1, ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, 1, ..·∅items
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIDEsIC4uaXRlbXMiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFBLE0sTyxFQUFJLEMsRUFBSyxBLEVBQUEiCn0=


test 'call with spread — trailing iterable', fn:
  expect cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ·∅a, ..·∅rest
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIGEsIC4ucmVzdCJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFBLEFBQUEsTSxPLEVBQUksRyxFQUFLLEEsRUFBQSIKfQ==


test 'call with spread — spread only', fn:
  expect cps_module ƒink:
    foo ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo ·ƒret_0, ..·∅items
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vIC4uaXRlbXMiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFBLE0sTyxFQUFNLEEsRUFBQSIKfQ==


test 'call with spread — passes through from varargs fn', fn:
  expect cps_module ƒink:
    fn ..args: foo ..args
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ..·args_0: ·∅foo ·ƒret_3, ..·args_0
        fn ·v_2: ·ƒret_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4gLi5hcmdzOiBmb28gLi5hcmdzIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQTtPQUFBLFNBQUssQSxFQUFBLE8sRUFBTSxBQUFBLE1BQVgsTyxFQUFpQixBLEVBQUE7T0FBakIsSSxFLEEsUUFBQSIKfQ==


