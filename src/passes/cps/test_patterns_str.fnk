{test, skip, expect, equals, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
string template patterns
---

test 'str templ pattern: capture all', fn:
  expect cps_module ƒink:
    '${foo}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·v_6:
          ·let ·v_6, fn ·foo_0:
            ·ƒret_1 ·foo_0
        fn ·v_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·str_match ·v_3, '', '', ·ƒfail_5, fn ·v_6:
                ·ƒsucc_4 ·ƒctx_30, ·v_6
            fn ·v_15: ·v_15 ·ƒctx_27, ·v_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: prefix and suffix', fn:
  expect cps_module ƒink:
    'foo${bar}spam' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·v_6:
          ·let ·v_6, fn ·bar_0:
            ·ƒret_1 ·bar_0
        fn ·v_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·str_match ·v_3, 'foo', 'spam', ·ƒfail_5, fn ·v_6:
                ·ƒsucc_4 ·ƒctx_30, ·v_6
            fn ·v_15: ·v_15 ·ƒctx_27, ·v_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: capture at start', fn:
  expect cps_module ƒink:
    '${foo}bar' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·v_6:
          ·let ·v_6, fn ·foo_0:
            ·ƒret_1 ·foo_0
        fn ·v_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·str_match ·v_3, '', 'bar', ·ƒfail_5, fn ·v_6:
                ·ƒsucc_4 ·ƒctx_30, ·v_6
            fn ·v_15: ·v_15 ·ƒctx_27, ·v_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: capture at end', fn:
  expect cps_module ƒink:
    'foo${bar}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·v_6:
          ·let ·v_6, fn ·bar_0:
            ·ƒret_1 ·bar_0
        fn ·v_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·str_match ·v_3, 'foo', '', ·ƒfail_5, fn ·v_6:
                ·ƒsucc_4 ·ƒctx_30, ·v_6
            fn ·v_15: ·v_15 ·ƒctx_27, ·v_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: match arm', fn:
  expect cps_module ƒink:
    match val:
      'foo${x}bar': x
      _: 0
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_80, ·ƒret_1:
      ·fn
        fn ·ƒctx_82, ·ƒret_21, ·x_0: ·ƒret_21 ·ƒctx_82, ·x_0
        fn ·v_25:
          ·fn
            fn ·ƒctx_84, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·fn
                fn ·ƒctx_85, ·v_10:
                  ·let ·v_10, fn ·x_0:
                    ·v_25 ·ƒctx_85, ·ƒsucc_4, ·v_10
                fn ·v_32:
                  ·fn
                    fn ·ƒctx_87, ·ƒsucc_8, ·ƒfail_9, ·v_7:
                      ·str_match ·v_7, 'foo', 'bar', ·ƒfail_9, fn ·v_10:
                        ·ƒsucc_8 ·ƒctx_87, ·v_10
                    fn ·v_19: ·v_19 ·ƒctx_84, ·v_32, ·ƒfail_5, ·v_3
            fn ·v_39:
              ·fn
                fn ·ƒctx_90, ·ƒret_44: ·ƒret_44 ·ƒctx_90, (i8 0)
                fn ·v_48:
                  ·fn
                    fn ·ƒctx_92, ·ƒsucc_41, ·ƒfail_42, ·v_40: ·v_48 ·ƒctx_92, ·ƒsucc_41
                    fn ·v_53:
                      ·fn
                        fn ·ƒctx_94, ·ƒret_55, ·v_54:
                          ·v_39
                            ·ƒctx_94
                            ·ƒret_55
                            fn ·ƒctx_96:
                              ·v_53
                                ·ƒctx_96
                                ·ƒret_55
                                fn ·ƒctx_98: ·panic _
                                ·v_54
                            ·v_54
                        fn ·v_65: ·v_65 ·ƒctx_80, ·ƒret_1, ·∅val
    # sm:-AEYBACNMABQAAgA2AQAjAAEAI0YATgEAI1QAFAAEAQAjAAEAIxABACM8AQAjPgEAIwwAMAEAIwwABAEAIwABACMOABQABAEAIxIABAEMAw
