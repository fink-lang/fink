{test, skip, expect, equals, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
string template patterns
---

test 'str templ pattern: capture all', fn:
  expect cps_module ƒink:
    '${foo}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_1:
      ·fn
        fn ·ƒctx_32, ·ƒv_6:
          ·let ·ƒv_6, fn ·foo_0:
            ·ƒret_1 ·ƒctx_32, ·foo_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_33, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_33, ·ƒv_3, '', '', ·ƒfail_5, fn ·ƒctx_35, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_35, ·ƒv_6
            fn ·ƒv_15:
              ·fn
                fn ·ƒctx_37: ·panic ·ƒctx_37
                fn ·ƒv_23: ·ƒv_15 ·ƒctx_30, ·ƒv_20, ·ƒv_23, ·∅val
    # sm:

test 'str templ pattern: prefix and suffix', fn:
  expect cps_module ƒink:
    'foo${bar}spam' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_1:
      ·fn
        fn ·ƒctx_32, ·ƒv_6:
          ·let ·ƒv_6, fn ·bar_0:
            ·ƒret_1 ·ƒctx_32, ·bar_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_33, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_33, ·ƒv_3, 'foo', 'spam', ·ƒfail_5, fn ·ƒctx_35, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_35, ·ƒv_6
            fn ·ƒv_15:
              ·fn
                fn ·ƒctx_37: ·panic ·ƒctx_37
                fn ·ƒv_23: ·ƒv_15 ·ƒctx_30, ·ƒv_20, ·ƒv_23, ·∅val
    # sm:

