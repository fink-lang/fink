{test, skip, expect, equals, cps_expr} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
string template patterns
---

test 'str templ pattern: capture all', fn:
  expect cps_expr ƒink:
    '${foo}' = val
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·foo_0:
          ·v_1 ·foo_0
      fn ·v_20:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·str_match ·v_3, '', '', ·ƒfail_5, fn ·v_6:
              ·ƒsucc_4 ·v_6
          fn ·v_15: ·v_15 ·v_20, ·panic, ·∅val
    #sourcemaps:

test 'str templ pattern: prefix and suffix', fn:
  expect cps_expr ƒink:
    'foo${bar}spam' = val
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·bar_0:
          ·v_1 ·bar_0
      fn ·v_20:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·str_match ·v_3, 'foo', 'spam', ·ƒfail_5, fn ·v_6:
              ·ƒsucc_4 ·v_6
          fn ·v_15: ·v_15 ·v_20, ·panic, ·∅val
    #sourcemaps:

test 'str templ pattern: capture at start', fn:
  expect cps_expr ƒink:
    '${foo}bar' = val
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·foo_0:
          ·v_1 ·foo_0
      fn ·v_20:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·str_match ·v_3, '', 'bar', ·ƒfail_5, fn ·v_6:
              ·ƒsucc_4 ·v_6
          fn ·v_15: ·v_15 ·v_20, ·panic, ·∅val
    #sourcemaps:

test 'str templ pattern: capture at end', fn:
  expect cps_expr ƒink:
    'foo${bar}' = val
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·bar_0:
          ·v_1 ·bar_0
      fn ·v_20:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·str_match ·v_3, 'foo', '', ·ƒfail_5, fn ·v_6:
              ·ƒsucc_4 ·v_6
          fn ·v_15: ·v_15 ·v_20, ·panic, ·∅val
    #sourcemaps:

test 'str templ pattern: match arm', fn:
  expect cps_expr ƒink:
    match val:
      'foo${x}bar': x
      _: 0
  | equals ƒink:
    ·fn
      fn ·ƒret_21, ·x_0: ·ƒret_21 ·x_0
      fn ·v_25:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·fn
              fn ·v_10:
                ·let ·v_10, fn ·x_0:
                  ·v_25 ·ƒsucc_4, ·v_10
              fn ·v_32:
                ·fn
                  fn ·ƒsucc_8, ·ƒfail_9, ·v_7:
                    ·str_match ·v_7, 'foo', 'bar', ·ƒfail_9, fn ·v_10:
                      ·ƒsucc_8 ·v_10
                  fn ·v_19: ·v_19 ·v_32, ·ƒfail_5, ·v_3
          fn ·v_39:
            ·fn
              fn ·ƒret_44: ·ƒret_44 0
              fn ·v_48:
                ·fn
                  fn ·ƒsucc_41, ·ƒfail_42, ·v_40: ·v_48 ·ƒsucc_41
                  fn ·v_53:
                    ·fn
                      fn ·ƒret_55, ·v_54:
                        ·v_39 ·ƒret_55, fn:
                          ·v_53 ·ƒret_55, fn: ·panic _, ·v_54, ·v_54
                      fn ·v_66: ·v_66 ·v_1, ·∅val
    #sourcemaps:
