{test, skip, expect, equals, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
string template patterns
---

test 'str templ pattern: capture all', fn:
  expect cps_module ƒink:
    '${foo}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·ƒv_6:
          ·let ·ƒv_6, fn ·foo_0:
            ·ƒret_1 ·ƒctx_29, ·foo_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_30, ·ƒv_3, '', '', ·ƒfail_5, fn ·ƒctx_32, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_32, ·ƒv_6
            fn ·ƒv_15: ·ƒv_15 ·ƒctx_27, ·ƒv_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: prefix and suffix', fn:
  expect cps_module ƒink:
    'foo${bar}spam' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·ƒv_6:
          ·let ·ƒv_6, fn ·bar_0:
            ·ƒret_1 ·ƒctx_29, ·bar_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_30, ·ƒv_3, 'foo', 'spam', ·ƒfail_5, fn ·ƒctx_32, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_32, ·ƒv_6
            fn ·ƒv_15: ·ƒv_15 ·ƒctx_27, ·ƒv_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: capture at start', fn:
  expect cps_module ƒink:
    '${foo}bar' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·ƒv_6:
          ·let ·ƒv_6, fn ·foo_0:
            ·ƒret_1 ·ƒctx_29, ·foo_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_30, ·ƒv_3, '', 'bar', ·ƒfail_5, fn ·ƒctx_32, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_32, ·ƒv_6
            fn ·ƒv_15: ·ƒv_15 ·ƒctx_27, ·ƒv_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: capture at end', fn:
  expect cps_module ƒink:
    'foo${bar}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_1:
      ·fn
        fn ·ƒctx_29, ·ƒv_6:
          ·let ·ƒv_6, fn ·bar_0:
            ·ƒret_1 ·ƒctx_29, ·bar_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_30, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_30, ·ƒv_3, 'foo', '', ·ƒfail_5, fn ·ƒctx_32, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_32, ·ƒv_6
            fn ·ƒv_15: ·ƒv_15 ·ƒctx_27, ·ƒv_20, ·panic, ·∅val
    # sm:

test 'str templ pattern: match arm', fn:
  expect cps_module ƒink:
    match val:
      'foo${x}bar': x
      _: 0
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_80, ·ƒret_1:
      ·fn
        fn ·ƒctx_82, ·ƒret_21, ·x_0: ·ƒret_21 ·ƒctx_82, ·x_0
        fn ·ƒv_25:
          ·fn
            fn ·ƒctx_84, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·fn
                fn ·ƒctx_85, ·ƒv_10:
                  ·let ·ƒv_10, fn ·x_0:
                    ·ƒv_25 ·ƒctx_85, ·ƒsucc_4, ·ƒv_10
                fn ·ƒv_32:
                  ·fn
                    fn ·ƒctx_87, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                      ·str_match ·ƒctx_87, ·ƒv_7, 'foo', 'bar', ·ƒfail_9, fn ·ƒctx_89, ·ƒv_10:
                        ·ƒsucc_8 ·ƒctx_89, ·ƒv_10
                    fn ·ƒv_19: ·ƒv_19 ·ƒctx_84, ·ƒv_32, ·ƒfail_5, ·ƒv_3
            fn ·ƒv_39:
              ·fn
                fn ·ƒctx_92, ·ƒret_44: ·ƒret_44 ·ƒctx_92, (i8 0)
                fn ·ƒv_48:
                  ·fn
                    fn ·ƒctx_94, ·ƒsucc_41, ·ƒfail_42, ·ƒv_40: ·ƒv_48 ·ƒctx_94, ·ƒsucc_41
                    fn ·ƒv_53:
                      ·fn
                        fn ·ƒctx_96, ·ƒret_55, ·ƒv_54:
                          ·ƒv_39
                            ·ƒctx_96
                            ·ƒret_55
                            fn ·ƒctx_98:
                              ·ƒv_53
                                ·ƒctx_98
                                ·ƒret_55
                                fn ·ƒctx_100: ·panic ·ƒctx_100
                                ·ƒv_54
                            ·ƒv_54
                        fn ·ƒv_65: ·ƒv_65 ·ƒctx_80, ·ƒret_1, ·∅val
    # sm:
