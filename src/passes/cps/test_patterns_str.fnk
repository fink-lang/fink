test 'str templ pattern: capture at end', fn:
  expect cps_module ƒink:
    'foo${bar}' = val
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_1:
      ·fn
        fn ·ƒctx_32, ·ƒv_6:
          ·let ·ƒv_6, fn ·bar_0:
            ·ƒret_1 ·ƒctx_32, ·bar_0
        fn ·ƒv_20:
          ·fn
            fn ·ƒctx_33, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·str_match ·ƒctx_33, ·ƒv_3, 'foo', '', ·ƒfail_5, fn ·ƒctx_35, ·ƒv_6:
                ·ƒsucc_4 ·ƒctx_35, ·ƒv_6
            fn ·ƒv_15:
              ·fn
                fn ·ƒctx_37: ·panic ·ƒctx_37
                fn ·ƒv_23: ·ƒv_15 ·ƒctx_30, ·ƒv_20, ·ƒv_23, ·∅val
    # sm:

test 'str templ pattern: match arm', fn:
  expect cps_module ƒink:
    match val:
      'foo${x}bar': x
      _: 0
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_81, ·ƒret_1:
      ·fn
        fn ·ƒctx_83, ·ƒret_21, ·x_0: ·ƒret_21 ·ƒctx_83, ·x_0
        fn ·ƒv_25:
          ·fn
            fn ·ƒctx_85, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·fn
                fn ·ƒctx_86, ·ƒv_10:
                  ·let ·ƒv_10, fn ·x_0:
                    ·ƒv_25 ·ƒctx_86, ·ƒsucc_4, ·ƒv_10
                fn ·ƒv_32:
                  ·fn
                    fn ·ƒctx_88, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                      ·str_match ·ƒctx_88, ·ƒv_7, 'foo', 'bar', ·ƒfail_9, fn ·ƒctx_90, ·ƒv_10:
                        ·ƒsucc_8 ·ƒctx_90, ·ƒv_10
                    fn ·ƒv_19: ·ƒv_19 ·ƒctx_85, ·ƒv_32, ·ƒfail_5, ·ƒv_3
            fn ·ƒv_40:
              ·fn
                fn ·ƒctx_93, ·ƒret_45: ·ƒret_45 ·ƒctx_93, (i8 0)
                fn ·ƒv_49:
                  ·fn
                    fn ·ƒctx_95, ·ƒsucc_42, ·ƒfail_43, ·ƒv_41: ·ƒv_49 ·ƒctx_95, ·ƒsucc_42
                    fn ·ƒv_54:
                      ·fn
                        fn ·ƒctx_97, ·ƒret_56, ·ƒv_55:
                          ·ƒv_40
                            ·ƒctx_97
                            ·ƒret_56
                            fn ·ƒctx_99:
                              ·ƒv_54
                                ·ƒctx_99
                                ·ƒret_56
                                fn ·ƒctx_101: ·panic ·ƒctx_101
                                ·ƒv_55
                            ·ƒv_55
                        fn ·ƒv_66: ·ƒv_66 ·ƒctx_81, ·ƒret_1, ·∅val
    # sm:
