                        ·ƒret_4 ·ƒctx_70, ·ƒv_21
          fn ·ƒv_3:
            ·new_type ·ƒctx_56, ƒ'Option', fn ·ƒctx_73, ·ƒv_37:
              ·type_set_new ·ƒctx_73, ·ƒv_37, ·ƒv_3, fn ·ƒctx_75, ·ƒv_40:
