{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
type declaration lowering (CPS level 0)
---

test 'unit type declaration', fn:
  expect cps_module ƒink:
    Foo = type _
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_14, ·ƒret_1:
      ·letrec fn ·Foo_0:
        ·new_type ·ƒctx_14, fn ·ƒctx_17, ·ƒv_2:
          ·set ·Foo_0, ·ƒv_2, fn:
            ·ƒpub ·ƒctx_17, ·Foo_0, fn ·ƒctx_19:
              ·ƒret_1 ·ƒctx_19, ·Foo_0
    # sm:KQABAAwAAQAMJAEADBgBAAwSAAIABgEADAABAAwYAQADDgACAAoBDAYAAQAGFgAUAAoAGAEABg4AAgAOAQsMAAEADAwBAAMOAAQBDAYOAAgAAgASAQsDAAEAAxAAFAAEAQADDgAKABQAAgAWAQADAAEAAxQAFAAEAQAD


