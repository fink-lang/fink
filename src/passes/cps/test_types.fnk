              ·ƒpub ·ƒctx_34, ·P_0, fn ·ƒctx_45:
                ·ƒret_3 ·ƒctx_45, ·P_0
    # sm:



test 'union of two existing types', fn:
  expect cps_module ƒink:
    Num = union:
      Int
      Float
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_24, ·ƒret_1:
      ·letrec fn ·Num_0:
        ·new_union ·ƒctx_24, fn ·ƒctx_27, ·ƒv_2:
          ·union_add ·ƒctx_27, ·ƒv_2, ·∅Int, fn ·ƒctx_29, ·ƒv_5:
            ·union_add ·ƒctx_29, ·ƒv_5, ·∅Float, fn ·ƒctx_31, ·ƒv_8:
              ·set ·Num_0, ·ƒv_8, fn:
                ·ƒpub ·ƒctx_31, ·Num_0, fn ·ƒctx_33:
                  ·ƒret_1 ·ƒctx_33, ·Num_0
