test 'generic type with one param', fn:
  expect cps_module ƒink:
    Spam = type T:
      ham: T
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_2:
      ·letrec fn ·Spam_0:
        ·fn
          fn ·ƒctx_39, ·ƒret_4, ·T_1:
            ·new_type ·ƒctx_39, ƒ'Spam', fn ·ƒctx_41, ·ƒv_5:
              ·type_set_field ·ƒctx_41, ·ƒv_5, ƒ'ham', ·T_1, fn ·ƒctx_43, ·ƒv_10:
                ·ƒret_4 ·ƒctx_43, ·ƒv_10
          fn ·ƒv_3:
            ·new_type ·ƒctx_37, ƒ'Spam', fn ·ƒctx_46, ·ƒv_18:
              ·type_set_new ·ƒctx_46, ·ƒv_18, ·ƒv_3, fn ·ƒctx_48, ·ƒv_21:
                ·set ·Spam_0, ·ƒv_21, fn:
                  ·ƒpub ·ƒctx_48, ·Spam_0, fn ·ƒctx_50:
                    ·ƒret_2 ·ƒctx_50, ·Spam_0
    # sm:

test 'generic type with two params', fn:
  expect cps_module ƒink:
    P = type T1, T2:
      a: T1
      b: T2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_44, ·ƒret_3:
      ·letrec fn ·P_0:
        ·fn
          fn ·ƒctx_46, ·ƒret_5, ·T1_1, ·T2_2:
            ·new_type ·ƒctx_46, ƒ'P', fn ·ƒctx_48, ·ƒv_6:
              ·type_set_field ·ƒctx_48, ·ƒv_6, ƒ'a', ·T1_1, fn ·ƒctx_50, ·ƒv_11:
                ·type_set_field ·ƒctx_50, ·ƒv_11, ƒ'b', ·T2_2, fn ·ƒctx_52, ·ƒv_15:
                  ·ƒret_5 ·ƒctx_52, ·ƒv_15
          fn ·ƒv_4:
            ·new_type ·ƒctx_44, ƒ'P', fn ·ƒctx_55, ·ƒv_25:
              ·type_set_new ·ƒctx_55, ·ƒv_25, ·ƒv_4, fn ·ƒctx_57, ·ƒv_28:
