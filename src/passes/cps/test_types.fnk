test 'generic union applies referenced constructor', fn:
  expect cps_module ƒink:
    U = union T:
      Foo T
      Bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_2:
      ·letrec fn ·U_0:
        ·fn
          fn ·ƒctx_38, ·ƒret_4, ·T_1:
            ·new_union ·ƒctx_38, fn ·ƒctx_40, ·ƒv_5:
              ·∅Foo
                ·ƒctx_40
                fn ·ƒctx_42, ·ƒv_9:
                  ·union_add ·ƒctx_42, ·ƒv_5, ·ƒv_9, fn ·ƒctx_44, ·ƒv_11:
                    ·union_add ·ƒctx_44, ·ƒv_11, ·∅Bar, fn ·ƒctx_46, ·ƒv_14:
                      ·ƒret_4 ·ƒctx_46, ·ƒv_14
                ·T_1
          fn ·ƒv_3:
            ·set ·U_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_36, ·U_0, fn ·ƒctx_49:
                ·ƒret_2 ·ƒctx_49, ·U_0
    # sm:


test 'enum with mixed member payloads', fn:
  expect cps_module ƒink:
    Light = enum:
      Red {foo: u8}
      Green u8, u16
      Blue
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_57, ·ƒret_1:
      ·letrec fn ·Light_0:
        ·new_enum ·ƒctx_57, fn ·ƒctx_60, ·ƒv_2:
          ·new_type ·ƒctx_60, fn ·ƒctx_62, ·ƒv_4:
            ·type_set_field ·ƒctx_62, ·ƒv_4, 'foo', ·∅u8, fn ·ƒctx_64, ·ƒv_8:
              ·enum_add ·ƒctx_64, ·ƒv_2, 'Red', ·ƒv_8, fn ·ƒctx_66, ·ƒv_11:
                ·new_type ·ƒctx_66, fn ·ƒctx_68, ·ƒv_13:
                  ·type_push ·ƒctx_68, ·ƒv_13, ·∅u8, fn ·ƒctx_70, ·ƒv_16:
                    ·type_push ·ƒctx_70, ·ƒv_16, ·∅u16, fn ·ƒctx_72, ·ƒv_19:
                      ·enum_add ·ƒctx_72, ·ƒv_11, 'Green', ·ƒv_19, fn ·ƒctx_74, ·ƒv_22:
                        ·new_type ·ƒctx_74, fn ·ƒctx_76, ·ƒv_24:
                          ·enum_add ·ƒctx_76, ·ƒv_22, 'Blue', ·ƒv_24, fn ·ƒctx_78, ·ƒv_27:
                            ·set ·Light_0, ·ƒv_27, fn:
                              ·ƒpub ·ƒctx_78, ·Light_0, fn ·ƒctx_80:
                                ·ƒret_1 ·ƒctx_80, ·Light_0
    # sm:

test 'generic enum with param', fn:
  expect cps_module ƒink:
    Option = enum T:
      Some T
      None
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_44, ·ƒret_2:
      ·letrec fn ·Option_0:
        ·fn
          fn ·ƒctx_46, ·ƒret_4, ·T_1:
            ·new_enum ·ƒctx_46, fn ·ƒctx_48, ·ƒv_5:
              ·new_type ·ƒctx_48, fn ·ƒctx_50, ·ƒv_7:
                ·type_push ·ƒctx_50, ·ƒv_7, ·T_1, fn ·ƒctx_52, ·ƒv_10:
                  ·enum_add ·ƒctx_52, ·ƒv_5, 'Some', ·ƒv_10, fn ·ƒctx_54, ·ƒv_13:
                    ·new_type ·ƒctx_54, fn ·ƒctx_56, ·ƒv_15:
                      ·enum_add ·ƒctx_56, ·ƒv_13, 'None', ·ƒv_15, fn ·ƒctx_58, ·ƒv_18:
                        ·ƒret_4 ·ƒctx_58, ·ƒv_18
          fn ·ƒv_3:
            ·set ·Option_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_44, ·Option_0, fn ·ƒctx_61:
                ·ƒret_2 ·ƒctx_61, ·Option_0
    # sm:
