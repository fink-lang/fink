      ·letrec fn ·P_0:
        ·fn
          fn ·ƒctx_36, ·ƒret_5, ·T1_1, ·T2_2:
            ·new_type ·ƒctx_36, fn ·ƒctx_38, ·ƒv_6:
              ·type_set_field ·ƒctx_38, ·ƒv_6, 'a', ·T1_1, fn ·ƒctx_40, ·ƒv_10:
                ·type_set_field ·ƒctx_40, ·ƒv_10, 'b', ·T2_2, fn ·ƒctx_42, ·ƒv_14:
                  ·ƒret_5 ·ƒctx_42, ·ƒv_14
          fn ·ƒv_4:
