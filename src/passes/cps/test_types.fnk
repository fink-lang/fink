                  ·ƒpub ·ƒctx_57, ·P_0, fn ·ƒctx_59:
                    ·ƒret_3 ·ƒctx_59, ·P_0
    # sm:



test 'union of two existing types', fn:
  expect cps_module ƒink:
    Num = union:
      Int
      Float
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_25, ·ƒret_1:
      ·letrec fn ·Num_0:
        ·new_union ·ƒctx_25, ƒ'Num', fn ·ƒctx_28, ·ƒv_2:
          ·union_add ·ƒctx_28, ·ƒv_2, ·∅Int, fn ·ƒctx_30, ·ƒv_6:
            ·union_add ·ƒctx_30, ·ƒv_6, ·∅Float, fn ·ƒctx_32, ·ƒv_9:
              ·set ·Num_0, ·ƒv_9, fn:
