test 'generic type with one param', fn:
  expect cps_module ƒink:
    Spam = type T:
      ham: T
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_2:
      ·letrec fn ·Spam_0:
        ·fn
          fn ·ƒctx_29, ·ƒret_4, ·T_1:
            ·new_type ·ƒctx_29, fn ·ƒctx_31, ·ƒv_5:
              ·type_set_field ·ƒctx_31, ·ƒv_5, 'ham', ·T_1, fn ·ƒctx_33, ·ƒv_9:
                ·ƒret_4 ·ƒctx_33, ·ƒv_9
          fn ·ƒv_3:
            ·set ·Spam_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_27, ·Spam_0, fn ·ƒctx_36:
                ·ƒret_2 ·ƒctx_36, ·Spam_0
    # sm:

test 'generic type with two params', fn:
