              ·new_type ·ƒctx_60, ƒ'Some', fn ·ƒctx_62, ·ƒv_8:
                ·type_push ·ƒctx_62, ·ƒv_8, ·T_1, fn ·ƒctx_64, ·ƒv_12:
                  ·enum_add ·ƒctx_64, ·ƒv_5, ƒ'Some', ·ƒv_12, fn ·ƒctx_66, ·ƒv_15:
                    ·new_type ·ƒctx_66, ƒ'None', fn ·ƒctx_68, ·ƒv_17:
