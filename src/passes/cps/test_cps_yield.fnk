---
yield — CPS lowering tests
---

# yield suspends execution, yielding a value to the scheduler.
# The continuation receives the resumed value.
#
# In CPS:
#   yield value
# becomes:
#   ·yield value, fn ·v_{cps_id}:
#     <continuation>


test 'yield literal', fn:
  expect cps_expr fink":
    yield 42

  | equals fink":
    ·yield 42, fn ·v_1:
      ·ƒ_cont ·v_1


test 'yield ident', fn:
  expect cps_expr fink":
    yield foo

  | equals fink":
    ·yield foo, fn ·v_1:
      ·ƒ_cont ·v_1


test 'yield bound to name', fn:
  expect cps_expr fink":
    result = yield 42

  | equals fink":
    ·yield 42, fn ·v_1:
      ·let ·v_1, fn result:
        ·ƒ_cont result


test 'yield apply result', fn:
  expect cps_expr fink":
    yield foo bar

  | equals fink":
    ·apply foo, bar, fn ·v_2:
      ·yield ·v_2, fn ·v_4:
        ·ƒ_cont ·v_4
