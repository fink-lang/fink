---
yield — CPS lowering tests
---

# yield suspends execution, yielding a value to the scheduler.
# The continuation receives the resumed value.
#
# In CPS:
#   yield value
# becomes:
#   ·yield value, fn ·v_{cps_id}:
#     <continuation>

{test, equals, expect, fink, cps_expr} = import 'fake!'

test 'yield literal', fn:
  expect cps_expr fink":
    yield 42

  | equals fink":
    ·yield 42, ·ƒ_0


test 'yield ident', fn:
  expect cps_expr fink":
    yield foo

  | equals fink":
    ·yield ·v_0, ·ƒ_0


test 'yield bound to name', fn:
  expect cps_expr fink":
    result = yield 42

  | equals fink":
    ·yield 42, fn ·v_3:
      ·let ·v_3, fn ·result_0:
        ·ƒ_1 ·result_0


test 'yield apply result', fn:
  expect cps_expr fink":
    yield foo bar

  | equals fink":
    ·v_0 ·bar_2, fn ·v_3:
      ·yield ·v_3, ·ƒ_0
