---
yield — CPS lowering tests
---

# yield suspends execution, yielding a value to the scheduler.
# The continuation receives the resumed value.
#
# In CPS:
#   yield value
# becomes:
#   ·yield value, ·state, fn ·v_N, ·state:
#     <continuation>


test 'yield literal', fn:
  expect cps_expr fink":
    yield 42

  | equals fink":
    ·yield 42, ·state, fn ·v_0, ·state:
      ·ƒ_cont ·v_0, ·state


test 'yield ident', fn:
  expect cps_expr fink":
    yield foo

  | equals fink":
    ·yield foo, ·state, fn ·v_0, ·state:
      ·ƒ_cont ·v_0, ·state


test 'yield bound to name', fn:
  expect cps_expr fink":
    result = yield 42

  | equals fink":
    ·yield 42, ·state, fn ·v_0, ·state:
      ·let ·v_0, fn result:
        ·ƒ_cont result, ·state


test 'yield apply result', fn:
  expect cps_expr fink":
    yield foo bar

  | equals fink":
    ·apply foo, bar, ·state, fn ·v_0, ·state:
      ·yield ·v_0, ·state, fn ·v_1, ·state:
        ·ƒ_cont ·v_1, ·state
