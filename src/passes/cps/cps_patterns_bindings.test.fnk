                          ·if ·ƒv_14,
                            fn: ·ƒsucc_7 ·ƒctx_72
                            fn: ·ƒfail_8 ·ƒctx_72
                    fn ·ƒv_23: ·ƒv_23 ·ƒctx_65, ·ƒv_36, ·ƒfail_4, ·ƒv_2
            fn ·ƒv_42:
              ·fn
                fn ·ƒctx_76, ·ƒret_44, ·ƒv_43:
                  ·ƒv_42
                    ·ƒctx_76
                    ·ƒret_44
                    fn ·ƒctx_78: ·panic ·ƒctx_78
                    ·ƒv_43
                fn ·ƒv_50: ·ƒv_50 ·ƒctx_61, ·ƒret_0, ·∅x
    # sm:


test 'range — bind-lhs check', fn:
  cps_module ƒink:
    0..10 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_0:
      ·fn
        fn ·ƒctx_38, ·ƒv_20: ·ƒret_0 ·ƒctx_38, ·ƒv_20
        fn ·ƒv_23:
          ·fn
            fn ·ƒctx_40, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·op_rngex ·ƒctx_40, (i8 0), (i8 10), fn ·ƒctx_42, ·ƒv_15:
                ·op_in ·ƒctx_42, ·ƒv_2, ·ƒv_15, fn ·ƒctx_44, ·ƒv_10:
                  ·if ·ƒv_10,
                    fn: ·ƒsucc_3 ·ƒctx_44
                    fn: ·ƒfail_4 ·ƒctx_44
            fn ·ƒv_19:
              ·fn
                fn ·ƒctx_47: ·panic ·ƒctx_47
                fn ·ƒv_26: ·ƒv_19 ·ƒctx_36, ·ƒv_23, ·ƒv_26, ·∅foo
    # sm:


---
fn params (·v_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  cps_module ƒink:
    fn [a, b]: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_61, ·ƒret_2:
      ·fn
        fn ·ƒctx_63, ·ƒret_40, ·ƒv_4:
          ·fn
            fn ·ƒctx_64, ·ƒv_9, ·ƒv_10:
              ·let ·ƒv_9, fn ·a_0:
                ·let ·ƒv_10, fn ·b_1:
                  ·ƒret_40 ·ƒctx_64, ·a_0
            fn ·ƒv_49:
              ·fn
                fn ·ƒctx_66, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                  ·guard_apply ·ƒctx_66, ·tuple_protocol, ·ƒv_6,
                    fn ·ƒctx_68, ·ƒv_23:
                      ·seq_pop ·ƒctx_68, ·ƒv_23, ·ƒfail_8, fn ·ƒctx_70, ·ƒv_9, ·ƒv_24:
                        ·seq_pop ·ƒctx_70, ·ƒv_24, ·ƒfail_8, fn ·ƒctx_72, ·ƒv_10, ·ƒv_15:
                          ·empty ·ƒctx_72, ·ƒv_15, fn ·ƒctx_74, ·ƒv_18:
                            ·if ·ƒv_18,
                              fn: ·ƒsucc_7 ·ƒctx_74, ·ƒv_9, ·ƒv_10
                              fn: ·ƒfail_8 ·ƒctx_74
                    fn ·ƒctx_77: ·ƒfail_8 ·ƒctx_77
                fn ·ƒv_36:
                  ·fn
                    fn ·ƒctx_79: ·panic ·ƒctx_79
                    fn ·ƒv_52: ·ƒv_36 ·ƒctx_63, ·ƒv_49, ·ƒv_52, ·ƒv_4
        fn ·ƒv_3: ·ƒret_2 ·ƒctx_61, ·ƒv_3
    # sm:

test 'fn — seq destructuring param with rest', fn:
  cps_module ƒink:
    fn [a, ..rest]: rest
  | equals ƒink:
