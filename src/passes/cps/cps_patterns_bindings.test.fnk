      ·fn
        fn ·ƒctx_54, ·ƒret_31, ·ƒv_4:
          ·fn
            fn ·ƒctx_55, ·ƒv_9, ·ƒv_10:
              ·let ·ƒv_9, fn ·a_0:
                ·let ·ƒv_10, fn ·rest_1:
                  ·ƒret_31 ·ƒctx_55, ·rest_1
            fn ·ƒv_40:
              ·fn
                fn ·ƒctx_57, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                  ·guard_apply ·ƒctx_57, ·tuple_protocol, ·ƒv_6,
                    fn ·ƒctx_59, ·ƒv_18:
                      ·seq_pop ·ƒctx_59, ·ƒv_18, ·ƒfail_8, fn ·ƒctx_61, ·ƒv_9, ·ƒv_15:
                        ·let ·ƒv_15, fn ·ƒv_10:
                          ·ƒsucc_7 ·ƒctx_61, ·ƒv_9, ·ƒv_10
                    fn ·ƒctx_63: ·ƒfail_8 ·ƒctx_63
                fn ·ƒv_27:
                  ·fn
                    fn ·ƒctx_65: ·panic ·ƒctx_65
                    fn ·ƒv_43: ·ƒv_27 ·ƒctx_54, ·ƒv_40, ·ƒv_43, ·ƒv_4
        fn ·ƒv_3: ·ƒret_2 ·ƒctx_52, ·ƒv_3
    # sm:


test 'varargs — complex destructuring desugars to pattern in body', fn:
  cps_module ƒink:
    fn a, [1, ..b]: b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_76, ·ƒret_2:
      ·fn
        fn ·ƒctx_78, ·ƒret_46, ·a_0, ·ƒv_4:
          ·fn
            fn ·ƒctx_79, ·ƒv_9, ·ƒv_10:
              ·fn
                fn ·ƒctx_80:
                  ·let ·ƒv_10, fn ·b_1:
                    ·ƒret_46 ·ƒctx_80, ·b_1
                fn ·ƒv_53:
                  ·fn
                    fn ·ƒctx_82, ·ƒsucc_30, ·ƒfail_31, ·ƒv_29:
                      ·op_eq ·ƒctx_82, ·ƒv_29, (i8 1), fn ·ƒctx_84, ·ƒv_34:
                        ·if ·ƒv_34,
                          fn: ·ƒsucc_30 ·ƒctx_84
                          fn: ·ƒfail_31 ·ƒctx_84
                    fn ·ƒv_42:
                      ·fn
                        fn ·ƒctx_87: ·panic ·ƒctx_87
                        fn ·ƒv_56: ·ƒv_42 ·ƒctx_79, ·ƒv_53, ·ƒv_56, ·ƒv_9
            fn ·ƒv_64:
              ·fn
                fn ·ƒctx_90, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                  ·guard_apply ·ƒctx_90, ·tuple_protocol, ·ƒv_6,
                    fn ·ƒctx_92, ·ƒv_18:
                      ·seq_pop ·ƒctx_92, ·ƒv_18, ·ƒfail_8, fn ·ƒctx_94, ·ƒv_9, ·ƒv_15:
                        ·let ·ƒv_15, fn ·ƒv_10:
                          ·ƒsucc_7 ·ƒctx_94, ·ƒv_9, ·ƒv_10
                    fn ·ƒctx_96: ·ƒfail_8 ·ƒctx_96
                fn ·ƒv_27:
                  ·fn
                    fn ·ƒctx_98: ·panic ·ƒctx_98
                    fn ·ƒv_67: ·ƒv_27 ·ƒctx_78, ·ƒv_64, ·ƒv_67, ·ƒv_4
        fn ·ƒv_3: ·ƒret_2 ·ƒctx_76, ·ƒv_3
    # sm:
