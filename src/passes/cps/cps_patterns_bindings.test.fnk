{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{cps_module} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected

---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  cps_module ƒink:
    x > 2 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_34, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·x_0, ·∅foo, fn:
          ·fn
            fn ·ƒctx_36, ·x_0: ·ƒret_1 ·ƒctx_36, ·x_0
            fn ·ƒv_18:
              ·fn
                fn ·ƒctx_38, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                  ·op_gt ·ƒctx_38, ·ƒv_3, (i8 2), fn ·ƒctx_40, ·ƒv_8:
                    ·if ·ƒv_8,
                      fn: ·ƒsucc_4 ·ƒctx_40, ·ƒv_3
                      fn: ·ƒfail_5 ·ƒctx_40
                fn ·ƒv_16:
                  ·fn
                    fn ·ƒctx_43: ·panic ·ƒctx_43
                    fn ·ƒv_21: ·ƒv_16 ·ƒctx_34, ·ƒv_18, ·ƒv_21, ·∅foo
    # sm:


test 'bind right — seq pattern', fn:
  cps_module ƒink:
    [a, b] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_54, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·fn
          fn ·ƒctx_56, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·a_0:
              ·let ·ƒv_8, fn ·b_1:
                ·ƒret_2 ·ƒctx_56, ·b_1
          fn ·ƒv_43:
            ·fn
              fn ·ƒctx_57, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·guard_apply ·ƒctx_57, ·tuple_protocol, ·ƒv_4,
                  fn ·ƒctx_59, ·ƒv_21:
                    ·seq_pop ·ƒctx_59, ·ƒv_21, ·ƒfail_6, fn ·ƒctx_61, ·ƒv_7, ·ƒv_22:
                      ·seq_pop ·ƒctx_61, ·ƒv_22, ·ƒfail_6, fn ·ƒctx_63, ·ƒv_8, ·ƒv_13:
                        ·empty ·ƒctx_63, ·ƒv_13, fn ·ƒctx_65, ·ƒv_16:
                          ·if ·ƒv_16,
                            fn: ·ƒsucc_5 ·ƒctx_65, ·ƒv_7, ·ƒv_8
                            fn: ·ƒfail_6 ·ƒctx_65
                  fn ·ƒctx_68: ·ƒfail_6 ·ƒctx_68
              fn ·ƒv_34:
                ·fn
                  fn ·ƒctx_70: ·panic ·ƒctx_70
                  fn ·ƒv_46: ·ƒv_34 ·ƒctx_54, ·ƒv_43, ·ƒv_46, ·∅foo
    # sm:


test 'bind right — rec pattern', fn:
  cps_module ƒink:
    {bar} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_38, ·ƒret_1:
      ·letrec fn ·bar_0:
        ·fn
          fn ·ƒctx_40, ·ƒv_6:
            ·let ·ƒv_6, fn ·bar_0:
              ·ƒret_1 ·ƒctx_40, ·bar_0
          fn ·ƒv_27:
            ·fn
              fn ·ƒctx_41, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·guard_apply ·ƒctx_41, ·rec_protocol, ·ƒv_3,
                  fn ·ƒctx_43, ·ƒv_11:
                    ·rec_pop ·ƒctx_43, ·ƒv_11, ƒ'bar', ·ƒfail_5, fn ·ƒctx_45, ·ƒv_6, ·ƒv_10:
                      ·ƒsucc_4 ·ƒctx_45, ·ƒv_6
                  fn ·ƒctx_47: ·ƒfail_5 ·ƒctx_47
              fn ·ƒv_21:
                ·fn
                  fn ·ƒctx_49: ·panic ·ƒctx_49
                  fn ·ƒv_30: ·ƒv_21 ·ƒctx_38, ·ƒv_27, ·ƒv_30, ·∅foo
    # sm:


test 'seq pattern', fn:
  cps_module ƒink:
    [a, 1] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_80, ·ƒret_1:
      ·letrec fn ·a_0:
        ·fn
          fn ·ƒctx_82, ·ƒv_6, ·ƒv_7:
            ·let ·ƒv_6, fn ·a_0:
              ·fn
                fn ·ƒctx_83: ·ƒret_1 ·ƒctx_83, ·panic
                fn ·ƒv_53:
                  ·fn
                    fn ·ƒctx_85, ·ƒsucc_37, ·ƒfail_38, ·ƒv_36:
                      ·op_eq ·ƒctx_85, ·ƒv_36, (i8 1), fn ·ƒctx_87, ·ƒv_41:
                        ·if ·ƒv_41,
                          fn: ·ƒsucc_37 ·ƒctx_87
                          fn: ·ƒfail_38 ·ƒctx_87
                    fn ·ƒv_49:
                      ·fn
                        fn ·ƒctx_90: ·panic ·ƒctx_90
                        fn ·ƒv_56: ·ƒv_49 ·ƒctx_82, ·ƒv_53, ·ƒv_56, ·ƒv_7
          fn ·ƒv_69:
            ·fn
              fn ·ƒctx_93, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·guard_apply ·ƒctx_93, ·tuple_protocol, ·ƒv_3,
                  fn ·ƒctx_95, ·ƒv_20:
                    ·seq_pop ·ƒctx_95, ·ƒv_20, ·ƒfail_5, fn ·ƒctx_97, ·ƒv_6, ·ƒv_21:
                      ·seq_pop ·ƒctx_97, ·ƒv_21, ·ƒfail_5, fn ·ƒctx_99, ·ƒv_7, ·ƒv_12:
                        ·empty ·ƒctx_99, ·ƒv_12, fn ·ƒctx_101, ·ƒv_15:
                          ·if ·ƒv_15,
                            fn: ·ƒsucc_4 ·ƒctx_101, ·ƒv_6, ·ƒv_7
                            fn: ·ƒfail_5 ·ƒctx_101
                  fn ·ƒctx_104: ·ƒfail_5 ·ƒctx_104
              fn ·ƒv_33:
                ·fn
                  fn ·ƒctx_106: ·panic ·ƒctx_106
                  fn ·ƒv_72: ·ƒv_33 ·ƒctx_80, ·ƒv_69, ·ƒv_72, ·∅foo
    # sm:

test 'seq pattern with non-empty rest', fn:
  cps_module ƒink:
    [a, ..] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_1:
      ·letrec fn ·a_0:
        ·fn
          fn ·ƒctx_39, ·ƒv_6:
            ·let ·ƒv_6, fn ·a_0:
              ·ƒret_1 ·ƒctx_39, ·a_0
          fn ·ƒv_26:
            ·fn
              fn ·ƒctx_40, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·guard_apply ·ƒctx_40, ·tuple_protocol, ·ƒv_3,
                  fn ·ƒctx_42, ·ƒv_11:
                    ·seq_pop ·ƒctx_42, ·ƒv_11, ·ƒfail_5, fn ·ƒctx_44, ·ƒv_6, ·ƒv_10:
                      ·ƒsucc_4 ·ƒctx_44, ·ƒv_6
                  fn ·ƒctx_46: ·ƒfail_5 ·ƒctx_46
              fn ·ƒv_20:
                ·fn
                  fn ·ƒctx_48: ·panic ·ƒctx_48
                  fn ·ƒv_29: ·ƒv_20 ·ƒctx_37, ·ƒv_26, ·ƒv_29, ·∅foo
    # sm:

test 'seq pattern with bound rest', fn:
  cps_module ƒink:
    [a, ..rest] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_2:
      ·letrec fn ·a_0, ·rest_1:
        ·fn
          fn ·ƒctx_47, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·a_0:
              ·let ·ƒv_8, fn ·rest_1:
                ·ƒret_2 ·ƒctx_47, ·rest_1
          fn ·ƒv_34:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·guard_apply ·ƒctx_48, ·tuple_protocol, ·ƒv_4,
                  fn ·ƒctx_50, ·ƒv_16:
                    ·seq_pop ·ƒctx_50, ·ƒv_16, ·ƒfail_6, fn ·ƒctx_52, ·ƒv_7, ·ƒv_13:
                      ·let ·ƒv_13, fn ·ƒv_8:
                        ·ƒsucc_5 ·ƒctx_52, ·ƒv_7, ·ƒv_8
                  fn ·ƒctx_54: ·ƒfail_6 ·ƒctx_54
              fn ·ƒv_25:
                ·fn
                  fn ·ƒctx_56: ·panic ·ƒctx_56
                  fn ·ƒv_37: ·ƒv_25 ·ƒctx_45, ·ƒv_34, ·ƒv_37, ·∅foo
    # sm:


---
range patterns
---

test 'range — exclusive in match arm', fn:
  cps_module ƒink:
    match x:
      0..10: 'low'
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_61, ·ƒret_0:
      ·fn
        fn ·ƒctx_63, ·ƒret_26: ·ƒret_26 ·ƒctx_63, 'low'
        fn ·ƒv_30:
          ·fn
            fn ·ƒctx_65, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·fn
                fn ·ƒctx_66: ·ƒv_30 ·ƒctx_66, ·ƒsucc_3
                fn ·ƒv_36:
                  ·fn
                    fn ·ƒctx_68, ·ƒsucc_7, ·ƒfail_8, ·ƒv_6:
                      ·op_rngex ·ƒctx_68, (i8 0), (i8 10), fn ·ƒctx_70, ·ƒv_19:
                        ·op_in ·ƒctx_70, ·ƒv_6, ·ƒv_19, fn ·ƒctx_72, ·ƒv_14:
                          ·if ·ƒv_14,
                            fn: ·ƒsucc_7 ·ƒctx_72
                            fn: ·ƒfail_8 ·ƒctx_72
                    fn ·ƒv_23: ·ƒv_23 ·ƒctx_65, ·ƒv_36, ·ƒfail_4, ·ƒv_2
            fn ·ƒv_42:
              ·fn
                fn ·ƒctx_76, ·ƒret_44, ·ƒv_43:
                  ·ƒv_42
                    ·ƒctx_76
                    ·ƒret_44
                    fn ·ƒctx_78: ·panic ·ƒctx_78
                    ·ƒv_43
                fn ·ƒv_50: ·ƒv_50 ·ƒctx_61, ·ƒret_0, ·∅x
    # sm:


test 'range — inclusive in match arm', fn:
