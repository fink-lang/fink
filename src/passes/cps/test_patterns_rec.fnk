{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
rec patterns
---

test 'rec — empty', fn:
  expect cps_module ƒink:
    {} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_0:
      ·fn
        fn ·ƒctx_38, ·v_5: ·ƒret_0 ·ƒctx_38, ·v_5
        fn ·v_26:
          ·fn
            fn ·ƒctx_40, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·is_rec_like ·v_2,
                fn ·v_16:
                  ·let ·v_16, fn ·v_8:
                    ·empty ·v_8, fn ·v_11:
                      ·if ·v_11,
                        fn: ·ƒsucc_3 ·ƒctx_40
                        fn: ·ƒfail_4 ·ƒctx_40
                fn: ·ƒfail_4 ·ƒctx_40
            fn ·v_23: ·v_23 ·ƒctx_36, ·v_26, ·panic, ·∅foo
    # sm:


