              ·guard_apply ·ƒctx_44, ·rec_protocol, ·ƒv_2,
                fn ·ƒctx_46, ·ƒv_16:
                  ·let ·ƒv_16, fn ·ƒv_8:
                    ·empty ·ƒctx_46, ·ƒv_8, fn ·ƒctx_48, ·ƒv_11:
                      ·if ·ƒv_11,
                        fn: ·ƒsucc_3 ·ƒctx_48
                        fn: ·ƒfail_4 ·ƒctx_48
                fn ·ƒctx_51: ·ƒfail_4 ·ƒctx_51
            fn ·ƒv_24:
              ·fn
                fn ·ƒctx_53: ·panic ·ƒctx_53
                fn ·ƒv_30: ·ƒv_24 ·ƒctx_40, ·ƒv_27, ·ƒv_30, ·∅foo
    # sm:


