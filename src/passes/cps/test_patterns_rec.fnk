{test, skip, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
rec patterns
---

test 'rec — empty', fn:
  expect cps_module ƒink:
    {} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_0:
      ·fn
        fn ·ƒctx_41, ·ƒv_5: ·ƒret_0 ·ƒctx_41, ·ƒv_5
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_43, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·is_rec_like ·ƒctx_43, ·ƒv_2,
                fn ·ƒctx_45, ·ƒv_16:
                  ·let ·ƒv_16, fn ·ƒv_8:
                    ·empty ·ƒctx_45, ·ƒv_8, fn ·ƒctx_47, ·ƒv_11:
                      ·if ·ƒv_11,
                        fn: ·ƒsucc_3 ·ƒctx_47
                        fn: ·ƒfail_4 ·ƒctx_47
                fn ·ƒctx_50: ·ƒfail_4 ·ƒctx_50
            fn ·ƒv_23:
              ·fn
                fn ·ƒctx_52: ·panic ·ƒctx_52
                fn ·ƒv_29: ·ƒv_23 ·ƒctx_39, ·ƒv_26, ·ƒv_29, ·∅foo
    # sm:


