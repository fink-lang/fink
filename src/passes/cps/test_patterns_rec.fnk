test 'rec — open rest discarded', fn:
  expect cps_expr ƒink:
    {bar, ..} = foo
  | equals ƒink:
    ·fn
      fn ·v_6:
        ·let ·v_6, fn ·bar_0:
          ·v_1 ·bar_0
      fn ·v_33:
        ·fn
          fn ·ƒsucc_4, ·ƒfail_5, ·v_3:
            ·is_rec_like ·v_3,
              fn ·v_18:
                ·rec_pop ·v_18, 'bar', ·ƒfail_5, fn ·v_6, ·v_10:
                  ·empty ·v_10, fn ·v_13:
                    ·if ·v_13,
                      fn: ·ƒfail_5 _
                      fn: ·ƒsucc_4 ·v_6
              fn: ·ƒfail_5 _
          fn ·v_27: ·v_27 ·v_33, ·panic, ·∅foo
    #sourcemaps:


test 'rec — open rest bound', fn:
  expect cps_expr ƒink:
    {bar, ..rest} = foo
  | equals ƒink:
    ·fn
      fn ·v_7, ·v_8:
        ·let ·v_7, fn ·bar_0:
          ·let ·v_8, fn ·rest_1:
            ·v_2 ·rest_1
      fn ·v_34:
        ·fn
          fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
            ·is_rec_like ·v_4,
              fn ·v_16:
                ·rec_pop ·v_16, 'bar', ·ƒfail_6, fn ·v_7, ·v_13:
                  ·let ·v_13, fn ·v_8:
                    ·ƒsucc_5 ·v_7, ·v_8
              fn: ·ƒfail_6 _
          fn ·v_25: ·v_25 ·v_34, ·panic, ·∅foo
