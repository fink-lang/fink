                    ·if ·v_13,
                      fn: ·ƒsucc_4 ·v_6
                      fn: ·ƒfail_5 _
              fn: ·ƒfail_5 _
          fn ·v_27: ·v_27 ·v_33, ·panic, ·∅foo
