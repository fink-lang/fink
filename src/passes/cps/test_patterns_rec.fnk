test 'rec — partial match', fn:
  expect cps_module ƒink:
    {x, y} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_48, ·ƒret_2:
      ·letrec fn ·x_0, ·y_1:
        ·fn
          fn ·ƒctx_50, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·x_0:
              ·let ·ƒv_8, fn ·y_1:
                ·ƒret_2 ·ƒctx_50, ·y_1
          fn ·ƒv_37:
            ·fn
              fn ·ƒctx_51, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·is_rec_like ·ƒctx_51, ·ƒv_4,
                  fn ·ƒctx_53, ·ƒv_14:
                    ·rec_pop ·ƒctx_53, ·ƒv_14, 'x', ·ƒfail_6, fn ·ƒctx_55, ·ƒv_7, ·ƒv_15:
                      ·rec_pop ·ƒctx_55, ·ƒv_15, 'y', ·ƒfail_6, fn ·ƒctx_57, ·ƒv_8, ·ƒv_13:
                        ·ƒsucc_5 ·ƒctx_57, ·ƒv_7, ·ƒv_8
                  fn ·ƒctx_59: ·ƒfail_6 ·ƒctx_59
              fn ·ƒv_28:
                ·fn
                  fn ·ƒctx_61: ·panic ·ƒctx_61
                  fn ·ƒv_40: ·ƒv_28 ·ƒctx_48, ·ƒv_37, ·ƒv_40, ·∅point
    # sm:


