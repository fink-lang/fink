test 'rec — closed with sub-pattern', fn:
  expect cps_expr ƒink:
    {foo, ..{bar, spam}} = x
  | equals ƒink:
    ·fn
      fn ·v_8, ·v_9:
        ·let ·v_8, fn ·foo_0:
          ·fn
            fn ·v_32, ·v_33:
              ·let ·v_32, fn ·bar_1:
                ·let ·v_33, fn ·spam_2:
                  ·v_3 ·spam_2
            fn ·v_63:
              ·fn
                fn ·ƒsucc_30, ·ƒfail_31, ·v_29:
                  ·is_rec_like ·v_29,
                    fn ·v_39:
                      ·rec_pop ·v_39, 'bar', ·ƒfail_31, fn ·v_32, ·v_40:
                        ·rec_pop ·v_40, 'spam', ·ƒfail_31, fn ·v_33, ·v_38:
                          ·ƒsucc_30 ·v_32, ·v_33
                    fn: ·ƒfail_31 _
                fn ·v_53: ·v_53 ·v_63, ·panic, ·v_9
      fn ·v_73:
        ·fn
          fn ·ƒsucc_6, ·ƒfail_7, ·v_5:
            ·is_rec_like ·v_5,
              fn ·v_17:
                ·rec_pop ·v_17, 'foo', ·ƒfail_7, fn ·v_8, ·v_14:
                  ·let ·v_14, fn ·v_9:
                    ·ƒsucc_6 ·v_8, ·v_9
              fn: ·ƒfail_7 _
          fn ·v_26: ·v_26 ·v_73, ·panic, ·∅x
    #sourcemaps:


