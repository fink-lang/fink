test 'rec — predicate guard in value position', fn:
  expect cps_module ƒink:
    {k: is_even v} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_1:
      ·fn
        fn ·ƒctx_47, ·v_6:
          ·let ·v_6, fn ·v_0:
            ·∅is_even
              ·ƒctx_47
              fn ·ƒctx_49, ·v_31:
                ·if ·k_31,
                  fn: ·ƒret_1 ·ƒctx_49
                  fn: ·panic ·ƒctx_49
              ·v_0
        fn ·v_38:
          ·fn
            fn ·ƒctx_52, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·is_rec_like ·ƒctx_52, ·v_3,
                fn ·ƒctx_54, ·v_11:
                  ·rec_pop ·ƒctx_54, ·v_11, 'k', ·ƒfail_5, fn ·ƒctx_56, ·v_6, ·v_10:
                    ·ƒsucc_4 ·ƒctx_56, ·v_6
                fn ·ƒctx_58: ·ƒfail_5 ·ƒctx_58
            fn ·v_20: ·v_20 ·ƒctx_45, ·v_38, ·panic, ·∅foo
    # sm:


test 'rec — infix comparison guard in value position', fn:
  expect cps_module ƒink:
    {k: v == 4} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_1:
      ·fn
        fn ·ƒctx_60, ·v_6:
          ·let ·v_6, fn ·v_0:
            ·fn
              fn ·ƒctx_61, ·v_0: ·ƒret_1 ·ƒctx_61, ·v_0
              fn ·v_38:
                ·fn
                  fn ·ƒctx_63, ·ƒsucc_23, ·ƒfail_24, ·v_22:
                    ·op_eq ·ƒctx_63, ·k_22, (i8 4), fn ·ƒctx_65, ·v_27:
                      ·if ·v_27,
                        fn: ·ƒsucc_23 ·ƒctx_65, ·k_22
                        fn: ·ƒfail_24 ·ƒctx_65
                  fn ·v_35: ·k_35 ·ƒctx_60, ·k_38, ·panic, ·v_6
        fn ·v_51:
          ·fn
            fn ·ƒctx_69, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·is_rec_like ·ƒctx_69, ·v_3,
                fn ·ƒctx_71, ·v_11:
                  ·rec_pop ·ƒctx_71, ·v_11, 'k', ·ƒfail_5, fn ·ƒctx_73, ·v_6, ·v_10:
                    ·ƒsucc_4 ·ƒctx_73, ·v_6
                fn ·ƒctx_75: ·ƒfail_5 ·ƒctx_75
            fn ·v_20: ·v_20 ·ƒctx_58, ·v_51, ·panic, ·∅foo
    # sm:


test 'rec — closed with sub-pattern', fn:
  expect cps_module ƒink:
    {foo, ..{bar, spam}} = x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_81, ·ƒret_3:
      ·letrec fn ·foo_0, ·bar_1, ·spam_2:
        ·fn
          fn ·ƒctx_83, ·v_8, ·v_9:
            ·let ·v_8, fn ·foo_0:
              ·fn
                fn ·ƒctx_84, ·v_32, ·v_33:
                  ·let ·v_32, fn ·bar_1:
                    ·let ·v_33, fn ·spam_2:
                      ·ƒret_3 ·ƒctx_84, ·spam_2
                fn ·v_63:
                  ·fn
                    fn ·ƒctx_85, ·ƒsucc_30, ·ƒfail_31, ·v_29:
                      ·is_rec_like ·ƒctx_85, ·v_29,
                        fn ·ƒctx_87, ·v_39:
                          ·rec_pop ·ƒctx_87, ·v_39, 'bar', ·ƒfail_31, fn ·ƒctx_89, ·v_32, ·v_40:
                            ·rec_pop ·ƒctx_89, ·v_40, 'spam', ·ƒfail_31, fn ·ƒctx_91, ·v_33, ·v_38:
                              ·ƒsucc_30 ·ƒctx_91, ·v_32, ·v_33
                        fn ·ƒctx_93: ·ƒfail_31 ·ƒctx_93
                    fn ·v_53: ·v_53 ·ƒctx_83, ·v_63, ·panic, ·v_9
          fn ·v_73:
            ·fn
              fn ·ƒctx_96, ·ƒsucc_6, ·ƒfail_7, ·v_5:
                ·is_rec_like ·ƒctx_96, ·v_5,
                  fn ·ƒctx_98, ·v_17:
                    ·rec_pop ·ƒctx_98, ·v_17, 'foo', ·ƒfail_7, fn ·ƒctx_100, ·v_8, ·v_14:
                      ·let ·v_14, fn ·v_9:
                        ·ƒsucc_6 ·ƒctx_100, ·v_8, ·v_9
                  fn ·ƒctx_102: ·ƒfail_7 ·ƒctx_102
              fn ·v_26: ·v_26 ·ƒctx_81, ·v_73, ·panic, ·∅x
    # sm:


