test 'rec — closed with sub-pattern', fn:
  expect cps_module ƒink:
    {foo, ..{bar, spam}} = x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_87, ·ƒret_3:
      ·letrec fn ·foo_0, ·bar_1, ·spam_2:
        ·fn
          fn ·ƒctx_89, ·ƒv_8, ·ƒv_9:
            ·let ·ƒv_8, fn ·foo_0:
              ·fn
                fn ·ƒctx_90, ·ƒv_32, ·ƒv_33:
                  ·let ·ƒv_32, fn ·bar_1:
                    ·let ·ƒv_33, fn ·spam_2:
                      ·ƒret_3 ·ƒctx_90, ·spam_2
                fn ·ƒv_63:
                  ·fn
                    fn ·ƒctx_91, ·ƒsucc_30, ·ƒfail_31, ·ƒv_29:
                      ·is_rec_like ·ƒctx_91, ·ƒv_29,
                        fn ·ƒctx_93, ·ƒv_39:
                          ·rec_pop ·ƒctx_93, ·ƒv_39, 'bar', ·ƒfail_31, fn ·ƒctx_95, ·ƒv_32, ·ƒv_40:
                            ·rec_pop ·ƒctx_95, ·ƒv_40, 'spam', ·ƒfail_31, fn ·ƒctx_97, ·ƒv_33, ·ƒv_38:
                              ·ƒsucc_30 ·ƒctx_97, ·ƒv_32, ·ƒv_33
                        fn ·ƒctx_99: ·ƒfail_31 ·ƒctx_99
                    fn ·ƒv_53:
                      ·fn
                        fn ·ƒctx_101: ·panic ·ƒctx_101
                        fn ·ƒv_66: ·ƒv_53 ·ƒctx_89, ·ƒv_63, ·ƒv_66, ·ƒv_9
          fn ·ƒv_76:
            ·fn
              fn ·ƒctx_104, ·ƒsucc_6, ·ƒfail_7, ·ƒv_5:
