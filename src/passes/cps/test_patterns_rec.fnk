        fn ·v_37:
          ·fn
            fn ·ƒctx_47, ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·is_rec_like ·v_4,
                fn ·v_14:
                  ·rec_pop ·v_14, 'x', ·ƒfail_6, fn ·v_7, ·v_15:
                    ·rec_pop ·v_15, 'y', ·ƒfail_6, fn ·v_8, ·v_13:
                      ·ƒsucc_5 ·ƒctx_47, ·v_7, ·v_8
                fn: ·ƒfail_6 ·ƒctx_47
            fn ·v_28: ·v_28 ·ƒctx_44, ·v_37, ·panic, ·∅point
    # sm:


test 'rec — open rest discarded', fn:
  expect cps_module ƒink:
    {bar, ..} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_40, ·ƒret_1:
      ·fn
        fn ·ƒctx_42, ·v_6:
          ·let ·v_6, fn ·bar_0:
            ·ƒret_1 ·bar_0
        fn ·v_33:
          ·fn
            fn ·ƒctx_43, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·is_rec_like ·v_3,
                fn ·v_18:
                  ·rec_pop ·v_18, 'bar', ·ƒfail_5, fn ·v_6, ·v_10:
                    ·empty ·v_10, fn ·v_13:
                      ·if ·v_13,
                        fn: ·ƒfail_5 ·ƒctx_43
                        fn: ·ƒsucc_4 ·ƒctx_43, ·v_6
                fn: ·ƒfail_5 ·ƒctx_43
            fn ·v_27: ·v_27 ·ƒctx_40, ·v_33, ·panic, ·∅foo
    # sm:


test 'rec — open rest bound', fn:
