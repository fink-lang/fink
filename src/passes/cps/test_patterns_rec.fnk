test 'rec — predicate guard in value position', fn:
  expect cps_module ƒink:
    {k: is_even v} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_47, ·ƒret_1:
      ·fn
        fn ·ƒctx_49, ·ƒv_6:
          ·let ·ƒv_6, fn ·v_0:
            ·∅is_even
              ·ƒctx_49
              fn ·ƒctx_51, ·ƒv_30:
                ·if ·ƒv_30,
                  fn: ·ƒret_1 ·ƒctx_51
                  fn: ·panic ·ƒctx_51
              ·v_0
        fn ·ƒv_37:
          ·fn
            fn ·ƒctx_54, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·is_rec_like ·ƒctx_54, ·ƒv_3,
                fn ·ƒctx_56, ·ƒv_11:
                  ·rec_pop ·ƒctx_56, ·ƒv_11, 'k', ·ƒfail_5, fn ·ƒctx_58, ·ƒv_6, ·ƒv_10:
                    ·ƒsucc_4 ·ƒctx_58, ·ƒv_6
                fn ·ƒctx_60: ·ƒfail_5 ·ƒctx_60
            fn ·ƒv_20:
              ·fn
                fn ·ƒctx_62: ·panic ·ƒctx_62
                fn ·ƒv_40: ·ƒv_20 ·ƒctx_47, ·ƒv_37, ·ƒv_40, ·∅foo
    # sm:


