test 'rec — partial match', fn:
  expect cps_expr ƒink:
    {x, y} = point
  | equals ƒink:
    ·fn
      fn ·v_7, ·v_8:
        ·let ·v_7, fn ·x_0:
          ·let ·v_8, fn ·y_1:
            ·v_2 ·y_1
      fn ·v_37:
        ·fn
          fn ·ƒsucc_5, ·ƒfail_6, ·v_4:
            ·is_rec_like ·v_4,
              fn ·v_14:
                ·rec_pop ·v_14, 'x', ·ƒfail_6, fn ·v_7, ·v_15:
                  ·rec_pop ·v_15, 'y', ·ƒfail_6, fn ·v_8, ·v_13:
                    ·ƒsucc_5 ·v_7, ·v_8
              fn: ·ƒfail_6 _
          fn ·v_28: ·v_28 ·v_37, ·panic, ·∅point
    #sourcemaps:


