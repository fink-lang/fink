    # sm:


test 'rec — partial match', fn:
  expect cps_module ƒink:
    {x, y} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_2:
      ·letrec fn ·x_0, ·y_1:
        ·fn
          fn ·ƒctx_47, ·v_7, ·v_8:
            ·let ·v_7, fn ·x_0:
              ·let ·v_8, fn ·y_1:
                ·ƒret_2 ·ƒctx_47, ·y_1
          fn ·v_37:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_5, ·ƒfail_6, ·v_4:
                ·is_rec_like ·ƒctx_48, ·v_4,
                  fn ·ƒctx_50, ·v_14:
                    ·rec_pop ·ƒctx_50, ·v_14, 'x', ·ƒfail_6, fn ·ƒctx_52, ·v_7, ·v_15:
                      ·rec_pop ·ƒctx_52, ·v_15, 'y', ·ƒfail_6, fn ·ƒctx_54, ·v_8, ·v_13:
                        ·ƒsucc_5 ·ƒctx_54, ·v_7, ·v_8
                  fn ·ƒctx_56: ·ƒfail_6 ·ƒctx_56
              fn ·v_28: ·v_28 ·ƒctx_45, ·v_37, ·panic, ·∅point
    # sm:


test 'rec — field rename', fn:
  expect cps_module ƒink:
    {x, y: z} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_2:
      ·letrec fn ·x_0:
        ·fn
          fn ·ƒctx_47, ·v_7, ·v_8:
            ·let ·v_7, fn ·x_0:
              ·let ·v_8, fn ·z_1:
                ·ƒret_2 ·ƒctx_47, ·z_1
          fn ·v_37:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_5, ·ƒfail_6, ·v_4:
                ·is_rec_like ·ƒctx_48, ·v_4,
                  fn ·ƒctx_50, ·v_14:
                    ·rec_pop ·ƒctx_50, ·v_14, 'x', ·ƒfail_6, fn ·ƒctx_52, ·v_7, ·v_15:
                      ·rec_pop ·ƒctx_52, ·v_15, 'y', ·ƒfail_6, fn ·ƒctx_54, ·v_8, ·v_13:
                        ·ƒsucc_5 ·ƒctx_54, ·v_7, ·v_8
                  fn ·ƒctx_56: ·ƒfail_6 ·ƒctx_56
              fn ·v_28: ·v_28 ·ƒctx_45, ·v_37, ·panic, ·∅point
    # sm:


# Computed-key destructure: `{(x): val}` -- x is a ref (resolved via
# scopes), used as the runtime key for the rec_pop. Test inputs use
# free `x` and `foo` so both show as `·∅` placeholders.
test 'dict — runtime key', fn:
  expect cps_module ƒink:
    {(x): val} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_1:
      ·fn
        fn ·ƒctx_35, ·v_6:
          ·let ·v_6, fn ·val_0:
            ·ƒret_1 ·ƒctx_35, ·val_0
        fn ·v_26:
          ·fn
            fn ·ƒctx_36, ·ƒsucc_4, ·ƒfail_5, ·v_3:
              ·is_rec_like ·ƒctx_36, ·v_3,
                fn ·ƒctx_38, ·v_11:
                  ·rec_pop ·ƒctx_38, ·v_11, ·∅x, ·ƒfail_5, fn ·ƒctx_40, ·v_6, ·v_10:
                    ·ƒsucc_4 ·ƒctx_40, ·v_6
                fn ·ƒctx_42: ·ƒfail_5 ·ƒctx_42
            fn ·v_20: ·v_20 ·ƒctx_33, ·v_26, ·panic, ·∅foo
    # sm:


test 'rec — open rest discarded', fn:
  expect cps_module ƒink:
    {bar, ..} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_41, ·ƒret_1:
      ·letrec fn ·bar_0:
        ·fn
          fn ·ƒctx_43, ·v_6:
            ·let ·v_6, fn ·bar_0:
              ·ƒret_1 ·ƒctx_43, ·bar_0
          fn ·v_33:
            ·fn
              fn ·ƒctx_44, ·ƒsucc_4, ·ƒfail_5, ·v_3:
                ·is_rec_like ·ƒctx_44, ·v_3,
                  fn ·ƒctx_46, ·v_18:
                    ·rec_pop ·ƒctx_46, ·v_18, 'bar', ·ƒfail_5, fn ·ƒctx_48, ·v_6, ·v_10:
                      ·empty ·ƒctx_48, ·v_10, fn ·ƒctx_50, ·v_13:
                        ·if ·v_13,
                          fn: ·ƒfail_5 ·ƒctx_50
                          fn: ·ƒsucc_4 ·ƒctx_50, ·v_6
                  fn ·ƒctx_53: ·ƒfail_5 ·ƒctx_53
              fn ·v_27: ·v_27 ·ƒctx_41, ·v_33, ·panic, ·∅foo
    # sm:


test 'rec — open rest bound', fn:
  expect cps_module ƒink:
    {bar, ..rest} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_42, ·ƒret_2:
      ·letrec fn ·bar_0, ·rest_1:
        ·fn
          fn ·ƒctx_44, ·v_7, ·v_8:
            ·let ·v_7, fn ·bar_0:
              ·let ·v_8, fn ·rest_1:
                ·ƒret_2 ·ƒctx_44, ·rest_1
          fn ·v_34:
            ·fn
              fn ·ƒctx_45, ·ƒsucc_5, ·ƒfail_6, ·v_4:
                ·is_rec_like ·ƒctx_45, ·v_4,
                  fn ·ƒctx_47, ·v_16:
                    ·rec_pop ·ƒctx_47, ·v_16, 'bar', ·ƒfail_6, fn ·ƒctx_49, ·v_7, ·v_13:
                      ·let ·v_13, fn ·v_8:
                        ·ƒsucc_5 ·ƒctx_49, ·v_7, ·v_8
                  fn ·ƒctx_51: ·ƒfail_6 ·ƒctx_51
              fn ·v_25: ·v_25 ·ƒctx_42, ·v_34, ·panic, ·∅foo
    # sm:


