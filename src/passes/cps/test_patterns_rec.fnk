      ·letrec fn ·bar_0, ·rest_1:
        ·fn
          fn ·ƒctx_44, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·bar_0:
              ·let ·ƒv_8, fn ·rest_1:
                ·ƒret_2 ·ƒctx_44, ·rest_1
          fn ·ƒv_34:
            ·fn
              fn ·ƒctx_45, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·is_rec_like ·ƒctx_45, ·ƒv_4,
                  fn ·ƒctx_47, ·ƒv_16:
                    ·rec_pop ·ƒctx_47, ·ƒv_16, 'bar', ·ƒfail_6, fn ·ƒctx_49, ·ƒv_7, ·ƒv_13:
