    # sm:


test 'rec — predicate guard in value position', fn:
  expect cps_module ƒink:
    {k: is_even v} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_1:
      ·fn
        fn ·ƒctx_47, ·ƒv_6:
          ·let ·ƒv_6, fn ·v_0:
            ·∅is_even
              ·ƒctx_47
              fn ·ƒctx_49, ·ƒv_31:
                ·if ·ƒv_31,
                  fn: ·ƒret_1 ·ƒctx_49
                  fn: ·panic ·ƒctx_49
              ·v_0
        fn ·ƒv_38:
          ·fn
            fn ·ƒctx_52, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·is_rec_like ·ƒctx_52, ·ƒv_3,
                fn ·ƒctx_54, ·ƒv_11:
                  ·rec_pop ·ƒctx_54, ·ƒv_11, 'k', ·ƒfail_5, fn ·ƒctx_56, ·ƒv_6, ·ƒv_10:
                    ·ƒsucc_4 ·ƒctx_56, ·ƒv_6
                fn ·ƒctx_58: ·ƒfail_5 ·ƒctx_58
            fn ·ƒv_20: ·ƒv_20 ·ƒctx_45, ·ƒv_38, ·panic, ·∅foo
    # sm:


test 'rec — infix comparison guard in value position', fn:
  expect cps_module ƒink:
    {k: v == 4} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_1:
      ·fn
        fn ·ƒctx_60, ·ƒv_6:
          ·let ·ƒv_6, fn ·v_0:
            ·fn
              fn ·ƒctx_61, ·v_0: ·ƒret_1 ·ƒctx_61, ·v_0
              fn ·ƒv_38:
                ·fn
                  fn ·ƒctx_63, ·ƒsucc_23, ·ƒfail_24, ·ƒv_22:
                    ·op_eq ·ƒctx_63, ·ƒv_22, (i8 4), fn ·ƒctx_65, ·ƒv_27:
                      ·if ·ƒv_27,
                        fn: ·ƒsucc_23 ·ƒctx_65, ·ƒv_22
                        fn: ·ƒfail_24 ·ƒctx_65
                  fn ·ƒv_35: ·ƒv_35 ·ƒctx_60, ·ƒv_38, ·panic, ·ƒv_6
        fn ·ƒv_51:
          ·fn
            fn ·ƒctx_69, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·is_rec_like ·ƒctx_69, ·ƒv_3,
                fn ·ƒctx_71, ·ƒv_11:
                  ·rec_pop ·ƒctx_71, ·ƒv_11, 'k', ·ƒfail_5, fn ·ƒctx_73, ·ƒv_6, ·ƒv_10:
                    ·ƒsucc_4 ·ƒctx_73, ·ƒv_6
                fn ·ƒctx_75: ·ƒfail_5 ·ƒctx_75
            fn ·ƒv_20: ·ƒv_20 ·ƒctx_58, ·ƒv_51, ·panic, ·∅foo
    # sm:


test 'rec — closed with sub-pattern', fn:
  expect cps_module ƒink:
    {foo, ..{bar, spam}} = x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_81, ·ƒret_3:
      ·letrec fn ·foo_0, ·bar_1, ·spam_2:
        ·fn
          fn ·ƒctx_83, ·ƒv_8, ·ƒv_9:
            ·let ·ƒv_8, fn ·foo_0:
              ·fn
                fn ·ƒctx_84, ·ƒv_32, ·ƒv_33:
                  ·let ·ƒv_32, fn ·bar_1:
                    ·let ·ƒv_33, fn ·spam_2:
                      ·ƒret_3 ·ƒctx_84, ·spam_2
                fn ·ƒv_63:
                  ·fn
                    fn ·ƒctx_85, ·ƒsucc_30, ·ƒfail_31, ·ƒv_29:
                      ·is_rec_like ·ƒctx_85, ·ƒv_29,
                        fn ·ƒctx_87, ·ƒv_39:
                          ·rec_pop ·ƒctx_87, ·ƒv_39, 'bar', ·ƒfail_31, fn ·ƒctx_89, ·ƒv_32, ·ƒv_40:
                            ·rec_pop ·ƒctx_89, ·ƒv_40, 'spam', ·ƒfail_31, fn ·ƒctx_91, ·ƒv_33, ·ƒv_38:
                              ·ƒsucc_30 ·ƒctx_91, ·ƒv_32, ·ƒv_33
                        fn ·ƒctx_93: ·ƒfail_31 ·ƒctx_93
                    fn ·ƒv_53: ·ƒv_53 ·ƒctx_83, ·ƒv_63, ·panic, ·ƒv_9
          fn ·ƒv_73:
            ·fn
              fn ·ƒctx_96, ·ƒsucc_6, ·ƒfail_7, ·ƒv_5:
                ·is_rec_like ·ƒctx_96, ·ƒv_5,
                  fn ·ƒctx_98, ·ƒv_17:
                    ·rec_pop ·ƒctx_98, ·ƒv_17, 'foo', ·ƒfail_7, fn ·ƒctx_100, ·ƒv_8, ·ƒv_14:
                      ·let ·ƒv_14, fn ·ƒv_9:
                        ·ƒsucc_6 ·ƒctx_100, ·ƒv_8, ·ƒv_9
                  fn ·ƒctx_102: ·ƒfail_7 ·ƒctx_102
              fn ·ƒv_26: ·ƒv_26 ·ƒctx_81, ·ƒv_73, ·panic, ·∅x
    # sm:


