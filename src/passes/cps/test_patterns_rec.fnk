{test, equals, expect, cps_expr} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
rec patterns
---

test 'rec — empty', fn:
  expect cps_expr ƒink:
    {} = foo
  | equals ƒink:
    ·fn
      fn ·v_5: ·v_0 ·v_5
      fn ·v_26:
        ·fn
          fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
            ·is_rec_like ·v_2,
              fn ·v_16:
                ·let ·v_16, fn ·v_8:
                  ·empty ·v_8, fn ·v_11:
                    ·if ·v_11,
                      fn: ·ƒsucc_3 _
                      fn: ·ƒfail_4 _
              fn: ·ƒfail_4 _
          fn ·v_23: ·v_23 ·v_26, ·panic, ·∅foo
    #sourcemaps:


test 'rec — non-empty', fn:
