    # sm:


# Computed-key destructure: `{(x): val}` -- x is a ref (resolved via
# scopes), used as the runtime key for the rec_pop. Test inputs use
# free `x` and `foo` so both show as `·∅` placeholders.
test 'dict — runtime key', fn:
  expect cps_module ƒink:
    {(x): val} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_1:
      ·fn
        fn ·ƒctx_38, ·ƒv_6:
          ·let ·ƒv_6, fn ·val_0:
            ·ƒret_1 ·ƒctx_38, ·val_0
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_39, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·is_rec_like ·ƒctx_39, ·ƒv_3,
                fn ·ƒctx_41, ·ƒv_11:
                  ·rec_pop ·ƒctx_41, ·ƒv_11, ·∅x, ·ƒfail_5, fn ·ƒctx_43, ·ƒv_6, ·ƒv_10:
                    ·ƒsucc_4 ·ƒctx_43, ·ƒv_6
                fn ·ƒctx_45: ·ƒfail_5 ·ƒctx_45
            fn ·ƒv_20:
              ·fn
                fn ·ƒctx_47: ·panic ·ƒctx_47
                fn ·ƒv_29: ·ƒv_20 ·ƒctx_36, ·ƒv_26, ·ƒv_29, ·∅foo
    # sm:


test 'rec — open rest discarded', fn:
