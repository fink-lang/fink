{test, skip, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
rec patterns
---

test 'rec — empty', fn:
  expect cps_module ƒink:
    {} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_0:
      ·fn
        fn ·ƒctx_38, ·v_5: ·ƒret_0 ·ƒctx_38, ·v_5
        fn ·v_26:
          ·fn
            fn ·ƒctx_40, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·is_rec_like ·ƒctx_40, ·v_2,
                fn ·ƒctx_42, ·v_16:
                  ·let ·v_16, fn ·v_8:
                    ·empty ·ƒctx_42, ·v_8, fn ·ƒctx_44, ·v_11:
                      ·if ·v_11,
                        fn: ·ƒsucc_3 ·ƒctx_44
                        fn: ·ƒfail_4 ·ƒctx_44
                fn ·ƒctx_47: ·ƒfail_4 ·ƒctx_47
            fn ·v_23: ·v_23 ·ƒctx_36, ·v_26, ·panic, ·∅foo
    # sm:


test 'rec — non-empty', fn:
