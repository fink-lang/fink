          ·let ·v_7, fn ·bar_0:
            ·let ·v_8, fn ·rest_1:
              ·ƒret_2 ·rest_1
        fn ·v_34:
          ·fn
            fn ·ƒctx_44, ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·is_rec_like ·v_4,
                fn ·v_16:
                  ·rec_pop ·v_16, 'bar', ·ƒfail_6, fn ·v_7, ·v_13:
                    ·let ·v_13, fn ·v_8:
                      ·ƒsucc_5 ·ƒctx_44, ·v_7, ·v_8
                fn: ·ƒfail_6 ·ƒctx_44
            fn ·v_25: ·v_25 ·ƒctx_41, ·v_34, ·panic, ·∅foo
    # sm:


