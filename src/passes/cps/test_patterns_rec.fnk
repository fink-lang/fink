test 'rec — partial match', fn:
  expect cps_module ƒink:
    {x, y} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_44, ·ƒret_2:
      ·fn
        fn ·ƒctx_46, ·v_7, ·v_8:
          ·let ·v_7, fn ·x_0:
            ·let ·v_8, fn ·y_1:
              ·ƒret_2 ·y_1
        fn ·v_37:
          ·fn
            fn ·ƒctx_47, ·ƒsucc_5, ·ƒfail_6, ·v_4:
              ·is_rec_like ·v_4,
                fn ·v_14:
                  ·rec_pop ·v_14, 'x', ·ƒfail_6, fn ·v_7, ·v_15:
                    ·rec_pop ·v_15, 'y', ·ƒfail_6, fn ·v_8, ·v_13:
                      ·ƒsucc_5 ·ƒctx_47, ·v_7, ·v_8
                fn: ·ƒfail_6 ·ƒctx_47
            fn ·v_28: ·v_28 ·ƒctx_44, ·v_37, ·panic, ·∅point
    # sm:


test 'rec — field rename', fn:
