{test, skip, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
rec patterns
---

test 'rec — empty', fn:
  expect cps_module ƒink:
    {} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_0:
      ·fn
        fn ·ƒctx_38, ·ƒv_5: ·ƒret_0 ·ƒctx_38, ·ƒv_5
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_40, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·is_rec_like ·ƒctx_40, ·ƒv_2,
                fn ·ƒctx_42, ·ƒv_16:
                  ·let ·ƒv_16, fn ·ƒv_8:
                    ·empty ·ƒctx_42, ·ƒv_8, fn ·ƒctx_44, ·ƒv_11:
                      ·if ·ƒv_11,
                        fn: ·ƒsucc_3 ·ƒctx_44
                        fn: ·ƒfail_4 ·ƒctx_44
                fn ·ƒctx_47: ·ƒfail_4 ·ƒctx_47
            fn ·ƒv_23: ·ƒv_23 ·ƒctx_36, ·ƒv_26, ·panic, ·∅foo
    # sm:


test 'rec — non-empty', fn:
  expect cps_module ƒink:
    {..} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_0:
      ·fn
        fn ·ƒctx_38, ·ƒv_5: ·ƒret_0 ·ƒctx_38, ·ƒv_5
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_40, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·is_rec_like ·ƒctx_40, ·ƒv_2,
                fn ·ƒctx_42, ·ƒv_16:
                  ·let ·ƒv_16, fn ·ƒv_8:
                    ·empty ·ƒctx_42, ·ƒv_8, fn ·ƒctx_44, ·ƒv_11:
                      ·if ·ƒv_11,
                        fn: ·ƒfail_4 ·ƒctx_44
                        fn: ·ƒsucc_3 ·ƒctx_44
                fn ·ƒctx_47: ·ƒfail_4 ·ƒctx_47
            fn ·ƒv_23: ·ƒv_23 ·ƒctx_36, ·ƒv_26, ·panic, ·∅foo
    # sm:


test 'rec — partial match', fn:
  expect cps_module ƒink:
    {x, y} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_2:
      ·letrec fn ·x_0, ·y_1:
        ·fn
          fn ·ƒctx_47, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·x_0:
              ·let ·ƒv_8, fn ·y_1:
                ·ƒret_2 ·ƒctx_47, ·y_1
          fn ·ƒv_37:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·is_rec_like ·ƒctx_48, ·ƒv_4,
                  fn ·ƒctx_50, ·ƒv_14:
                    ·rec_pop ·ƒctx_50, ·ƒv_14, 'x', ·ƒfail_6, fn ·ƒctx_52, ·ƒv_7, ·ƒv_15:
                      ·rec_pop ·ƒctx_52, ·ƒv_15, 'y', ·ƒfail_6, fn ·ƒctx_54, ·ƒv_8, ·ƒv_13:
                        ·ƒsucc_5 ·ƒctx_54, ·ƒv_7, ·ƒv_8
                  fn ·ƒctx_56: ·ƒfail_6 ·ƒctx_56
              fn ·ƒv_28: ·ƒv_28 ·ƒctx_45, ·ƒv_37, ·panic, ·∅point
    # sm:


test 'rec — field rename', fn:
  expect cps_module ƒink:
    {x, y: z} = point
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_45, ·ƒret_2:
      ·letrec fn ·x_0:
        ·fn
          fn ·ƒctx_47, ·ƒv_7, ·ƒv_8:
            ·let ·ƒv_7, fn ·x_0:
              ·let ·ƒv_8, fn ·z_1:
                ·ƒret_2 ·ƒctx_47, ·z_1
          fn ·ƒv_37:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_5, ·ƒfail_6, ·ƒv_4:
                ·is_rec_like ·ƒctx_48, ·ƒv_4,
                  fn ·ƒctx_50, ·ƒv_14:
                    ·rec_pop ·ƒctx_50, ·ƒv_14, 'x', ·ƒfail_6, fn ·ƒctx_52, ·ƒv_7, ·ƒv_15:
                      ·rec_pop ·ƒctx_52, ·ƒv_15, 'y', ·ƒfail_6, fn ·ƒctx_54, ·ƒv_8, ·ƒv_13:
                        ·ƒsucc_5 ·ƒctx_54, ·ƒv_7, ·ƒv_8
                  fn ·ƒctx_56: ·ƒfail_6 ·ƒctx_56
              fn ·ƒv_28: ·ƒv_28 ·ƒctx_45, ·ƒv_37, ·panic, ·∅point
    # sm:


# Computed-key destructure: `{(x): val}` -- x is a ref (resolved via
# scopes), used as the runtime key for the rec_pop. Test inputs use
# free `x` and `foo` so both show as `·∅` placeholders.
test 'dict — runtime key', fn:
  expect cps_module ƒink:
    {(x): val} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_1:
      ·fn
        fn ·ƒctx_35, ·ƒv_6:
          ·let ·ƒv_6, fn ·val_0:
            ·ƒret_1 ·ƒctx_35, ·val_0
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_36, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
              ·is_rec_like ·ƒctx_36, ·ƒv_3,
                fn ·ƒctx_38, ·ƒv_11:
                  ·rec_pop ·ƒctx_38, ·ƒv_11, ·∅x, ·ƒfail_5, fn ·ƒctx_40, ·ƒv_6, ·ƒv_10:
                    ·ƒsucc_4 ·ƒctx_40, ·ƒv_6
                fn ·ƒctx_42: ·ƒfail_5 ·ƒctx_42
            fn ·ƒv_20: ·ƒv_20 ·ƒctx_33, ·ƒv_26, ·panic, ·∅foo
    # sm:


test 'rec — open rest discarded', fn:
  expect cps_module ƒink:
    {bar, ..} = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_41, ·ƒret_1:
      ·letrec fn ·bar_0:
        ·fn
          fn ·ƒctx_43, ·ƒv_6:
            ·let ·ƒv_6, fn ·bar_0:
              ·ƒret_1 ·ƒctx_43, ·bar_0
          fn ·ƒv_33:
            ·fn
              fn ·ƒctx_44, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·is_rec_like ·ƒctx_44, ·ƒv_3,
                  fn ·ƒctx_46, ·ƒv_18:
                    ·rec_pop ·ƒctx_46, ·ƒv_18, 'bar', ·ƒfail_5, fn ·ƒctx_48, ·ƒv_6, ·ƒv_10:
                      ·empty ·ƒctx_48, ·ƒv_10, fn ·ƒctx_50, ·ƒv_13:
                        ·if ·ƒv_13,
                          fn: ·ƒfail_5 ·ƒctx_50
                          fn: ·ƒsucc_4 ·ƒctx_50, ·ƒv_6
                  fn ·ƒctx_53: ·ƒfail_5 ·ƒctx_53
              fn ·ƒv_27: ·ƒv_27 ·ƒctx_41, ·ƒv_33, ·panic, ·∅foo
    # sm:


test 'rec — open rest bound', fn:
