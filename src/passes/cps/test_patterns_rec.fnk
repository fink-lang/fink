          fn ·ƒv_33:
            ·fn
              fn ·ƒctx_47, ·ƒsucc_4, ·ƒfail_5, ·ƒv_3:
                ·is_rec_like ·ƒctx_47, ·ƒv_3,
                  fn ·ƒctx_49, ·ƒv_18:
                    ·rec_pop ·ƒctx_49, ·ƒv_18, 'bar', ·ƒfail_5, fn ·ƒctx_51, ·ƒv_6, ·ƒv_10:
                      ·empty ·ƒctx_51, ·ƒv_10, fn ·ƒctx_53, ·ƒv_13:
                        ·if ·ƒv_13,
                          fn: ·ƒfail_5 ·ƒctx_53
