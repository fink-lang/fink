test 'rec — empty', fn:
  expect cps_expr fink":
    {} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_done ·v_2, ·panic, fn ·v_0:
        ·ƒ_0 ·v_0


test 'rec — non-empty', fn:
  expect cps_expr fink":
    {..} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_not_done ·v_2, ·panic, fn: ·ƒ_0


test 'rec — partial match', fn:
  expect cps_expr fink":
    {x, y} = point
  | equals fink":
    ·match_rec point, ·panic, fn ·v_2:
      ·match_field ·v_2, 'x', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_field ·v_4, 'y', ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn y:
              ·ƒ_0 y


test 'rec — field rename', fn:
  expect cps_expr fink":
    {x, y: z} = point
  | equals fink":
    ·match_rec point, ·panic, fn ·v_2:
      ·match_field ·v_2, 'x', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_field ·v_4, 'y', ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn z:
              ·ƒ_0 z


test 'rec — open rest discarded', fn:
  expect cps_expr fink":
    {bar, ..} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_field ·v_2, 'bar', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn bar:
          ·match_not_done ·v_4, ·panic, fn: ·ƒ_0


test 'rec — open rest bound', fn:
  expect cps_expr fink":
    {bar, ..rest} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_field ·v_2, 'bar', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn bar:
          ·match_rest ·v_4, ·panic, fn ·v_9:
            ·let ·v_9, fn rest:
              ·ƒ_0 rest


test 'rec — closed exact', fn:
  expect cps_expr fink":
    {bar, ..{}} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_field ·v_2, 'bar', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn bar:
          ·match_rest ·v_4, ·panic, fn ·v_9:
            ·match_rec ·v_9, ·panic, fn ·v_11:
              ·match_done ·v_11, ·panic, fn ·v_0:
                ·ƒ_0 ·v_0


test 'rec — closed with sub-pattern', fn:
  expect cps_expr fink":
    {foo, ..{bar, spam}} = x
  | equals fink":
    ·match_rec x, ·panic, fn ·v_2:
      ·match_field ·v_2, 'foo', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn foo:
          ·match_rest ·v_4, ·panic, fn ·v_9:
            ·match_rec ·v_9, ·panic, fn ·v_11:
              ·match_field ·v_11, 'bar', ·panic, fn ·v_12, ·v_13:
                ·let ·v_12, fn bar:
                  ·match_field ·v_13, 'spam', ·panic, fn ·v_17, ·v_18:
                    ·let ·v_17, fn spam:
                      ·ƒ_0 spam


test 'match block bind', fn:
  expect cps_expr fink":
    match foo:
      1: 2
      x: x
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_9:
          ·match_value ·v_2, 1, ·ƒ_fail, fn: ·ƒ_8
        fn ·ƒ_8:
          ·let 2, fn ·v_6:
            ·ƒ_0 ·v_6
      ·match_arm
        fn ·v_19:
          ·let ·v_2, fn x:
            ·ƒ_18 x
        fn ·ƒ_18, x:
          ·let x, fn ·v_16:
            ·ƒ_0 ·v_16
      fn ·v_0: ·ƒ_0 ·v_0


