                ·match_if ·∅foo, 2, ·a_0, 3, ·panic, fn:
                  ·match_next ·v_25, ·panic, fn ·v_33, ·v_34:
                    ·fn
                      fn ·v_51: ·match_done ·v_34, ·panic, ·v_1
                      fn ·v_59:
                        ·fn
                          fn ·v_37, ·v_38, ·v_39:
                            ·op_eq ·v_37, 4, fn ·v_42:
                              ·if ·v_42,
                                fn: ·v_38 _
                                fn: ·v_39 _
                          fn ·v_50: ·v_50 ·v_33, ·v_59, ·panic
          fn ·v_78:
            ·fn
              fn ·v_8, ·v_9, ·v_10:
                ·op_eq ·v_8, 1, fn ·v_13:
                  ·if ·v_13,
                    fn: ·v_9 _
                    fn: ·v_10 _
              fn ·v_21: ·v_21 ·v_4, ·v_78, ·panic
    #sourcemaps:



