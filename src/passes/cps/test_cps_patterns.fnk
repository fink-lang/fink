---
CPS pattern lowering tests
---

# Expected CPS expansion for every pattern form.
# Match primitives are emitted as App { BuiltIn::Match* } directly by the CPS transform.
#
# Failure continuation convention:
#   ·panic   — default; pattern mismatch is a compile/runtime error
#   ·ƒ_fail  — inside a ·match_block arm; failure tries the next arm
#
# Every ·match_* primitive shape:
#   ·match_* scrutinee, …args…, ·fail, fn <bindings>: body
#
# Primitives:
#   ·match_seq      — initialize seq cursor from scrutinee
#   ·match_next     — pop head from cursor, advance; fn ·v, ·cursor, …
#   ·match_done     — assert cursor exhausted; ·fail if not
#   ·match_not_done — assert cursor not exhausted; ·fail if empty
#   ·match_rest     — bind remaining cursor as value (zero or more)
#   ·match_rec      — initialize rec cursor from scrutinee
#   ·match_field    — extract named field from rec cursor; fn ·v, ·cursor, …
#   ·match_value    — assert extracted temp equals literal; ·fail if not
#   ·match_if       — apply fn to args, ·fail if falsy; no result binding (guard)
#   ·match_apply    — apply fn to args, bind result; ·fail if wrong tag (constructor/extractor)
#                     deferred: name resolution distinguishes predicate (→ ·match_if)
#                     from constructor/extractor (→ ·match_apply) based on callee
#   ·match_block    — try arms in order; first match wins
#   ·match_arm      — single arm: matcher cont + body cont
#
# Binding: bare ident in pattern position → ·let (always a binding, never a lookup)
# Wildcard (_): discard; no binding, temp passed directly to next primitive

{test, equals, expect, fink, cps_expr} = import 'fake!'


---
bind
---

test 'plain bind', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let ·∅foo, fn ·x_0:
      ·ƒ_1 ·x_0

test 'simple guard', fn:
  expect cps_expr fink":
    a > 0 = foo
  | equals fink":
    ·let ·∅foo, fn ·a_0:
      ·match_if ·op_gt, ·∅a, 0, ·panic, fn:
        ·ƒ_1 _


test 'nested guard', fn:
  expect cps_expr fink":
    a > 0 or a < 9 = foo
  | equals fink":
    ·let ·∅foo, fn ·a_0:
      ·op_gt ·∅a, 0, fn ·v_5:
        ·op_lt ·∅a, 9, fn ·v_9:
          ·match_if ·op_or, ·v_5, ·v_9, ·panic, fn:
            ·ƒ_1 _


---
seq patterns
---

test 'seq — empty', fn:
  expect cps_expr fink":
    [] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_2:
      ·match_done ·v_2, ·panic, ·ƒ_0


test 'seq — nested empty', fn:
  expect cps_expr fink":
    [a, []] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·a_0:
          ·match_next ·v_5, ·panic, fn ·v_8, ·v_9:
            ·match_seq ·v_8, ·panic, fn ·v_12:
              ·match_done ·v_12, ·panic, fn ·v_13:
                ·match_done ·v_9, ·panic, ·ƒ_1


test 'seq — exact two elements', fn:
  expect cps_expr fink":
    [a, b] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·a_0:
          ·match_next ·v_6, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·b_1:
              ·match_done ·v_10, ·panic, ·ƒ_2



test 'seq — lone spread non-empty discard', fn:
  expect cps_expr fink":
    [..] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_2:
      ·match_not_done ·v_2, ·panic, fn:
        ·ƒ_0 _


test 'seq — spread non-empty bound', fn:
  expect cps_expr fink":
    [..rest] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_rest ·v_3, ·panic, fn ·v_5:
        ·let ·v_5, fn ·rest_0:
          ·ƒ_1 ·rest_0


test 'seq — head then spread discard', fn:
  expect cps_expr fink":
    [head, ..] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·head_0:
          ·match_not_done ·v_5, ·panic, fn:
            ·ƒ_1 _


test 'seq — head then spread bound', fn:
  expect cps_expr fink":
    [head, ..tail] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·head_0:
          ·match_rest ·v_6, ·panic, fn ·v_10:
            ·let ·v_10, fn ·tail_1:
              ·ƒ_2 ·tail_1


