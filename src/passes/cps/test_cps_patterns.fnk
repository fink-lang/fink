test 'fn — seq destructuring param', fn:
  expect cps_expr fink":
    fn [a, b]: a
  | equals fink":
    ·fn
      fn ·v_2, ·ƒ_17:
        ·match_seq ·v_2, ·panic, fn ·v_4:
          ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
            ·let ·v_5, fn a:
              ·match_next ·v_6, ·panic, fn ·v_10, ·v_11:
                ·let ·v_10, fn b:
                  ·match_done ·v_11, ·panic, fn ·v_15:
                    ·let a, fn ·v_19:
                      ·ƒ_17 ·v_19
      fn ·v_1: ·ƒ_0 ·v_1

test 'fn — seq destructuring param with rest', fn:
  expect cps_expr fink":
    fn [a, ..rest]: rest
  | equals fink":
    ·fn
      fn ·v_2, ·ƒ_15:
        ·match_seq ·v_2, ·panic, fn ·v_4:
          ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
            ·let ·v_5, fn a:
              ·match_rest ·v_6, ·panic, fn ·v_11:
                ·let ·v_11, fn rest:
                  ·let rest, fn ·v_17:
                    ·ƒ_15 ·v_17
      fn ·v_1: ·ƒ_0 ·v_1


test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps_expr fink":
    fn a, [1, ..b]: b
  | equals fink":
    ·fn
      fn a, ·v_3, ·ƒ_16:
        ·match_seq ·v_3, ·panic, fn ·v_5:
          ·match_next ·v_5, ·panic, fn ·v_6, ·v_7:
            ·match_value ·v_6, 1, ·panic, fn:
              ·match_rest ·v_7, ·panic, fn ·v_12:
                ·let ·v_12, fn b:
                  ·let b, fn ·v_18:
                    ·ƒ_16 ·v_18
      fn ·v_1: ·ƒ_0 ·v_1
