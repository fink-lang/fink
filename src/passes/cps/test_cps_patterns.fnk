test 'seq — literal element', fn:
  expect cps_expr fink":
    [a, 1] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·a_0:
          ·match_next ·v_5, ·panic, fn ·v_8, ·v_9:
            ·match_value ·v_8, 1, ·panic, fn:
              ·match_done ·v_9, ·panic, ·ƒ_1


test 'seq — infix guard', fn:
  expect cps_expr fink":
    [x, y >= 2] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·x_0:
          ·match_next ·v_6, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·y_1:
              ·match_if ·op_gte, ·∅y, 2, ·panic, fn:
                ·match_done ·v_10, ·panic, ·ƒ_2


test 'seq — predicate guard', fn:
  expect cps_expr fink":
    [x, is_even y] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·x_0:
          ·match_next ·v_6, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·y_1:
              ·match_if ·∅is_even, ·y_1, ·panic, fn:
                ·match_done ·v_10, ·panic, ·ƒ_2


test 'seq — constructor guard with payload', fn:
  expect cps_expr fink":
    [x, Ok b] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·x_0:
          ·match_next ·v_6, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·b_1:
              ·match_if ·∅Ok, ·b_1, ·panic, fn:
                ·match_done ·v_10, ·panic, ·ƒ_2


test 'seq — constructor predicate with wildcard', fn:
  expect cps_expr fink":
    [x, is_none _] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·x_0:
          ·match_next ·v_5, ·panic, fn ·v_8, ·v_9:
            ·match_if ·∅is_none, ·v_8, ·panic, fn:
              ·match_done ·v_9, ·panic, ·ƒ_1


test 'seq — multi-arg guard with bound element', fn:
  expect cps_expr fink":
    [1, foo 2, a, 3; 4] = bar
  | equals fink":
    ·match_seq ·∅bar, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·match_value ·v_4, 1, ·panic, fn:
          ·match_next ·v_5, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·a_0:
              ·match_if ·∅foo, 2, ·a_0, 3, ·panic, fn:
                ·match_next ·v_10, ·panic, fn ·v_18, ·v_19:
                  ·match_value ·v_18, 4, ·panic, fn:
                    ·match_done ·v_19, ·panic, ·ƒ_1



test 'seq — nested', fn:
  expect cps_expr fink":
    [a, [b, c]] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_5:
      ·match_next ·v_5, ·panic, fn ·v_6, ·v_7:
        ·let ·v_6, fn ·a_0:
          ·match_next ·v_7, ·panic, fn ·v_10, ·v_11:
            ·match_seq ·v_10, ·panic, fn ·v_14:
              ·match_next ·v_14, ·panic, fn ·v_15, ·v_16:
                ·let ·v_15, fn ·b_1:
                  ·match_next ·v_16, ·panic, fn ·v_19, ·v_20:
                    ·let ·v_19, fn ·c_2:
                      ·match_done ·v_20, ·panic, fn ·v_23:
                        ·match_done ·v_11, ·panic, ·ƒ_3

test 'seq — nested with bind-right', fn:
  expect cps_expr fink":
    [a, [b, c] |= d] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_6:
      ·match_next ·v_6, ·panic, fn ·v_7, ·v_8:
        ·let ·v_7, fn ·a_0:
          ·match_next ·v_8, ·panic, fn ·v_11, ·v_12:
            ·let ·v_11, fn ·d_3:
              ·match_seq ·v_11, ·panic, fn ·v_15:
                ·match_next ·v_15, ·panic, fn ·v_16, ·v_17:
                  ·let ·v_16, fn ·b_1:
                    ·match_next ·v_17, ·panic, fn ·v_20, ·v_21:
                      ·let ·v_20, fn ·c_2:
                        ·match_done ·v_21, ·panic, fn ·v_24:
                          ·match_done ·v_12, ·panic, ·ƒ_4


---
rec patterns
---

test 'rec — empty', fn:
  expect cps_expr fink":
    {} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_2:
      ·match_done ·v_2, ·panic, ·ƒ_0


test 'rec — non-empty', fn:
  expect cps_expr fink":
    {..} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_2:
      ·match_not_done ·v_2, ·panic, fn:
        ·ƒ_0 _


test 'rec — partial match', fn:
  expect cps_expr fink":
    {x, y} = point
  | equals fink":
    ·match_rec ·∅point, ·panic, fn ·v_4:
      ·match_field ·v_4, 'x', ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·x_0:
          ·match_field ·v_6, 'y', ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·y_1:
              ·ƒ_2 ·y_1


test 'rec — field rename', fn:
  expect cps_expr fink":
    {x, y: z} = point
  | equals fink":
    ·match_rec ·∅point, ·panic, fn ·v_4:
      ·match_field ·v_4, 'x', ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·x_0:
          ·match_field ·v_6, 'y', ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·z_1:
              ·ƒ_2 ·z_1


test 'rec — open rest discarded', fn:
  expect cps_expr fink":
    {bar, ..} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·match_not_done ·v_5, ·panic, fn:
            ·ƒ_1 _


test 'rec — open rest bound', fn:
  expect cps_expr fink":
    {bar, ..rest} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_4:
      ·match_field ·v_4, 'bar', ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·bar_0:
          ·match_rest ·v_6, ·panic, fn ·v_10:
            ·let ·v_10, fn ·rest_1:
              ·ƒ_2 ·rest_1


test 'rec — closed exact', fn:
  expect cps_expr fink":
    {bar, ..{}} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·match_rest ·v_5, ·panic, fn ·v_9:
            ·match_rec ·v_9, ·panic, fn ·v_11:
              ·match_done ·v_11, ·panic, ·ƒ_1


test 'rec — closed with sub-pattern', fn:
  expect cps_expr fink":
    {foo, ..{bar, spam}} = x
  | equals fink":
    ·match_rec ·∅x, ·panic, fn ·v_5:
      ·match_field ·v_5, 'foo', ·panic, fn ·v_6, ·v_7:
        ·let ·v_6, fn ·foo_0:
          ·match_rest ·v_7, ·panic, fn ·v_11:
            ·match_rec ·v_11, ·panic, fn ·v_13:
              ·match_field ·v_13, 'bar', ·panic, fn ·v_14, ·v_15:
                ·let ·v_14, fn ·bar_1:
                  ·match_field ·v_15, 'spam', ·panic, fn ·v_18, ·v_19:
                    ·let ·v_18, fn ·spam_2:
                      ·ƒ_3 ·spam_2


test 'match block bind', fn:
  expect cps_expr fink":
    match foo:
      1: 2
      x: x
  | equals fink":
    ·match_arm
      fn ·v_6, ·ƒ_4, ·ƒ_5:
        ·match_value ·v_6, 1, ·ƒ_4, fn:
          ·ƒ_5 _
      fn ·ƒ_9:
        ·ƒ_9 2
      fn ·v_16:
        ·match_arm
          fn ·v_20, ·ƒ_18, ·ƒ_19:
            ·let ·v_20, fn ·x_0:
              ·ƒ_19 ·x_0
          fn ·x_0, ·ƒ_22:
            ·ƒ_22 ·x_0
          fn ·v_27:
            ·match_block ·∅foo, ·v_16, ·v_27, ·ƒ_1


---
match block — simple arms
---

test 'match wildcard', fn:
  expect cps_expr fink":
    match foo:
      _: 42
  | equals fink":
    ·match_arm
      fn ·v_5, ·ƒ_3, ·ƒ_4:
        ·ƒ_4 _
      fn ·ƒ_7:
        ·ƒ_7 42
      fn ·v_13:
        ·match_block ·∅foo, ·v_13, ·ƒ_0


test 'match bind', fn:
  expect cps_expr fink":
    match foo:
      x: x
  | equals fink":
    ·match_arm
      fn ·v_6, ·ƒ_4, ·ƒ_5:
        ·let ·v_6, fn ·x_0:
          ·ƒ_5 ·x_0
      fn ·x_0, ·ƒ_8:
        ·ƒ_8 ·x_0
      fn ·v_13:
        ·match_block ·∅foo, ·v_13, ·ƒ_1


test 'match literal arms', fn:
  expect cps_expr fink":
    match foo:
      1: 'one'
      2: 'two'
      _: 'other'
  | equals fink":
    ·match_arm
      fn ·v_5, ·ƒ_3, ·ƒ_4:
        ·match_value ·v_5, 1, ·ƒ_3, fn:
          ·ƒ_4 _
      fn ·ƒ_8:
        ·ƒ_8 'one'
      fn ·v_15:
        ·match_arm
          fn ·v_19, ·ƒ_17, ·ƒ_18:
            ·match_value ·v_19, 2, ·ƒ_17, fn:
              ·ƒ_18 _
          fn ·ƒ_22:
            ·ƒ_22 'two'
          fn ·v_29:
            ·match_arm
              fn ·v_33, ·ƒ_31, ·ƒ_32:
                ·ƒ_32 _
              fn ·ƒ_35:
                ·ƒ_35 'other'
              fn ·v_41:
                ·match_block ·∅foo, ·v_15, ·v_29, ·v_41, ·ƒ_0


test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·match_arm
      fn ·v_5, ·ƒ_3, ·ƒ_4:
        ·match_value ·v_5, true, ·ƒ_3, fn:
          ·ƒ_4 _
      fn ·ƒ_8:
        ·op_plus ·∅y, 1, ·ƒ_8
      fn ·v_17:
        ·match_arm
          fn ·v_21, ·ƒ_19, ·ƒ_20:
            ·match_value ·v_21, false, ·ƒ_19, fn:
              ·ƒ_20 _
          fn ·ƒ_24:
            ·ƒ_24 ·∅y
          fn ·v_31:
            ·match_block ·∅x, ·v_17, ·v_31, ·ƒ_0


test 'match child ·scope — binding in arm body', fn:
  expect cps_expr fink":
    match n:
      a > 1:
        ni = a
        ni
  | equals fink":
    ·match_arm
      fn ·v_7, ·ƒ_5, ·ƒ_6:
        ·let ·v_7, fn ·a_0:
          ·match_if ·op_gt, ·∅a, 1, ·ƒ_5, fn:
            ·ƒ_6 _
      fn ·a_0, ·ƒ_11:
        ·let ·a_0, fn ·ni_1:
          ·ƒ_11 ·ni_1
      fn ·v_22:
        ·match_block ·∅n, ·v_22, ·ƒ_2


---
match block — seq/rec pattern arms
---

test 'match — seq pattern arm', fn:
  expect cps_expr fink":
    match foo:
      [a, b]: a
  | equals fink":
    ·match_arm
      fn ·v_7, ·ƒ_5, ·ƒ_6:
        ·match_seq ·v_7, ·ƒ_5, fn ·v_9:
          ·match_next ·v_9, ·ƒ_5, fn ·v_10, ·v_11:
            ·let ·v_10, fn ·a_0:
              ·match_next ·v_11, ·ƒ_5, fn ·v_14, ·v_15:
                ·let ·v_14, fn ·b_1:
                  ·match_done ·v_15, ·ƒ_5, ·ƒ_6
      fn ·a_0, ·b_1, ·ƒ_20:
        ·ƒ_20 ·a_0
      fn ·v_39:
        ·match_block ·∅foo, ·v_39, ·ƒ_2

test 'match — rec pattern arm', fn:
  expect cps_expr fink":
    match foo:
      {bar}: bar
  | equals fink":
    ·match_arm
      fn ·v_6, ·ƒ_4, ·ƒ_5:
        ·match_rec ·v_6, ·ƒ_4, fn ·v_8:
          ·match_field ·v_8, 'bar', ·ƒ_4, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·bar_0:
              ·ƒ_5 ·bar_0
      fn ·bar_0, ·ƒ_14:
        ·ƒ_14 ·bar_0
      fn ·v_26:
        ·match_block ·∅foo, ·v_26, ·ƒ_1


test 'multi-arm match', fn:
  expect cps_expr fink":
    match foo:
      [a]: a
      [a, b]: a
  | equals fink":
    ·match_arm
      fn ·v_8, ·ƒ_6, ·ƒ_7:
        ·match_seq ·v_8, ·ƒ_6, fn ·v_10:
          ·match_next ·v_10, ·ƒ_6, fn ·v_11, ·v_12:
            ·let ·v_11, fn ·a_0:
              ·match_done ·v_12, ·ƒ_6, ·ƒ_7
      fn ·a_0, ·ƒ_17:
        ·ƒ_17 ·a_0
      fn ·v_31:
        ·match_arm
          fn ·v_35, ·ƒ_33, ·ƒ_34:
            ·match_seq ·v_35, ·ƒ_33, fn ·v_37:
              ·match_next ·v_37, ·ƒ_33, fn ·v_38, ·v_39:
                ·let ·v_38, fn ·a_1:
                  ·match_next ·v_39, ·ƒ_33, fn ·v_42, ·v_43:
                    ·let ·v_42, fn ·b_2:
                      ·match_done ·v_43, ·ƒ_33, ·ƒ_34
          fn ·a_1, ·b_2, ·ƒ_48:
            ·ƒ_48 ·a_1
          fn ·v_67:
            ·match_block ·∅foo, ·v_31, ·v_67, ·ƒ_3


test 'multi-arg match', fn:
  expect cps_expr fink":
    match a, b:
      x, y: x
  | equals fink":
    ·match_arm
      fn ·v_9, ·v_10, ·ƒ_7, ·ƒ_8:
        ·let ·v_9, fn ·x_0:
          ·let ·v_10, fn ·y_1:
            ·ƒ_8 ·y_1
      fn ·x_0, ·y_1, ·ƒ_13:
        ·ƒ_13 ·x_0
      fn ·v_20:
        ·match_block ·∅a, ·∅b, ·v_20, ·ƒ_2


---
pattern bindings (bind-lhs, outside match)
---

test 'irrefutable binding with guard', fn:
  expect cps_expr fink":
    x > 2 = foo
  | equals fink":
    ·let ·∅foo, fn ·x_0:
      ·match_if ·op_gt, ·∅x, 2, ·panic, fn:
        ·ƒ_1 _


test 'bind right — seq pattern', fn:
  expect cps_expr fink":
    [a, b] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·a_0:
          ·match_next ·v_6, ·panic, fn ·v_9, ·v_10:
            ·let ·v_9, fn ·b_1:
              ·match_done ·v_10, ·panic, ·ƒ_2


test 'bind right — rec pattern', fn:
  expect cps_expr fink":
    {bar} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·ƒ_1 ·bar_0


test 'seq pattern', fn:
  expect cps_expr fink":
    [a, 1] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·a_0:
          ·match_next ·v_5, ·panic, fn ·v_8, ·v_9:
            ·match_value ·v_8, 1, ·panic, fn:
              ·match_done ·v_9, ·panic, ·ƒ_1

test 'seq pattern with non-empty rest', fn:
  expect cps_expr fink":
    [a, ..] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_3:
      ·match_next ·v_3, ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·a_0:
          ·match_not_done ·v_5, ·panic, fn:
            ·ƒ_1 _

test 'seq pattern with bound rest', fn:
  expect cps_expr fink":
    [a, ..rest] = foo
  | equals fink":
    ·match_seq ·∅foo, ·panic, fn ·v_4:
      ·match_next ·v_4, ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·a_0:
          ·match_rest ·v_6, ·panic, fn ·v_10:
            ·let ·v_10, fn ·rest_1:
              ·ƒ_2 ·rest_1

test 'rec pattern', fn:
  expect cps_expr fink":
    {bar} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·ƒ_1 ·bar_0

test 'rec pattern with non-empty rest', fn:
  expect cps_expr fink":
    {bar, ..} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·match_not_done ·v_5, ·panic, fn:
            ·ƒ_1 _

test 'rec pattern exact - empty rest', fn:
  expect cps_expr fink":
    {bar, ..{}} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_3:
      ·match_field ·v_3, 'bar', ·panic, fn ·v_4, ·v_5:
        ·let ·v_4, fn ·bar_0:
          ·match_rest ·v_5, ·panic, fn ·v_9:
            ·match_rec ·v_9, ·panic, fn ·v_11:
              ·match_done ·v_11, ·panic, ·ƒ_1

test 'rec pattern with bound rest', fn:
  expect cps_expr fink":
    {bar, ..rest} = foo
  | equals fink":
    ·match_rec ·∅foo, ·panic, fn ·v_4:
      ·match_field ·v_4, 'bar', ·panic, fn ·v_5, ·v_6:
        ·let ·v_5, fn ·bar_0:
          ·match_rest ·v_6, ·panic, fn ·v_10:
            ·let ·v_10, fn ·rest_1:
              ·ƒ_2 ·rest_1


---
range patterns
---

test 'range — exclusive in match arm', fn:
  expect cps_expr fink":
    match x:
      0..10: 'low'
  | equals fink":
    ·match_arm
      fn ·v_5, ·ƒ_3, ·ƒ_4:
        ·op_rngex 0, 10, fn ·v_9:
          ·match_if ·op_in, ·v_5, ·v_9, ·ƒ_3, fn:
            ·ƒ_4 _
      fn ·ƒ_11:
        ·ƒ_11 'low'
      fn ·v_20:
        ·match_block ·∅x, ·v_20, ·ƒ_0


test 'range — inclusive in match arm', fn:
  expect cps_expr fink":
    match x:
      0...10: 'low'
  | equals fink":
    ·match_arm
      fn ·v_5, ·ƒ_3, ·ƒ_4:
        ·op_rngin 0, 10, fn ·v_9:
          ·match_if ·op_in, ·v_5, ·v_9, ·ƒ_3, fn:
            ·ƒ_4 _
      fn ·ƒ_11:
        ·ƒ_11 'low'
      fn ·v_20:
        ·match_block ·∅x, ·v_20, ·ƒ_0


test 'range — bind-lhs check', fn:
  expect cps_expr fink":
    0..10 = foo
  | equals fink":
    ·op_rngex 0, 10, fn ·v_4:
      ·match_if ·op_in, ·∅foo, ·v_4, ·panic, fn:
        ·ƒ_0 _


---
fn params (·ƒ_fail = unreachable, type checker guarantees)
---

test 'fn — seq destructuring param', fn:
  expect cps_expr fink":
    fn [a, b]: a
  | equals fink":
    ·fn
      fn ·v_4, ·ƒ_17:
        ·match_seq ·v_4, ·panic, fn ·v_6:
          ·match_next ·v_6, ·panic, fn ·v_7, ·v_8:
            ·let ·v_7, fn ·a_0:
              ·match_next ·v_8, ·panic, fn ·v_11, ·v_12:
                ·let ·v_11, fn ·b_1:
                  ·match_done ·v_12, ·panic, fn ·v_15:
                    ·ƒ_17 ·a_0
      fn ·v_3:
        ·ƒ_2 ·v_3

test 'fn — seq destructuring param with rest', fn:
  expect cps_expr fink":
    fn [a, ..rest]: rest
  | equals fink":
    ·fn
      fn ·v_4, ·ƒ_15:
        ·match_seq ·v_4, ·panic, fn ·v_6:
          ·match_next ·v_6, ·panic, fn ·v_7, ·v_8:
            ·let ·v_7, fn ·a_0:
              ·match_rest ·v_8, ·panic, fn ·v_12:
                ·let ·v_12, fn ·rest_1:
                  ·ƒ_15 ·rest_1
      fn ·v_3:
        ·ƒ_2 ·v_3


test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps_expr fink":
    fn a, [1, ..b]: b
  | equals fink":
    ·fn
      fn ·a_0, ·v_4, ·ƒ_16:
        ·match_seq ·v_4, ·panic, fn ·v_6:
          ·match_next ·v_6, ·panic, fn ·v_7, ·v_8:
            ·match_value ·v_7, 1, ·panic, fn:
              ·match_rest ·v_8, ·panic, fn ·v_13:
                ·let ·v_13, fn ·b_1:
                  ·ƒ_16 ·b_1
      fn ·v_3:
        ·ƒ_2 ·v_3
