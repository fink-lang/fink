    {bar} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·v_2:
      ·match_field ·v_2, 'bar', ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn bar:
          ·ƒ_0 bar


test 'seq pattern', fn:
  expect cps_expr fink":
    [a, 1] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
