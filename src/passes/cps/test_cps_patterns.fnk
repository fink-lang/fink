test 'rec — empty', fn:
  expect cps_expr fink":
    {} = foo
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_rec foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_done ·m_0, ·panic, fn ·v_1, ·scope, ·state:
          ·ƒ_cont ·v_1, ·state


test 'rec — non-empty', fn:
  expect cps_expr fink":
    {..} = foo
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_rec foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_not_done ·m_0, ·panic, fn ·scope, ·state:
          ·ƒ_cont ·v_1, ·state


test 'rec — partial match', fn:
  expect cps_expr fink":
    {x, y} = point
  | equals fink":
    ·load ·scope, ·id'point', fn point, ·scope:
      ·match_rec point, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'x', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'x', ·v_1, fn x, ·scope:
            ·match_field ·m_2, 'y', ·panic, fn ·v_3, ·m_4, ·scope, ·state:
              ·match_store ·scope, ·id'y', ·v_3, fn y, ·scope:
                ·ƒ_cont ·v_5, ·state


test 'rec — field rename', fn:
  expect cps_expr fink":
    {x, y: z} = point
  | equals fink":
    ·load ·scope, ·id'point', fn point, ·scope:
      ·match_rec point, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'x', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'x', ·v_1, fn x, ·scope:
            ·match_field ·m_2, 'y', ·panic, fn ·v_3, ·m_4, ·scope, ·state:
              ·match_store ·scope, ·id'z', ·v_3, fn z, ·scope:
                ·ƒ_cont ·v_5, ·state


test 'rec — open rest discarded', fn:
  expect cps_expr fink":
    {bar, ..} = foo
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_rec foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'bar', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'bar', ·v_1, fn bar, ·scope:
            ·match_not_done ·m_2, ·panic, fn ·scope, ·state:
              ·ƒ_cont ·v_3, ·state


test 'rec — open rest bound', fn:
  expect cps_expr fink":
    {bar, ..rest} = foo
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_rec foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'bar', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'bar', ·v_1, fn bar, ·scope:
            ·match_rest ·m_2, ·panic, fn ·v_3, ·scope, ·state:
              ·match_store ·scope, ·id'rest', ·v_3, fn rest, ·scope:
                ·ƒ_cont ·v_4, ·state


test 'rec — closed exact', fn:
  expect cps_expr fink":
    {bar, ..{}} = foo
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_rec foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'bar', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'bar', ·v_1, fn bar, ·scope:
            ·match_rest ·m_2, ·panic, fn ·v_3, ·scope, ·state:
              ·match_rec ·v_3, ·panic, fn ·m_4, ·scope, ·state:
                ·match_done ·m_4, ·panic, fn ·v_5, ·scope, ·state:
                  ·ƒ_cont ·v_6, ·state


test 'rec — closed with sub-pattern', fn:
  expect cps_expr fink":
    {foo, ..{bar, spam}} = x
  | equals fink":
    ·load ·scope, ·id'x', fn x, ·scope:
      ·match_rec x, ·panic, fn ·m_0, ·scope, ·state:
        ·match_field ·m_0, 'foo', ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'foo', ·v_1, fn foo, ·scope:
            ·match_rest ·m_2, ·panic, fn ·v_3, ·scope, ·state:
              ·match_rec ·v_3, ·panic, fn ·m_4, ·scope, ·state:
                ·match_field ·m_4, 'bar', ·panic, fn ·v_5, ·m_6, ·scope, ·state:
                  ·match_store ·scope, ·id'bar', ·v_5, fn bar, ·scope:
                    ·match_field ·m_6, 'spam', ·panic, fn ·v_7, ·m_8, ·scope, ·state:
                      ·match_store ·scope, ·id'spam', ·v_7, fn spam, ·scope:
                        ·ƒ_cont ·v_10, ·state


test 'match block bind', fn:
  expect cps_expr fink":
    match foo:
      1: 2
      x: x
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_block foo, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_value ·v_0, 1, ·ƒ_fail, fn ·scope, ·state:
            ·ƒ_cont 2, ·state
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_store ·scope, ·id'x', ·v_0, fn x, ·scope:
            ·load ·scope, ·id'x', fn x, ·scope:
              ·ƒ_cont x, ·state
        fn ·v_2, ·scope, ·state: ·ƒ_cont ·v_2, ·state


---
match block — simple arms
---

test 'match wildcard', fn:
  expect cps_expr fink":
    match foo:
      _: 42
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_block foo, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·ƒ_cont 42, ·state
        fn ·v_1, ·scope, ·state: ·ƒ_cont ·v_1, ·state


test 'match bind', fn:
  expect cps_expr fink":
    match foo:
      x: x
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_block foo, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_store ·scope, ·id'x', ·v_0, fn x, ·scope:
            ·load ·scope, ·id'x', fn x, ·scope:
              ·ƒ_cont x, ·state
        fn ·v_1, ·scope, ·state: ·ƒ_cont ·v_1, ·state


test 'match literal arms', fn:
  expect cps_expr fink":
    match foo:
      1: 'one'
      2: 'two'
      _: 'other'
  | equals fink":
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_block foo, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_value ·v_0, 1, ·ƒ_fail, fn ·scope, ·state:
            ·ƒ_cont 'one', ·state
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_value ·v_0, 2, ·ƒ_fail, fn ·scope, ·state:
            ·ƒ_cont 'two', ·state
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·ƒ_cont 'other', ·state
        fn ·v_3, ·scope, ·state: ·ƒ_cont ·v_3, ·state


test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·load ·scope, ·id'x', fn x, ·scope:
      ·match_block x, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_value ·v_0, true, ·ƒ_fail, fn ·scope, ·state:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'y', fn y, ·scope:
                ·apply ·op_plus, y, 1, ·state, fn ·v_2, ·state:
                  ·ƒ_cont ·v_2, ·state
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_value ·v_0, false, ·ƒ_fail, fn ·scope, ·state:
            ·load ·scope, ·id'y', fn y, ·scope:
              ·ƒ_cont y, ·state
        fn ·v_4, ·scope, ·state: ·ƒ_cont ·v_4, ·state


test 'match child ·scope — binding in arm body', fn:
  expect cps_expr fink":
    match n:
      a > 1:
        ni = a
        ni
  | equals fink":
    ·load ·scope, ·id'n', fn n, ·scope:
      ·match_block n, ·panic, ·state,
        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_store ·scope, ·id'a', ·v_0, fn a, ·scope:
            ·load ·scope, ·op'>', fn ·op_gt, ·scope:
              ·load ·scope, ·id'a', fn a, ·scope:
                ·match_if ·op_gt, a, 1, ·ƒ_fail, fn ·scope, ·state:
                  ·load ·scope, ·id'a', fn a, ·scope:
                    ·match_store ·scope, ·id'ni', a, fn ni, ·scope:
                      ·load ·scope, ·id'ni', fn ni, ·scope:
                        ·ƒ_cont ni, ·state
        fn ·v_1, ·scope, ·state: ·ƒ_cont ·v_1, ·state


