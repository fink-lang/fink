test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·fn
      fn ·v_22: ·op_plus ·∅y, 1, ·v_22
      fn ·v_28:
        ·fn
          fn ·v_2, ·v_3, ·v_4:
            ·fn
              fn: ·v_28 ·v_3
