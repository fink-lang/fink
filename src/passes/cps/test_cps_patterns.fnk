  expect cps_expr fink":
    {} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·m_0:
      ·match_done ·m_0, ·panic, fn ·v_2:
        ·ƒ_0 ·v_2


test 'rec — non-empty', fn:
  expect cps_expr fink":
    {..} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·m_0:
      ·match_not_done ·m_0, ·panic, fn:
        ·ƒ_0 ·v_2


test 'rec — partial match', fn:
  expect cps_expr fink":
    {x, y} = point
  | equals fink":
    ·match_rec point, ·panic, fn ·m_0:
      ·match_field ·m_0, 'x', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_field ·m_1, 'y', ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn y:
              ·ƒ_0 ·v_8


test 'rec — field rename', fn:
  expect cps_expr fink":
    {x, y: z} = point
  | equals fink":
    ·match_rec point, ·panic, fn ·m_0:
      ·match_field ·m_0, 'x', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_field ·m_1, 'y', ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn z:
              ·ƒ_0 ·v_8


test 'rec — open rest discarded', fn:
  expect cps_expr fink":
    {bar, ..} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·m_0:
      ·match_field ·m_0, 'bar', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn bar:
          ·match_not_done ·m_1, ·panic, fn:
            ·ƒ_0 ·v_5


test 'rec — open rest bound', fn:
  expect cps_expr fink":
    {bar, ..rest} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·m_0:
      ·match_field ·m_0, 'bar', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn bar:
          ·match_rest ·m_1, ·panic, fn ·v_5:
            ·let ·v_5, fn rest:
              ·ƒ_0 ·v_8


test 'rec — closed exact', fn:
  expect cps_expr fink":
    {bar, ..{}} = foo
  | equals fink":
    ·match_rec foo, ·panic, fn ·m_0:
      ·match_field ·m_0, 'bar', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn bar:
          ·match_rest ·m_1, ·panic, fn ·v_5:
            ·match_rec ·v_5, ·panic, fn ·m_2:
              ·match_done ·m_2, ·panic, fn ·v_7:
                ·ƒ_0 ·v_8


test 'rec — closed with sub-pattern', fn:
  expect cps_expr fink":
    {foo, ..{bar, spam}} = x
  | equals fink":
    ·match_rec x, ·panic, fn ·m_0:
      ·match_field ·m_0, 'foo', ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn foo:
          ·match_rest ·m_1, ·panic, fn ·v_5:
            ·match_rec ·v_5, ·panic, fn ·m_2:
              ·match_field ·m_2, 'bar', ·panic, fn ·v_7, ·m_3:
                ·let ·v_7, fn bar:
                  ·match_field ·m_3, 'spam', ·panic, fn ·v_10, ·m_4:
                    ·let ·v_10, fn spam:
                      ·ƒ_0 ·v_14


test 'match block bind', fn:
  expect cps_expr fink":
    match foo:
      1: 2
      x: x
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_value ·v_2, 1, ·ƒ_fail, fn:
          ·ƒ_0 2
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·let ·v_2, fn x:
          ·ƒ_0 x
      fn ·v_15: ·ƒ_0 ·v_15


---
match block — simple arms
---

test 'match wildcard', fn:
  expect cps_expr fink":
    match foo:
      _: 42
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·ƒ_0 42
      fn ·v_6: ·ƒ_0 ·v_6


test 'match bind', fn:
  expect cps_expr fink":
    match foo:
      x: x
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·let ·v_2, fn x:
          ·ƒ_0 x
      fn ·v_9: ·ƒ_0 ·v_9


test 'match literal arms', fn:
  expect cps_expr fink":
    match foo:
      1: 'one'
      2: 'two'
      _: 'other'
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_value ·v_2, 1, ·ƒ_fail, fn:
          ·ƒ_0 'one'
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_value ·v_2, 2, ·ƒ_fail, fn:
          ·ƒ_0 'two'
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·ƒ_0 'other'
      fn ·v_18: ·ƒ_0 ·v_18


test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·match_block x, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_value ·v_2, true, ·ƒ_fail, fn:
          ·apply ·op_plus, y, 1, fn ·v_7:
            ·ƒ_0 ·v_7
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_value ·v_2, false, ·ƒ_fail, fn:
          ·ƒ_0 y
      fn ·v_19: ·ƒ_0 ·v_19


test 'match child ·scope — binding in arm body', fn:
  expect cps_expr fink":
    match n:
      a > 1:
        ni = a
        ni
  | equals fink":
    ·match_block n, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·let ·v_2, fn a:
          ·match_if ·op_gt, a, 1, ·ƒ_fail, fn:
            ·let a, fn ni:
              ·ƒ_0 ni
      fn ·v_17: ·ƒ_0 ·v_17


---
match block — seq/rec pattern arms
---

test 'match — seq pattern arm', fn:
  expect cps_expr fink":
    match foo:
      [a, b]: a
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_seq ·v_2, ·ƒ_fail, fn ·m_0:
          ·match_next ·m_0, ·ƒ_fail, fn ·v_4, ·m_1:
            ·let ·v_4, fn a:
              ·match_next ·m_1, ·ƒ_fail, fn ·v_7, ·m_2:
                ·let ·v_7, fn b:
                  ·match_done ·m_2, ·ƒ_fail, fn ·v_10:
                    ·ƒ_0 a
      fn ·v_25: ·ƒ_0 ·v_25

test 'match — rec pattern arm', fn:
  expect cps_expr fink":
    match foo:
      {bar}: bar
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_rec ·v_2, ·ƒ_fail, fn ·m_0:
          ·match_field ·m_0, 'bar', ·ƒ_fail, fn ·v_4, ·m_1:
            ·let ·v_4, fn bar:
              ·ƒ_0 bar
      fn ·v_16: ·ƒ_0 ·v_16


test 'multi-arm match', fn:
  expect cps_expr fink":
    match foo:
      [a]: a
      [a, b]: a
  | equals fink":
    ·match_block foo, ·panic,
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_seq ·v_2, ·ƒ_fail, fn ·m_0:
          ·match_next ·m_0, ·ƒ_fail, fn ·v_4, ·m_1:
            ·let ·v_4, fn a:
              ·match_done ·m_1, ·ƒ_fail, fn ·v_7:
                ·ƒ_0 a
      ·match_branch fn ·v_2, ·ƒ_cont, ·ƒ_fail:
        ·match_seq ·v_2, ·ƒ_fail, fn ·m_2:
          ·match_next ·m_2, ·ƒ_fail, fn ·v_19, ·m_3:
            ·let ·v_19, fn a:
              ·match_next ·m_3, ·ƒ_fail, fn ·v_22, ·m_4:
                ·let ·v_22, fn b:
                  ·match_done ·m_4, ·ƒ_fail, fn ·v_25:
                    ·ƒ_0 a
      fn ·v_40: ·ƒ_0 ·v_40


test 'multi-arg match', fn:
  expect cps_expr fink":
    match a, b:
      x, y: x
  | equals fink":
    ·match_block a, b, ·panic,
      ·match_branch fn ·v_3, ·v_4, ·ƒ_cont, ·ƒ_fail:
        ·let ·v_3, fn x:
          ·let ·v_4, fn y:
            ·ƒ_0 x
      fn ·v_15: ·ƒ_0 ·v_15


