test 'irrefutable binding with guard', fn:
  expect cps_expr fink":
    x > 2 = foo
  | equals fink":
    ·let foo, fn x:
      ·match_if ·op_gt, x, 2, ·panic, fn: ·ƒ_0


test 'bind right — seq pattern', fn:
  expect cps_expr fink":
    [a, b] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn b:
              ·match_done ·v_9, ·panic, fn ·v_0:
                ·ƒ_0 ·v_0


