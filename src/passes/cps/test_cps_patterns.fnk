test 'seq — literal element', fn:
  expect cps_expr fink":
    [a, 1] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn a:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·match_value ·v_5, 1, ·panic, fn:
              ·match_done ·m_2, ·panic, fn ·v_8:
                ·ƒ_0 ·v_8


test 'seq — infix guard', fn:
  expect cps_expr fink":
    [x, y >= 2] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn y:
              ·match_if ·op_gte, y, 2, ·panic, fn:
                ·match_done ·m_2, ·panic, fn ·v_10:
                  ·ƒ_0 ·v_10


test 'seq — predicate guard', fn:
  expect cps_expr fink":
    [x, is_even y] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn y:
              ·match_if is_even, y, ·panic, fn:
                ·match_done ·m_2, ·panic, fn ·v_11:
                  ·ƒ_0 ·v_11


test 'seq — constructor guard with payload', fn:
  expect cps_expr fink":
    [x, Ok b] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn b:
              ·match_if Ok, b, ·panic, fn:
                ·match_done ·m_2, ·panic, fn ·v_11:
                  ·ƒ_0 ·v_11


test 'seq — constructor predicate with wildcard', fn:
  expect cps_expr fink":
    [x, is_none _] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn x:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·match_if is_none, ·v_5, ·panic, fn:
              ·match_done ·m_2, ·panic, fn ·v_10:
                ·ƒ_0 ·v_10


test 'seq — multi-arg guard with bound element', fn:
  expect cps_expr fink":
    [1, foo 2, a, 3; 4] = bar
  | equals fink":
    ·match_seq bar, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·match_value ·v_2, 1, ·panic, fn:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn a:
              ·match_if foo, 2, a, 3, ·panic, fn:
                ·match_next ·m_2, ·panic, fn ·v_13, ·m_3:
                  ·match_value ·v_13, 4, ·panic, fn:
                    ·match_done ·m_3, ·panic, fn ·v_16:
                      ·ƒ_0 ·v_16



test 'seq — nested', fn:
  expect cps_expr fink":
    [a, [b, c]] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn a:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·match_seq ·v_5, ·panic, fn ·m_3:
              ·match_next ·m_3, ·panic, fn ·v_7, ·m_4:
                ·let ·v_7, fn b:
                  ·match_next ·m_4, ·panic, fn ·v_10, ·m_5:
                    ·let ·v_10, fn c:
                      ·match_done ·m_5, ·panic, fn ·v_13:
                        ·match_done ·m_2, ·panic, fn ·v_14:
                          ·ƒ_0 ·v_14

test 'seq — nested with bind-right', fn:
  expect cps_expr fink":
    [a, [b, c] |= d] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·m_0:
      ·match_next ·m_0, ·panic, fn ·v_2, ·m_1:
        ·let ·v_2, fn a:
          ·match_next ·m_1, ·panic, fn ·v_5, ·m_2:
            ·let ·v_5, fn d:
              ·match_seq ·v_5, ·panic, fn ·m_3:
                ·match_next ·m_3, ·panic, fn ·v_8, ·m_4:
                  ·let ·v_8, fn b:
                    ·match_next ·m_4, ·panic, fn ·v_11, ·m_5:
                      ·let ·v_11, fn c:
                        ·match_done ·m_5, ·panic, fn ·v_14:
                          ·match_done ·m_2, ·panic, fn ·v_15:
                            ·ƒ_0 ·v_15


