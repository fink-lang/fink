test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·match_arm
      fn ·v_5, ·v_3, ·v_4:
        ·fn
          fn ·v_7, ·v_8, ·v_9:
            ·op_eq ·v_7, true, fn ·v_12:
              ·if ·v_12,
                fn: ·v_8 _
                fn: ·v_9 _
          fn ·v_20: ·v_20 ·v_5, ·v_4, ·v_3
      fn ·v_23: ·op_plus ·∅y, 1, ·v_23
      fn ·v_35:
        ·match_arm
          fn ·v_39, ·v_37, ·v_38:
            ·fn
              fn ·v_41, ·v_42, ·v_43:
                ·op_eq ·v_41, false, fn ·v_46:
                  ·if ·v_46,
                    fn: ·v_42 _
                    fn: ·v_43 _
