          ·match_next ·m_0, ·panic, fn ·v_5, ·m_1:
            ·match_value ·v_5, 1, ·panic, fn:
              ·match_rest ·m_1, ·panic, fn ·v_8:
                ·let ·v_8, fn b:
                  ·ƒ_12 b
      fn ·v_1: ·ƒ_0 ·v_1
