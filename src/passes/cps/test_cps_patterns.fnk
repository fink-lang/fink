match block — simple arms
---

test 'match wildcard', fn:
  expect cps_expr fink":
    match foo:
      _: 42
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_8: ·ƒ_fail
        fn ·ƒ_7:
          ·let 42, fn ·v_5:
            ·ƒ_0 ·v_5
      fn ·v_0: ·ƒ_0 ·v_0


test 'match bind', fn:
  expect cps_expr fink":
    match foo:
      x: x
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_9:
          ·let ·v_2, fn x:
            ·ƒ_8 x
        fn ·ƒ_8, x:
          ·let x, fn ·v_6:
            ·ƒ_0 ·v_6
      fn ·v_0: ·ƒ_0 ·v_0


test 'match literal arms', fn:
  expect cps_expr fink":
    match foo:
      1: 'one'
      2: 'two'
      _: 'other'
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_9:
          ·match_value ·v_2, 1, ·ƒ_fail, fn: ·ƒ_8
        fn ·ƒ_8:
          ·let 'one', fn ·v_6:
            ·ƒ_0 ·v_6
      ·match_arm
        fn ·v_19:
          ·match_value ·v_2, 2, ·ƒ_fail, fn: ·ƒ_18
        fn ·ƒ_18:
          ·let 'two', fn ·v_16:
            ·ƒ_0 ·v_16
      ·match_arm
        fn ·v_28: ·ƒ_fail
        fn ·ƒ_27:
          ·let 'other', fn ·v_25:
            ·ƒ_0 ·v_25
      fn ·v_0: ·ƒ_0 ·v_0


test 'match — expression in arm', fn:
  expect cps_expr fink":
    match x:
      true: y + 1
      false: y
  | equals fink":
    ·match_block x,
      ·match_arm
        fn ·v_11:
          ·match_value ·v_2, true, ·ƒ_fail, fn: ·ƒ_10
        fn ·ƒ_10:
          ·apply ·op_plus, y, 1, fn ·v_0:
            ·ƒ_0 ·v_0
      ·match_arm
        fn ·v_21:
          ·match_value ·v_2, false, ·ƒ_fail, fn: ·ƒ_20
        fn ·ƒ_20:
          ·let y, fn ·v_18:
            ·ƒ_0 ·v_18
      fn ·v_0: ·ƒ_0 ·v_0


test 'match child ·scope — binding in arm body', fn:
  expect cps_expr fink":
    match n:
      a > 1:
        ni = a
        ni
  | equals fink":
    ·match_block n,
      ·match_arm
        fn ·v_13:
          ·let ·v_2, fn a:
            ·match_if ·op_gt, a, 1, ·ƒ_fail, fn: ·ƒ_12
        fn ·ƒ_12, a:
          ·let a, fn ni:
            ·ƒ_0 ni
      fn ·v_0: ·ƒ_0 ·v_0


---
match block — seq/rec pattern arms
---

test 'match — seq pattern arm', fn:
  expect cps_expr fink":
    match foo:
      [a, b]: a
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_21:
          ·match_seq ·v_2, ·ƒ_fail, fn ·v_4:
            ·match_next ·v_4, ·ƒ_fail, fn ·v_5, ·v_6:
              ·let ·v_5, fn a:
                ·match_next ·v_6, ·ƒ_fail, fn ·v_10, ·v_11:
                  ·let ·v_10, fn b:
                    ·match_done ·v_11, ·ƒ_fail, fn ·v_20:
                      ·ƒ_20 ·v_20
        fn ·ƒ_20, a, b:
          ·let a, fn ·v_18:
            ·ƒ_0 ·v_18
      fn ·v_0: ·ƒ_0 ·v_0

test 'match — rec pattern arm', fn:
  expect cps_expr fink":
    match foo:
      {bar}: bar
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_15:
          ·match_rec ·v_2, ·ƒ_fail, fn ·v_4:
            ·match_field ·v_4, 'bar', ·ƒ_fail, fn ·v_5, ·v_6:
              ·let ·v_5, fn bar:
                ·ƒ_14 bar
        fn ·ƒ_14, bar:
          ·let bar, fn ·v_12:
            ·ƒ_0 ·v_12
      fn ·v_0: ·ƒ_0 ·v_0


test 'multi-arm match', fn:
  expect cps_expr fink":
    match foo:
      [a]: a
      [a, b]: a
  | equals fink":
    ·match_block foo,
      ·match_arm
        fn ·v_16:
          ·match_seq ·v_2, ·ƒ_fail, fn ·v_4:
            ·match_next ·v_4, ·ƒ_fail, fn ·v_5, ·v_6:
              ·let ·v_5, fn a:
                ·match_done ·v_6, ·ƒ_fail, fn ·v_15:
                  ·ƒ_15 ·v_15
        fn ·ƒ_15, a:
          ·let a, fn ·v_13:
            ·ƒ_0 ·v_13
      ·match_arm
        fn ·v_47:
          ·match_seq ·v_2, ·ƒ_fail, fn ·v_30:
            ·match_next ·v_30, ·ƒ_fail, fn ·v_31, ·v_32:
              ·let ·v_31, fn a:
                ·match_next ·v_32, ·ƒ_fail, fn ·v_36, ·v_37:
                  ·let ·v_36, fn b:
                    ·match_done ·v_37, ·ƒ_fail, fn ·v_46:
                      ·ƒ_46 ·v_46
        fn ·ƒ_46, a, b:
          ·let a, fn ·v_44:
            ·ƒ_0 ·v_44
      fn ·v_0: ·ƒ_0 ·v_0


test 'multi-arg match', fn:
  expect cps_expr fink":
    match a, b:
      x, y: x
  | equals fink":
    ·match_block a, b,
      ·match_arm
        fn ·v_13, ·v_14:
          ·let ·v_3, fn x:
            ·let ·v_4, fn y:
              ·ƒ_12 y
        fn ·ƒ_12, x, y:
          ·let x, fn ·v_10:
            ·ƒ_0 ·v_10
      fn ·v_0: ·ƒ_0 ·v_0


