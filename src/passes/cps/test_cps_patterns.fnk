---
CPS pattern lowering — design scratch pad (WIP)
---

# WIP: design document for pattern lowering pass. Not yet wired to test runner.
# Expected CPS expansion for every pattern form.
#
# Failure continuation convention:
#   ·panic   — default; pattern mismatch is a compile/runtime error
#   ·ƒ_fail  — inside a ·match_block arm; failure tries the next arm
#
# Every ·match_* primitive shape:
#   ·match_* scrutinee, …args…, ·ƒ_fail, fn <bindings>: body
#
# Cursor-based traversal primitives:
#   ·match_seq      — initialize seq cursor from scrutinee
#   ·match_next     — pop head from cursor, advance; fn ·v, ·cursor, …
#   ·match_done     — assert cursor exhausted; ·ƒ_fail if not
#   ·match_not_done — assert cursor not exhausted; ·ƒ_fail if empty
#   ·match_rest     — bind remaining cursor as value (zero or more)
#   ·match_rec      — initialize rec cursor from scrutinee
#   ·match_field    — extract named field from rec cursor; fn ·v, ·cursor, …
#   ·match_bind     — bind extracted temp to name; always succeeds
#   ·match_value    — assert extracted temp equals literal; ·ƒ_fail if not
#   ·match_if       — apply fn to args, ·ƒ_fail if falsy; no result binding (guard)
#   ·match_apply    — apply fn to args, bind result; ·ƒ_fail if wrong tag (constructor/extractor)
#                     deferred: name resolution distinguishes predicate (→ ·match_if)
#                     from constructor/extractor (→ ·match_apply) based on callee
#
# Binding rules:
#   bare ident in pattern position — always a binding (·match_bind), never a lookup
#   wildcard (_) — discard; no ·match_bind, temp passed directly to next primitive
#   to match a constructor value without payload: use a predicate (e.g. is_none _)
#
# Optimization hint (not in IR yet):
#   ·match_size  — early length check when collection is realized



---
bind
---

test 'plain bind', fn:
  expect cps_expr fink":
    x = foo
  | equals fink":
    ·let foo, fn x:
      ·ƒ_0 x

test 'simple guard', fn:
  expect cps_expr fink":
    a > 0 = foo
  | equals fink":
    ·let foo, fn a:
      ·match_if ·op_gt, a, 0, ·panic, fn: ·ƒ_0


test 'nested guard', fn:
  expect cps_expr fink":
    a > 0 or a < 9 = foo
  | equals fink":
    ·let foo, fn a:
      ·apply ·op_gt, a, 0, fn ·v_5:
        ·apply ·op_lt, a, 9, fn ·v_9:
          ·match_if ·op_or, ·v_5, ·v_9, ·panic, fn: ·ƒ_0


---
seq patterns
---

test 'seq — empty', fn:
  expect cps_expr fink":
    [] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_done ·v_2, ·panic, fn ·v_0:
        ·ƒ_0 ·v_0


test 'seq — nested empty', fn:
  expect cps_expr fink":
    [a, []] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·match_seq ·v_8, ·panic, fn ·v_12:
              ·match_done ·v_12, ·panic, fn ·v_13:
                ·match_done ·v_9, ·panic, fn ·v_0:
                  ·ƒ_0 ·v_0


test 'seq — exact two elements', fn:
  expect cps_expr fink":
    [a, b] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn b:
              ·match_done ·v_9, ·panic, fn ·v_0:
                ·ƒ_0 ·v_0



test 'seq — lone spread non-empty discard', fn:
  expect cps_expr fink":
    [..] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_not_done ·v_2, ·panic, fn: ·ƒ_0


test 'seq — spread non-empty bound', fn:
  expect cps_expr fink":
    [..rest] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_rest ·v_2, ·panic, fn ·v_4:
        ·let ·v_4, fn rest:
          ·ƒ_0 rest


test 'seq — head then spread discard', fn:
  expect cps_expr fink":
    [head, ..] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn head:
          ·match_not_done ·v_4, ·panic, fn: ·ƒ_0


test 'seq — head then spread bound', fn:
  expect cps_expr fink":
    [head, ..tail] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn head:
          ·match_rest ·v_4, ·panic, fn ·v_9:
            ·let ·v_9, fn tail:
              ·ƒ_0 tail


