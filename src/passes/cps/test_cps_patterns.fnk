                ·match_if ·op_in, ·v_0, ·v_1, ·ƒ_fail, fn ·scope, ·state:
                  ·ƒ_cont 'low', ·state
        fn ·v_2, ·scope, ·state: ·ƒ_cont ·v_2, ·state


