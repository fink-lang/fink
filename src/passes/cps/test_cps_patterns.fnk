test 'fn — seq destructuring param', fn:
  expect cps_expr fink":
    fn [a, b]: a
  | equals fink":
    ·fn
      fn ·v_2, ·ƒ_11:
        ·match_seq ·v_2, ·panic, fn ·m_0:
          ·match_next ·m_0, ·panic, fn ·v_4, ·m_1:
            ·let ·v_4, fn a:
              ·match_next ·m_1, ·panic, fn ·v_7, ·m_2:
                ·let ·v_7, fn b:
                  ·match_done ·m_2, ·panic, fn ·v_10:
                    ·ƒ_11 a
      fn ·v_1: ·ƒ_0 ·v_1

test 'fn — seq destructuring param with rest', fn:
