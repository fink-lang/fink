test 'seq — literal element', fn:
  expect cps_expr fink":
    [a, 1] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·match_value ·v_8, 1, ·panic, fn:
              ·match_done ·v_9, ·panic, fn ·v_0:
                ·ƒ_0 ·v_0


test 'seq — infix guard', fn:
  expect cps_expr fink":
    [x, y >= 2] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn y:
              ·match_if ·op_gte, y, 2, ·panic, fn:
                ·match_done ·v_9, ·panic, fn ·v_0:
                  ·ƒ_0 ·v_0


test 'seq — predicate guard', fn:
  expect cps_expr fink":
    [x, is_even y] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn y:
              ·match_if is_even, y, ·panic, fn:
                ·match_done ·v_9, ·panic, fn ·v_0:
                  ·ƒ_0 ·v_0


test 'seq — constructor guard with payload', fn:
  expect cps_expr fink":
    [x, Ok b] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn b:
              ·match_if Ok, b, ·panic, fn:
                ·match_done ·v_9, ·panic, fn ·v_0:
                  ·ƒ_0 ·v_0


test 'seq — constructor predicate with wildcard', fn:
  expect cps_expr fink":
    [x, is_none _] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn x:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·match_if is_none, ·v_8, ·panic, fn:
              ·match_done ·v_9, ·panic, fn ·v_0:
                ·ƒ_0 ·v_0


test 'seq — multi-arg guard with bound element', fn:
  expect cps_expr fink":
    [1, foo 2, a, 3; 4] = bar
  | equals fink":
    ·match_seq bar, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·match_value ·v_3, 1, ·panic, fn:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn a:
              ·match_if foo, 2, a, 3, ·panic, fn:
                ·match_next ·v_9, ·panic, fn ·v_18, ·v_19:
                  ·match_value ·v_18, 4, ·panic, fn:
                    ·match_done ·v_19, ·panic, fn ·v_0:
                      ·ƒ_0 ·v_0



test 'seq — nested', fn:
  expect cps_expr fink":
    [a, [b, c]] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·match_seq ·v_8, ·panic, fn ·v_12:
              ·match_next ·v_12, ·panic, fn ·v_13, ·v_14:
                ·let ·v_13, fn b:
                  ·match_next ·v_14, ·panic, fn ·v_18, ·v_19:
                    ·let ·v_18, fn c:
                      ·match_done ·v_19, ·panic, fn ·v_23:
                        ·match_done ·v_9, ·panic, fn ·v_0:
                          ·ƒ_0 ·v_0

test 'seq — nested with bind-right', fn:
  expect cps_expr fink":
    [a, [b, c] |= d] = foo
  | equals fink":
    ·match_seq foo, ·panic, fn ·v_2:
      ·match_next ·v_2, ·panic, fn ·v_3, ·v_4:
        ·let ·v_3, fn a:
          ·match_next ·v_4, ·panic, fn ·v_8, ·v_9:
            ·let ·v_8, fn d:
              ·match_seq ·v_8, ·panic, fn ·v_13:
                ·match_next ·v_13, ·panic, fn ·v_14, ·v_15:
                  ·let ·v_14, fn b:
                    ·match_next ·v_15, ·panic, fn ·v_19, ·v_20:
                      ·let ·v_19, fn c:
                        ·match_done ·v_20, ·panic, fn ·v_24:
                          ·match_done ·v_9, ·panic, fn ·v_0:
                            ·ƒ_0 ·v_0


