{test, skip, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'dict — field rename', fn:
  expect cps_module ƒink:
    {'foo bar': z} = {'foo bar': 42}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_43, ·ƒret_1:
      ·rec_put ·ƒctx_43, {}, 'foo bar', (i8 42), fn ·ƒctx_46, ·ƒv_5:
        ·fn
          fn ·ƒctx_47, ·ƒv_10:
            ·let ·ƒv_10, fn ·z_0:
              ·ƒret_1 ·ƒctx_47, ·z_0
          fn ·ƒv_31:
            ·fn
              fn ·ƒctx_48, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                ·guard_apply ·ƒctx_48, ·rec_protocol, ·ƒv_7,
                  fn ·ƒctx_50, ·ƒv_15:
                    ·rec_pop ·ƒctx_50, ·ƒv_15, 'foo bar', ·ƒfail_9, fn ·ƒctx_52, ·ƒv_10, ·ƒv_14:
                      ·ƒsucc_8 ·ƒctx_52, ·ƒv_10
                  fn ·ƒctx_54: ·ƒfail_9 ·ƒctx_54
              fn ·ƒv_25:
                ·fn
                  fn ·ƒctx_56: ·panic ·ƒctx_56
                  fn ·ƒv_34: ·ƒv_25 ·ƒctx_46, ·ƒv_31, ·ƒv_34, ·ƒv_5
    # sm:



test 'dict — runtime key', fn:
  expect cps_module ƒink:
    x = 'foobar'
    {(x): val} = {'foobar': 42}
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_50, ·ƒret_2:
      ·letrec fn ·x_0:
        ·set ·x_0, 'foobar', fn:
          ·ƒpub ·ƒctx_50, ·x_0, fn ·ƒctx_53:
            ·rec_put ·ƒctx_53, {}, 'foobar', (i8 42), fn ·ƒctx_55, ·ƒv_7:
              ·fn
                fn ·ƒctx_56, ·ƒv_12:
                  ·let ·ƒv_12, fn ·val_1:
                    ·ƒret_2 ·ƒctx_56, ·val_1
                fn ·ƒv_33:
                  ·fn
                    fn ·ƒctx_57, ·ƒsucc_10, ·ƒfail_11, ·ƒv_9:
                      ·guard_apply ·ƒctx_57, ·rec_protocol, ·ƒv_9,
                        fn ·ƒctx_59, ·ƒv_17:
                          ·rec_pop ·ƒctx_59, ·ƒv_17, ·x_0, ·ƒfail_11, fn ·ƒctx_61, ·ƒv_12, ·ƒv_16:
                            ·ƒsucc_10 ·ƒctx_61, ·ƒv_12
                        fn ·ƒctx_63: ·ƒfail_11 ·ƒctx_63
                    fn ·ƒv_27:
                      ·fn
                        fn ·ƒctx_65: ·panic ·ƒctx_65
                        fn ·ƒv_36: ·ƒv_27 ·ƒctx_55, ·ƒv_33, ·ƒv_36, ·ƒv_7
    # sm:
