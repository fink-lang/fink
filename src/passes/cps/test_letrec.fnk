---
Import + user binding. Imports are external — `foo` from
`{foo} = import ...` is bound by the import machinery and is
NOT a module slot (correctly excluded from the letrec list).
`main` IS a slot because it's a user-bound name.
---

test 'letrec with import binding', fn:
  expect cps_module ƒink:
    {foo} = import './bar.fnk'
    main = fn:
      foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_3:
      ·letrec fn ·main_1:
        ·import ·ƒctx_58, './bar.fnk', fn ·ƒctx_61, ·v_6:
          ·fn
            fn ·ƒctx_62, ·v_11:
              ·let ·v_11, fn ·foo_0:
                ·fn
                  fn ·ƒctx_63, ·ƒret_29: ·foo_0 ·ƒctx_63, ·ƒret_29, (i8 1)
                  fn ·v_28:
                    ·let ·v_28, fn ·main_1:
                      ·ƒpub ·ƒctx_62, ·main_1, fn ·ƒctx_66:
                        ·ƒret_3 ·ƒctx_66, ·main_1
            fn ·v_43:
              ·fn
                fn ·ƒctx_68, ·ƒsucc_9, ·ƒfail_10, ·v_8:
                  ·is_rec_like ·ƒctx_68, ·v_8,
                    fn ·ƒctx_70, ·v_16:
                      ·rec_pop ·ƒctx_70, ·v_16, 'foo', ·ƒfail_10, fn ·ƒctx_72, ·v_11, ·v_15:
                        ·ƒsucc_9 ·ƒctx_72, ·v_11
                    fn ·ƒctx_74: ·ƒfail_10 ·ƒctx_74
                fn ·v_25: ·v_25 ·ƒctx_61, ·v_43, ·panic, ·v_6
    # sm:


---
Forward ref through a closure — `x` is defined before `foo` but
its fn body references `foo`. When `x` is later called, `foo`'s
slot has been filled. This is the legal mutual-rec shape: refs
to a not-yet-filled slot are fine as long as they happen inside
a fn body that's only invoked after the fill.

(Anti-pattern in practice — define callees before callers in
source order. The shape is permitted because mutual recursion
needs it, not because writing it this way for a single fn is
encouraged. A future lint could flag avoidable forward refs.)
---

test 'letrec closure forward ref', fn:
  expect cps_module ƒink:
    x = fn: foo 5
    foo = fn n: n + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_38, ·ƒret_3:
      ·letrec fn ·x_0, ·foo_1:
        ·fn
          fn ·ƒctx_40, ·ƒret_5: ·foo_1 ·ƒctx_40, ·ƒret_5, (i8 5)
          fn ·v_4:
            ·set ·ƒctx_38, ·x_0, ·v_4, fn ·ƒctx_43:
              ·ƒpub ·ƒctx_43, ·x_0, fn ·ƒctx_45:
                ·fn
                  fn ·ƒctx_46, ·ƒret_13, ·n_2: ·op_plus ·ƒctx_46, ·n_2, (i8 1), ·ƒret_13
                  fn ·v_12:
                    ·set ·ƒctx_45, ·foo_1, ·v_12, fn ·ƒctx_49:
                      ·ƒpub ·ƒctx_49, ·foo_1, fn ·ƒctx_51:
                        ·ƒret_3 ·ƒctx_51, ·foo_1
    # sm:


---
Standalone top-level destructure — `[a, b] = [1, 2]` lowers via
the pattern-match path. Both `a` and `b` are module-local slots,
declared in the letrec and bound by the matcher's success body.
Verifies the LetRec wrapper composes with the destructure
machinery.
---

test 'letrec with seq destructure', fn:
  expect cps_module ƒink:
    [a, b] = [1, 2]
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_60, ·ƒret_2:
      ·letrec fn ·a_0, ·b_1:
        ·seq_prepend ·ƒctx_60, (i8 2), [], fn ·ƒctx_63, ·v_5:
          ·seq_prepend ·ƒctx_63, (i8 1), ·v_5, fn ·ƒctx_65, ·v_8:
            ·fn
              fn ·ƒctx_66, ·v_13, ·v_14:
                ·let ·v_13, fn ·a_0:
                  ·let ·v_14, fn ·b_1:
                    ·ƒret_2 ·ƒctx_66, ·b_1
              fn ·v_48:
                ·fn
                  fn ·ƒctx_67, ·ƒsucc_11, ·ƒfail_12, ·v_10:
                    ·is_seq_like ·ƒctx_67, ·v_10,
                      fn ·ƒctx_69, ·v_27:
                        ·seq_pop ·ƒctx_69, ·v_27, ·ƒfail_12, fn ·ƒctx_71, ·v_13, ·v_28:
                          ·seq_pop ·ƒctx_71, ·v_28, ·ƒfail_12, fn ·ƒctx_73, ·v_14, ·v_19:
                            ·empty ·ƒctx_73, ·v_19, fn ·ƒctx_75, ·v_22:
                              ·if ·v_22,
                                fn: ·ƒsucc_11 ·ƒctx_75, ·v_13, ·v_14
                                fn: ·ƒfail_12 ·ƒctx_75
                      fn ·ƒctx_78: ·ƒfail_12 ·ƒctx_78
                  fn ·v_39: ·v_39 ·ƒctx_65, ·v_48, ·panic, ·v_8
    # sm:-AAQBAA8AAQAPGAAUAAQBAA8MAAQBAA8MAD4ABAEADwABAA8YABQALAAUAAQBAA8AAQAPGAAUACQBAA8MAAQBAA8AAQAPDgAUAAQBAA8MAAQBAA8OAAQBFAE



