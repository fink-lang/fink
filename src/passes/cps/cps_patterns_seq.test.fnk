{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{cps_module} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected

---
seq patterns
---

test 'seq — empty', fn:
  cps_module ƒink:
    [] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_0:
      ·fn
        fn ·ƒctx_41: ·ƒret_0 ·ƒctx_41, ·panic
        fn ·ƒv_26:
          ·fn
            fn ·ƒctx_43, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·guard_apply ·ƒctx_43, ·tuple_protocol, ·ƒv_2,
                fn ·ƒctx_45, ·ƒv_15:
                  ·let ·ƒv_15, fn ·ƒv_7:
                    ·empty ·ƒctx_45, ·ƒv_7, fn ·ƒctx_47, ·ƒv_10:
                      ·if ·ƒv_10,
                        fn: ·ƒsucc_3 ·ƒctx_47
                        fn: ·ƒfail_4 ·ƒctx_47
                fn ·ƒctx_50: ·ƒfail_4 ·ƒctx_50
            fn ·ƒv_23:
              ·fn
                fn ·ƒctx_52: ·panic ·ƒctx_52
                fn ·ƒv_29: ·ƒv_23 ·ƒctx_39, ·ƒv_26, ·ƒv_29, ·∅foo
    # sm:


