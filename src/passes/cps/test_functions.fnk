test 'identity function', fn:
  expect cps_expr ƒink:
    fn x: x
  | equals ƒink:
    ·fn
      fn ·ƒret_3, ·x_0: ·ƒret_3 ·x_0
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4geDogeCJdLAogICJtYXBwaW5ncyI6ICJBQUFBLEFBQUE7S0FBQSxTQUFHLEksRSxBQUFILFFBQU07S0FBTixJLEUsQSxLQUFBIgp9

test 'function with operator in body', fn:
  expect cps_expr ƒink:
    fn x: x + 1
  | equals ƒink:
    ·fn
      fn ·ƒret_3, ·x_0: ·op_plus ·x_0, 1, ·ƒret_3
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4geDogeCArIDEiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBO0tBQUEsU0FBRyxJLEVBQUssQUFBQSxTQUFGLEksRUFBSSxDLEVBQVY7S0FBQSxJLEUsQSxLQUFBIgp9

test 'try — result bound, code continues', fn:
  expect cps_expr ƒink:
    ni = try foo bar
    ni + 1
  | equals ƒink:
    ·fn
      fn ·ƒret_3:
        ·∅foo fn ·v_6:
          ·let ·v_6, fn ·ni_0:
            ·op_plus ·ni_0, 1, ·ƒret_3, ·∅bar
      fn ·v_2: ·v_1 ·v_2
    #sourcemaps:


