test 'named fn', fn:
  expect cps_expr ƒink:
    double = fn a: a
  | equals ƒink:
    ·fn
      fn ·ƒret_4, ·a_1: ·ƒret_4 ·a_1
      fn ·v_3:
        ·let ·v_3, fn ·double_0:
          ·v_2 ·double_0
