test 'forward ref', fn:
  expect cps_module ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_28, ·ƒret_2:
      ·letrec fn ·foo_0:
        ·fn
          fn ·ƒctx_30, ·ƒret_4, ·a_1:
            ·op_plus ·ƒctx_30, ·a_1, (i8 1), fn ·ƒctx_32, ·ƒv_8:
              ·foo_0 ·ƒctx_32, ·ƒret_4, ·ƒv_8
          fn ·ƒv_3:
            ·set ·foo_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_28, ·foo_0, fn ·ƒctx_35:
                ·foo_0 ·ƒctx_35, ·ƒret_2, (i8 1)
    # sm:RgABABsAAQAbJAEAGxgBLAUSAAIABgErGwABABsYAQADDgACAAoBDA8AAQAPCAAUABgBDAkWAQUBCgACABIBDgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQACgAYAQcFDgACABYBBwkAAQADEAAUAAQBAAkSAAQBCAUOABQBEw8OAAIAEgELFQABABUMAQADDgAEAQwPDgAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEsBQABAAMQABQABAEABRIABgEIAQABAAEGAQAB


test 'mutual recursion', fn:
  expect cps_module ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·letrec fn ·ping_0, ·pong_1:
        ·fn
          fn ·ƒctx_39, ·ƒret_6, ·x_2: ·pong_1 ·ƒctx_39, ·ƒret_6, ·x_2
          fn ·ƒv_5:
            ·set ·ping_0, ·ƒv_5, fn:
              ·ƒpub ·ƒctx_37, ·ping_0, fn ·ƒctx_42:
                ·fn
                  fn ·ƒctx_43, ·ƒret_14, ·x_3: ·ping_0 ·ƒctx_43, ·ƒret_14, ·x_3
                  fn ·ƒv_13:
                    ·set ·pong_1, ·ƒv_13, fn:
                      ·ƒpub ·ƒctx_42, ·pong_1, fn ·ƒctx_46:
                        ·ƒret_4 ·ƒctx_46, ·pong_1
    # sm:



