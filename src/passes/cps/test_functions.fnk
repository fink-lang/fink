            fn ·ƒctx_34, ·ƒret_8, ·b_3: ·op_plus ·ƒctx_34, ·a_1, ·b_3, ·ƒret_8
            fn ·v_7:
              ·let ·v_7, fn ·ni_2:
                ·ƒret_6 ·ƒctx_33, ·ni_2
        fn ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·ƒctx_31, ·foo_0, fn ·ƒctx_38:
              ·ƒret_4 ·ƒctx_38, ·foo_0
