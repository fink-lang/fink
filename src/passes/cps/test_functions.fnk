{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_module ƒink:
    fn a: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ·a_0: ·ƒret_3 ·a_0
        fn ·v_2: ·ƒret_1 ·v_2
    # sm:EQABAAcAAQAHJAEABxIACAEABwABAAcYAQwBFgEFAQoABAEGAQABAAEUAQABGgELBwoABAEABwABAAcUAQAH


test 'fn two params', fn:
  expect cps_module ƒink:
    fn a, b: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·a_0, ·b_1: ·ƒret_4 ·a_0
        fn ·v_3: ·ƒret_2 ·v_3
    # sm:EgABAAoAAQAKJAEAChIACAEACgABAAoYARIBFgELAQ4BBgEKAAQBBgEAAQABFAEAARoBEQoKAAQBAAoAAQAKFAEACg


test 'named fn', fn:
  expect cps_module ƒink:
    double = fn a: a
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·a_1: ·ƒret_4 ·a_1
        fn ·v_3:
          ·let ·v_3, fn ·double_0:
            ·ƒpub ·double_0, fn:
              ·ƒret_2 ·double_0
    # sm:HAABABAAAQAQJAEAEBIACAESBwABAAcYAQwBFgEFAQoABAEGAQABAAEUAQABGgELBwoAEAEDAQABAAEMAQQHCgAKAREGFAAUAQAGAAEABhABAAYUAAgAGAEABgABAAYUAQAG



---
ported from test_cps — functions and closures
---

test 'function binding', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·x_1: ·op_plus ·x_1, 1, ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·inc_0, fn:
              ·ƒret_2 ·inc_0
    # sm:IAABABEAAQARJAEAERIACAEMCwABAAsYAQwFFgEFAQoABAEGBQABAAUUAQABCgAEAQgBAgAEAQcFIgELCwoAEAEDAQABAAEMAQQLCgAKAQsDDgAUAQADAAEAAxABAAMOAAgAGAEAAwABAAMUAQAD


test '·closure over outer variable', fn:
  expect cps_module ƒink:
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·fn
        fn ·ƒret_6, ·a_1:
          ·fn
            fn ·ƒret_8, ·b_2: ·op_plus ·a_1, ·b_2, ·ƒret_8
            fn ·v_7:
              ·let ·v_7, fn ·ni_3:
                ·ƒret_6 ·ni_3
        fn ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·foo_0, fn:
              ·ƒret_4 ·foo_0
    # sm:MAABACcAAQAnJAEAJxIACAEMIQABACEYAT4CFgE3AQoAEAEUDwABAA8gARQFFgENAQoABAEOBQABAAUUAQABCgAEAQgBCgAEAQcFKgETDwoAGAEDAQABAAEMAQQPCgAKAQkCDAAcAS4CAAEAAhQBAAIcAT0hCgAQAQMBAAEAAQwBBCEKAAoBCwMOABQBAAMAAQADEAEAAw4ACAAYAQADAAEAAxQBAAM


test 'three sequential bindings', fn:
  expect cps_module ƒink:
    a = 1
    b = 2
    c = a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·let 1, fn ·a_0:
        ·ƒpub ·a_0, fn:
          ·let 2, fn ·b_1:
            ·ƒpub ·b_1, fn:
              ·op_plus ·a_0, ·b_1, fn ·v_8:
                ·let ·v_8, fn ·c_2:
                  ·ƒpub ·c_2, fn:
                    ·ƒret_3 ·c_2
    # sm:MAABABUAAQAVJAEYCRIACAETAQABAAEMAQQBAgAKAQcBCgAMAQABAAEAARABAAEKAAgAEAEQAQABAAEMAQQBAgAKAQcBCgAUAQABAAEAARABAAEKAAgAGAEUBQABAAUUAQABCgAEAQgBCgAKAQcFCgAcAQMBAAEAAQwBBAUKAAoBBwEKACABAAEAAQABEAEAAQoACAAkAQABAAEAARQBAAE



---
ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_module ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·a_1:
          ·op_plus ·a_1, 1, fn ·v_8:
            ·foo_0 ·ƒret_4, ·v_8
        fn ·v_3:
          ·let ·v_3, fn ·foo_0:
            ·ƒpub ·foo_0, fn:
              ·foo_0 ·ƒret_2, 1
    # sm:KAABABsAAQAbJAEsBRIACAEfDwABAA8YAQwJFgEFAQoAEAEOBQABAAUUAQABCgAEAQgBAgAKAQcFCgAUAQcJAAEAAxABAAkSAAQBCAUaARMPCgAQAQMBAAEAAQwBBA8KAAoBCwMOABQBAAMAAQADEAEAAw4ACAAYASwFAAEAAxABAAUSAAQBCAE


test 'mutual recursion', fn:
  expect cps_module ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·fn
        fn ·ƒret_6, ·x_2: ·pong_1 ·ƒret_6, ·x_2
        fn ·v_5:
          ·let ·v_5, fn ·ping_0:
            ·ƒpub ·ping_0, fn:
              ·fn
                fn ·ƒret_14, ·x_3: ·ping_0 ·ƒret_14, ·x_3
                fn ·v_13:
                  ·let ·v_13, fn ·pong_1:
                    ·ƒpub ·pong_1, fn:
                      ·ƒret_4 ·pong_1
    # sm:NQABACcAAQAnJAEoExIACAEZDAABAAwYAQwGFgEFAQoABAEGBgABAAQSAQAGEgAEAQoBGgEVDAoAEAEDAQABAAEMAQQMCgAKAQ0EEAAUAQAEAAEABBABAAQQAAgAGAE2DAABAAwoAQwGGAEFAQoABAEGBgABAAQSAQAGFAAEAQoBKgEVDAwAIAEDAQABAAEMAQQMDAAKAQ0EEAAkAQAEAAEABBABAAQQAAgAKAEABAABAAQUAQAE



---
varargs functions
---

test 'multi-param function', fn:
  expect cps_module ƒink:
    fn x, y: x + y
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·x_0, ·y_1: ·op_plus ·x_0, ·y_1, ·ƒret_4
        fn ·v_3: ·ƒret_2 ·v_3
    # sm:FgABAA4AAQAOJAEADhIACAEADgABAA4YARIFFgELAQ4BBgEKAAQBBgUAAQAFFAEAAQoABAEIAQoABAEHBSIBEQ4KAAQBAA4AAQAOFAEADg


test 'varargs — collect rest', fn:
  expect cps_module ƒink:
    fn a, ..rest: rest
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·a_0, ..·rest_1: ·ƒret_4 ·rest_1
        fn ·v_3: ·ƒret_2 ·v_3
    # sm:FAABABIAAQASJAEAEhIACAEAEgABABIYARwEFgEVAQ4BCgQAAQAEBAEABBAABAEMBAABAAQUAQAEIAEbEgoABAEAEgABABIUAQAS



---
functions — additional
---

test 'identity function', fn:
  expect cps_module ƒink:
    fn x: x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ·x_0: ·ƒret_3 ·x_0
        fn ·v_2: ·ƒret_1 ·v_2
    # sm:EQABAAcAAQAHJAEABxIACAEABwABAAcYAQwBFgEFAQoABAEGAQABAAEUAQABGgELBwoABAEABwABAAcUAQAH

test 'function with operator in body', fn:
  expect cps_module ƒink:
    fn x: x + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·fn
        fn ·ƒret_3, ·x_0: ·op_plus ·x_0, 1, ·ƒret_3
        fn ·v_2: ·ƒret_1 ·v_2
    # sm:FQABAAsAAQALJAEACxIACAEACwABAAsYAQwFFgEFAQoABAEGBQABAAUUAQABCgAEAQgBAgAEAQcFIgELCwoABAEACwABAAsUAQAL

test 'try — result bound, code continues', fn:
  expect cps_module ƒink:
    ni = try foo bar
    ni + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·∅foo
        fn ·v_4:
          ·let ·v_4, fn ·ni_0:
            ·ƒpub ·ni_0, fn:
              ·op_plus ·ni_0, 1, ·ƒret_1
        ·∅bar
    # sm:GwABABcAAQAXJAEiBhIACAEPBwABAAMgAQAHCgAQAQsBAAEAAQwBDAcKAAoBEQIMABQBAAIAAQACEAEAAgwACAAYASIGAAEABhQBAAIMAAQBCgECAAQBCQYcAQcD


