    inc = fn x: x + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_20, ·ƒret_2:
      ·fn
        fn ·ƒctx_22, ·ƒret_4, ·x_1: ·op_plus ·ƒctx_22, ·x_1, (i8 1), ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·ƒctx_20, ·inc_0, fn ·ƒctx_25:
              ·ƒret_2 ·ƒctx_25, ·inc_0
