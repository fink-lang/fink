test 'three sequential bindings', fn:
  expect cps_module ƒink:
    a = 1
    b = 2
    c = a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_31, ·ƒret_3:
      ·letrec fn ·a_0, ·b_1, ·c_2:
        ·set ·ƒctx_31, ·a_0, (i8 1), fn ·ƒctx_34:
          ·ƒpub ·ƒctx_34, ·a_0, fn ·ƒctx_36:
            ·set ·ƒctx_36, ·b_1, (i8 2), fn ·ƒctx_38:
              ·ƒpub ·ƒctx_38, ·b_1, fn ·ƒctx_40:
                ·op_plus ·ƒctx_40, ·a_0, ·b_1, fn ·ƒctx_42, ·v_8:
                  ·set ·ƒctx_42, ·c_2, ·v_8, fn ·ƒctx_44:
                    ·ƒpub ·ƒctx_44, ·c_2, fn ·ƒctx_46:
                      ·ƒret_3 ·ƒctx_46, ·c_2
    # sm:



