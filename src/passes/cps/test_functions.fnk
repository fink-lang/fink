test 'try — result bound, code continues', fn:
  expect cps_module ƒink:
    ni = try foo bar
    ni + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·∅foo
        ·ƒctx_17
        fn ·ƒctx_20, ·v_4:
          ·let ·v_4, fn ·ni_0:
            ·ƒpub ·ni_0, fn ·ƒctx_22:
              ·op_plus ·ni_0, (i8 1), ·ƒret_1
        ·∅bar
    # sm:JQABABcAAQAXJAEAFxgBIgYSAAIABgEPBwABAAMaACQAGAEABwoAAgAOAQsBAAEAAQwBDAcKAAoBEQIMAAIAEgEAAgABAAIQAQACDAAKABQAAgAWASIGAAEABhQBAAIMAAYBCgEAAQABBgEAAQQABAEJBhwBBwM







