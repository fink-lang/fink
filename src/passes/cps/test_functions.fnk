test 'closure over outer variable', fn:
  expect cps_module ƒink:
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_4:
      ·letrec fn ·foo_0:
        ·fn
          fn ·ƒctx_37, ·ƒret_6, ·a_1:
            ·letrec fn ·ni_2:
              ·fn
                fn ·ƒctx_38, ·ƒret_8, ·b_3: ·op_plus ·ƒctx_38, ·a_1, ·b_3, ·ƒret_8
                fn ·v_7:
                  ·set ·ƒctx_37, ·ni_2, ·v_7, fn ·ƒctx_41:
                    ·ƒret_6 ·ƒctx_41, ·ni_2
          fn ·v_5:
            ·set ·ƒctx_35, ·foo_0, ·v_5, fn ·ƒctx_44:
              ·ƒpub ·ƒctx_44, ·foo_0, fn ·ƒctx_46:
                ·ƒret_4 ·ƒctx_46, ·foo_0
    # sm:



