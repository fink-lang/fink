test 'function binding', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_20, ·ƒret_2:
      ·fn
        fn ·ƒctx_22, ·ƒret_4, ·x_1: ·op_plus ·x_1, (i8 1), ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·inc_0, fn ·ƒctx_25:
              ·ƒret_2 ·ƒctx_25, ·inc_0
    # sm:LQABABEAAQARJAEAERgBABESAAIABgEMCwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAEAAQoABgEIAQABAAEGAQABBAAEAQcFEgAQAQsLCgACAA4BAwEAAQABDAEECwoACgELAw4AAgASAQADAAEAAxABAAMOAAoAFAACABYBAAMAAQADFAAUAAQBAAM


test '·closure over outer variable', fn:
  expect cps_module ƒink:
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_31, ·ƒret_4:
      ·fn
        fn ·ƒctx_33, ·ƒret_6, ·a_1:
          ·fn
            fn ·ƒctx_34, ·ƒret_8, ·b_2: ·op_plus ·a_1, ·b_2, ·ƒret_8
            fn ·v_7:
              ·let ·v_7, fn ·ni_3:
                ·ƒret_6 ·ƒctx_36, ·ni_3
        fn ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·foo_0, fn ·ƒctx_40:
              ·ƒret_4 ·ƒctx_40, ·foo_0
    # sm:QwABACcAAQAnJAEAJxgBACcSAAIABgEMIQABACEIABAAGAE-AhYBNwEKAAIADgEUDwABAA8IABgAGAEUBRYBDQEKAAQBDgUAAQAFFAEAAQoABAEIAQoABAEHBRIAGAETDwoAAgAWAQMBAAEAAQwBBA8KAAoBCQIMAAIAGgEuAgABAAIUABQABAEAAgwAEAE9IQoAAgAOAQMBAAEAAQwBBCEKAAoBCwMOAAIAEgEAAwABAAMQAQADDgAKABQAAgAWAQADAAEAAxQAFAAEAQAD


test 'three sequential bindings', fn:
  expect cps_module ƒink:
    a = 1
    b = 2
    c = a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_3:
      ·let (i8 1), fn ·a_0:
        ·ƒpub ·a_0, fn ·ƒctx_30:
          ·let (i8 2), fn ·b_1:
            ·ƒpub ·b_1, fn ·ƒctx_32:
              ·op_plus ·a_0, ·b_1, fn ·ƒctx_33, ·v_8:
                ·let ·v_8, fn ·c_2:
                  ·ƒpub ·c_2, fn ·ƒctx_35:
                    ·ƒret_3 ·ƒctx_35, ·c_2
    # sm:QwABABUAAQAVJAEAFRgBGAkSAAIABgETAQABAAEOAQQBAAEAAQYBAAEEAAoBBwEKAAIACgEAAQABAAEQAQABCgAKABQAAgAOARABAAEAAQ4BBAEAAQABBgEAAQQACgEHAQoAAgASAQABAAEAARABAAEKAAoAFAACABYBFAUAAQAFFAEAAQoABAEIAQoACgAYAQcFCgACABoBAwEAAQABDAEEBQoACgEHAQoAAgAeAQABAAEAARABAAEKAAoAFAACACIBAAEAAQABFAAUAAQBAAE



---
ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_module ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_2:
      ·fn
        fn ·ƒctx_29, ·ƒret_4, ·a_1:
          ·op_plus ·a_1, (i8 1), fn ·ƒctx_30, ·v_8:
            ·foo_0 ·ƒctx_30, ·ƒret_4, ·v_8
        fn ·v_3:
          ·let ·v_3, fn ·foo_0:
            ·ƒpub ·foo_0, fn ·ƒctx_34:
              ·foo_0 ·ƒctx_34, ·ƒret_2, (i8 1)
    # sm:PAABABsAAQAbJAEAGxgBLAUSAAIABgEfDwABAA8IABAAGAEMCRYBBQEKAAIADgEOBQABAAUUAQABCgAGAQgBAAEAAQYBAAEEAAoAGAEHBQoAAgASAQcJAAEAAxAAFAAEAQAJEgAEAQgFCgAQARMPCgACAA4BAwEAAQABDAEEDwoACgELAw4AAgASAQADAAEAAxABAAMOAAoAFAACABYBLAUAAQADEAAUAAQBAAUSAAYBCAEAAQABBgEAAQ


test 'mutual recursion', fn:
  expect cps_module ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_4:
      ·fn
        fn ·ƒctx_38, ·ƒret_6, ·x_2: ·pong_1 ·ƒctx_38, ·ƒret_6, ·x_2
        fn ·v_5:
          ·let ·v_5, fn ·ping_0:
            ·ƒpub ·ping_0, fn ·ƒctx_42:
              ·fn
                fn ·ƒctx_43, ·ƒret_14, ·x_3: ·ping_0 ·ƒctx_43, ·ƒret_14, ·x_3
                fn ·v_13:
                  ·let ·v_13, fn ·pong_1:
                    ·ƒpub ·pong_1, fn ·ƒctx_47:
                      ·ƒret_4 ·ƒctx_47, ·pong_1
    # sm:



