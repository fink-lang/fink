---
ported from test_cps — functions and closures
---

test 'function binding', fn:
  expect cps_expr ƒink:
    inc = fn x: x + 1
  | equals ƒink:
    ·fn
      fn ·ƒret_4, ·x_1: ·op_plus ·x_1, 1, ·ƒret_4
      fn ·v_3:
        ·let ·v_3, fn ·inc_0:
          ·v_2 ·inc_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiaW5jID0gZm4geDogeCArIDEiXSwKICAibWFwcGluZ3MiOiAiQUFBTSxBQUFBO0tBQUEsU0FBRyxJLEVBQUssQUFBQSxTQUFGLEksRUFBSSxDLEVBQVY7S0FBQSxJO0lBQUYsQUFBQSxLQUFFLEksS0FBTixNO00sQSxLQUFBIgp9


test '·closure over outer variable', fn:
  expect cps_expr ƒink:
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals ƒink:
    ·fn
      fn ·ƒret_6, ·a_1:
        ·fn
          fn ·ƒret_8, ·b_2: ·op_plus ·a_1, ·b_2, ·ƒret_8
          fn ·v_7:
            ·let ·v_7, fn ·ni_3:
              ·ƒret_6 ·ni_3
      fn ·v_5:
        ·let ·v_5, fn ·foo_0:
          ·v_4 ·foo_0
    #sourcemaps:


test 'three sequential bindings', fn:
  expect cps_expr ƒink:
    a = 1
    b = 2
    c = a + b
  | equals ƒink:
    ·fn
      fn ·ƒret_5:
        ·let 1, fn ·a_0:
          ·let 2, fn ·b_1:
            ·op_plus ·a_0, ·b_1, fn ·v_10:
              ·let ·v_10, fn ·c_2:
                ·ƒret_5 ·c_2
      fn ·v_4: ·v_3 ·v_4
    #sourcemaps:



---
ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_expr ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·fn
      fn ·ƒret_4:
        ·fn
          fn ·ƒret_6, ·a_1:
            ·op_plus ·a_1, 1, fn ·v_10:
              ·foo_0 ·ƒret_6, ·v_10
          fn ·v_5:
            ·let ·v_5, fn ·foo_0:
              ·foo_0 ·ƒret_4, 1
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:


test 'mutual recursion', fn:
  expect cps_expr ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·fn
      fn ·ƒret_6:
        ·fn
          fn ·ƒret_8, ·x_2: ·pong_1 ·ƒret_8, ·x_2
          fn ·v_7:
            ·let ·v_7, fn ·ping_0:
              ·fn
                fn ·ƒret_16, ·x_3: ·ping_0 ·ƒret_16, ·x_3
                fn ·v_15:
                  ·let ·v_15, fn ·pong_1:
                    ·ƒret_6 ·pong_1
      fn ·v_5: ·v_4 ·v_5
    #sourcemaps:



