test 'function binding', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_21, ·ƒret_2:
      ·letrec fn ·inc_0:
        ·fn
          fn ·ƒctx_23, ·ƒret_4, ·x_1: ·op_plus ·ƒctx_23, ·x_1, (i8 1), ·ƒret_4
          fn ·ƒv_3:
            ·set ·inc_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_21, ·inc_0, fn ·ƒctx_26:
                ·ƒret_2 ·ƒctx_26, ·inc_0
