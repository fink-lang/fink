    fn a: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_9, ·ƒret_1:
      ·fn
        fn ·ƒctx_11, ·ƒret_3, ·a_0: ·ƒret_3 ·ƒctx_11, ·a_0
        fn ·v_2: ·ƒret_1 ·ƒctx_9, ·v_2
