test 'closure over outer variable', fn:
  expect cps_module ƒink:
    foo = fn a:
      ni = fn b:
        a + b
      ni
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_4:
      ·letrec fn ·foo_0:
        ·fn
          fn ·ƒctx_35, ·ƒret_6, ·a_1:
            ·letrec fn ·ni_2:
              ·fn
                fn ·ƒctx_36, ·ƒret_8, ·b_3: ·op_plus ·ƒctx_36, ·a_1, ·b_3, ·ƒret_8
                fn ·ƒv_7:
                  ·set ·ni_2, ·ƒv_7, fn:
                    ·ƒret_6 ·ƒctx_35, ·ni_2
          fn ·ƒv_5:
            ·set ·foo_0, ·ƒv_5, fn:
              ·ƒpub ·ƒctx_33, ·foo_0, fn ·ƒctx_40:
                ·ƒret_4 ·ƒctx_40, ·foo_0
    # sm:



