test 'forward ref', fn:
  expect cps_module ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_29, ·ƒret_2:
      ·letrec fn ·foo_0:
        ·fn
          fn ·ƒctx_31, ·ƒret_4, ·a_1:
            ·op_plus ·ƒctx_31, ·a_1, (i8 1), fn ·ƒctx_33, ·v_8:
              ·foo_0 ·ƒctx_33, ·ƒret_4, ·v_8
          fn ·v_3:
            ·set ·ƒctx_29, ·foo_0, ·v_3, fn ·ƒctx_36:
              ·ƒpub ·ƒctx_36, ·foo_0, fn ·ƒctx_38:
                ·foo_0 ·ƒctx_38, ·ƒret_2, (i8 1)
    # sm:SQABABsAAQAbJAEAGxgBLAUSAAIABgErGwABABsYAQADDgACAAoBDA8AAQAPCAAUABgBDAkWAQUBCgACABIBDgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQACgAYAQcFCgACABYBBwkAAQADEAAUAAQBAAkSAAQBCAUKABQBEw8KAAIAEgELFQABABUMABQABAEAAw4ABAEMDwoACgAUAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEsBQABAAMQABQABAEABRIABgEIAQABAAEGAQAB


test 'mutual recursion', fn:
  expect cps_module ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_4:
      ·letrec fn ·ping_0, ·pong_1:
        ·fn
          fn ·ƒctx_41, ·ƒret_6, ·x_2: ·pong_1 ·ƒctx_41, ·ƒret_6, ·x_2
          fn ·v_5:
            ·set ·ƒctx_39, ·ping_0, ·v_5, fn ·ƒctx_44:
              ·ƒpub ·ƒctx_44, ·ping_0, fn ·ƒctx_46:
                ·fn
                  fn ·ƒctx_47, ·ƒret_14, ·x_3: ·ping_0 ·ƒctx_47, ·ƒret_14, ·x_3
                  fn ·v_13:
                    ·set ·ƒctx_46, ·pong_1, ·v_13, fn ·ƒctx_50:
                      ·ƒpub ·ƒctx_50, ·pong_1, fn ·ƒctx_52:
                        ·ƒret_4 ·ƒctx_52, ·pong_1
    # sm:



