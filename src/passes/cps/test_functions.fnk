test 'three sequential bindings', fn:
  expect cps_module ƒink:
    a = 1
    b = 2
    c = a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_28, ·ƒret_3:
      ·letrec fn ·a_0, ·b_1, ·c_2:
        ·set ·a_0, (i8 1), fn:
          ·ƒpub ·ƒctx_28, ·a_0, fn ·ƒctx_31:
            ·set ·b_1, (i8 2), fn:
              ·ƒpub ·ƒctx_31, ·b_1, fn ·ƒctx_33:
                ·op_plus ·ƒctx_33, ·a_0, ·b_1, fn ·ƒctx_35, ·ƒv_8:
                  ·set ·c_2, ·ƒv_8, fn:
                    ·ƒpub ·ƒctx_35, ·c_2, fn ·ƒctx_37:
                      ·ƒret_3 ·ƒctx_37, ·c_2
    # sm:



