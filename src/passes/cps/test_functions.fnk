test 'try — result bound, code continues', fn:
  expect cps_module ƒink:
    ni = try foo bar
    ni + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_19, ·ƒret_1:
      ·letrec fn ·ni_0:
        ·∅foo
          ·ƒctx_19
          fn ·ƒctx_22, ·v_4:
            ·set ·ƒctx_22, ·ni_0, ·v_4, fn ·ƒctx_24:
              ·ƒpub ·ƒctx_24, ·ni_0, fn ·ƒctx_26:
                ·op_plus ·ƒctx_26, ·ni_0, (i8 1), ·ƒret_1
          ·∅bar
    # sm:MgABABcAAQAXJAEAFxgBIgYSAAIABgEhFwABABcYAQACDAACAAoBEgcAAQADHgAoABgBAAcKAAIAEgEREAABABAMABQABAEAAgwABAESBwoACgAUAAIAFgERAgABAAIQABQABAEAAgwACgAUAAIAGgEiBgABAAYUABQABAEAAgwABgEKAQABAAEGAQABBAAEAQkGIAEHAw







