          fn ·v_3:
            ·set ·ƒctx_22, ·inc_0, ·v_3, fn ·ƒctx_27:
              ·ƒpub ·ƒctx_27, ·inc_0, fn ·ƒctx_29:
                ·ƒret_2 ·ƒctx_29, ·inc_0
