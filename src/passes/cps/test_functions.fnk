ported from test_cps — forward refs and mutual recursion
---

test 'forward ref', fn:
  expect cps_module ƒink:
    foo = fn a: foo a + 1
    foo 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_27, ·ƒret_2:
      ·fn
        fn ·ƒctx_29, ·ƒret_4, ·a_1:
          ·op_plus ·ƒctx_29, ·a_1, (i8 1), fn ·ƒctx_31, ·v_8:
            ·foo_0 ·ƒctx_31, ·ƒret_4, ·v_8
        fn ·v_3:
          ·let ·v_3, fn ·foo_0:
            ·ƒpub ·ƒctx_27, ·foo_0, fn ·ƒctx_34:
              ·foo_0 ·ƒctx_34, ·ƒret_2, (i8 1)
    # sm:QAABABsAAQAbJAEAGxgBLAUSAAIABgEfDwABAA8IABAAGAEMCRYBBQEKAAIADgEOBQABAAUUABQABAEAAQoABgEIAQABAAEGAQABBAAKABgBBwUKAAIAEgEHCQABAAMQABQABAEACRIABAEIBQoAEAETDwoAAgAOAQMBAAEAAQwBBA8KAAoBCwMOAAIAEgEAAwABAAMQABQABAEAAw4ACgAUAAIAFgEsBQABAAMQABQABAEABRIABgEIAQABAAEGAQAB


test 'mutual recursion', fn:
  expect cps_module ƒink:
    ping = fn x: pong x
    pong = fn x: ping x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_4:
      ·fn
        fn ·ƒctx_38, ·ƒret_6, ·x_2: ·pong_1 ·ƒctx_38, ·ƒret_6, ·x_2
        fn ·v_5:
          ·let ·v_5, fn ·ping_0:
            ·ƒpub ·ƒctx_36, ·ping_0, fn ·ƒctx_41:
              ·fn
                fn ·ƒctx_42, ·ƒret_14, ·x_3: ·ping_0 ·ƒctx_42, ·ƒret_14, ·x_3
                fn ·v_13:
                  ·let ·v_13, fn ·pong_1:
                    ·ƒpub ·ƒctx_41, ·pong_1, fn ·ƒctx_45:
                      ·ƒret_4 ·ƒctx_45, ·pong_1
    # sm:



