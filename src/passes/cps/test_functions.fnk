{test, skip, expect, equals, cps_module} = import '!fake'
{ƒink} = import 'fink/blocks.fnk'

---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_module ƒink:
    fn a: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_9, ·ƒret_1:
      ·fn
        fn ·ƒctx_11, ·ƒret_3, ·a_0: ·ƒret_3 ·ƒctx_11, ·a_0
        fn ·ƒv_2: ·ƒret_1 ·ƒctx_9, ·ƒv_2
