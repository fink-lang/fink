test 'try — result bound, code continues', fn:
  expect cps_module ƒink:
    ni = try foo bar
    ni + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_18, ·ƒret_1:
      ·letrec fn ·ni_0:
        ·∅foo
          ·ƒctx_18
          fn ·ƒctx_21, ·ƒv_4:
            ·set ·ni_0, ·ƒv_4, fn:
              ·ƒpub ·ƒctx_21, ·ni_0, fn ·ƒctx_23:
                ·op_plus ·ƒctx_23, ·ni_0, (i8 1), ·ƒret_1
          ·∅bar
    # sm:LwABABcAAQAXJAEAFxgBIgYSAAIABgEhFwABABcYAQACDAACAAoBEgcAAQADHgAoABgBAAcOAAIAEgEREAABABAMAQACDAAEARIHDgAIAAIAFgERAgABAAIQABQABAEAAgwACgAUAAIAGgEiBgABAAYUABQABAEAAgwABgEKAQABAAEGAQABBAAEAQkGIAEHAw







