{test, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
function definition — ·closure synthesis
---

test 'fn one param', fn:
  expect cps_expr ƒink:
    fn a: a
  | equals ƒink:
    ·fn
      fn ·ƒret_3, ·a_0: ·ƒret_3 ·a_0
      fn ·v_2: ·v_1 ·v_2
