                  2
                  ·a_0
                  3
            fn ·v_99:
              ·fn
                fn ·ƒsucc_41, ·ƒfail_42, ·v_40:
                  ·op_eq ·v_40, 1, fn ·v_45:
                    ·if ·v_45,
                      fn: ·ƒsucc_41 _
                      fn: ·ƒfail_42 _
                fn ·v_53: ·v_53 ·v_99, ·panic, ·v_6
        fn ·v_107:
