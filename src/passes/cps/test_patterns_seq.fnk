                  fn ·v_92:
                    ·if ·v_92,
                      fn:
                        ·fn
                          fn: ·ƒret_1 ·panic
                          fn ·v_79:
                            ·fn
                              fn ·ƒsucc_63, ·ƒfail_64, ·v_62:
                                ·op_eq ·v_62, 4, fn ·v_67:
                                  ·if ·v_67,
                                    fn: ·ƒsucc_63 _
                                    fn: ·ƒfail_64 _
