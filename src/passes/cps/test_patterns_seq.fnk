{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
seq patterns
---

test 'seq — empty', fn:
  expect cps_module ƒink:
    [] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_0:
      ·fn
        fn ·ƒctx_37: ·ƒret_0 ·ƒctx_37, ·panic
        fn ·ƒv_25:
          ·fn
            fn ·ƒctx_39, ·ƒsucc_3, ·ƒfail_4, ·ƒv_2:
              ·is_seq_like ·ƒctx_39, ·ƒv_2,
                fn ·ƒctx_41, ·ƒv_15:
                  ·let ·ƒv_15, fn ·ƒv_7:
                    ·empty ·ƒctx_41, ·ƒv_7, fn ·ƒctx_43, ·ƒv_10:
                      ·if ·ƒv_10,
                        fn: ·ƒsucc_3 ·ƒctx_43
                        fn: ·ƒfail_4 ·ƒctx_43
                fn ·ƒctx_46: ·ƒfail_4 ·ƒctx_46
            fn ·ƒv_22: ·ƒv_22 ·ƒctx_35, ·ƒv_25, ·panic, ·∅foo
    # sm:


