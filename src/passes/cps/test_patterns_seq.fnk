{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
seq patterns
---

test 'seq — empty', fn:
  expect cps_module ƒink:
    [] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_0:
      ·fn
        fn ·ƒctx_37: ·ƒret_0 ·ƒctx_37, ·panic
        fn ·v_25:
          ·fn
            fn ·ƒctx_39, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·is_seq_like ·ƒctx_39, ·v_2,
                fn ·ƒctx_41, ·v_15:
                  ·let ·v_15, fn ·v_7:
                    ·empty ·ƒctx_41, ·v_7, fn ·ƒctx_43, ·v_10:
                      ·if ·v_10,
                        fn: ·ƒsucc_3 ·ƒctx_43
                        fn: ·ƒfail_4 ·ƒctx_43
                fn ·ƒctx_46: ·ƒfail_4 ·ƒctx_46
            fn ·v_22: ·v_22 ·ƒctx_35, ·v_25, ·panic, ·∅foo
    # sm:


