test 'seq — nested', fn:
  expect cps_module ƒink:
    [a, [b, c]] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_94, ·ƒret_3:
      ·letrec fn ·a_0, ·b_1, ·c_2:
        ·fn
          fn ·ƒctx_96, ·ƒv_8, ·ƒv_9:
            ·let ·ƒv_8, fn ·a_0:
              ·fn
                fn ·ƒctx_97, ·ƒv_40, ·ƒv_41:
