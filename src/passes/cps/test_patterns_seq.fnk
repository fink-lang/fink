                fn ·v_22:
                  ·seq_pop ·v_22, ·ƒfail_5, fn ·v_6, ·v_27:
                    ·seq_pop ·v_27, ·ƒfail_5, fn ·v_7, ·v_23:
                      ·seq_pop ·v_23, ·ƒfail_5, fn ·v_8, ·v_14:
                        ·empty ·v_14, fn ·v_17:
