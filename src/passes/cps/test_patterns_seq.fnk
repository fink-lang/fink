test 'seq — empty', fn:
  expect cps_module ƒink:
    [] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_0:
      ·fn
        fn ·ƒctx_37: ·ƒret_0 ·ƒctx_37, ·panic
        fn ·v_25:
          ·fn
            fn ·ƒctx_39, ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·is_seq_like ·v_2,
                fn ·v_15:
                  ·let ·v_15, fn ·v_7:
                    ·empty ·v_7, fn ·v_10:
                      ·if ·v_10,
                        fn: ·ƒsucc_3 ·ƒctx_39
                        fn: ·ƒfail_4 ·ƒctx_39
                fn: ·ƒfail_4 ·ƒctx_39
            fn ·v_22: ·v_22 ·ƒctx_35, ·v_25, ·panic, ·∅foo
    # sm:


