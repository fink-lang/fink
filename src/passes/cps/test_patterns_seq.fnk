{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'

---
seq patterns
---

test 'seq — empty', fn:
  expect cps_module ƒink:
    [] = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·fn
        fn: ·ƒret_0 ·panic
        fn ·v_25:
          ·fn
            fn ·ƒsucc_3, ·ƒfail_4, ·v_2:
              ·is_seq_like ·v_2,
                fn ·v_15:
                  ·let ·v_15, fn ·v_7:
                    ·empty ·v_7, fn ·v_10:
                      ·if ·v_10,
                        fn: ·ƒsucc_3 _
                        fn: ·ƒfail_4 _
                fn: ·ƒfail_4 _
            fn ·v_22: ·v_22 ·v_25, ·panic, ·∅foo
    #sourcemaps:


