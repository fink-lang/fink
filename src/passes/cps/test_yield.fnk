---
yield — CPS lowering tests
---

# yield suspends execution, yielding a value to the scheduler.
# The continuation receives the resumed value.
#
# In CPS:
#   yield value
# becomes:
#   ·yield value, fn ·v_{cps_id}:
#     <continuation>

{test, equals, expect, cps_expr} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'yield literal', fn:
  expect cps_expr ƒink:
    yield 42

  | equals ƒink:
    ·yield 42, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieWllbGQgNDIiXSwKICAibWFwcGluZ3MiOiAiQUFBQSxBQUFBLE9BQU0sRSxFIgp9


test 'yield ident', fn:
  expect cps_expr ƒink:
    yield foo

  | equals ƒink:
    ·yield ·∅foo, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieWllbGQgZm9vIl0sCiAgIm1hcHBpbmdzIjogIkFBQUEsQUFBQSxPQUFNLEssRSIKfQ==


test 'yield bound to name', fn:
  expect cps_expr ƒink:
    result = yield 42

  | equals ƒink:
    ·yield 42, fn ·v_3:
      ·let ·v_3, fn ·result_0:
        ·v_1 ·result_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsicmVzdWx0ID0geWllbGQgNDIiXSwKICAibWFwcGluZ3MiOiAiQUFBUyxBQUFBLE9BQU0sRSxLQUFOLEk7RUFBRixBQUFBLEtBQUUsSSxLQUFULFM7SSxBLEtBQUEiCn0=


test 'yield apply result', fn:
  expect cps_expr ƒink:
    yield foo bar

  | equals ƒink:
    ·∅foo fn ·v_3: ·yield ·v_3, ·v_0, ·∅bar
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieWllbGQgZm9vIGJhciJdLAogICJtYXBwaW5ncyI6ICJBQUFNLEFBQUEsTUFBQSxHQUFBLEksRUFBTixBQUFBLE9BQU0sSSxFLEksRUFBSSIKfQ==
