---
CPS pattern lowering tests
---

# Expected CPS expansion for every pattern form.
#
# All patterns lower to PatternMatch — a matcher function applied to the subject:
#   ·fn
#     fn <binds>: <body>                                      — body receives matched values
#     fn ·v_N:
#       ·fn
#         fn ·v_subj, ·v_succ, ·v_fail: <matcher_body>       — matcher tests, calls succ/fail
#         fn ·v_M: ·v_M subject, ·v_N, ·panic                — matcher(subject, body, panic)
#
# Failure continuation convention:
#   ·panic   — default; pattern mismatch is a compile/runtime error
#   ·v_fail  — inside a match arm; failure tries the next arm
#
# Collection primitives (used inside matcher bodies):
#   ·seq_pop seq, ·fail, fn head, tail: …   — pop head element; fail if empty
#   ·rec_pop rec, 'name', ·fail, fn val, rest: …  — extract named field; fail if missing
#   ·empty   collection, fn bool: …         — predicate; caller branches with If
#
# Literal/guard/range patterns use ·op_eq, ·op_gt, etc. inside the matcher.
# Match blocks use a fail-chain: mp_1(subj, k, fn: mp_2(subj, k, fn: panic))
#
# Binding: bare ident in pattern position → ·let (always a binding, never a lookup)
# Wildcard (_): discard; no binding, temp passed directly to next primitive

{test, equals, expect, cps_module} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
bind
---

test 'plain bind', fn:
  expect cps_module ƒink:
    x = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·ƒctx_12, ·x_0, ·∅foo, fn ·ƒctx_15:
          ·ƒpub ·ƒctx_15, ·x_0, fn ·ƒctx_17:
            ·ƒret_1 ·ƒctx_17, ·x_0
    # sm:JAABAAcAAQAHJAEABxgBAAcSAAIABgEABwABAAcYAQABCgACAAoBAAcAAQAHDAAUAAQBAAEKAAQBCAMQAAoAFAACAA4BBwEAAQABEAAUAAQBAAEKAAoAFAACABIBAAEAAQABFAAUAAQBAAE


test 'simple guard', fn:
  expect cps_module ƒink:
    a > 0 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_32, ·ƒret_1:
      ·letrec fn ·a_0:
        ·set ·ƒctx_32, ·a_0, ·∅foo, fn ·ƒctx_35:
          ·fn
            fn ·ƒctx_36, ·a_0: ·ƒret_1 ·ƒctx_36, ·a_0
            fn ·v_18:
              ·fn
                fn ·ƒctx_38, ·ƒsucc_4, ·ƒfail_5, ·v_3:
                  ·op_gt ·ƒctx_38, ·v_3, (i8 0), fn ·ƒctx_40, ·v_8:
                    ·if ·v_8,
                      fn: ·ƒsucc_4 ·ƒctx_40, ·v_3
                      fn: ·ƒfail_5 ·ƒctx_40
                fn ·v_16: ·v_16 ·ƒctx_35, ·v_18, ·panic, ·∅foo
    # sm:


test 'nested guard', fn:
  expect cps_module ƒink:
    a > 0 or a < 9 = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_36, ·ƒret_1:
      ·letrec fn ·a_0:
        ·set ·ƒctx_36, ·a_0, ·∅foo, fn ·ƒctx_39:
          ·fn
            fn ·ƒctx_40, ·a_0: ·ƒret_1 ·ƒctx_40, ·a_0
            fn ·v_22:
              ·fn
                fn ·ƒctx_42, ·ƒsucc_4, ·ƒfail_5, ·v_3:
                  ·op_lt ·ƒctx_42, ·a_0, (i8 9), fn ·ƒctx_44, ·v_8:
                    ·op_or ·ƒctx_44, ·v_3, ·v_8, fn ·ƒctx_46, ·v_11:
                      ·if ·v_11,
                        fn: ·ƒsucc_4 ·ƒctx_46, ·v_3
                        fn: ·ƒfail_5 ·ƒctx_46
                fn ·v_20: ·v_20 ·ƒctx_39, ·v_22, ·panic, ·∅foo
    # sm:


