test 'fn body with bind', fn:
  expect cps_module ƒink:
    fn a:
      x = a + 1
      x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·a_0:
          ·op_plus ·a_0, 1, fn ·v_7:
            ·let ·v_7, fn ·x_1:
              ·ƒret_4 ·x_1
        fn ·v_3: ·ƒret_2 ·v_3
    # sm:JQABABUAAQAVJAEAFRIAAgAGAQAVAAEAFQgAEAEoARYBIQEKAAIADgESBQABAAUUAQABCgAEAQgBAgAKAQcFCgACABIBAwEAAQABDAEEBQoACgEHAQoAAgAWARgBAAEAARQBAAEKABABJxUKAAQBABUAAQAVFAEAFQ


