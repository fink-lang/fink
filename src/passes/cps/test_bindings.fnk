module level
---

test 'two bindings at module level', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·let 2, fn ·bar_1:
            ·ƒpub ·bar_1, fn:
              ·ƒret_2 ·bar_1
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuYmFyID0gMiJdLAogICJtYXBwaW5ncyI6ICJBLEEsZ0IsTztFQUFJLEFBQUEsS0FBRSxDLEtBQU4sTTtJQUFBLEFBQUEsTUFBQSxNLEk7TUFDSSxBQUFBLEtBQUUsQyxLQUFOLE07UUFBQSxBQUFBLE1BQUEsTSxJO1UsQSxRQUFBIgp9


test 'two fns at module level — main calls add', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·fn
        fn ·ƒret_6, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_6
        fn ·v_5:
          ·let ·v_5, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·fn
                fn ·ƒret_14: ·add_0 ·ƒret_14, 3, 4
                fn ·v_13:
                  ·let ·v_13, fn ·main_1:
                    ·ƒpub ·main_1, fn:
                      ·ƒret_4 ·main_1
    #sourcemaps:

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_9:
      ·fn
        fn ·ƒret_11, ·a_3, ·b_4: ·op_plus ·a_3, ·b_4, ·ƒret_11
        fn ·v_10:
          ·let ·v_10, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·fn
                fn ·ƒret_19, ·a_5, ·b_6:
                  ·fn
                    fn ·ƒret_21, ·foo_7: ·ƒret_21 ·foo_7
                    fn ·v_20:
                      ·let ·v_20, fn ·add_8:
                        ·add_8
                          fn ·v_29: ·op_minus ·a_5, ·v_29, ·ƒret_19
                          ·b_6
                fn ·v_18:
                  ·let ·v_18, fn ·sub_1:
                    ·ƒpub ·sub_1, fn:
                      ·fn
                        fn ·ƒret_42: ·add_0 ·ƒret_42, 3, 4
                        fn ·v_41:
                          ·let ·v_41, fn ·main_2:
                            ·ƒpub ·main_2, fn:
                              ·ƒret_9 ·main_2
    #sourcemaps:

