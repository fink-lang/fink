---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·x_1: ·op_plus ·x_1, 1, ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·inc_0, fn:
              ·inc_0 ·ƒret_2, 5
    # sm:KAABABcAAQAXJAEkBRIAAgAGARcLAAEACwgAEAEMBRYBBQEKAAQBBgUAAQAFFAEAAQoABAEIAQIABAEHBRIAEAELCwoAAgAOAQMBAAEAAQwBBAsKAAoBCwMOAAIAEgEAAwABAAMQAQADDgAIAAIAFgEkBQABAAMQAQAFEgAEAQgB


test 'chained binding is sequential ·match_store', fn:
  expect cps_module ƒink:
    foo = spam = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·spam_1:
        ·let ·spam_1, fn ·foo_0:
          ·ƒpub ·foo_0, fn:
            ·ƒret_2 ·foo_0
    # sm:HAABAA4AAQAOJAEADhIAAgAGARYBAAEAAQwBBAECAAoBDQQQAAIACgEDAQABAAEMAQQEEAAKAQsDDgACAA4BAAMAAQADEAEAAw4ACAACABIBAAMAAQADFAEAAw


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_module ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4:
          ·∅ham
            fn ·v_7:
              ·let ·v_7, fn ·ni_1:
                ·ƒret_4 ·ni_1
            1
        fn ·v_3:
          ·v_3 fn ·v_15:
            ·let ·v_15, fn ·spam_0:
              ·ƒpub ·spam_0, fn:
                ·ƒret_2 ·spam_0
    # sm:NAABABwAAQAcJAEAHBIAAgAGAQ4VAAEAFQgAEAEiAhIAAgAOAQ8FAAEAAygBAAUKAAIAFgEDAQABAAEMAQQFCgAKAQkCDAACABoBGgIAAQACFAEAAh4BBwECABABGRUKAAIADgEAFQABABUSAQAVDAACABIBAwEAAQABDAEEFQwACgENBBAAAgAWAQAEAAEABBABAAQQAAgAAgAaAQAEAAEABBQBAAQ


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_module ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·op_plus ·foo_0, 1, fn ·v_6:
            ·let ·v_6, fn ·bar_1:
              ·ƒpub ·bar_1, fn:
                ·ƒret_2 ·bar_1
    # sm:KwABABUAAQAVJAEQDRIAAgAGAQcBAAEAAQwBBAECAAoBCwMOAAIACgEAAwABAAMQAQADDgAIAAIADgEcBwABAAcUAQADDgAEAQwBAgAKAQsHCgACABIBAwEAAQABDAEEBwoACgELAw4AAgAWAQADAAEAAxABAAMOAAgAAgAaAQADAAEAAxQBAAM


test 'binding rhs is a call', fn:
  expect cps_module ƒink:
    foo = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·∅add
        fn ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·foo_0, fn:
              ·ƒret_1 ·foo_0
        1
        2
    # sm:HAABAA4AAQAOJAEADhIAAgAGAQwIAAEAAyABAAgKAAIADgEDAQABAAEMAQQICgAKAQsDDgACABIBAAMAAQADEAEAAw4ACAACABYBAAMAAQADFAEAAxgBFAEMAQYB


test 'expression result discarded', fn:
  expect cps_module ƒink:
    foo 1
    bar
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·∅foo
        fn ·v_3:
          ·let ·v_3, fn ·v_5:
            ·ƒret_0 ·∅bar
        1
    # sm:FQABAAkAAQAJJAEMAxIAAgAGAQsFAAEAAyABAAUKAAIADgEABQABAAUMAQAFCgAKAQAFCgACABIBDAMAAQADFAEAAxoBAwE


test 'chained member access', fn:
  expect cps_module ƒink:
    foo.bar.baz
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_dot ·∅foo, 'bar', fn ·v_3:
        ·op_dot ·v_3, 'baz', ·ƒret_0
    # sm:GwABAAsAAQALJAEACxIAAgAGAQAHAAEABxIBAAMQAAQBCAMAAQADAgEAAwYBAAMCAAoBBwcKAAIACgEACwABAAsSAQAHCgAEARADAAEAAwIBAAMGAQADAgAEAQ8L



---
module level
---

test 'two bindings at module level', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·let 2, fn ·bar_1:
            ·ƒpub ·bar_1, fn:
              ·ƒret_2 ·bar_1
    # sm:IgABAA8AAQAPJAEQBxIAAgAGAQcBAAEAAQwBBAECAAoBCwMOAAIACgEAAwABAAMQAQADDgAIAAIADgEYAQABAAEMAQQBAgAKAQsDDgACABIBAAMAAQADEAEAAw4ACAACABYBAAMAAQADFAEAAw


test 'two fns at module level — main calls add', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·fn
        fn ·ƒret_6, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_6
        fn ·v_5:
          ·let ·v_5, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·fn
                fn ·ƒret_14: ·add_0 ·ƒret_14, 3, 4
                fn ·v_13:
                  ·let ·v_13, fn ·main_1:
                    ·ƒpub ·main_1, fn:
                      ·ƒret_4 ·main_1
    # sm:RAABACwAAQAsJAEuFRIAAgAGASEQAAEAEAgAEAEWBRYBDwEOAQYBCgAEAQoFAAEABRQBAAEKAAQBCAEKAAQBBwUSABABFRAKAAIADgEDAQABAAEMAQQQCgAKAQsDDgACABIBAAMAAQADEAEAAw4ACAACABYBPA4AAQAOCAAgAQwIFAAEAQAIAAEAAxABAAgUAAQBCAECAAQBBgECACABGQ4MAAIAHgEDAQABAAEMAQQODAAKAQ0EEAACACIBAAQAAQAEEAEABBAACAACACYBAAQAAQAEFAEABA

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_9:
      ·fn
        fn ·ƒret_11, ·a_3, ·b_4: ·op_plus ·a_3, ·b_4, ·ƒret_11
        fn ·v_10:
          ·let ·v_10, fn ·add_0:
            ·ƒpub ·add_0, fn:
              ·fn
                fn ·ƒret_19, ·a_5, ·b_6:
                  ·fn
                    fn ·ƒret_21, ·foo_7: ·ƒret_21 ·foo_7
                    fn ·v_20:
                      ·let ·v_20, fn ·add_8:
                        ·add_8
                          fn ·v_29: ·op_minus ·a_5, ·v_29, ·ƒret_19
                          ·b_6
                fn ·v_18:
                  ·let ·v_18, fn ·sub_1:
                    ·ƒpub ·sub_1, fn:
                      ·fn
                        fn ·ƒret_42: ·add_0 ·ƒret_42, 3, 4
                        fn ·v_41:
                          ·let ·v_41, fn ·main_2:
                            ·ƒpub ·main_2, fn:
                              ·ƒret_9 ·main_2
    # sm:fQABAFsAAQBbJAGMARUSAAIABgF_EAABABAIABABFgUYAQ8BDgEGAQoABAEKBQABAAUUAQABCgAEAQgBCgAEAQcFFAAQARUQDAACAA4BAwEAAQABDAEEEAwACgELAw4AAgASAQADAAEAAxABAAMOAAgAAgAWATooAAEAKAgAIAE-

