test 'block bind then ·apply', fn:
  expect cps_module ƒink:
    x = 42
    foo x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·let 42, fn ·x_0:
        ·ƒpub ·x_0, fn:
          ·∅foo ·ƒret_1, ·x_0
