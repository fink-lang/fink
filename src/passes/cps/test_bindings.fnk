{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
binding — ·match_store synthesis
---

test 'bind literal', fn:
  expect cps_module ƒink:
    x = 42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·let 42, fn ·x_0:
        ·ƒpub ·x_0, fn:
          ·ƒret_1 ·x_0
    # sm:FQABAAYAAQAGJAEABhIAAgAGAQQBAAEAAQwBBAIEAAoBBwEKAAIACgEAAQABAAEQAQABCgAIAAIADgEAAQABAAEUAQAB


test 'bind ident', fn:
  expect cps_module ƒink:
    x = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·let ·∅foo, fn ·x_0:
        ·ƒpub ·x_0, fn:
          ·ƒret_1 ·x_0
    # sm:FQABAAcAAQAHJAEABxIAAgAGAQQBAAEAAQwBBAMQAAoBBwEKAAIACgEAAQABAAEQAQABCgAIAAIADgEAAQABAAEUAQAB



