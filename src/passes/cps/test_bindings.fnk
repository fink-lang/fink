              ·set ·ƒctx_23, ·x_1, ·v_7, fn ·ƒctx_25:
                ·ƒret_4 ·ƒctx_25, ·x_1
        fn ·v_3: ·ƒret_2 ·ƒctx_19, ·v_3
    # sm:OQABABUAAQAVJAEAFRgBABUSAAIABgEAFQABABUIABAAGAEoARYBIQEKAAIADgEFFQABABUYARABCgACABIBCAUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQACgAYAQcFCgACABYBBwkAAQAJDAAUAAQBAAEKAAQBCAUKAAoAFAACABoBEAEAAQABFAAUAAQBAAEKABABJxUKAAQBABUAAQAVFAEAFRQABAEAFQ


---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_24, ·ƒret_2:
      ·letrec fn ·inc_0:
        ·fn
          fn ·ƒctx_26, ·ƒret_4, ·x_1: ·op_plus ·ƒctx_26, ·x_1, (i8 1), ·ƒret_4
          fn ·v_3:
            ·set ·ƒctx_24, ·inc_0, ·v_3, fn ·ƒctx_29:
              ·ƒpub ·ƒctx_29, ·inc_0, fn ·ƒctx_31:
                ·inc_0 ·ƒctx_31, ·ƒret_2, (i8 5)
    # sm:PgABABcAAQAXJAEAFxgBJAUSAAIABgEjFwABABcYAQADDgACAAoBDAsAAQALCAAUABgBDAUWAQUBCgAEAQYFAAEABRQAFAAEAQABCgAGAQgBAAEAAQYBAAEEAAQBBwUSABQBCwsKAAIAEgELEQABABEMABQABAEAAw4ABAEMCwoACgAUAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEkBQABAAMQABQABAEABRIABgEIAQABAAEGAQAB


test 'chained binding is sequential ·match_store', fn:
  expect cps_module ƒink:
    foo = spam = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·letrec fn ·foo_0:
        ·let (i8 1), fn ·spam_1:
          ·set ·ƒctx_16, ·foo_0, ·spam_1, fn ·ƒctx_19:
            ·ƒpub ·ƒctx_19, ·foo_0, fn ·ƒctx_21:
              ·ƒret_2 ·ƒctx_21, ·foo_0
    # sm:LQABAA4AAQAOJAEADhgBAA4SAAIABgEADgABAA4YAQADDgACAAoBFgEAAQABDgEEAQABAAEGAQABBAAKAQ0EEAACAA4BCw4AAQAODAAUAAQBAAMOAAQBDAQQAAoAFAACABIBCwMAAQADEAAUAAQBAAMOAAoAFAACABYBAAMAAQADFAAUAAQBAAM


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_module ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_2:
      ·letrec fn ·spam_0:
        ·fn
          fn ·ƒctx_35, ·ƒret_4:
            ·letrec fn ·ni_1:
              ·∅ham
                ·ƒctx_35
                fn ·ƒctx_37, ·v_7:
                  ·set ·ƒctx_37, ·ni_1, ·v_7, fn ·ƒctx_39:
                    ·ƒret_4 ·ƒctx_39, ·ni_1
                i8 1
          fn ·v_3:
            ·v_3 ·ƒctx_33, fn ·ƒctx_42, ·v_17:
              ·set ·ƒctx_42, ·spam_0, ·v_17, fn ·ƒctx_44:
                ·ƒpub ·ƒctx_44, ·spam_0, fn ·ƒctx_46:
                  ·ƒret_2 ·ƒctx_46, ·spam_0
    # sm:


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_module ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_24, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·ƒctx_24, ·foo_0, (i8 1), fn ·ƒctx_27:
          ·ƒpub ·ƒctx_27, ·foo_0, fn ·ƒctx_29:
            ·op_plus ·ƒctx_29, ·foo_0, (i8 1), fn ·ƒctx_31, ·v_6:
              ·set ·ƒctx_31, ·bar_1, ·v_6, fn ·ƒctx_33:
                ·ƒpub ·ƒctx_33, ·bar_1, fn ·ƒctx_35:
                  ·ƒret_2 ·ƒctx_35, ·bar_1
    # sm:SQABABUAAQAVJAEAFRgBEA0SAAIABgEPFQABABUYAQADEgEQAw4AAgAKAQ8HAAEABwwAFAAEAQADDgAGAQwBAAEAAQYBAAEEAAoAFAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBHAcAAQAHFAAUAAQBAAMOAAYBDAEAAQABBgEAAQQACgAYAQsHCgACABYBCw0AAQANDAAUAAQBAAMOAAQBDAcKAAoAFAACABoBCwMAAQADEAAUAAQBAAMOAAoAFAACAB4BAAMAAQADFAAUAAQBAAM


