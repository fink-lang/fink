{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
binding — ·match_store synthesis
---

test 'bind literal', fn:
  expect cps_module ƒink:
    x = 42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·ƒctx_12, ·x_0, (i8 42), fn ·ƒctx_15:
          ·ƒpub ·ƒctx_15, ·x_0, fn ·ƒctx_17:
            ·ƒret_1 ·ƒctx_17, ·x_0
    # sm:JgABAAYAAQAGJAEABhgBAAYSAAIABgEABgABAAYYAQABCgACAAoBAAYAAQAGDAAUAAQBAAEKAAYBCAIAAQACBgEAAgYACgAUAAIADgEHAQABAAEQABQABAEAAQoACgAUAAIAEgEAAQABAAEUABQABAEAAQ


test 'bind ident', fn:
  expect cps_module ƒink:
    x = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·ƒctx_12, ·x_0, ·∅foo, fn ·ƒctx_15:
          ·ƒpub ·ƒctx_15, ·x_0, fn ·ƒctx_17:
            ·ƒret_1 ·ƒctx_17, ·x_0
    # sm:JAABAAcAAQAHJAEABxgBAAcSAAIABgEABwABAAcYAQABCgACAAoBAAcAAQAHDAAUAAQBAAEKAAQBCAMQAAoAFAACAA4BBwEAAQABEAAUAAQBAAEKAAoAFAACABIBAAEAAQABFAAUAAQBAAE



