---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_22, ·ƒret_2:
      ·fn
        fn ·ƒctx_24, ·ƒret_4, ·x_1: ·op_plus ·x_1, (i8 1), ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·inc_0, fn ·ƒctx_27:
              ·inc_0 ·ƒctx_27, ·ƒret_2, (i8 5)
    # sm:MQABABcAAQAXJAEAFxgBJAUSAAIABgEXCwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAEAAQoABgEIAQABAAEGAQABBAAEAQcFEgAQAQsLCgACAA4BAwEAAQABDAEECwoACgELAw4AAgASAQADAAEAAxABAAMOAAoAFAACABYBJAUAAQADEAAUAAQBAAUSAAYBCAEAAQABBgEAAQ


test 'chained binding is sequential ·match_store', fn:
  expect cps_module ƒink:
    foo = spam = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_14, ·ƒret_2:
      ·let (i8 1), fn ·spam_1:
        ·let ·spam_1, fn ·foo_0:
          ·ƒpub ·foo_0, fn ·ƒctx_18:
            ·ƒret_2 ·ƒctx_18, ·foo_0
    # sm:IgABAA4AAQAOJAEADhgBAA4SAAIABgEWAQABAAEOAQQBAAEAAQYBAAEEAAoBDQQQAAIACgEDAQABAAEMAQQEEAAKAQsDDgACAA4BAAMAAQADEAEAAw4ACgAUAAIAEgEAAwABAAMUABQABAEAAw


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_module ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_29, ·ƒret_2:
      ·fn
        fn ·ƒctx_31, ·ƒret_4:
          ·∅ham
            ·ƒctx_31
            fn ·ƒctx_33, ·v_7:
              ·let ·v_7, fn ·ni_1:
                ·ƒret_4 ·ƒctx_34, ·ni_1
            i8 1
        fn ·v_3:
          ·v_3 ·ƒctx_36, fn ·ƒctx_38, ·v_15:
            ·let ·v_15, fn ·spam_0:
              ·ƒpub ·spam_0, fn ·ƒctx_40:
                ·ƒret_2 ·ƒctx_40, ·spam_0
    # sm:QgABABwAAQAcJAEAHBgBABwSAAIABgEOFQABABUIABAAGAEiAhIAAgAOAQ8FAAEAAyIALAAYAQAFCgACABYBAwEAAQABDAEEBQoACgEJAgwAAgAaARoCAAEAAhQAFAAEAQACHgEHAQABAAEGAQABAgAQARkVCgACAA4BABUAAQAVDAAUAAoAGAEAFQwAAgASAQMBAAEAAQwBBBUMAAoBDQQQAAIAFgEABAABAAQQAQAEEAAKABQAAgAaAQAEAAEABBQAFAAEAQAE


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_module ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_21, ·ƒret_2:
      ·let (i8 1), fn ·foo_0:
        ·ƒpub ·foo_0, fn ·ƒctx_24:
          ·op_plus ·foo_0, (i8 1), fn ·ƒctx_25, ·v_6:
            ·let ·v_6, fn ·bar_1:
              ·ƒpub ·bar_1, fn ·ƒctx_27:
                ·ƒret_2 ·ƒctx_27, ·bar_1
    # sm:NQABABUAAQAVJAEAFRgBEA0SAAIABgEHAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIACgEAAwABAAMQAQADDgAKABQAAgAOARwHAAEABxQBAAMOAAYBDAEAAQABBgEAAQQACgAYAQsHCgACABIBAwEAAQABDAEEBwoACgELAw4AAgAWAQADAAEAAxABAAMOAAoAFAACABoBAAMAAQADFAAUAAQBAAM


test 'binding rhs is a call', fn:
  expect cps_module ƒink:
    foo = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·∅add
        ·ƒctx_16
        fn ·ƒctx_19, ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·foo_0, fn ·ƒctx_21:
              ·ƒret_1 ·ƒctx_21, ·foo_0
        i8 1
        i8 2
    # sm:JgABAA4AAQAOJAEADhgBAA4SAAIABgEMCAABAAMaACQAGAEACAoAAgAOAQMBAAEAAQwBBAgKAAoBCwMOAAIAEgEAAwABAAMQAQADDgAKABQAAgAWAQADAAEAAxQAFAAEAQADGAEUAQABAAEGAQABDAEGAQABAAEGAQAB


test 'expression result discarded', fn:
  expect cps_module ƒink:
    foo 1
    bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_0:
      ·∅foo
        ·ƒctx_12
        fn ·ƒctx_15, ·v_3:
          ·let ·v_3, fn ·v_5:
            ·ƒret_0 ·ƒctx_16, ·∅bar
        i8 1
    # sm:HAABAAkAAQAJJAEACRgBDAMSAAIABgELBQABAAMaACQAGAEABQoAAgAOAQAFAAEABQwBAAUKAAoBAAUKAAIAEgEMAwABAAMUABQABAEAAxoBAwEAAQABBgEAAQ


test 'chained member access', fn:
  expect cps_module ƒink:
    foo.bar.baz
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·op_dot ·∅foo, 'bar', fn ·ƒctx_13, ·v_3:
        ·op_dot ·v_3, 'baz', ·ƒret_0
    # sm:HQABAAsAAQALJAEACxgBAAsSAAIABgEABwABAAcSAQADEAAEAQgDAAEAAwIBAAMGAQADAgAKABgBBwcKAAIACgEACwABAAsSAQAHCgAEARADAAEAAwIBAAMGAQADAgAEAQ8L



---
module level
---

test 'two bindings at module level', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_2:
      ·let (i8 1), fn ·foo_0:
        ·ƒpub ·foo_0, fn ·ƒctx_19:
          ·let (i8 2), fn ·bar_1:
            ·ƒpub ·bar_1, fn ·ƒctx_21:
              ·ƒret_2 ·ƒctx_21, ·bar_1
    # sm:KwABAA8AAQAPJAEADxgBEAcSAAIABgEHAQABAAEOAQQBAAEAAQYBAAEEAAoBCwMOAAIACgEAAwABAAMQAQADDgAKABQAAgAOARgBAAEAAQ4BBAEAAQABBgEAAQQACgELAw4AAgASAQADAAEAAxABAAMOAAoAFAACABYBAAMAAQADFAAUAAQBAAM


test 'two fns at module level — main calls add', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·fn
        fn ·ƒctx_39, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·a_2, ·b_3, ·ƒret_6
        fn ·v_5:
          ·let ·v_5, fn ·add_0:
            ·ƒpub ·add_0, fn ·ƒctx_42:
              ·fn
                fn ·ƒctx_43, ·ƒret_14: ·add_0 ·ƒctx_43, ·ƒret_14, (i8 3), (i8 4)
                fn ·v_13:
                  ·let ·v_13, fn ·main_1:
                    ·ƒpub ·main_1, fn ·ƒctx_47:
                      ·ƒret_4 ·ƒctx_47, ·main_1
    # sm:

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_71, ·ƒret_9:
      ·fn
        fn ·ƒctx_73, ·ƒret_11, ·a_3, ·b_4: ·op_plus ·a_3, ·b_4, ·ƒret_11
        fn ·v_10:
          ·let ·v_10, fn ·add_0:
            ·ƒpub ·add_0, fn ·ƒctx_76:
              ·fn
                fn ·ƒctx_77, ·ƒret_19, ·a_5, ·b_6:
                  ·fn
                    fn ·ƒctx_78, ·ƒret_21, ·foo_7: ·ƒret_21 ·ƒctx_78, ·foo_7
                    fn ·v_20:
                      ·let ·v_20, fn ·add_8:
                        ·add_8
                          ·ƒctx_81
                          fn ·ƒctx_83, ·v_29: ·op_minus ·a_5, ·v_29, ·ƒret_19
                          ·b_6
                fn ·v_18:
                  ·let ·v_18, fn ·sub_1:
                    ·ƒpub ·sub_1, fn ·ƒctx_86:
                      ·fn
                        fn ·ƒctx_87, ·ƒret_42: ·add_0 ·ƒctx_87, ·ƒret_42, (i8 3), (i8 4)
                        fn ·v_41:
                          ·let ·v_41, fn ·main_2:
                            ·ƒpub ·main_2, fn ·ƒctx_91:
                              ·ƒret_9 ·ƒctx_91, ·main_2
    # sm:

