{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
binding — ·match_store synthesis
---

test 'bind literal', fn:
  expect cps_module ƒink:
    x = 42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·x_0, (i8 42), fn:
          ·ƒpub ·ƒctx_11, ·x_0, fn ·ƒctx_14:
            ·ƒret_1 ·ƒctx_14, ·x_0
    # sm:IwABAAYAAQAGJAEABhgBAAYSAAIABgEABgABAAYYAQABCgACAAoBAAYAAQAGDAEAAQoABgEIAgABAAIGAQACBgAIAAIADgEHAQABAAEQABQABAEAAQoACgAUAAIAEgEAAQABAAEUABQABAEAAQ


test 'bind ident', fn:
  expect cps_module ƒink:
    x = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_1:
      ·letrec fn ·x_0:
        ·set ·x_0, ·∅foo, fn:
          ·ƒpub ·ƒctx_11, ·x_0, fn ·ƒctx_14:
            ·ƒret_1 ·ƒctx_14, ·x_0
    # sm:IQABAAcAAQAHJAEABxgBAAcSAAIABgEABwABAAcYAQABCgACAAoBAAcAAQAHDAEAAQoABAEIAxAACAACAA4BBwEAAQABEAAUAAQBAAEKAAoAFAACABIBAAEAAQABFAAUAAQBAAE



