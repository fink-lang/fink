      ·fn
        fn ·ƒret_4, ·a_0:
          ·op_plus ·a_0, 1, fn ·v_7:
            ·let ·v_7, fn ·x_1:
              ·ƒret_4 ·x_1
        fn ·v_3: ·ƒret_2 ·v_3
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm4gYTpcbiAgeCA9IGEgKyAxXG4gIHgiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBQSxBQUFBO09BQUEsU0FBRyxJO01BQ0ssQUFBQSxTQUFGLEksRUFBSSxDLEtBQUosSTtRQUFGLEFBQUEsS0FBRSxJLEtBQUosSTtVLEFBREYsUUFFRTtPQUZGLEksRSxBLFFBQUEiCn0=


