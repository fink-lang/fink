---
module level
---

test 'two bindings at module level', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_19, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·ƒctx_19, ·foo_0, (i8 1), fn ·ƒctx_22:
          ·ƒpub ·ƒctx_22, ·foo_0, fn ·ƒctx_24:
            ·set ·ƒctx_24, ·bar_1, (i8 2), fn ·ƒctx_26:
              ·ƒpub ·ƒctx_26, ·bar_1, fn ·ƒctx_28:
                ·ƒret_2 ·ƒctx_28, ·bar_1
    # sm:PQABAA8AAQAPJAEADxgBEAcSAAIABgEPDwABAA8YAQADEgEQAw4AAgAKAQ8HAAEABwwAFAAEAQADDgAGAQwBAAEAAQYBAAEEAAoAFAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBEAcAAQAHDAAUAAQBAAMOAAYBDAEAAQABBgEAAQQACgAUAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEAAwABAAMUABQABAEAAw


test 'two fns at module level — main calls add', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_40, ·ƒret_4:
      ·letrec fn ·add_0, ·main_1:
        ·fn
          fn ·ƒctx_42, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_42, ·a_2, ·b_3, ·ƒret_6
          fn ·v_5:
            ·set ·ƒctx_40, ·add_0, ·v_5, fn ·ƒctx_45:
              ·ƒpub ·ƒctx_45, ·add_0, fn ·ƒctx_47:
                ·fn
                  fn ·ƒctx_48, ·ƒret_14: ·add_0 ·ƒctx_48, ·ƒret_14, (i8 3), (i8 4)
                  fn ·v_13:
                    ·set ·ƒctx_47, ·main_1, ·v_13, fn ·ƒctx_51:
                      ·ƒpub ·ƒctx_51, ·main_1, fn ·ƒctx_53:
                        ·ƒret_4 ·ƒctx_53, ·main_1
    # sm:

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_77, ·ƒret_9:
      ·letrec fn ·add_0, ·sub_1, ·main_2:
        ·fn
          fn ·ƒctx_79, ·ƒret_11, ·a_3, ·b_4: ·op_plus ·ƒctx_79, ·a_3, ·b_4, ·ƒret_11
          fn ·v_10:
            ·set ·ƒctx_77, ·add_0, ·v_10, fn ·ƒctx_82:
              ·ƒpub ·ƒctx_82, ·add_0, fn ·ƒctx_84:
                ·fn
                  fn ·ƒctx_85, ·ƒret_19, ·a_5, ·b_6:
                    ·letrec fn ·add_7:
                      ·fn
                        fn ·ƒctx_86, ·ƒret_21, ·foo_8: ·ƒret_21 ·ƒctx_86, ·foo_8
                        fn ·v_20:
                          ·set ·ƒctx_85, ·add_7, ·v_20, fn ·ƒctx_89:
                            ·add_7
                              ·ƒctx_89
                              fn ·ƒctx_91, ·v_29: ·op_minus ·ƒctx_91, ·a_5, ·v_29, ·ƒret_19
                              ·b_6
                  fn ·v_18:
                    ·set ·ƒctx_84, ·sub_1, ·v_18, fn ·ƒctx_94:
                      ·ƒpub ·ƒctx_94, ·sub_1, fn ·ƒctx_96:
                        ·fn
                          fn ·ƒctx_97, ·ƒret_44: ·add_0 ·ƒctx_97, ·ƒret_44, (i8 3), (i8 4)
                          fn ·v_43:
                            ·set ·ƒctx_96, ·main_2, ·v_43, fn ·ƒctx_100:
                              ·ƒpub ·ƒctx_100, ·main_2, fn ·ƒctx_102:
                                ·ƒret_9 ·ƒctx_102, ·main_2
    # sm:twEAAQBbAAEAWyQBAFsYAYwBFRIAAgAGAYsBWwABAFsYAQADEgEuAxIBXgQQAAIACgF_


