test 'fn body with bind', fn:
  expect cps_module ƒink:
    fn a:
      x = a + 1
      x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_18, ·ƒret_2:
      ·fn
        fn ·ƒctx_20, ·ƒret_4, ·a_0:
          ·letrec fn ·x_1:
            ·op_plus ·ƒctx_20, ·a_0, (i8 1), fn ·ƒctx_22, ·ƒv_7:
              ·set ·x_1, ·ƒv_7, fn:
                ·ƒret_4 ·ƒctx_22, ·x_1
        fn ·ƒv_3: ·ƒret_2 ·ƒctx_18, ·ƒv_3
    # sm:NgABABUAAQAVJAEAFRgBABUSAAIABgEAFQABABUIABAAGAEoARYBIQEKAAIADgEFFQABABUYARABCgACABIBCAUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQACgAYAQcFDgACABYBBwkAAQAJDAEAAQoABAEIBQ4ACAACABoBEAEAAQABFAAUAAQBAAEKABABJxUOAAQBABUAAQAVFAEAFRQABAEAFQ


---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_23, ·ƒret_2:
      ·letrec fn ·inc_0:
        ·fn
          fn ·ƒctx_25, ·ƒret_4, ·x_1: ·op_plus ·ƒctx_25, ·x_1, (i8 1), ·ƒret_4
          fn ·ƒv_3:
            ·set ·inc_0, ·ƒv_3, fn:
              ·ƒpub ·ƒctx_23, ·inc_0, fn ·ƒctx_28:
                ·inc_0 ·ƒctx_28, ·ƒret_2, (i8 5)
    # sm:OwABABcAAQAXJAEAFxgBJAUSAAIABgEjFwABABcYAQADDgACAAoBDAsAAQALCAAUABgBDAUWAQUBCgAEAQYFAAEABRQAFAAEAQABCgAGAQgBAAEAAQYBAAEEAAQBBwUSABQBCwsOAAIAEgELEQABABEMAQADDgAEAQwLDgAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEkBQABAAMQABQABAEABRIABgEIAQABAAEGAQAB


test 'chained binding is sequential ·match_store', fn:
  expect cps_module ƒink:
    foo = spam = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_15, ·ƒret_2:
      ·letrec fn ·foo_0:
        ·let (i8 1), fn ·spam_1:
          ·set ·foo_0, ·spam_1, fn:
            ·ƒpub ·ƒctx_15, ·foo_0, fn ·ƒctx_18:
              ·ƒret_2 ·ƒctx_18, ·foo_0
    # sm:KgABAA4AAQAOJAEADhgBAA4SAAIABgEADgABAA4YAQADDgACAAoBFgEAAQABDgEEAQABAAEGAQABBAAKAQ0EEAACAA4BCw4AAQAODAEAAw4ABAEMBBAACAACABIBCwMAAQADEAAUAAQBAAMOAAoAFAACABYBAAMAAQADFAAUAAQBAAM


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_module ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_31, ·ƒret_2:
      ·letrec fn ·spam_0:
        ·fn
          fn ·ƒctx_33, ·ƒret_4:
            ·letrec fn ·ni_1:
              ·∅ham
                ·ƒctx_33
                fn ·ƒctx_35, ·ƒv_7:
                  ·set ·ni_1, ·ƒv_7, fn:
                    ·ƒret_4 ·ƒctx_35, ·ni_1
                i8 1
          fn ·ƒv_3:
            ·ƒv_3 ·ƒctx_31, fn ·ƒctx_38, ·ƒv_16:
              ·set ·spam_0, ·ƒv_16, fn:
                ·ƒpub ·ƒctx_38, ·spam_0, fn ·ƒctx_40:
                  ·ƒret_2 ·ƒctx_40, ·spam_0
    # sm:


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_module ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_22, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·foo_0, (i8 1), fn:
          ·ƒpub ·ƒctx_22, ·foo_0, fn ·ƒctx_25:
            ·op_plus ·ƒctx_25, ·foo_0, (i8 1), fn ·ƒctx_27, ·ƒv_6:
              ·set ·bar_1, ·ƒv_6, fn:
                ·ƒpub ·ƒctx_27, ·bar_1, fn ·ƒctx_29:
                  ·ƒret_2 ·ƒctx_29, ·bar_1
    # sm:QwABABUAAQAVJAEAFRgBEA0SAAIABgEPFQABABUYAQADEgEQAw4AAgAKAQ8HAAEABwwBAAMOAAYBDAEAAQABBgEAAQQACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBHAcAAQAHFAAUAAQBAAMOAAYBDAEAAQABBgEAAQQACgAYAQsHDgACABYBCw0AAQANDAEAAw4ABAEMBw4ACAACABoBCwMAAQADEAAUAAQBAAMOAAoAFAACAB4BAAMAAQADFAAUAAQBAAM


test 'binding rhs is a call', fn:
  expect cps_module ƒink:
    foo = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·letrec fn ·foo_0:
        ·∅add
          ·ƒctx_17
          fn ·ƒctx_20, ·ƒv_5:
            ·set ·foo_0, ·ƒv_5, fn:
              ·ƒpub ·ƒctx_20, ·foo_0, fn ·ƒctx_22:
                ·ƒret_1 ·ƒctx_22, ·foo_0
          i8 1
          i8 2
    # sm:LgABAA4AAQAOJAEADhgBAA4SAAIABgEADgABAA4YAQADDgACAAoBDAgAAQADHgAoABgBAAgOAAIAEgELDgABAA4MAQADDgAEAQwIDgAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEAAwABAAMUABQABAEAAxwBFAEAAQABBgEAARABBgEAAQABBgEAAQ


test 'expression result discarded', fn:
