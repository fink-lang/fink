---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_module ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4, ·x_1: ·op_plus ·x_1, 1, ·ƒret_4
        fn ·v_3:
          ·let ·v_3, fn ·inc_0:
            ·ƒpub ·inc_0, fn:
              ·inc_0 ·ƒret_2, 5
    #sourcemaps:


test 'chained binding is sequential ·match_store', fn:
  expect cps_module ƒink:
    foo = spam = 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·spam_1:
        ·let ·spam_1, fn ·foo_0:
          ·ƒpub ·foo_0, fn:
            ·ƒret_2 ·foo_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gc3BhbSA9IDEiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBVyxBQUFBLEtBQUUsQyxLQUFQLE87SUFBRixBQUFBLEtBQUUsTyxLQUFOLE07TUFBQSxBQUFBLE1BQUEsTSxJO1EsQSxRQUFBIgp9


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_module ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·fn
        fn ·ƒret_4:
          ·∅ham
            fn ·v_7:
              ·let ·v_7, fn ·ni_1:
                ·ƒret_4 ·ni_1
            1
        fn ·v_3:
          ·v_3 fn ·v_15:
            ·let ·v_15, fn ·spam_0:
              ·ƒpub ·spam_0, fn:
                ·ƒret_2 ·spam_0
    #sourcemaps:


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_module ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·let 1, fn ·foo_0:
        ·ƒpub ·foo_0, fn:
          ·op_plus ·foo_0, 1, fn ·v_6:
            ·let ·v_6, fn ·bar_1:
              ·ƒpub ·bar_1, fn:
                ·ƒret_2 ·bar_1
    #sourcemaps:


test 'binding rhs is a call', fn:
  expect cps_module ƒink:
    foo = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·∅add
        fn ·v_5:
          ·let ·v_5, fn ·foo_0:
            ·ƒpub ·foo_0, fn:
              ·ƒret_1 ·foo_0
        1
        2
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gYWRkIDEsIDIiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBTSxBQUFBO09BQUEsSTtNQUFGLEFBQUEsS0FBRSxJLEtBQU4sTTtRQUFBLEFBQUEsTUFBQSxNLEk7VSxBLFFBQUE7SUFBVTtJQUFHIgp9


test 'expression result discarded', fn:
