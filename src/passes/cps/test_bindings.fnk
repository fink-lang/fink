---
scoping and sequential bindings
---

test 'calling a local — still goes through ·load', fn:
  expect cps_expr ƒink:
    inc = fn x: x + 1
    inc 5
  | equals ƒink:
    ·fn
      fn ·ƒret_4:
        ·fn
          fn ·ƒret_6, ·x_1: ·op_plus ·x_1, 1, ·ƒret_6
          fn ·v_5:
            ·let ·v_5, fn ·inc_0:
              ·inc_0 ·ƒret_4, 5
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:


test 'chained binding is sequential ·match_store', fn:
  expect cps_expr ƒink:
    foo = spam = 1
  | equals ƒink:
    ·let 1, fn ·spam_1:
      ·let ·spam_1, fn ·foo_0:
        ·v_2 ·foo_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gc3BhbSA9IDEiXSwKICAibWFwcGluZ3MiOiAiQUFBVyxBQUFBLEtBQUUsQyxLQUFQLE87RUFBRixBQUFBLEtBQUUsTyxLQUFOLE07SSxBLEtBQUEiCn0=


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_expr ƒink:
    spam = (
      ni = ham 1
      ni
    )
  | equals ƒink:
    ·fn
      fn ·ƒret_4:
        ·∅ham fn ·v_7:
          ·let ·v_7, fn ·ni_1:
            ·ƒret_4 ·ni_1, 1
      fn ·v_3:
        ·v_3 fn ·v_15:
          ·let ·v_15, fn ·spam_0:
            ·v_2 ·spam_0
    #sourcemaps:


---
ported from test_cps — sequential and module-level
---

test 'sequential bindings', fn:
  expect cps_expr ƒink:
    foo = 1
    bar = foo + 1
  | equals ƒink:
    ·fn
      fn ·ƒret_4:
        ·let 1, fn ·foo_0:
          ·op_plus ·foo_0, 1, fn ·v_8:
            ·let ·v_8, fn ·bar_1:
              ·ƒret_4 ·bar_1
      fn ·v_3: ·v_2 ·v_3
    #sourcemaps:


test 'binding rhs is a call', fn:
  expect cps_expr ƒink:
    foo = add 1, 2
  | equals ƒink:
    ·∅add fn ·v_5:
      ·let ·v_5, fn ·foo_0:
        ·v_1 ·foo_0, 1, 2
