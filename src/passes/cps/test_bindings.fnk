      ·∅foo
        ·ƒctx_12
        fn ·ƒctx_15, ·ƒv_3:
          ·let ·ƒv_3, fn ·ƒv_5:
            ·ƒret_0 ·ƒctx_15, ·∅bar
        i8 1
    # sm:HAABAAkAAQAJJAEACRgBDAMSAAIABgELBQABAAMaACQAGAEABQ4AAgAOAQAFAAEABQwBAAUOAAoBAAUOAAIAEgEMAwABAAMUABQABAEAAxoBAwEAAQABBgEAAQ


test 'chained member access', fn:
  expect cps_module ƒink:
    foo.bar.baz
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·op_dot ·ƒctx_11, ·∅foo, 'bar', fn ·ƒctx_14, ·ƒv_3:
        ·op_dot ·ƒctx_14, ·ƒv_3, 'baz', ·ƒret_0
    # sm:IQABAAsAAQALJAEACxgBAAsSAAIABgEABwABAAcSABQABAEAAxAABAEIAwABAAMCAQADBgEAAwIACgAYAQcHDgACAAoBAAsAAQALEgAUAAQBAAcOAAQBEAMAAQADAgEAAwYBAAMCAAQBDws



---
module level
---

test 'two bindings at module level', fn:
  expect cps_module ƒink:
    foo = 1
    bar = 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_2:
      ·letrec fn ·foo_0, ·bar_1:
        ·set ·foo_0, (i8 1), fn:
          ·ƒpub ·ƒctx_17, ·foo_0, fn ·ƒctx_20:
            ·set ·bar_1, (i8 2), fn:
              ·ƒpub ·ƒctx_20, ·bar_1, fn ·ƒctx_22:
                ·ƒret_2 ·ƒctx_22, ·bar_1
    # sm:NwABAA8AAQAPJAEADxgBEAcSAAIABgEPDwABAA8YAQADEgEQAw4AAgAKAQ8HAAEABwwBAAMOAAYBDAEAAQABBgEAAQQACAACAA4BCwMAAQADEAAUAAQBAAMOAAoAFAACABIBEAcAAQAHDAEAAw4ABgEMAQABAAEGAQABBAAIAAIAFgELAwABAAMQABQABAEAAw4ACgAUAAIAGgEAAwABAAMUABQABAEAAw


test 'two fns at module level — main calls add', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_38, ·ƒret_4:
      ·letrec fn ·add_0, ·main_1:
        ·fn
          fn ·ƒctx_40, ·ƒret_6, ·a_2, ·b_3: ·op_plus ·ƒctx_40, ·a_2, ·b_3, ·ƒret_6
          fn ·ƒv_5:
            ·set ·add_0, ·ƒv_5, fn:
              ·ƒpub ·ƒctx_38, ·add_0, fn ·ƒctx_43:
                ·fn
                  fn ·ƒctx_44, ·ƒret_14: ·add_0 ·ƒctx_44, ·ƒret_14, (i8 3), (i8 4)
                  fn ·ƒv_13:
                    ·set ·main_1, ·ƒv_13, fn:
                      ·ƒpub ·ƒctx_43, ·main_1, fn ·ƒctx_47:
                        ·ƒret_4 ·ƒctx_47, ·main_1
    # sm:

test 'shadowed binding — inner add does not affect outer', fn:
  expect cps_module ƒink:
    add = fn a, b:
      a + b
    sub = fn a, b:
      add = fn foo: foo
      a - add b
    main = fn:
      add 3, 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_73, ·ƒret_9:
      ·letrec fn ·add_0, ·sub_1, ·main_2:
        ·fn
          fn ·ƒctx_75, ·ƒret_11, ·a_3, ·b_4: ·op_plus ·ƒctx_75, ·a_3, ·b_4, ·ƒret_11
          fn ·ƒv_10:
            ·set ·add_0, ·ƒv_10, fn:
              ·ƒpub ·ƒctx_73, ·add_0, fn ·ƒctx_78:
                ·fn
                  fn ·ƒctx_79, ·ƒret_19, ·a_5, ·b_6:
                    ·letrec fn ·add_7:
                      ·fn
                        fn ·ƒctx_80, ·ƒret_21, ·foo_8: ·ƒret_21 ·ƒctx_80, ·foo_8
                        fn ·ƒv_20:
                          ·set ·add_7, ·ƒv_20, fn:
                            ·add_7
                              ·ƒctx_79
                              fn ·ƒctx_83, ·ƒv_29: ·op_minus ·ƒctx_83, ·a_5, ·ƒv_29, ·ƒret_19
                              ·b_6
                  fn ·ƒv_18:
                    ·set ·sub_1, ·ƒv_18, fn:
                      ·ƒpub ·ƒctx_78, ·sub_1, fn ·ƒctx_86:
                        ·fn
                          fn ·ƒctx_87, ·ƒret_43: ·add_0 ·ƒctx_87, ·ƒret_43, (i8 3), (i8 4)
                          fn ·ƒv_42:
                            ·set ·main_2, ·ƒv_42, fn:
                              ·ƒpub ·ƒctx_86, ·main_2, fn ·ƒctx_90:
                                ·ƒret_9 ·ƒctx_90, ·main_2
    # sm:qwEAAQBbAAEAWyQBAFsYAYwBFRIAAgAGAYsBWwABAFsYAQADEgEuAxIBXgQQAAIACgF_


