--- a fn-type declaration: new_fn_type seeds, fn_type_param cons-prepends each
    arg type, fn_type_result sets the result. ---
test 'function type declaration', fn:
  cps_module ƒink:
    Foo = type: fn u8, u8: u8
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_1:
      ·letrec fn ·Foo_0:
        ·new_fn_type ·ƒctx_30, ƒ'Foo', fn ·ƒctx_33, ·ƒv_3:
          ·fn_type_param ·ƒctx_33, ·ƒv_3, ·∅u8, fn ·ƒctx_35, ·ƒv_6:
            ·fn_type_param ·ƒctx_35, ·ƒv_6, ·∅u8, fn ·ƒctx_37, ·ƒv_9:
              ·fn_type_result ·ƒctx_37, ·ƒv_9, ·∅u8, fn ·ƒctx_39, ·ƒv_12:
                ·set ·Foo_0, ·ƒv_12, fn:
                  ·ƒpub ·ƒctx_39, ·Foo_0, fn ·ƒctx_41:
                    ·ƒret_1 ·ƒctx_41, ·Foo_0
    # sm:


--- constructing a fn-type instance: build the closure, then APPLY the fn-type
    `Foo` to it (apply routes to type_apply's $FnType arm -> $FnInst). ---
test 'function type instance construction', fn:
  cps_module ƒink:
    Foo = type: fn u8, u8: u8
    add = Foo fn a, b: a
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_50, ·ƒret_4:
      ·letrec fn ·Foo_0, ·add_1:
        ·new_fn_type ·ƒctx_50, ƒ'Foo', fn ·ƒctx_53, ·ƒv_6:
          ·fn_type_param ·ƒctx_53, ·ƒv_6, ·∅u8, fn ·ƒctx_55, ·ƒv_9:
            ·fn_type_param ·ƒctx_55, ·ƒv_9, ·∅u8, fn ·ƒctx_57, ·ƒv_12:
              ·fn_type_result ·ƒctx_57, ·ƒv_12, ·∅u8, fn ·ƒctx_59, ·ƒv_15:
                ·set ·Foo_0, ·ƒv_15, fn:
                  ·ƒpub ·ƒctx_59, ·Foo_0, fn ·ƒctx_61:
                    ·fn
                      fn ·ƒctx_62, ·ƒret_19, ·a_2, ·b_3: ·ƒret_19 ·ƒctx_62, ·a_2
                      fn ·ƒv_18:
                        ·Foo_0
                          ·ƒctx_61
                          fn ·ƒctx_65, ·ƒv_24:
                            ·set ·add_1, ·ƒv_24, fn:
                              ·ƒpub ·ƒctx_65, ·add_1, fn ·ƒctx_67:
                                ·ƒret_4 ·ƒctx_67, ·add_1
                          ·ƒv_18
    # sm:


---
typed destructure lowering: `Foo a, b` guards the value then peels positionals
via the tuple/seq_pop machinery; `Foo ..whole` guards then binds the whole
projected value; `Foo ..` (match arm) guards only.
---

test 'typed destructure positionals', fn:
  cps_module ƒink:
    Foo a, b = foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_59, ·ƒret_2:
      ·guard_apply ·ƒctx_59, ·∅Foo, ·∅foo,
        fn ·ƒctx_62, ·ƒv_4:
          ·fn
            fn ·ƒctx_63, ·ƒv_10, ·ƒv_11:
              ·let ·ƒv_10, fn ·a_0:
                ·let ·ƒv_11, fn ·b_1:
                  ·ƒret_2 ·ƒctx_63, ·b_1
            fn ·ƒv_46:
              ·fn
                fn ·ƒctx_64, ·ƒsucc_8, ·ƒfail_9, ·ƒv_7:
                  ·guard_apply ·ƒctx_64, ·tuple_protocol, ·ƒv_7,
                    fn ·ƒctx_66, ·ƒv_24:
                      ·seq_pop ·ƒctx_66, ·ƒv_24, ·ƒfail_9, fn ·ƒctx_68, ·ƒv_10, ·ƒv_25:
                        ·seq_pop ·ƒctx_68, ·ƒv_25, ·ƒfail_9, fn ·ƒctx_70, ·ƒv_11, ·ƒv_16:
                          ·empty ·ƒctx_70, ·ƒv_16, fn ·ƒctx_72, ·ƒv_19:
                            ·if ·ƒv_19,
                              fn: ·ƒsucc_8 ·ƒctx_72, ·ƒv_10, ·ƒv_11
                              fn: ·ƒfail_9 ·ƒctx_72
                    fn ·ƒctx_75: ·ƒfail_9 ·ƒctx_75
                fn ·ƒv_37:
                  ·fn
                    fn ·ƒctx_77: ·panic ·ƒctx_77
                    fn ·ƒv_49: ·ƒv_37 ·ƒctx_62, ·ƒv_46, ·ƒv_49, ·ƒv_4
        fn ·ƒctx_80: ·panic ·ƒctx_80
    # sm:

