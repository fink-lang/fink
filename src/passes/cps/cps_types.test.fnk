{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{cps_module} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected

---
type declaration lowering (CPS level 0)
---

test 'unit type declaration', fn:
  cps_module ƒink:
    Foo = type _
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_15, ·ƒret_1:
      ·letrec fn ·Foo_0:
        ·new_type ·ƒctx_15, ƒ'Foo', fn ·ƒctx_18, ·ƒv_2:
          ·set ·Foo_0, ·ƒv_2, fn:
            ·ƒpub ·ƒctx_18, ·Foo_0, fn ·ƒctx_20:
              ·ƒret_1 ·ƒctx_20, ·Foo_0
    # sm:KwABAAwAAQAMJAEADBgBAAwSAAIABgEADAABAAwYAQADDgACAAoBDAYAAQAGFgAUAAQBAAYOAAoAGAEABg4AAgAOAQsMAAEADAwBAAMOAAQBDAYOAAgAAgASAQsDAAEAAxAAFAAEAQADDgAKABQAAgAWAQADAAEAAxQAFAAEAQAD


