test 'generic union applies referenced constructor', fn:
  cps_module ƒink:
    U = union T:
      Foo T
      Bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_46, ·ƒret_2:
      ·letrec fn ·U_0:
        ·fn
          fn ·ƒctx_48, ·ƒret_4, ·T_1:
            ·new_union ·ƒctx_48, ƒ'U', fn ·ƒctx_50, ·ƒv_5:
              ·∅Foo
                ·ƒctx_50
                fn ·ƒctx_52, ·ƒv_10:
                  ·union_add ·ƒctx_52, ·ƒv_5, ·ƒv_10, fn ·ƒctx_54, ·ƒv_12:
                    ·union_add ·ƒctx_54, ·ƒv_12, ·∅Bar, fn ·ƒctx_56, ·ƒv_15:
                      ·ƒret_4 ·ƒctx_56, ·ƒv_15
                ·T_1
          fn ·ƒv_3:
            ·new_type ·ƒctx_46, ƒ'U', fn ·ƒctx_59, ·ƒv_27:
              ·type_set_new ·ƒctx_59, ·ƒv_27, ·ƒv_3, fn ·ƒctx_61, ·ƒv_30:
                ·set ·U_0, ·ƒv_30, fn:
                  ·ƒpub ·ƒctx_61, ·U_0, fn ·ƒctx_63:
                    ·ƒret_2 ·ƒctx_63, ·U_0
    # sm:


test 'enum with mixed member payloads', fn:
