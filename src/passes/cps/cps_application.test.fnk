{test, skip, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{cps_module} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected

---
application — ·apply synthesis
---

test '·apply ident to literal', fn:
  cps_module ƒink:
    foo 42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, (i8 42)
    # sm:DwABAAYAAQAGJAEABhYBAAYSAAIABgEABgABAAMSABIABAEABhIABgEIAgABAAIGAQAC


test '·apply ident to ident', fn:
  cps_module ƒink:
    foo bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ·∅bar
    # sm:DQABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAMSABIABAEABxIABAEIAw



---
pipe — lowered as application
---

test 'pipe two stages', fn:
  cps_module ƒink:
    a | foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ·∅a
    # sm:DQABAAcAAQAHJAEABxYBAAcSAAIABgEEAQABBAMSABIABAEHBxIABAEAAQ


test 'pipe three stages', fn:
  cps_module ƒink:
    a | foo | bar
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅foo
        ·ƒctx_11
        fn ·ƒctx_14, ·ƒv_3: ·∅bar ·ƒctx_14, ·ƒret_0, ·ƒv_3
        ·∅a
    # sm:FAABAA0AAQANJAEADRgBAA0SAAIABgEEAQABBAMaACQAGAEHDQ4ABAEQAQABBAMSABQABAETDRIABAEADRgBAAE



---
try expression
---

test 'try', fn:
  cps_module ƒink:
    try foo
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, ·∅foo
    # sm:CwABAAcAAQAHJAEABxYBAAcSAAIABgEABwABAAcUABIABAEIAw



---
ported from test_cps — calls and application
---

test 'simple call', fn:
  cps_module ƒink:
    add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅add ·ƒctx_7, ·ƒret_0, (i8 1), (i8 2)
    # sm:EwABAAgAAQAIJAEACBYBAAgSAAIABgEACAABAAMSABIABAEACBIABgEIAQABAAEGAQABBAAGAQYBAAEAAQYBAAE


test 'nested call', fn:
  cps_module ƒink:
    add (mul 2, 3), 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_13, ·ƒret_0:
      ·∅mul
        ·ƒctx_13
        fn ·ƒctx_16, ·ƒv_5: ·∅add ·ƒctx_16, ·ƒret_0, ·ƒv_5, (i8 1)
        i8 2
        i8 3
    # sm:HQABABEAAQARJAEAERgBABESAAIABgEKCAABAAMaACQAGAEACA4ABAEJEQABAAMSABQABAEAERIABAEKCA4ABgEWAQABAAEGAQABDgENAQABAAEGAQABDAEGAQABAAEGAQAB


test 'postfix tag', fn:
  cps_module ƒink:
    (foo bar)tag
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅foo
        ·ƒctx_11
        fn ·ƒctx_14, ·ƒv_4: ·∅tag ·ƒctx_14, ·ƒret_0, ·ƒv_4
        ·∅bar
    # sm:FAABAAwAAQAMJAEADBgBAAwSAAIABgECBwABAAMaACQAGAEABw4ABAEBDAABEgMSABQABAERDBIABAECBxgBCAM


test 'call with spread', fn:
  cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, ·∅a, ..·∅rest
    # sm:EQABAA0AAQANJAEADRYBAA0SAAIABgEADQABAAMSABIABAEADRIABAEIAQwABAEKBAABAAQEAQAE


test 'simple pipe', fn:
  cps_module ƒink:
    x | f
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅f ·ƒctx_6, ·ƒret_0, ·∅x
    # sm:DQABAAUAAQAFJAEABRYBAAUSAAIABgEEAQABBAEOABIABAEHBRIABAEAAQ


test 'pipe chain', fn:
  cps_module ƒink:
    x | f | g
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·∅f
        ·ƒctx_11
        fn ·ƒctx_14, ·ƒv_3: ·∅g ·ƒctx_14, ·ƒret_0, ·ƒv_3
        ·∅x
    # sm:FAABAAkAAQAJJAEACRgBAAkSAAIABgEEAQABBAEWACQAGAEHCQ4ABAEMAQABBAEOABQABAEPCRIABAEACRgBAAE


test 'partial apply', fn:
  cps_module ƒink:
    add 3, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_12, ·ƒret_1:
      ·fn
        fn ·ƒctx_14, ·ƒret_3, ·ƒv_0: ·∅add ·ƒctx_14, ·ƒret_3, (i8 3), ·ƒv_0
        fn ·ƒv_2: ·ƒret_1 ·ƒctx_12, ·ƒv_2
    # sm:IAABAAgAAQAIJAEACBgBAAgSAAIABgEACAABAAgIABAAGAEACBYBAAgOAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQ4AEAENCA4ABAEACAABAAgUAQAIFAAEAQAI


test 'pipe with lambda — literal head', fn:
  cps_module ƒink:
    3 | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·fn
        fn ·ƒctx_18, ·ƒret_4, ·a_0: ·op_plus ·ƒctx_18, ·a_0, (i8 2), ·ƒret_4
        fn ·ƒv_3: ·ƒv_3 ·ƒctx_16, ·ƒret_1, (i8 3)
    # sm:JAABAA8AAQAPJAEADxgBAA8SAAIABgEICwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQABAEHBRIAEAELCw4ABAEDAQABBAsQABQABAEHDxIABgEAAQABAAEGAQAB


test 'pipe with lambda — ident head', fn:
  cps_module ƒink:
    x | fn a: a + 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·fn
        fn ·ƒctx_18, ·ƒret_4, ·a_0: ·op_plus ·ƒctx_18, ·a_0, (i8 2), ·ƒret_4
        fn ·ƒv_3: ·ƒv_3 ·ƒctx_16, ·ƒret_1, ·∅x
    # sm:IgABAA8AAQAPJAEADxgBAA8SAAIABgEICwABAAsIABAAGAEMBRYBBQEKAAQBBgUAAQAFFAAUAAQBAAEKAAYBCAEAAQABBgEAAQQABAEHBRIAEAELCw4ABAEDAQABBAsQABQABAEHDxIABAEAAQ


test 'pipe with partial', fn:
  cps_module ƒink:
    3 | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·fn
        fn ·ƒctx_19, ·ƒret_4, ·ƒv_0: ·∅add ·ƒctx_19, ·ƒret_4, (i8 2), ·ƒv_0
        fn ·ƒv_3: ·ƒv_3 ·ƒctx_17, ·ƒret_1, (i8 3)
    # sm:JAABAAwAAQAMJAEADBgBAAwSAAIABgEICAABAAgIABAAGAEACBYBAAgOAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQ4AEAENCA4ABAEDAQABBAgQABQABAEHDBIABgEAAQABAAEGAQAB


test 'pipe with partial — ident head', fn:
  cps_module ƒink:
    x | add 2, ?
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·fn
        fn ·ƒctx_19, ·ƒret_4, ·ƒv_0: ·∅add ·ƒctx_19, ·ƒret_4, (i8 2), ·ƒv_0
        fn ·ƒv_3: ·ƒv_3 ·ƒctx_17, ·ƒret_1, ·∅x
    # sm:IgABAAwAAQAMJAEADBgBAAwSAAIABgEICAABAAgIABAAGAEACBYBAAgOAAQBAAgAAQADEgAUAAQBAAgSAAYBCAEAAQABBgEAAQQABAEGAQ4AEAENCA4ABAEDAQABBAgQABQABAEHDBIABAEAAQ


--- BUG: a `?` partial in a pipe RHS inside a NESTED fn body (tail
position) is not eliminated by the partial-application desugar pass, so a
`Partial` node survives to CPS and panics:
  "Partial should be eliminated before CPS transform" (transform.rs:345)
`equals ?, 10` is legal (== `fn $: equals $, 10`); `x | equals ?, 10`
works at module/main top level but NOT when the same pipe is the tail
expr of a thunk passed to a fn (`run fn: x | equals ?, 10`). Fix lives in
PartialPass (src/passes/ast_desugar/mod.rs) -- the wrap-into-Fn boundary
isn't recognized for a pipe-partial in a nested fn body tail. See
.scratch/bug-partial-in-nested-fn-pipe.md. Skipped until fixed.
---
skip test 'pipe with partial inside nested fn body', fn:
  cps_module ƒink:
    run fn:
      x | add 2, ?
  | equals ƒink:
    TODO



---
varargs — spread preserved in IR
---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  cps_module ƒink:
    foo 1, ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, (i8 1), ..·∅items
    # sm:EwABAA4AAQAOJAEADhYBAA4SAAIABgEADgABAAMSABIABAEADhIABgEIAQABAAEGAQABBAAEAQoFAAEABQQBAAU


test 'call with spread — trailing iterable', fn:
  cps_module ƒink:
    foo a, ..rest
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_7, ·ƒret_0:
      ·∅foo ·ƒctx_7, ·ƒret_0, ·∅a, ..·∅rest
    # sm:EQABAA0AAQANJAEADRYBAA0SAAIABgEADQABAAMSABIABAEADRIABAEIAQwABAEKBAABAAQEAQAE


test 'call with spread — spread only', fn:
  cps_module ƒink:
    foo ..items
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·∅foo ·ƒctx_6, ·ƒret_0, ..·∅items
    # sm:DwABAAsAAQALJAEACxYBAAsSAAIABgEACwABAAMSABIABAEACxIABAEMBQABAAUEAQAF


test 'call with spread — passes through from varargs fn', fn:
  cps_module ƒink:
    fn ..args: foo ..args
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_1:
      ·fn
        fn ·ƒctx_13, ·ƒret_3, ..·args_0: ·∅foo ·ƒctx_13, ·ƒret_3, ..·args_0
        fn ·ƒv_2: ·ƒret_1 ·ƒctx_11, ·ƒv_2
    # sm:IAABABUAAQAVJAEAFRgBABUSAAIABgEAFQABABUIABAAGAEWChYBCwQAAQAEBAEABBAABAEMCgABAAMSABQABAEAChIABAEMBAABAAQEAQAEEAAQASEVDgAEAQAVAAEAFRQBABUUAAQBABU
