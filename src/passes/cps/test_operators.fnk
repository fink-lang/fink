{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_module ƒink:
    a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_plus ·∅a, ·∅b, ·ƒret_0
    # sm:DQABAAUAAQAFJAEABRYBAAUSAAIABgEABQABAAUUAQABDAAEAQgBDAAEAQcF


test 'infix literal', fn:
  expect cps_module ƒink:
    a + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_6, ·ƒret_0:
      ·op_plus ·∅a, (i8 1), ·ƒret_0
    # sm:DwABAAUAAQAFJAEABRYBAAUSAAIABgEABQABAAUUAQABDAAGAQgBAAEAAQYBAAEEAAQBBwU



---
unary ops
---

test 'unary not', fn:
  expect cps_module ƒink:
    not x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_5, ·ƒret_0:
      ·op_not ·∅x, ·ƒret_0
    # sm:CwABAAUAAQAFJAEABRYBAAUSAAIABgEABQABAAUSAQgBDAAEAQcF


test 'unary minus', fn:
  expect cps_module ƒink:
    -x
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_5, ·ƒret_0:
      ·op_minus ·∅x, ·ƒret_0
    # sm:CwABAAIAAQACJAEAAhYBAAISAAIABgEAAgABAAIWAQIBDAAEAQEC

---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_module ƒink:
    a < b < c
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_15, ·ƒret_0:
      ·op_lt ·∅a, ·∅b, fn ·ƒctx_17, ·v_4:
        ·op_lt ·∅b, ·∅c, fn ·ƒctx_18, ·v_6:
          ·op_and ·v_4, ·v_6, ·ƒret_0
    # sm:IQABAAkAAQAJJAEACRgBAAkSAAIABgEACQABAAkQAQABDAAEAQgBDAAKABgBBwkKAAIACgEACQABAAkQAQgBDAAEAQgBDAAKABgBDwkKAAIADgEACQABAAkSAQAJCgAEAQAJCgAEAQAJ

