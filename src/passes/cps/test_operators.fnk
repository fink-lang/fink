---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_module ƒink:
    a < b < c
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_lt ·∅a, ·∅b, fn ·v_4:
        ·op_lt ·∅b, ·∅c, fn ·v_6:
          ·op_and ·v_4, ·v_6, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSA8IGIgPCBjIl0sCiAgIm1hcHBpbmdzIjogIkEsQSxnQixPO0VBQUEsQUFBQSxPQUFBLEcsRUFBSSxHLEtBQUosSTtJQUFBLEFBQUEsT0FBSSxHLEVBQUksRyxLQUFSLEk7TUFBQSxBQUFBLFFBQUEsSSxFQUFBLEksRSIKfQ==

