{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_module ƒink:
    a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_plus ·∅a, ·∅b, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSArIGIiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBRSxBQUFBLFNBQUYsRyxFQUFJLEcsRSIKfQ==


test 'infix literal', fn:
  expect cps_module ƒink:
    a + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_plus ·∅a, 1, ·ƒret_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSArIDEiXSwKICAibWFwcGluZ3MiOiAiQSxBLGdCLE87RUFBRSxBQUFBLFNBQUYsRyxFQUFJLEMsRSIKfQ==



