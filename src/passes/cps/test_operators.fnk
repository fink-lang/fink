{test, expect, equals, cps_expr} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_expr ƒink:
    a + b
  | equals ƒink:
    ·op_plus ·∅a, ·∅b, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSArIGIiXSwKICAibWFwcGluZ3MiOiAiQUFBRSxBQUFBLFNBQUYsRyxFQUFJLEcsRSIKfQ==


test 'infix literal', fn:
  expect cps_expr ƒink:
    a + 1
  | equals ƒink:
    ·op_plus ·∅a, 1, ·v_0
    #sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiYSArIDEiXSwKICAibWFwcGluZ3MiOiAiQUFBRSxBQUFBLFNBQUYsRyxFQUFJLEMsRSIKfQ==



