{test, expect, equals, cps_module} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

---
infix operators — op ·load + ·apply synthesis
---

test 'infix add', fn:
  expect cps_module ƒink:
    a + b
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_plus ·∅a, ·∅b, ·ƒret_0
    # sm:DAABAAUAAQAFJAEABRIAAgAGAQAFAAEABRQBAAEMAAQBCAEMAAQBBwU


test 'infix literal', fn:
  expect cps_module ƒink:
    a + 1
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_plus ·∅a, (i8 1), ·ƒret_0
    # sm:DgABAAUAAQAFJAEABRIAAgAGAQAFAAEABRQBAAEMAAYBCAEAAQABBgEAAQQABAEHBQ



---
unary ops
---

test 'unary not', fn:
  expect cps_module ƒink:
    not x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_not ·∅x, ·ƒret_0
    # sm:CgABAAUAAQAFJAEABRIAAgAGAQAFAAEABRIBCAEMAAQBBwU


test 'unary minus', fn:
  expect cps_module ƒink:
    -x
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_minus ·∅x, ·ƒret_0
    # sm:CgABAAIAAQACJAEAAhIAAgAGAQACAAEAAhYBAgEMAAQBAQI

---
chained comparisons
---

test 'chained cmp', fn:
  expect cps_module ƒink:
    a < b < c
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_lt ·∅a, ·∅b, fn ·v_4:
        ·op_lt ·∅b, ·∅c, fn ·v_6:
          ·op_and ·v_4, ·v_6, ·ƒret_0
    # sm:HgABAAkAAQAJJAEACRIAAgAGAQAJAAEACRABAAEMAAQBCAEMAAoBBwkKAAIACgEACQABAAkQAQgBDAAEAQgBDAAKAQ8JCgACAA4BAAkAAQAJEgEACQoABAEACQoABAEACQ

---
range
---

test 'range excl', fn:
  expect cps_module ƒink:
    0..10
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_rngex (i8 0), (i8 10), ·ƒret_0
    # sm:EAABAAUAAQAFJAEABRIAAgAGAQAFAAEABRgBAAEAAQABBgEAAQQABgEGAgABAAIGAQACBgAEAQUF


test 'range incl', fn:
  expect cps_module ƒink:
    0...10
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·op_rngin (i8 0), (i8 10), ·ƒret_0
    # sm:EAABAAYAAQAGJAEABhIAAgAGAQAGAAEABhgBAAEAAQABBgEAAQQABgEIAgABAAIGAQACBgAEAQcG


