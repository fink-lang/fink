


---
statement-level partial
---

test 'partial in infix rhs', fn:
  expect partial fink":
    ? + 5
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      InfixOp '+'
        Ident '$'
        LitInt '5'


test 'partial in infix lhs', fn:
  expect partial fink":
    1 + ?
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      InfixOp '+'
        LitInt '1'
        Ident '$'


test 'partial used twice - single param', fn:
  expect partial fink":
    ? + ?
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      InfixOp '+'
        Ident '$'
        Ident '$'


test 'partial in apply arg', fn:
  expect partial fink":
    add 5, ?
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Apply
        Ident 'add'
        LitInt '5'
        Ident '$'


test 'partial in unary', fn:
  expect partial fink":
    -?
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      UnaryOp '-'
        Ident '$'


test 'partial in member access', fn:
  expect partial fink":
    ?.foo
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Member '.'
        Ident '$'
        Ident 'foo'


test 'partial in computed member access', fn:
  expect partial fink":
    ?.(0)
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Member '.'
        Ident '$'
        Group '(..)'
          LitInt '0'


test 'partial in range', fn:
  expect partial fink":
    (1..?)
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      InfixOp '..'
        LitInt '1'
        Ident '$'


test 'partial in spread', fn:
  expect partial fink":
    [..?]
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      LitSeq '[..]'
        Spread '..'
          Ident '$'


test 'bare partial - identity function', fn:
  expect partial fink":
    (?)
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Ident '$'


test 'partial in binding rhs', fn:
  expect partial fink":
    add5 = add 5, ?
  | equals fink":
    Bind '='
      Ident 'add5'
      Fn ':'
        Patterns
          Ident '$'
        Apply
          Ident 'add'
          LitInt '5'
          Ident '$'


---
group as explicit scope boundary
---

test 'group narrows scope - member expr key preserves group', fn:
  expect partial fink":
    foo.(?)
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Member '.'
        Ident 'foo'
        Group '(..)'
          Ident '$'


test 'group with multiple partial refs - same param', fn:
  expect partial fink":
    (foo ?.(1), ?.(2))
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Apply
        Ident 'foo'
        Member '.'
          Ident '$'
          Group '(..)'
            LitInt '1'
        Member '.'
          Ident '$'
          Group '(..)'
            LitInt '2'


test 'nested groups - each is its own scope', fn:
  expect partial fink":
    (foo (bar ?) ?)
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Apply
        Ident 'foo'
        Fn ':'
          Patterns
            Ident '$'
          Apply
            Ident 'bar'
            Ident '$'
        Ident '$'


---
transparent containers - partial bubbles through
---

test 'partial in seq literal - seq is transparent', fn:
  expect partial fink":
    [?, ?]
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      LitSeq '[..]'
        Ident '$'
        Ident '$'


test 'partial with member projection in seq', fn:
  expect partial fink":
    [?.(0), ?.(1)]
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      LitSeq '[..]'
        Member '.'
          Ident '$'
          Group '(..)'
            LitInt '0'
        Member '.'
          Ident '$'
          Group '(..)'
            LitInt '1'


test 'partial in rec literal - rec is transparent', fn:
  expect partial fink":
    {foo: ?, bar: ?}
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      LitRec '{..}'
        Arm ':'
          Ident 'foo'
          Ident '$'
        Arm ':'
          Ident 'bar'
          Ident '$'


test 'partial in nested seq - all same param', fn:
  expect partial fink":
    [?, [?, ?]]
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      LitSeq '[..]'
        Ident '$'
        LitSeq '[..]'
          Ident '$'
          Ident '$'


test 'partial in spread apply', fn:
  expect partial fink":
    foo ..?
  | equals fink":
    Fn ':'
      Patterns
        Ident '$'
      Apply
        Ident 'foo'
        Spread '..'
          Ident '$'


---
pipe segments as scope boundaries
---

test 'partial in pipe segment', fn:
  expect partial fink":
    items
    | filter ? % 2 == 0
  | equals fink":
    Pipe
      Ident 'items'
      Fn ':'
        Patterns
          Ident '$'
        Apply
          Ident 'filter'
          InfixOp '=='
            InfixOp '%'
              Ident '$'
              LitInt '2'
            LitInt '0'


test 'partial in multiple pipe segments', fn:
  expect partial fink":
    items
    | filter is_even ?
    | map ? * 2
  | equals fink":
    Pipe
      Ident 'items'
      Fn ':'
        Patterns
          Ident '$'
        Apply
          Ident 'filter'
          Apply
            Ident 'is_even'
            Ident '$'
      Fn ':'
        Patterns
          Ident '$'
        Apply
          Ident 'map'
          InfixOp '*'
            Ident '$'
            LitInt '2'
