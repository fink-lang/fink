

---
no change in AST
---
test 'AST remains the same', fn:
  expect partial fink":
    5 + 5
  | equals ":
    No Change



---
statement-level partial
---

test 'partial in infix rhs', fn:
  expect partial fink":
    ? + 5
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      InfixOp '+',
        SynthIdent '·$_0'
        LitInt '5'


test 'partial in infix lhs', fn:
  expect partial fink":
    1 + ?
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      InfixOp '+',
        LitInt '1'
        SynthIdent '·$_0'


test 'partial used twice - single param', fn:
  expect partial fink":
    ? + ?
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      InfixOp '+',
        SynthIdent '·$_0'
        SynthIdent '·$_0'


test 'partial in apply arg', fn:
  expect partial fink":
    add 5, ?
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Apply
        Ident 'add'
        LitInt '5'
        SynthIdent '·$_0'


test 'partial in unary', fn:
  expect partial fink":
    -?
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      UnaryOp '-',
        SynthIdent '·$_0'


test 'partial in member access', fn:
  expect partial fink":
    ?.foo
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Member '.',
        SynthIdent '·$_0'
        Ident 'foo'


test 'partial in computed member access', fn:
  expect partial fink":
    ?.(0)
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Member '.',
        SynthIdent '·$_0'
        Group '(..)',
          LitInt '0'


test 'partial in range', fn:
  expect partial fink":
    (1..?)
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      InfixOp '..',
        LitInt '1'
        SynthIdent '·$_0'


test 'partial in spread', fn:
  expect partial fink":
    [..?]
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      LitSeq '[..]',
        Spread '..',
          SynthIdent '·$_0'


test 'bare partial - identity function', fn:
  expect partial fink":
    (?)
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      SynthIdent '·$_0'


test 'partial in binding rhs', fn:
  expect partial fink":
    add5 = add 5, ?
  | equals fink":
    Bind '=',
      Ident 'add5'
      Fn ':',
        Patterns
          SynthIdent '·$_0'
        Apply
          Ident 'add'
          LitInt '5'
          SynthIdent '·$_0'


---
group as explicit scope boundary
---

test 'group narrows scope - member expr key preserves group', fn:
  expect partial fink":
    foo.(?)
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Member '.',
        Ident 'foo'
        Group '(..)',
          SynthIdent '·$_0'


test 'group with multiple partial refs - same param', fn:
  expect partial fink":
    (foo ?.(1), ?.(2))
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Apply
        Ident 'foo'
        Member '.',
          SynthIdent '·$_0'
          Group '(..)',
            LitInt '1'
        Member '.',
          SynthIdent '·$_0'
          Group '(..)',
            LitInt '2'


test 'nested groups - each is its own scope', fn:
  expect partial fink":
    (foo (bar ?) ?)
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_1'
      Apply
        Ident 'foo'
        Fn ':',
          Patterns
            SynthIdent '·$_0'
          Apply
            Ident 'bar'
            SynthIdent '·$_0'
        SynthIdent '·$_1'


---
transparent containers - partial bubbles through
---

test 'partial in seq literal - seq is transparent', fn:
  expect partial fink":
    [?, ?]
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      LitSeq '[..]',
        SynthIdent '·$_0'
        SynthIdent '·$_0'


test 'partial with member projection in seq', fn:
  expect partial fink":
    [?.(0), ?.(1)]
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      LitSeq '[..]',
        Member '.',
          SynthIdent '·$_0'
          Group '(..)',
            LitInt '0'
        Member '.',
          SynthIdent '·$_0'
          Group '(..)',
            LitInt '1'


test 'partial in rec literal - rec is transparent', fn:
  expect partial fink":
    {foo: ?, bar: ?}
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      LitRec '{..}',
        Arm ':',
          Ident 'foo'
          SynthIdent '·$_0'
        Arm ':',
          Ident 'bar'
          SynthIdent '·$_0'


test 'partial in nested seq - all same param', fn:
  expect partial fink":
    [?, [?, ?]]
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      LitSeq '[..]',
        SynthIdent '·$_0'
        LitSeq '[..]',
          SynthIdent '·$_0'
          SynthIdent '·$_0'


test 'partial in spread apply', fn:
  expect partial fink":
    foo ..?
  | equals fink":
    Fn ':',
      Patterns
        SynthIdent '·$_0'
      Apply
        Ident 'foo'
        Spread '..',
          SynthIdent '·$_0'


---
pipe segments as scope boundaries
---

test 'partial in pipe segment', fn:
  expect partial fink":
    items
    | filter ? % 2 == 0
  | equals fink":
    Pipe
      Ident 'items'
      Fn ':',
        Patterns
          SynthIdent '·$_0'
        Apply
          Ident 'filter'
          InfixOp '==',
            InfixOp '%',
              SynthIdent '·$_0'
              LitInt '2'
            LitInt '0'


test 'partial in multiple pipe segments', fn:
  expect partial fink":
    items
    | filter is_even ?
    | map ? * 2
  | equals fink":
    Pipe
      Ident 'items'
      Fn ':',
        Patterns
          SynthIdent '·$_0'
        Apply
          Ident 'filter'
          Apply
            Ident 'is_even'
            SynthIdent '·$_0'
      Fn ':',
        Patterns
          SynthIdent '·$_1'
        Apply
          Ident 'map'
          InfixOp '*',
            SynthIdent '·$_1'
            LitInt '2'
