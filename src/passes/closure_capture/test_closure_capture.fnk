---
closure capture tests
---

# Closure capture — annotates CPS IR with explicit capture lists.
#
# Consumes name resolution output (Resolution::Captured) and produces a
# capture graph: one entry per LetFn mapping it to the names it closes over.
#
# Output: standard CPS IR, with closure LetFn nodes annotated:
#   ·fn
#     fn {cap: [x, y]}, param: body   — closure, captures x and y
#     fn cont: ...
#
# Pure LetFn nodes (no captures) render unchanged:
#   ·fn
#     fn param: body
#     fn cont: ...
#
# Self-recursive refs resolve as Recursive (not Captured) — no capture entry.
# Mutual recursion: each fn captures the other's binding.
#
# Test format:
#   test 'name', fn:
#     expect closure_capture fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps with capture annotations>


---
pure functions
---

test 'fn with no captures', fn:
  expect closure_capture fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn x: ·ƒ_cont x, ·state
      fn ·v_0:
        ·let ·v_0, fn f:
          ·ƒ_cont f, ·state


---
recursion
---

test 'self-recursive fn is pure', fn:
  expect closure_capture fink":
    f = fn a:
      f a

  | equals fink":
    ·fn
      fn a:
        ·apply f, a, ·state, fn ·v_4, ·state:
          ·ƒ_cont ·v_4, ·state
      fn ·v_0:
        ·let ·v_0, fn f:
          ·ƒ_cont f, ·state

test 'mutual recursion — each fn captures the other', fn:
  expect closure_capture fink":
    f = fn a:
      g a
    g = fn b:
      f b

  | equals fink":
    ·fn
      fn:
        ·fn
          fn {cap: [g]}, a:
            ·apply g, a, ·state, fn ·v_5, ·state:
              ·ƒ_cont ·v_5, ·state
          fn ·v_1:
            ·let ·v_1, fn f:
              ·fn
                fn {cap: [f]}, b:
                  ·apply f, b, ·state, fn ·v_15, ·state:
                    ·ƒ_cont ·v_15, ·state
                fn ·v_11:
                  ·let ·v_11, fn g:
                    ·ƒ_cont g, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


---
depth-2 captures
---

test 'depth-2 capture — fn b directly uses x, fn a does not', fn:
  expect closure_capture fink":
    x = 1
    fn a:
      fn b:
        x

  | equals fink":
    ·fn
      fn:
        ·let 1, fn x:
          ·fn
            fn a:
              ·fn
                fn {cap: [x]}, b: ·ƒ_cont x, ·state
                fn ·v_5: ·ƒ_cont ·v_5, ·state
            fn ·v_3: ·ƒ_cont ·v_3, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state

test 'multiple captures', fn:
  expect closure_capture fink":
    x = 1
    y = 2
    fn a:
      x + y

  | equals fink":
    ·fn
      fn:
        ·let 1, fn x:
          ·let 2, fn y:
            ·fn
              fn {cap: [x, y]}, a:
                ·apply ·op_plus, x, y, ·state, fn ·v_9, ·state:
                  ·ƒ_cont ·v_9, ·state
              fn ·v_5: ·ƒ_cont ·v_5, ·state
      fn ·v_0: ·ƒ_cont ·v_0, ·state


---
simple captures
---

test 'fn captures one outer binding', fn:
  expect closure_capture fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a:
        ·fn
          fn {cap: [a]}, b:
            ·apply ·op_plus, a, b, ·state, fn ·v_6, ·state:
              ·ƒ_cont ·v_6, ·state
          fn ·v_2: ·ƒ_cont ·v_2, ·state
      fn ·v_0:
        ·let ·v_0, fn foo:
          ·ƒ_cont foo, ·state
