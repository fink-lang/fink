---
closure capture tests
---

# Closure capture — annotates CPS IR with explicit capture lists.
#
# Consumes name resolution output (Resolution::Captured) and produces a
# capture graph: one entry per LetFn mapping it to the names it closes over.
#
# Output: standard CPS IR, with closure LetFn nodes annotated:
#   ·fn
#     fn {cap: [x, y]}, param: body   — closure, captures x and y
#     fn cont: ...
#
# Pure LetFn nodes (no captures) render unchanged:
#   ·fn
#     fn param: body
#     fn cont: ...
#
# Self-recursive refs resolve as Recursive (not Captured) — no capture entry.
# Mutual recursion: each fn captures the other's binding.
#
# Test format:
#   test 'name', fn:
#     expect closure_capture fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps with capture annotations>


---
pure functions
---

test 'fn with no captures', fn:
  expect closure_capture fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·let x, fn ·v_5:
          ·ƒ_3 ·v_5
      fn ·v_1:
        ·let ·v_1, fn f:
          ·ƒ_0 f


---
recursion
---

test 'self-recursive fn is pure', fn:
  expect closure_capture fink":
    f = fn a:
      f a

  | equals fink":
    ·fn
      fn a, ·ƒ_3:
        ·apply f, a, fn ·v_3:
          ·ƒ_3 ·v_3
      fn ·v_1:
        ·let ·v_1, fn f:
          ·ƒ_0 f

test 'mutual recursion — each fn captures the other', fn:
  expect closure_capture fink":
    f = fn a:
      g a
    g = fn b:
      f b

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·fn
          fn {cap: [g]}, a, ·ƒ_5:
            ·apply g, a, fn ·v_5:
              ·ƒ_5 ·v_5
          fn ·v_3:
            ·let ·v_3, fn f:
              ·fn
                fn {cap: [f]}, b, ·ƒ_15:
                  ·apply f, b, fn ·v_15:
                    ·ƒ_15 ·v_15
                fn ·v_13:
                  ·let ·v_13, fn g:
                    ·ƒ_2 g
      fn ·v_1: ·ƒ_0 ·v_1


---
depth-2 captures
---

test 'depth-2 capture — fn b directly uses x, fn a does not', fn:
  expect closure_capture fink":
    x = 1
    fn a:
      fn b:
        x

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·let 1, fn x:
          ·fn
            fn a, ·ƒ_7:
              ·fn
                fn {cap: [x]}, b, ·ƒ_10:
                  ·let x, fn ·v_12:
                    ·ƒ_10 ·v_12
                fn ·v_8: ·ƒ_7 ·v_8
            fn ·v_5: ·ƒ_2 ·v_5
      fn ·v_1: ·ƒ_0 ·v_1

test 'multiple captures', fn:
  expect closure_capture fink":
    x = 1
    y = 2
    fn a:
      x + y

  | equals fink":
    ·fn
      fn ·ƒ_2:
        ·let 1, fn x:
          ·let 2, fn y:
            ·fn
              fn {cap: [x, y]}, a, ·ƒ_9:
                ·apply ·op_plus, x, y, fn ·v_9:
                  ·ƒ_9 ·v_9
              fn ·v_7: ·ƒ_2 ·v_7
      fn ·v_1: ·ƒ_0 ·v_1


---
simple captures
---

test 'fn captures one outer binding', fn:
  expect closure_capture fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, ·ƒ_3:
        ·fn
          fn {cap: [a]}, b, ·ƒ_6:
            ·apply ·op_plus, a, b, fn ·v_6:
              ·ƒ_6 ·v_6
          fn ·v_4: ·ƒ_3 ·v_4
      fn ·v_1:
        ·let ·v_1, fn foo:
          ·ƒ_0 foo
