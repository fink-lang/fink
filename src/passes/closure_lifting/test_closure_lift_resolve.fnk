---
name resolution after closure lifting
---

# After closure lifting, name resolution is re-run on the lifted CPS IR.
# Key invariants:
#   - Former captures are now leading params → resolve as `local`
#   - No `captured` refs remain in the lifted output
#   - Hoisted fn names resolve as `local` at module scope
#   - Pure fns are unchanged
#
# Test format:
#   test 'name', fn:
#     expect closure_lift_resolve fink":
#       <fink source>
#
#     | equals fink":
#       <expected classified resolution>

{test, equals, expect, fink, closure_lift_resolve} = import 'fake!'

---
pure fn — unchanged
---

test 'pure fn params resolve as local', fn:
  expect closure_lift_resolve fink":
    f = fn x: x

  | equals fink":
    (ref 4, x) == (local (bind 2, x)) in scope 1


---
simple closure — capture becomes leading param
---

test 'captured var resolves as local after lift', fn:
  expect closure_lift_resolve fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    (ref 7, a) == (local (bind 20, a)) in scope 22
    (ref 8, b) == (local (bind 5, b)) in scope 22
    (ref 21, a) == (local (bind 2, a)) in scope 1


---
depth-2 closure — all captures become leading params
---

# BUG: `a` in the innermost fn still resolves as `captured` after lifting.
# After lifting, `a` and `b` should both be leading params of the hoisted fn
# and resolve as `local`. Fix: re-run closure lifting until no captured refs remain,
# or fix the lifting pass to handle depth > 1 captures in a single pass.

test 'depth-2: all captured vars resolve as local after lift', fn:
  expect closure_lift_resolve fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    (ref 44, a) == (local (bind 56, a)) in scope 58
    (ref 45, b) == (local (bind 5, b)) in scope 58
    (ref 14, c) == (local (bind 34, c)) in scope 36
    (ref 35, c) == (local (bind 8, c)) in scope 46
    (ref 10, a) == (local (bind 42, a)) in scope 46
    (ref 11, b) == (local (bind 43, b)) in scope 46
    (ref 57, a) == (local (bind 2, a)) in scope 1


---
match with binding — captured var after final cont_lift
---

# After lift_all, the final cont_lift may hoist continuations into new fn scopes,
# re-introducing captured refs that closure_lifting already resolved.
# All refs should be `local` after lift_all — no `captured` should remain.

test 'match with binding: no captured refs after lift', fn:
  expect closure_lift_resolve fink":
    main = fn:
      x = 5
      match x:
        0: 0
        _: x + 1

  | equals fink":
    (ref 83, x) == (local (bind 94, x)) in scope 96
    (ref 75, x) == (local (bind 94, x)) in scope 96
    (ref 26, x) == (local (bind 74, x)) in scope 76
    (ref 5, x) == (local (bind 82, x)) in scope 84
    (ref 95, x) == (local (bind 4, x)) in scope 1


---
recursive fn in match — captured and unresolved refs after final cont_lift
---

# A recursive fn with a match body produces:
#   - captured refs to `n` (the fn param) in hoisted arm bodies
#   - unresolved ref to `recurse` (the self-ref) in the recursive call arm
# All should be `local` (or `recursive`) after lift_all.

test 'recursive fn in match: no captured or unresolved refs after lift', fn:
  expect closure_lift_resolve fink":
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5

  | equals fink":
    (ref 114, n) == (local (bind 137, n)) in scope 139
    (ref 106, n) == (local (bind 137, n)) in scope 139
    (ref 52, recurse) == (local (bind 121, recurse)) in scope 123
    (ref 27, recurse) == (local (bind 97, recurse)) in scope 99
    (ref 98, recurse) == unresolved
    (ref 28, n) == (local (bind 105, n)) in scope 107
    (ref 6, n) == (local (bind 113, n)) in scope 115
    (ref 138, n) == (local (bind 4, n)) in scope 3
    (ref 122, recurse) == (local (bind 49, recurse)) in scope 1
