---
closure lifting tests
---

# Closure lifting — rewrites closure LetFn nodes so captured values are
# threaded as explicit leading params. After this pass no fn closes over
# anything — all values are passed explicitly.
#
# Rewrite per closure LetFn (non-empty captures):
#   Before:  fn {cap: [x]}, b: <body>
#   After:   fn x, b: <body>    — x promoted to leading param; fn hoisted to top
#
# Call sites use ·fn_closure to partially apply the hoisted fn with its captures.
#
# Test format:
#   test 'name', fn:
#     expect closure_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>

{test, equals, expect, fink, closure_lift} = import 'fake!'

---
pure functions — unchanged
---

test 'pure fn is unchanged', fn:
  expect closure_lift fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·let x, fn ·v_5:
          ·ƒ_3 ·v_5
      fn ·v_1:
        ·let ·v_1, fn f:
          ·ƒ_0 f


test 'pure nested fn — inner fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·fn
      fn a, ·ƒ_3:
        ·fn
          fn b, ·ƒ_6:
            ·let b, fn ·v_8:
              ·ƒ_6 ·v_8
          fn ·v_4: ·ƒ_3 ·v_4
      fn ·v_1:
        ·let ·v_1, fn foo:
          ·ƒ_0 foo


---
closure lifting
---

test 'captured binding becomes leading param', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_23:
        ·op_plus a, b, fn ·v_6:
          ·ƒ_6 ·v_6
      fn ·v_22:
        ·fn
          fn a, ·ƒ_3:
            ·fn
              fn ·v_25, ·ƒ_31:
                ·let ·v_25, fn ·v_4:
                  ·ƒ_3 ·v_4
              fn ·ƒ_30:
                ·fn_closure ·v_22, a, fn ·v_30:
                  ·ƒ_30 ·v_30
          fn ·v_1:
            ·let ·v_1, fn foo:
              ·ƒ_0 foo


test 'depth-2 — innermost closure hoisted, intermediate fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·fn
      fn a, b, ·ƒ_59:
        ·fn
          fn ·v_49, ·ƒ_67:
            ·let ·v_49, fn ·v_7:
              ·ƒ_6 ·v_7
          fn ·ƒ_66:
            ·fn_closure ·v_46, a, b, fn ·v_66:
              ·ƒ_66 ·v_66
      fn ·v_58:
        ·fn
          fn c, ·v_12, ·ƒ_37:
            ·op_plus ·v_12, c, fn ·v_9:
              ·ƒ_9 ·v_9
          fn ·v_36:
            ·fn
              fn a, b, c, ·ƒ_47:
                ·fn
                  fn ·v_39, ·ƒ_71:
                    ·let ·v_39, fn ·ƒ_30:
                      ·op_plus a, b, fn ·v_30:
                        ·ƒ_30 ·v_30
                  fn ·ƒ_70:
                    ·fn_closure ·v_36, c, fn ·v_70:
                      ·ƒ_70 ·v_70
              fn ·v_46:
                ·fn
                  fn a, ·ƒ_3:
                    ·fn
                      fn ·v_61, ·ƒ_75:
                        ·let ·v_61, fn ·v_4:
                          ·ƒ_3 ·v_4
                      fn ·ƒ_74:
                        ·fn_closure ·v_58, a, fn ·v_74:
                          ·ƒ_74 ·v_74
                  fn ·v_1:
                    ·let ·v_1, fn foo:
                      ·ƒ_0 foo


test 'multiple captures — all captured vars become leading params', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_40:
        ·fn
          fn ·v_32, ·ƒ_48:
            ·let ·v_32, fn ·v_7:
              ·ƒ_6 ·v_7
          fn ·ƒ_47:
            ·fn_closure ·v_29, a, b, fn ·v_47:
              ·ƒ_47 ·v_47
      fn ·v_39:
        ·fn
          fn a, b, c, ·ƒ_30:
            ·op_plus a, b, fn ·v_9:
              ·ƒ_9 ·v_9
          fn ·v_29:
            ·fn
              fn a, ·ƒ_3:
                ·fn
                  fn ·v_42, ·ƒ_52:
                    ·let ·v_42, fn ·v_4:
                      ·ƒ_3 ·v_4
                  fn ·ƒ_51:
                    ·fn_closure ·v_39, a, fn ·v_51:
                      ·ƒ_51 ·v_51
              fn ·v_1:
                ·let ·v_1, fn foo:
                  ·ƒ_0 foo


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect closure_lift fink":
    f = fn x: x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_39:
        ·op_plus a, b, fn ·v_16:
          ·ƒ_16 ·v_16
      fn ·v_38:
        ·fn
          fn ·ƒ_2:
            ·fn
              fn x, ·ƒ_5:
                ·let x, fn ·v_7:
                  ·ƒ_5 ·v_7
              fn ·v_3:
                ·let ·v_3, fn f:
                  ·fn
                    fn a, ·ƒ_13:
                      ·fn
                        fn ·v_41, ·ƒ_47:
                          ·let ·v_41, fn ·v_14:
                            ·ƒ_13 ·v_14
                        fn ·ƒ_46:
                          ·fn_closure ·v_38, a, fn ·v_46:
                            ·ƒ_46 ·v_46
                    fn ·v_11:
                      ·let ·v_11, fn g:
                        ·ƒ_2 g
          fn ·v_1: ·ƒ_0 ·v_1

# NOTE: depth-1 closure (g captures a) — lift_all terminates in 1 pass since
# the ·fn_closure call site's args (a) resolve as local after lifting.
