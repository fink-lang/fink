---
closure lifting tests
---

# Closure lifting — rewrites closure LetFn nodes so captured values are
# threaded as explicit leading params. After this pass no fn closes over
# anything — all values are passed explicitly.
#
# Rewrite per closure LetFn (non-empty captures):
#   Before:  fn {cap: [x]}, b: <body>
#   After:   fn x, b: <body>    — x promoted to leading param; fn hoisted to top
#
# Call sites use ·fn_closure to partially apply the hoisted fn with its captures.
#
# Test format:
#   test 'name', fn:
#     expect closure_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>


---
pure functions — unchanged
---

test 'pure fn is unchanged', fn:
  expect closure_lift fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·let x, fn ·v_5:
          ·ƒ_3 ·v_5
      fn ·v_1:
        ·let ·v_1, fn f:
          ·ƒ_0 f


test 'pure nested fn — inner fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·fn
      fn a, ·ƒ_3:
        ·fn
          fn b, ·ƒ_6:
            ·let b, fn ·v_8:
              ·ƒ_6 ·v_8
          fn ·v_4: ·ƒ_3 ·v_4
      fn ·v_1:
        ·let ·v_1, fn foo:
          ·ƒ_0 foo


---
closure lifting
---

test 'captured binding becomes leading param', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_24:
        ·apply ·op_plus, a, b, fn ·v_6:
          ·ƒ_6 ·v_6
      fn ·v_23:
        ·fn
          fn a, ·ƒ_3:
            ·apply ·fn_closure, ·v_23, a, fn ·v_26:
              ·let ·v_26, fn ·v_4:
                ·ƒ_3 ·v_4
          fn ·v_1:
            ·let ·v_1, fn foo:
              ·ƒ_0 foo


test 'depth-2 — innermost closure hoisted, intermediate fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·fn
      fn a, b, ·ƒ_46:
        ·apply ·fn_closure, ·v_35, a, b, fn ·v_38:
          ·let ·v_38, fn ·v_7:
            ·ƒ_6 ·v_7
      fn ·v_45:
        ·fn
          fn a, b, c, ·ƒ_36:
            ·apply ·op_plus, a, b, fn ·v_12:
              ·apply ·op_plus, ·v_12, c, fn ·v_9:
                ·ƒ_9 ·v_9
          fn ·v_35:
            ·fn
              fn a, ·ƒ_3:
                ·apply ·fn_closure, ·v_45, a, fn ·v_48:
                  ·let ·v_48, fn ·v_4:
                    ·ƒ_3 ·v_4
              fn ·v_1:
                ·let ·v_1, fn foo:
                  ·ƒ_0 foo


test 'multiple captures — all captured vars become leading params', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_41:
        ·apply ·fn_closure, ·v_30, a, b, fn ·v_33:
          ·let ·v_33, fn ·v_7:
            ·ƒ_6 ·v_7
      fn ·v_40:
        ·fn
          fn a, b, c, ·ƒ_31:
            ·apply ·op_plus, a, b, fn ·v_9:
              ·ƒ_9 ·v_9
          fn ·v_30:
            ·fn
              fn a, ·ƒ_3:
                ·apply ·fn_closure, ·v_40, a, fn ·v_43:
                  ·let ·v_43, fn ·v_4:
                    ·ƒ_3 ·v_4
              fn ·v_1:
                ·let ·v_1, fn foo:
                  ·ƒ_0 foo


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect closure_lift fink":
    f = fn x: x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_41:
        ·apply ·op_plus, a, b, fn ·v_16:
          ·ƒ_16 ·v_16
      fn ·v_40:
        ·fn
          fn ·ƒ_2:
            ·fn
              fn x, ·ƒ_5:
                ·let x, fn ·v_7:
                  ·ƒ_5 ·v_7
              fn ·v_3:
                ·let ·v_3, fn f:
                  ·fn
                    fn a, ·ƒ_13:
                      ·apply ·fn_closure, ·v_40, a, fn ·v_43:
                        ·let ·v_43, fn ·v_14:
                          ·ƒ_13 ·v_14
                    fn ·v_11:
                      ·let ·v_11, fn g:
                        ·ƒ_2 g
          fn ·v_1: ·ƒ_0 ·v_1

# NOTE: depth-1 closure (g captures a) — lift_all terminates in 1 pass since
# the ·fn_closure call site's args (a) resolve as local after lifting.
