---
closure lifting tests
---

# Closure lifting — rewrites closure LetFn nodes so captured values are
# threaded as explicit leading params. After this pass no fn closes over
# anything — all values are passed explicitly.
#
# Rewrite per closure LetFn (non-empty captures):
#   Before:  fn {cap: [x]}, b: <body>
#   After:   fn x, b: <body>    — x promoted to leading param; fn hoisted to top
#
# Call sites use ·fn_closure to partially apply the hoisted fn with its captures.
#
# Test format:
#   test 'name', fn:
#     expect closure_lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected rewritten cps>

{test, equals, expect, fink, closure_lift} = import 'fake!'

---
pure functions — unchanged
---

test 'pure fn is unchanged', fn:
  expect closure_lift fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn x, ·ƒ_3:
        ·let x, fn ·v_5:
          ·ƒ_3 ·v_5
      fn ·v_1:
        ·let ·v_1, fn f:
          ·ƒ_0 f


test 'pure nested fn — inner fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·fn
      fn a, ·ƒ_3:
        ·fn
          fn b, ·ƒ_6:
            ·let b, fn ·v_8:
              ·ƒ_6 ·v_8
          fn ·v_4: ·ƒ_3 ·v_4
      fn ·v_1:
        ·let ·v_1, fn foo:
          ·ƒ_0 foo


---
closure lifting
---

test 'captured binding becomes leading param', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_23: ·op_plus a, b, ·ƒ_6
      fn ·v_22:
        ·fn
          fn a, ·ƒ_3:
            ·fn_closure ·v_22, a, fn ·v_4:
              ·ƒ_3 ·v_4
          fn ·v_1:
            ·let ·v_1, fn foo:
              ·ƒ_0 foo


test 'depth-2 — innermost closure hoisted, intermediate fn stays nested', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·fn
      fn ·v_55, a, b, ·ƒ_60:
        ·fn_closure ·v_44, a, b, fn ·v_7:
          ·ƒ_6 ·v_7
      fn ·v_59:
        ·fn
          fn ·v_66, a, b, c, ·ƒ_69:
            ·fn_closure ·v_36, c, fn ·ƒ_30, ·v_33:
              ·op_plus a, b, ·ƒ_30
          fn ·v_68:
            ·fn
              fn c, ·v_12, ·ƒ_37: ·op_plus ·v_12, c, ·ƒ_9
              fn ·v_36:
                ·fn_closure ·v_68, ·v_36, fn ·v_44, ·v_52:
                  ·fn
                    fn a, ·ƒ_3:
                      ·fn_closure ·v_59, ·v_44, a, fn ·v_4:
                        ·ƒ_3 ·v_4
                    fn ·v_1:
                      ·let ·v_1, fn foo:
                        ·ƒ_0 foo


test 'multiple captures — all captured vars become leading params', fn:
  expect closure_lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·fn
      fn ·v_38, a, b, ·ƒ_43:
        ·fn_closure ·v_29, a, b, fn ·v_7:
          ·ƒ_6 ·v_7
      fn ·v_42:
        ·fn
          fn a, b, c, ·ƒ_30: ·op_plus a, b, ·ƒ_9
          fn ·v_29:
            ·fn
              fn a, ·ƒ_3:
                ·fn_closure ·v_42, ·v_29, a, fn ·v_4:
                  ·ƒ_3 ·v_4
              fn ·v_1:
                ·let ·v_1, fn foo:
                  ·ƒ_0 foo


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect closure_lift fink":
    f = fn x: x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn a, b, ·ƒ_39: ·op_plus a, b, ·ƒ_16
      fn ·v_38:
        ·fn
          fn ·ƒ_2:
            ·fn
              fn x, ·ƒ_5:
                ·let x, fn ·v_7:
                  ·ƒ_5 ·v_7
              fn ·v_3:
                ·let ·v_3, fn f:
                  ·fn
                    fn a, ·ƒ_13:
                      ·fn_closure ·v_38, a, fn ·v_14:
                        ·ƒ_13 ·v_14
                    fn ·v_11:
                      ·let ·v_11, fn g:
                        ·ƒ_2 g
          fn ·v_1: ·ƒ_0 ·v_1

# NOTE: depth-1 closure (g captures a) — lift_all terminates in 1 pass since
# the ·fn_closure call site's args (a) resolve as local after lifting.


---
match — forward ref bug
---

# BUG: after lift_all, the match_block fn references ·ƒ_3 (foo's cont param)
# as a forward reference — ·ƒ_3 is defined later in the tree, not as a param
# of the match_block fn. Closure lifting should have captured it.
#
# The first hoisted fn should have ·ƒ_3 threaded as a leading cap param.
# Current (buggy) output has: fn n, ·v_18, ·ƒ_46: ·match_block n, ·v_18, ·ƒ_3
# where ·ƒ_3 is NOT a param — it's a dangling forward ref.

test 'match — no forward refs after lift', fn:
  expect closure_lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·fn
      fn n, ·v_18, ·ƒ_46: ·match_block n, ·v_18, ·ƒ_3
      fn ·v_45:
        ·fn
          fn n, ·ƒ_3:
            ·fn_closure ·v_45, n, fn ·ƒ_31, ·v_42:
              ·fn
                fn ·ƒ_11, ·ƒ_35:
                  ·let 42, fn ·v_13:
                    ·ƒ_11 ·v_13
                fn ·ƒ_34:
                  ·fn
                    fn ·v_8, ·ƒ_6, ·ƒ_7, ·ƒ_38:
                      ·match_value ·v_8, 0, ·ƒ_6, fn: ·ƒ_7 _
                    fn ·ƒ_37: ·match_arm ·ƒ_37, ·ƒ_34, ·ƒ_31
          fn ·v_1:
            ·let ·v_1, fn foo:
              ·ƒ_0 foo
