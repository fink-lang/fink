---
match lowering — rewrites Match* builtins into primitive CPS (If/LetFn/App)
---

# Input is a Fink module; output is the CPS after match lowering.
# At this stage the IR is nested (pre-lifting), no closures.
#
# Match* builtins should be gone from the output — replaced by
# If nodes, comparisons, and regular function calls.
#
# Test format:
#   test 'name', fn:
#     expect match_lower fink":
#       <fink source>
#
#     | equals fink":
#       <expected CPS after match lowering>


{test, expect, equals, fink, match_lower} = import '!fake'


# ---
# guarded bind
# ---

# test 'guard bind', fn:
#   expect match_lower fink":
#     a > 1 = 5
#     a

#   | equals fink":
#     TODO


---
literal matching — single arm
---

test 'match literal single arm', fn:
  expect match_lower fink":
    match 1:
      1: 42

  | equals fink":
    ·fn
      fn ·v_24:
        ·v_24 42
      fn ·v_43:
        ·fn
          fn ·v_6, ·v_4, ·v_5:
            ·fn
              fn ·v_8, ·v_9, ·v_10:
                ·op_eq ·v_8, 1, fn ·v_13:
                  ·if ·v_13,
                    fn:
                      ·v_9 _
                    fn:
                      ·v_10 _
              fn ·v_21:
                ·v_21 ·v_6, ·v_5, ·v_4
          fn ·v_44:
            ·v_44 1,
              fn:
                ·panic _
              fn:
                ·v_43 fn ·v_36:
                  ·export _


test 'match literal first of two arms', fn:
  expect match_lower fink":
    match 1:
      0: 42
      _: 99

  | equals fink":
    ·fn
      fn ·v_24:
        ·v_24 42
      fn ·v_65:
        ·fn
          fn ·v_6, ·v_4, ·v_5:
            ·fn
              fn ·v_8, ·v_9, ·v_10:
                ·op_eq ·v_8, 0, fn ·v_13:
                  ·if ·v_13,
                    fn:
                      ·v_9 _
                    fn:
                      ·v_10 _
              fn ·v_21:
                ·v_21 ·v_6, ·v_5, ·v_4
          fn ·v_66:
            ·v_66 1,
              fn:
                ·fn
                  fn ·v_40:
                    ·v_40 99
                  fn ·v_57:
                    ·fn
                      fn ·v_38, ·v_36, ·v_37:
                        ·v_37 _
                      fn ·v_58:
                        ·v_58 1,
                          fn:
                            ·panic _
                          fn:
                            ·v_57 fn ·v_48:
                              ·export _
              fn:
                ·v_65 fn ·v_48:
                  ·export _



test 'match variable binding', fn:
  expect match_lower fink":
    match 5:
      x: x + 1

  | equals fink":
    ·fn
      fn ·x_0, ·v_9:
        ·op_plus ·x_0, 1, ·v_9
      fn ·v_26:
        ·fn
          fn ·v_7, ·v_5, ·v_6:
            ·v_6 ·v_7
          fn ·v_27:
            ·v_27 5,
              fn:
                ·panic _
              fn ·v_30:
                ·v_26 ·v_30, fn ·v_19:
                  ·export _



test 'match literal then variable', fn:
  expect match_lower fink":
    match 1:
      0: 42
      x: x + 1

  | equals fink":
    ·fn
      fn ·v_25:
        ·v_25 42
      fn ·v_70:
        ·fn
          fn ·v_7, ·v_5, ·v_6:
            ·fn
              fn ·v_9, ·v_10, ·v_11:
                ·op_eq ·v_9, 0, fn ·v_14:
                  ·if ·v_14,
                    fn:
                      ·v_10 _
                    fn:
                      ·v_11 _
              fn ·v_22:
                ·v_22 ·v_7, ·v_6, ·v_5
          fn ·v_71:
            ·v_71 1,
              fn:
                ·fn
                  fn ·x_0, ·v_41:
                    ·op_plus ·x_0, 1, ·v_41
                  fn ·v_60:
                    ·fn
                      fn ·v_39, ·v_37, ·v_38:
                        ·v_38 ·v_39
                      fn ·v_61:
                        ·v_61 1,
                          fn:
                            ·panic _
                          fn ·v_64:
                            ·v_60 ·v_64, fn ·v_51:
                              ·export _
              fn:
                ·v_70 fn ·v_51:
                  ·export _



# Design sketch — target output for match with guard:
#
#   mb_2 = fn x, cont: cont x + 1
#   mp_2 = fn subj, succ, fail:
#     if subj > 0 or subj < 0,
#       fn: mb_2 subj, succ
#       fn: fail _
#
#   mb_1 = fn cont: cont 42
#   mp_1 = fn subj, succ, fail:
#     if subj > 0,
#       fn: mb_1 succ
#       fn: fail _
#
#   m_0 = fn subj, cont:
#     mp_1 subj, cont,
#       fn: mp_2 subj, cont,
#         fn: panic _
#
#   m_0 1, outer_cont

test 'match with guard', fn:
  expect match_lower fink":
    match 1:
      x > 0: 42
      x > 0 or x < 0: x + 1

  | equals fink":
    ·fn
      fn ·v_24:
        ·v_24 42
      fn ·v_89:
        ·fn
          fn ·v_8, ·v_6, ·v_7:
            ·fn
              fn ·v_10, ·v_11, ·v_12:
                ·op_gt ·v_10, 0, fn ·v_15:
                  ·if ·v_15,
                    fn:
                      ·v_11 ·v_10
                    fn:
                      ·v_12 _
              fn ·v_23:
                ·v_23 ·v_8, ·v_7, ·v_6
          fn ·v_90:
            ·v_90 1,
              fn:
                ·fn
                  fn ·v_58:
                    ·op_plus ·x_1, 1, ·v_58
                  fn ·v_81:
                    ·fn
                      fn ·v_38, ·v_36, ·v_37:
                        ·fn
                          fn ·v_40, ·v_41, ·v_42:
                            ·op_lt ·x_1, 0, fn ·v_45:
                              ·op_or ·v_40, ·v_45, fn ·v_48:
                                ·if ·v_48,
                                  fn:
                                    ·v_41 ·v_40
                                  fn:
                                    ·v_42 _
                          fn ·v_57:
                            ·v_57 ·v_38, ·v_37, ·v_36
                      fn ·v_82:
                        ·v_82 1,
                          fn:
                            ·panic _
                          fn:
                            ·v_81 fn ·v_72:
                              ·export _
              fn:
                ·v_89 fn ·v_72:
                  ·export _






test 'record destructure with guard', fn:
  expect match_lower fink":
    x = 1
    y = 3
    match foo:
      {x, y: z}: x + y + z
      {z > 1 or z < 1}: x + y + z

  | equals fink":
    ·let 1, fn ·x_0:
      ·let 3, fn ·y_1:
        ·fn
          fn ·x_2, ·z_3, ·v_27:
            ·op_plus ·x_2, ·y_1, fn ·v_30:
              ·op_plus ·v_30, ·z_3, ·v_27
          fn ·v_96:
            ·fn
              fn ·v_15, ·v_13, ·v_14:
                ·match_rec ·v_15, ·v_13, fn ·v_17:
                  ·match_field ·v_17, 'x', ·v_13, fn ·v_18, ·v_19:
                    ·let ·v_18, fn ·x_2:
                      ·match_field ·v_19, 'y', ·v_13, fn ·v_22, ·v_23:
                        ·let ·v_22, fn ·z_3:
                          ·v_14 ·z_3
              fn ·v_97:
                ·v_97 ·∅foo,
                  fn:
                    ·fn
                      fn ·v_60:
                        ·op_plus ·x_0, ·y_1, fn ·v_63:
                          ·op_plus ·v_63, ·z_4, ·v_60
                      fn ·v_88:
                        ·fn
                          fn ·v_56, ·v_54, ·v_55:
                            ·match_rec ·v_56, ·v_54, ·v_55
                          fn ·v_89:
                            ·v_89 ·∅foo,
                              fn:
                                ·panic _
                              fn:
                                ·v_88 fn ·v_75:
                                  ·export ·x_0, ·y_1
                  fn ·v_100, ·v_101:
                    ·v_96 ·v_100, ·v_101, fn ·v_75:
                      ·export ·x_0, ·y_1

