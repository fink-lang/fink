---
closure capture tests
---

# Closure capture — annotates CPS IR with explicit capture lists.
#
# Consumes name resolution output (Resolution::Captured) and produces a
# capture graph: one entry per LetFn mapping it to the names it closes over.
#
# Output: standard CPS IR, with closure LetFn nodes annotated:
#   ·fn
#     fn {cap: [x, y]}, param: body   — closure, captures x and y
#     fn cont: ...
#
# Pure LetFn nodes (no captures) render unchanged:
#   ·fn
#     fn param: body
#     fn cont: ...
#
# Self-recursive refs resolve as Recursive (not Captured) — no capture entry.
# Mutual recursion: each fn captures the other's binding.
#
# Test format:
#   test 'name', fn:
#     expect closure_capture fink":
#       <fink source>
#
#     | equals fink":
#       <expected cps with capture annotations>

{test, equals, expect, fink, closure_capture} = import 'fake!'

---
pure functions
---

test 'fn with no captures', fn:
  expect closure_capture fink":
    f = fn x: x

  | equals fink":
    ·fn
      fn ·x_1, ·ƒ_4:
        ·ƒ_4 ·x_1
      fn ·v_3:
        ·let ·v_3, fn ·f_0:
          ·ƒ_2 ·f_0


---
recursion
---

test 'self-recursive fn is pure', fn:
  expect closure_capture fink":
    f = fn a:
      f a

  | equals fink":
    ·fn
      fn {cap: [·f_0]}, ·a_1, ·ƒ_4:
        ·f_0 ·a_1, ·ƒ_4
      fn ·v_3:
        ·let ·v_3, fn ·f_0:
          ·ƒ_2 ·f_0

test 'mutual recursion — each fn captures the other', fn:
  expect closure_capture fink":
    f = fn a:
      g a
    g = fn b:
      f b

  | equals fink":
    ·fn
      fn ·ƒ_6:
        ·fn
          fn {cap: [·g_1]}, ·a_2, ·ƒ_8:
            ·g_1 ·a_2, ·ƒ_8
          fn ·v_7:
            ·let ·v_7, fn ·f_0:
              ·fn
                fn {cap: [·f_0]}, ·b_3, ·ƒ_16:
                  ·f_0 ·b_3, ·ƒ_16
                fn ·v_15:
                  ·let ·v_15, fn ·g_1:
                    ·ƒ_6 ·g_1
      fn ·v_5:
        ·ƒ_4 ·v_5


---
depth-2 captures
---

test 'depth-2 capture — fn b directly uses x, fn a does not', fn:
  expect closure_capture fink":
    x = 1
    fn a:
      fn b:
        x

  | equals fink":
    ·fn
      fn ·ƒ_5:
        ·let 1, fn ·x_0:
          ·fn
            fn ·a_1, ·ƒ_8:
              ·fn
                fn {cap: [·x_0]}, ·b_2, ·ƒ_10:
                  ·ƒ_10 ·x_0
                fn ·v_9:
                  ·ƒ_8 ·v_9
            fn ·v_7:
              ·ƒ_5 ·v_7
      fn ·v_4:
        ·ƒ_3 ·v_4

test 'multiple captures', fn:
  expect closure_capture fink":
    x = 1
    y = 2
    fn a:
      x + y

  | equals fink":
    ·fn
      fn ·ƒ_5:
        ·let 1, fn ·x_0:
          ·let 2, fn ·y_1:
            ·fn
              fn {cap: [·x_0, ·y_1]}, ·a_2, ·ƒ_9:
                ·op_plus ·x_0, ·y_1, ·ƒ_9
              fn ·v_8:
                ·ƒ_5 ·v_8
      fn ·v_4:
        ·ƒ_3 ·v_4


---
simple captures
---

test 'fn captures one outer binding', fn:
  expect closure_capture fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·fn
      fn ·a_1, ·ƒ_5:
        ·fn
          fn {cap: [·a_1]}, ·b_2, ·ƒ_7:
            ·op_plus ·a_1, ·b_2, ·ƒ_7
          fn ·v_6:
            ·ƒ_5 ·v_6
      fn ·v_4:
        ·let ·v_4, fn ·foo_0:
          ·ƒ_3 ·foo_0
