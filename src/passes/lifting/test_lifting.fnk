  expect lift ƒink:
    {foo} = import './bar.fnk'

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_49 = fn {·ƒret_50}, [·v_10]:
        ·foo_0 = ·v_10
        ·ƒret_50 ·foo_0
      ·v_66 = fn {·ƒfail_67}:
        ·ƒfail_67 _
      ·v_97 = fn {·ƒsucc_98}, [·v_10, ·v_14]:
        ·ƒsucc_98 ·v_10
      ·v_80 = fn {·ƒfail_81, ·ƒsucc_83}, [·v_15]:
        ·v_102 = ·closure ·v_97, ·ƒsucc_83
        ·rec_pop ·v_15, 'foo', ·ƒfail_81, ·v_102
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_71 = ·closure ·v_66, ·ƒfail_9
        ·v_87 = ·closure ·v_80, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_87, ·v_71
      ·v_40 = fn {·ƒret_41}, [·v_5]:
        ·v_52 = ·closure ·v_49, ·ƒret_41
        ·v_24 ·v_52, ·panic, ·v_5
      ·ƒret_56 = fn [·v_45]:
        ·import './bar.fnk', ·v_45
      ·closure ·v_40, ·ƒret_2, ·ƒret_56


---
Regression test for the fooobar lifting bug — module with multiple
top-level fns where the results of calls are bound to names. Previously
downstream wasm emit panicked with `unknown local: add_0` because capture
analysis didn't track LetVal names that aliased hoisted fn references
(`add_0 = v_14` where v_14 is the hoisted add-fn). Nested inline conts
referencing `add_0` couldn't see it in scope_binds and therefore didn't
capture it. Fixed by always adding LetVal names to scope_binds during
extraction, regardless of whether the val aliases a hoisted fn.
---

test 'multiple top-level fns with bound call results', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3

  | equals ƒink:
    ·ƒink_module fn ·ƒret_8:
      ·v_9 = fn [·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_76 = fn {·ƒret_77}, [·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3
        ·ƒret_77 ·p_3
      ·v_63 = fn {·ƒret_64}, [·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1
        ·mul_2 = ·v_22
        ·ƒpub ·mul_2
        ·v_81 = ·closure ·v_76, ·ƒret_64
        ·mul_2 ·v_81, ·s_1, 3
      ·add_0 = ·v_9
      ·ƒpub ·add_0
      ·ƒret_73 = fn [·v_68]:
        ·add_0 ·v_68, 1, 2
      ·closure ·v_63, ·ƒret_8, ·ƒret_73



test 'spawn with closure over channel', fn:
  expect lift ƒink:
    ch = channel 0
    fut = spawn fn:
      receive ch
    77 >> ch
    result = await fut
    result

  | equals ƒink:
    ·ƒink_module fn ·ƒret_7:
      ·v_68 = fn {·ch_69}, [·ƒret_14]:
        ·receive ·ch_69, ·ƒret_14
      ·v_114 = fn {·ƒret_115}, [·v_30]:
        ·result_2 = ·v_30
        ·ƒpub ·result_2
        ·ƒret_115 ·result_2
      ·v_95 = fn {·fut_96, ·ƒret_98}, [·v_25]:
        ·v_27 = ·v_25
        ·v_119 = ·closure ·v_114, ·ƒret_98
        ·await ·fut_96, ·v_119
      ·v_129 = fn {·ch_130}, [·v_102]:
        ·op_shr 77, ·ch_130, ·v_102
      ·v_80 = fn {·ch_81, ·ƒret_83}, [·v_21]:
        ·fut_1 = ·v_21
        ·ƒpub ·fut_1
        ·v_132 = ·closure ·v_129, ·ch_81
        ·closure ·v_95, ·fut_1, ·ƒret_83, ·v_132
      ·v_59 = fn {·ƒret_60}, [·v_10]:
        ·ch_0 = ·v_10
        ·ƒpub ·ch_0
        ·v_71 = ·closure ·v_68, ·ch_0
        ·v_87 = ·closure ·v_80, ·ch_0, ·ƒret_60
        ·spawn ·v_71, ·v_87
      ·ƒret_75 = fn [·v_64]:
        ·channel 0, ·v_64
      ·closure ·v_59, ·ƒret_7, ·ƒret_75
