---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_25, ·ƒret_3:
      ·v_28 = fn {·a_29}, [·ƒret_7, ·b_2]:
        ·op_plus ·a_29, ·b_2, ·ƒret_7
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·closure ·v_28, ·a_1, ·ƒret_5
      ·ƒpub ·foo_0
      ·ƒret_3 ·foo_0
    # sm:PwABAB0AAQAdJAAYABIAAgAGARwPAAEADw4ABAEADwYAAAACAQkBDAAAAAYAAAACABIABAEQAQoAAAACAAIACgEOBQABAAUUAQABDAAEAQgBCgAEABIABgErFwAAAAELAxAABAEMFwwABAEAFwYAAAACABIABAEGAQoAAAACAAIACgEKDwABAA8UAQAPDAAEAQkBCgAEABIABgERAwABAAMQAQADDgAGAQADAAEAAxQBAAM


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_5:
      ·v_6 = fn [·ƒret_7, ·x_2]:
        ·ƒret_7 ·x_2
      ·v_43 = fn {·a_44}, [·ƒret_15, ·b_4]:
        ·op_plus ·a_44, ·b_4, ·ƒret_15
      ·v_12 = fn [·ƒret_13, ·a_3]:
        ·closure ·v_43, ·a_3, ·ƒret_13
      ·f_0 = ·v_6
      ·ƒpub ·f_0
      ·g_1 = ·v_12
      ·ƒpub ·g_1
      ·ƒret_5 ·g_1
    # sm:

---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_4:
      ·v_59 = fn {·c_60, ·ƒret_62}, [·v_13]:
        ·op_plus ·v_13, ·c_60, ·ƒret_62
      ·v_47 = fn {·a_48, ·b_50}, [·ƒret_10, ·c_3]:
        ·v_66 = ·closure ·v_59, ·c_3, ·ƒret_10
        ·op_plus ·a_48, ·b_50, ·v_66
      ·v_38 = fn {·a_39}, [·ƒret_8, ·b_2]:
        ·closure ·v_47, ·a_39, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_38, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·foo_0
    # sm:


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_4:
      ·v_42 = fn {·a_43, ·b_45}, [·ƒret_10, ·c_3]:
        ·op_plus ·a_43, ·b_45, ·ƒret_10
      ·v_33 = fn {·a_34}, [·ƒret_8, ·b_2]:
        ·closure ·v_42, ·a_34, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_33, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·foo_0
    # sm:


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    foo = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·add_0 = ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·ƒpub ·add_0
      ·foo_1 = ·v_13 = fn [·ƒret_14]:
        ·add_0 ·ƒret_14, (i8 3), (i8 4)
      ·ƒpub ·foo_1
      ·ƒret_4 ·foo_1
    # sm:RQABACwAAQAsJAAYABIAAgAGAQwQAAAAAQsDEAAEAQwQDAAEAQAQBgAAAAIAEgAEAQYBCgAEAQYBCgAAAAIAAgAKAQoFAAEABRQBAAEKAAQBCAEKAAQAEgAGASkDAAEAAxABAAMOAAYBPA4AAAABCwMQAAQBDA4OAAQBAA4GAAAAAgAUAAAAAgACAAoBDAgAAQADEAAUAAYBCAEAAQABBgEAAQQABgEGAQABAAEGAQABBAAGASUDAAEAAxABAAMOAAYBAAMAAQADFAEAAw

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_60, ·ƒret_6:
      ·v_7 = fn [·ƒret_8, ·x_3]:
        ·op_mul ·x_3, (i8 2), ·ƒret_8
      ·v_15 = fn [·ƒret_16, ·x_4]:
        ·op_plus ·x_4, (i8 1), ·ƒret_16
      ·v_73 = fn {·inc_74, ·ƒret_76}, [·v_27]:
        ·x_5 = ·v_27
        ·inc_74 ·ƒret_76, ·x_5
      ·v_62 = fn {·double_63, ·inc_65}, [·ƒret_24]:
        ·v_80 = ·closure ·v_73, ·inc_65, ·ƒret_24
        ·double_63 ·v_80, (i8 5)
      ·double_0 = ·v_7
      ·ƒpub ·double_0
      ·inc_1 = ·v_15
      ·ƒpub ·inc_1
      ·v_67 = ·closure ·v_62, ·double_0, ·inc_1
      ·foo_2 = ·v_67
      ·ƒpub ·foo_2
      ·ƒret_6 ·foo_2
    # sm:

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_3:
      ·v_61 = fn {·ƒret_62}, [·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, (i8 1), ·ƒret_62
      ·v_74 = fn {·ƒfail_75}:
        ·ƒfail_75 _
      ·v_120 = fn {·ƒsucc_121, ·v_123, ·ƒfail_125}, [·v_17]:
        ·if ·v_17,
          fn:
            ·ƒsucc_121 ·v_123
          fn:
            ·ƒfail_125 _
      ·v_103 = fn {·ƒsucc_104, ·ƒfail_106}, [·v_10, ·v_14]:
        ·v_129 = ·closure ·v_120, ·ƒsucc_104, ·v_10, ·ƒfail_106
        ·empty ·v_14, ·v_129
      ·v_87 = fn {·ƒfail_88, ·ƒsucc_90}, [·v_22]:
        ·v_110 = ·closure ·v_103, ·ƒsucc_90, ·ƒfail_88
        ·seq_pop ·v_22, ·ƒfail_88, ·v_110
      ·v_30 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_79 = ·closure ·v_74, ·ƒfail_9
        ·v_94 = ·closure ·v_87, ·ƒfail_9, ·ƒsucc_8
        ·is_seq_like ·v_7, ·v_94, ·v_79
      ·spam_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_64 = ·closure ·v_61, ·ƒret_5
        ·v_30 ·v_64, ·panic, ·foo_1
      ·ƒpub ·spam_0
      ·ƒret_3 ·spam_0
    # sm:-


test 'record destructure', fn:
  expect lift ƒink:
    ham = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_52, ·ƒret_3:
      ·v_55 = fn {·ƒret_56}, [·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, (i8 1), ·ƒret_56
      ·v_68 = fn {·ƒfail_69}:
        ·ƒfail_69 _
      ·v_97 = fn {·ƒsucc_98}, [·v_10, ·v_14]:
        ·ƒsucc_98 ·v_10
      ·v_81 = fn {·ƒfail_82, ·ƒsucc_84}, [·v_15]:
        ·v_102 = ·closure ·v_97, ·ƒsucc_84
        ·rec_pop ·v_15, 'x', ·ƒfail_82, ·v_102
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_73 = ·closure ·v_68, ·ƒfail_9
        ·v_88 = ·closure ·v_81, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_88, ·v_73
      ·ham_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_58 = ·closure ·v_55, ·ƒret_5
        ·v_24 ·v_58, ·panic, ·foo_1
      ·ƒpub ·ham_0
      ·ƒret_3 ·ham_0
    # sm:


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_70, ·ƒret_2:
      ·v_29 = fn [·ƒret_25]:
        ·ƒret_25 (i8 42)
      ·v_83 = fn {·ƒsucc_84}:
        ·v_29 ·ƒsucc_84
      ·v_104 = fn {·ƒsucc_105, ·ƒfail_107}, [·v_15]:
        ·if ·v_15,
          fn:
            ·ƒsucc_105 _
          fn:
            ·ƒfail_107 _
      ·v_23 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_111 = ·closure ·v_104, ·ƒsucc_11, ·ƒfail_12
        ·op_eq ·v_10, (i8 0), ·v_111
      ·v_41 = fn [·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_86 = ·closure ·v_83, ·ƒsucc_7
        ·v_23 ·v_86, ·ƒfail_8, ·v_6
      ·ƒret_80 = fn:
        ·panic _
      ·v_49 = fn [·ƒret_43, ·v_42]:
        ·v_41 ·ƒret_43, ·ƒret_80, ·v_42
      ·foo_0 = ·v_3 = fn [·ƒret_4, ·n_1]:
        ·v_49 ·ƒret_4, ·n_1
      ·ƒpub ·foo_0
      ·ƒret_2 ·foo_0
    # sm:


