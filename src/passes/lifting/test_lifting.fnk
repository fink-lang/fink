test 'match arm refs top-level binding', fn:
  expect lift ƒink:
    x = 5
    match x:
      0: 0
      _: x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·v_27 = fn [·ƒret_23]:
        ·ƒret_23 0
      ·v_106 = fn {·ƒsucc_107}:
        ·v_27 ·ƒsucc_107
      ·v_156 = fn {·ƒsucc_157, ·ƒfail_159}, [·v_13]:
        ·if ·v_13,
          fn:
            ·ƒsucc_157 _
          fn:
            ·ƒfail_159 _
      ·v_21 = fn [·ƒsucc_9, ·ƒfail_10, ·v_8]:
        ·v_163 = ·closure ·v_156, ·ƒsucc_9, ·ƒfail_10
        ·op_eq ·v_8, 0, ·v_163
      ·v_39 = fn [·ƒsucc_5, ·ƒfail_6, ·v_4]:
        ·v_109 = ·closure ·v_106, ·ƒsucc_5
        ·v_21 ·v_109, ·ƒfail_6, ·v_4
      ·v_87 = fn {·x_88}, [·ƒret_44]:
        ·op_plus ·x_88, 1, ·ƒret_44
      ·v_99 = fn {·v_100}, [·ƒsucc_41, ·ƒfail_42, ·v_40]:
        ·v_100 ·ƒsucc_41
      ·ƒret_177 = fn:
        ·panic _
      ·v_143 = fn {·v_144, ·ƒret_146, ·v_148}:
        ·v_144 ·ƒret_146, ·ƒret_177, ·v_148
      ·v_127 = fn {·v_128}, [·ƒret_57, ·v_56]:
        ·v_152 = ·closure ·v_143, ·v_128, ·ƒret_57, ·v_56
        ·v_39 ·ƒret_57, ·v_152, ·v_56
      ·v_113 = fn {·ƒret_114, ·x_116}, [·v_90]:
        ·v_102 = ·closure ·v_99, ·v_90
        ·v_130 = ·closure ·v_127, ·v_102
        ·v_130 ·ƒret_114, ·x_116
      ·x_0 = 5
      ·ƒpub ·x_0
      ·v_118 = ·closure ·v_113, ·ƒret_1, ·x_0
      ·closure ·v_87, ·x_0, ·v_118
    # sm:


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

