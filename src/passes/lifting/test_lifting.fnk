---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'fn call result bound at module level', fn:
  expect lift ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_4:
      ·v_5 = fn [·ƒctx_35, ·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·v_44 = fn {·ƒret_45}, [·ƒctx_40, ·v_16]:
        ·x_1 = ·v_16
        ·ƒpub ·x_1
        ·ƒret_45 ·ƒctx_42, ·x_1
      ·add_0 = ·v_5
      ·ƒpub ·add_0
      ·v_49 = ·closure ·v_44, ·ƒret_4
      ·add_0 ·ƒctx_38, ·v_49, (i8 1), (i8 2)
    # sm:


test 'chained ops at module level', fn:
  expect lift ƒink:
    2 * 3 + 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·v_14 = fn {·ƒret_15}, [·ƒctx_13, ·v_3]:
        ·op_plus ·v_3, (i8 4), ·ƒret_15
      ·v_19 = ·closure ·v_14, ·ƒret_0
      ·op_mul (i8 2), (i8 3), ·v_19
