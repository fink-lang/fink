# BROKEN: lift panics with "did not converge after 20 rounds" when a
# top-level pattern destructure's RHS lowers to sub-expressions. The
# pass structurally converges around round 4 but the `needs_lifting`
# predicate keeps reporting more work until the round cap trips.
#
# Ident RHS (e.g. `[a, b] = foo`) does NOT trigger this — the subject
# is a pre-existing value ref and no sub-lowering is needed.
#
# Expected outputs marked TODO — update each once the bug is fixed.

test 'top-level seq destructure with literal rhs — lift non-convergence', fn:
  expect lift ƒink:
    [a, b] = [1, 2]

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·seq_prepend 2, [], fn ·v_5:
        ·seq_prepend 1, ·v_5, fn ·v_8:
          ·v_48 = fn [·v_13, ·v_14]:
            ·a_0 = ·v_13
            ·b_1 = ·v_14
            ·v_2 ·b_1
          ·v_60 = fn {·ƒfail_61}:
            ·ƒfail_61 _
          ·v_104 = fn {·ƒsucc_105, ·v_107, ·v_109, ·ƒfail_111}, [·v_22]:
            if ·v_22,
              fn:
                ·ƒsucc_105 ·v_107, ·v_109
              fn:
                ·ƒfail_111 _
          ·v_91 = fn {·ƒsucc_92, ·v_94, ·ƒfail_96}, [·v_14, ·v_19]:
            ·v_115 = ·closure ·v_104, ·ƒsucc_92, ·v_94, ·v_14, ·ƒfail_96
            ·empty ·v_19, ·v_115
          ·v_80 = fn {·ƒfail_81, ·ƒsucc_83}, [·v_13, ·v_28]:
            ·v_100 = ·closure ·v_91, ·ƒsucc_83, ·v_13, ·ƒfail_81
            ·seq_pop ·v_28, ·ƒfail_81, ·v_100
          ·v_69 = fn {·ƒfail_70, ·ƒsucc_72}, [·v_27]:
            ·v_87 = ·closure ·v_80, ·ƒfail_70, ·ƒsucc_72
            ·seq_pop ·v_27, ·ƒfail_70, ·v_87
          ·v_39 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
            ·v_65 = ·closure ·v_60, ·ƒfail_12
            ·v_76 = ·closure ·v_69, ·ƒfail_12, ·ƒsucc_11
            ·is_seq_like ·v_10, ·v_76, ·v_65
          ·v_39 ·v_48, panic, ·v_8


