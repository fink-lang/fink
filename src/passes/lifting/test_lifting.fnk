---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·f_0 = ·v_5 = fn [·x_1], ·ret_6:
      ·v_6 ·x_1

    ·export ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·v_8 = fn [·b_2], ·ret_9:
      ·v_9 ·b_2

    ·foo_0 = ·v_6 = fn [·a_1], ·ret_7:
      ·v_7 ·v_8

    ·export ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·v_25 = fn {·v_26}, [·v_9]:
      ·x_1 = ·v_9
      ·op_plus ·x_1, 4, ·v_26

    ·main_0 = ·v_5 = fn ·ret_6:
      ·v_30 = ·closure ·v_25, ·v_6
      ·op_mul 2, 3, ·v_30

    ·export ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·v_22 = fn {·a_23}, [·b_2], ·ret_9:
      ·op_plus ·a_23, ·b_2, ·v_9

    ·foo_0 = ·v_6 = fn [·a_1], ·ret_7:
      ·closure ·v_22, ·a_1, ·v_7

    ·export ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·f_0 = ·v_9 = fn [·x_2], ·ret_10:
      ·v_10 ·x_2

    ·v_35 = fn {·a_36}, [·b_4], ·ret_18:
      ·op_plus ·a_36, ·b_4, ·v_18

    ·g_1 = ·v_15 = fn [·a_3], ·ret_16:
      ·closure ·v_35, ·a_3, ·v_16

    ·export ·f_0, ·g_1


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·v_48 = fn {·c_49, ·v_51}, [·v_15]:
      ·op_plus ·v_15, ·c_49, ·v_51

    ·v_39 = fn {·a_40, ·b_42}, [·c_3], ·ret_12:
      ·v_55 = ·closure ·v_48, ·c_3, ·v_12
      ·op_plus ·a_40, ·b_42, ·v_55

    ·v_32 = fn {·a_33}, [·b_2], ·ret_10:
      ·closure ·v_39, ·a_33, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn [·a_1], ·ret_8:
      ·closure ·v_32, ·a_1, ·v_8

    ·export ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·v_34 = fn {·a_35, ·b_37}, [·c_3], ·ret_12:
      ·op_plus ·a_35, ·b_37, ·v_12

    ·v_27 = fn {·a_28}, [·b_2], ·ret_10:
      ·closure ·v_34, ·a_28, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn [·a_1], ·ret_8:
      ·closure ·v_27, ·a_1, ·v_8

    ·export ·foo_0


test 'yield — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      q = yield 42
      1 + q

  | equals ƒink:
    ·v_24 = fn {·v_25}, [·v_8]:
      ·q_1 = ·v_8
      ·op_plus 1, ·q_1, ·v_25

    ·main_0 = ·v_5 = fn ·ret_6:
      ·v_29 = ·closure ·v_24, ·v_6
      ·yield 42, ·v_29

    ·export ·main_0


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·add_0 = ·v_8 = fn [·a_2, ·b_3], ·ret_9:
      ·op_plus ·a_2, ·b_3, ·v_9

    ·main_1 = ·v_16 = fn ·ret_17:
      ·add_0 3, 4, ·v_17

    ·export ·add_0, ·main_1

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·double_0 = ·v_11 = fn [·x_3], ·ret_12:
      ·op_mul ·x_3, 2, ·v_12

    ·inc_1 = ·v_19 = fn [·x_4], ·ret_20:
      ·op_plus ·x_4, 1, ·v_20

    ·v_55 = fn {·v_56}, [·v_31]:
      ·x_5 = ·v_31
      ·inc_1 ·x_5, ·v_56

    ·main_2 = ·v_27 = fn ·ret_28:
      ·v_60 = ·closure ·v_55, ·v_28
      ·double_0 5, ·v_60

    ·export ·double_0, ·inc_1, ·main_2

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·v_50 = fn {·v_51}, [·v_12]:
      ·a_2 = ·v_12
      ·op_plus ·a_2, 1, ·v_51

    ·v_69 = fn {·v_70, ·v_72, ·v_74}, [·v_19]:
      if ·v_19,
        fn:
          ·v_70 ·v_72
        fn:
          ·v_74 _

    ·v_58 = fn {·v_59, ·v_61}, [·v_12, ·v_16]:
      ·v_78 = ·closure ·v_69, ·v_59, ·v_12, ·v_61
      ·empty ·v_16, ·v_78

    ·v_27 = fn [·v_9, ·succ_10], ·fail_11:
      ·v_65 = ·closure ·v_58, ·v_10, ·v_11
      ·seq_pop ·v_9, ·v_11, ·v_65

    ·main_0 = ·v_6 = fn [·foo_1], ·ret_7:
      ·v_53 = ·closure ·v_50, ·v_7
      ·v_27 ·foo_1, ·v_53, panic

    ·export ·main_0


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·v_44 = fn {·v_45}, [·v_12]:
      ·x_2 = ·v_12
      ·op_plus ·x_2, 1, ·v_45

    ·v_52 = fn {·v_53}, [·v_12, ·v_16]:
      ·v_53 ·v_12

    ·v_21 = fn [·v_9, ·succ_10], ·fail_11:
      ·v_57 = ·closure ·v_52, ·v_10
      ·rec_pop ·v_9, 'x', ·v_11, ·v_57

    ·main_0 = ·v_6 = fn [·foo_1], ·ret_7:
      ·v_47 = ·closure ·v_44, ·v_7
      ·v_21 ·foo_1, ·v_47, panic

    ·export ·main_0


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·v_31 = fn ·ret_27:
      ·v_27 42

    ·v_74 = fn {·v_75}:
      ·v_31 ·v_75

    ·v_82 = fn {·v_83, ·v_85}, [·v_17]:
      if ·v_17,
        fn:
          ·v_83 _
        fn:
          ·v_85 _

    ·v_25 = fn [·v_12, ·succ_13], ·fail_14:
      ·v_89 = ·closure ·v_82, ·v_13, ·v_14
      ·op_eq ·v_12, 0, ·v_89

    ·v_43 = fn [·v_8, ·succ_9], ·fail_10:
      ·v_77 = ·closure ·v_74, ·v_9
      ·v_25 ·v_8, ·v_77, ·v_10

    ·ret_71 = fn:
      panic _

    ·v_52 = fn [·v_44], ·ret_45:
      ·v_43 ·v_44, ·v_45, ·v_71

    ·foo_0 = ·v_5 = fn [·n_1], ·ret_6:
      ·v_52 ·n_1, ·v_6

    ·export ·foo_0


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·v_76 = fn {·n_77}, ·ret_28:
      ·op_plus ·n_77, 1, ·v_28

    ·v_97 = fn {·v_98, ·v_100}:
      ·v_98 ·v_100

    ·v_119 = fn {·v_120, ·v_122}, [·v_18]:
      if ·v_18,
        fn:
          ·v_120 _
        fn:
          ·v_122 _

    ·v_26 = fn [·v_13, ·succ_14], ·fail_15:
      ·v_126 = ·closure ·v_119, ·v_14, ·v_15
      ·op_eq ·v_13, 0, ·v_126

    ·v_83 = fn {·v_84}, [·v_9, ·succ_10], ·fail_11:
      ·v_102 = ·closure ·v_97, ·v_84, ·v_10
      ·v_26 ·v_9, ·v_102, ·v_11

    ·ret_115 = fn:
      panic _

    ·v_90 = fn {·v_91}, [·v_47], ·ret_48:
      ·v_91 ·v_47, ·v_48, ·v_115

    ·v_106 = fn {·v_107}, [·v_56]:
      ·r_2 = ·v_56
      ·v_107 ·r_2

    ·foo_0 = ·v_6 = fn [·n_1], ·ret_7:
      ·v_79 = ·closure ·v_76, ·n_1
      ·v_86 = ·closure ·v_83, ·v_79
      ·v_93 = ·closure ·v_90, ·v_86
      ·v_111 = ·closure ·v_106, ·v_7
      ·v_93 ·n_1, ·v_111

    ·export ·foo_0


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·v_32 = fn ·ret_28:
      ·v_28 1

    ·v_128 = fn {·v_129}:
      ·v_32 ·v_129

    ·v_165 = fn {·v_166, ·v_168}, [·v_18]:
      if ·v_18,
        fn:
          ·v_166 _
        fn:
          ·v_168 _

    ·v_26 = fn [·v_13, ·succ_14], ·fail_15:
      ·v_172 = ·closure ·v_165, ·v_14, ·v_15
      ·op_eq ·v_13, 0, ·v_172

    ·v_44 = fn [·v_9, ·succ_10], ·fail_11:
      ·v_131 = ·closure ·v_128, ·v_10
      ·v_26 ·v_9, ·v_131, ·v_11

    ·v_119 = fn {·v_120}, [·v_53]:
      ·fib_0 ·v_53, ·v_120

    ·v_103 = fn {·n_104}, ·ret_49:
      ·v_124 = ·closure ·v_119, ·v_49
      ·op_plus ·n_104, 1, ·v_124

    ·v_112 = fn {·v_113}, [·v_45, ·succ_46], ·fail_47:
      ·v_113 ·v_46

    ·ret_176 = fn:
      panic _

    ·v_152 = fn {·v_153, ·v_155, ·v_157}:
      ·v_153 ·v_155, ·v_157, ·v_176

    ·v_135 = fn {·v_136}, [·v_66], ·ret_67:
      ·v_161 = ·closure ·v_152, ·v_136, ·v_66, ·v_67
      ·v_44 ·v_66, ·v_67, ·v_161

    ·v_143 = fn {·v_144}, [·v_79]:
      ·r_2 = ·v_79
      ·v_144 ·r_2

    ·fib_0 = ·v_6 = fn [·n_1], ·ret_7:
      ·v_106 = ·closure ·v_103, ·n_1
      ·v_115 = ·closure ·v_112, ·v_106
      ·v_138 = ·closure ·v_135, ·v_115
      ·v_148 = ·closure ·v_143, ·v_7
      ·v_138 ·n_1, ·v_148

    ·export ·fib_0


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn ·ret_5:
      ·op_eq 'hello', 'hello', ·v_5

    ·export ·main_0


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn ·ret_5:
      ·v_5 'hello'

    ·export ·main_0

# TODO not sure this is correct
test 'match — seq literal guard', fn:
  expect lift ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        _: 0

  | equals ƒink:
    ·v_63 = fn [·val_1], ·ret_59:
      ·v_59 ·val_1

    ·v_183 = fn {·v_184, ·v_186}:
      ·val_1 = ·v_184
      ·v_63 ·v_184, ·v_186

    ·v_217 = fn {·v_218, ·v_220}, [·v_47]:
      if ·v_47,
        fn:
          ·v_218 _
        fn:
          ·v_220 _

    ·v_55 = fn [·v_42, ·succ_43], ·fail_44:
      ·v_224 = ·closure ·v_217, ·v_43, ·v_44
      ·op_eq ·v_42, 1, ·v_224

    ·v_170 = fn {·v_171, ·v_173}, [·v_21, ·v_22]:
      ·v_188 = ·closure ·v_183, ·v_22, ·v_171
      ·v_55 ·v_21, ·v_188, ·v_173

    ·v_228 = fn {·v_229, ·v_231, ·v_233}, [·v_29, ·v_30]:
      ·v_229 ·v_231, ·v_233

    ·v_204 = fn {·v_205, ·v_207, ·v_209}, [·v_22, ·v_27]:
      ·v_237 = ·closure ·v_228, ·v_207, ·v_209, ·v_22
      ·seq_pop ·v_27, ·v_205, ·v_237

    ·v_192 = fn {·v_193, ·v_195}, [·v_21, ·v_33]:
      ·v_213 = ·closure ·v_204, ·v_193, ·v_195, ·v_21
      ·seq_pop ·v_33, ·v_193, ·v_213

    ·v_40 = fn [·v_18, ·succ_19], ·fail_20:
      ·v_199 = ·closure ·v_192, ·v_20, ·v_19
      ·seq_pop ·v_18, ·v_20, ·v_199

    ·v_85 = fn [·v_14, ·succ_15], ·fail_16:
      ·v_175 = ·closure ·v_170, ·v_15, ·v_16
      ·v_40 ·v_14, ·v_175, ·v_16

    ·v_94 = fn ·ret_90:
      ·v_90 0

    ·v_99 = fn [·v_86, ·succ_87], ·fail_88:
      ·v_94 ·v_87

    ·ret_179 = fn:
      panic _

    ·v_159 = fn {·v_160, ·v_162}:
      ·v_99 ·v_160, ·v_162, ·v_179

    ·v_112 = fn [·v_100], ·ret_101:
      ·v_166 = ·closure ·v_159, ·v_100, ·v_101
      ·v_85 ·v_100, ·v_101, ·v_166

    ·v_145 = fn {·v_146}, [·v_12]:
      ·v_112 ·v_12, ·v_146

    ·v_136 = fn {·v_137}, [·v_9]:
      ·v_150 = ·closure ·v_145, ·v_137
      ·seq_prepend 1, ·v_9, ·v_150

    ·main_0 = ·v_5 = fn ·ret_6:
      ·v_141 = ·closure ·v_136, ·v_6
      ·seq_prepend 42, [], ·v_141

    ·export ·main_0

# TODO not sure this is correct
test 'match — rec literal guard', fn:
  expect lift ƒink:
    main = fn:
      match {kind: 1, val: 42}:
        {kind: 1, val}: val
        _: 0

  | equals ƒink:
    ·v_62 = fn [·val_1], ·ret_58:
      ·v_58 ·val_1

    ·v_182 = fn {·v_183, ·v_185}:
      ·val_1 = ·v_183
      ·v_62 ·v_183, ·v_185

    ·v_214 = fn {·v_215, ·v_217}, [·v_46]:
      if ·kind_46,
        fn:
          ·v_215 _
        fn:
          ·v_217 _

    ·v_54 = fn [·v_41, ·succ_42], ·fail_43:
      ·v_221 = ·closure ·v_214, ·v_42, ·v_43
      ·op_eq ·kind_41, 1, ·v_221

    ·v_169 = fn {·v_170, ·v_172}, [·v_23, ·v_24]:
      ·v_187 = ·closure ·v_182, ·v_24, ·v_170
      ·kind_54 ·v_23, ·v_187, ·v_172

    ·v_203 = fn {·v_204, ·v_206}, [·v_24, ·v_29]:
      ·v_204 ·v_206, ·v_24

    ·v_191 = fn {·v_192, ·v_194}, [·v_23, ·v_30]:
      ·v_210 = ·closure ·v_203, ·v_194, ·v_23
      ·rec_pop ·v_30, 'val', ·v_192, ·v_210

    ·v_39 = fn [·v_20, ·succ_21], ·fail_22:
      ·v_198 = ·closure ·v_191, ·v_22, ·v_21
      ·rec_pop ·v_20, 'kind', ·v_22, ·v_198

    ·v_84 = fn [·v_16, ·succ_17], ·fail_18:
      ·v_174 = ·closure ·v_169, ·v_17, ·v_18
      ·v_39 ·v_16, ·v_174, ·v_18

    ·v_93 = fn ·ret_89:
      ·v_89 0

    ·v_98 = fn [·v_85, ·succ_86], ·fail_87:
      ·v_93 ·v_86

    ·ret_178 = fn:
      panic _

    ·v_158 = fn {·v_159, ·v_161}:
      ·v_98 ·v_159, ·v_161, ·v_178

    ·v_111 = fn [·v_99], ·ret_100:
      ·v_165 = ·closure ·v_158, ·v_99, ·v_100
      ·v_84 ·v_99, ·v_100, ·v_165

    ·v_144 = fn {·v_145}, [·v_14]:
      ·v_111 ·v_14, ·v_145

    ·v_135 = fn {·v_136}, [·v_10]:
      ·v_149 = ·closure ·v_144, ·v_136
      ·rec_put ·v_10, 'val', 42, ·v_149

    ·main_0 = ·v_5 = fn ·ret_6:
      ·v_140 = ·closure ·v_135, ·v_6
      ·rec_put {}, 'kind', 1, ·v_140

    ·export ·main_0
