---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·f_0 = ·v_5 = fn [·x_1], ·v_6:
      ·v_6 ·x_1

    ·export ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·v_8 = fn [·b_2], ·v_9:
      ·v_9 ·b_2

    ·foo_0 = ·v_6 = fn [·a_1], ·v_7:
      ·v_7 ·v_8

    ·export ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·v_25 = fn {·v_26}, [·v_9]:
      ·x_1 = ·v_9
      ·op_plus ·x_1, 4, ·v_26

    ·main_0 = ·v_5 = fn ·v_6:
      ·v_30 = ·closure ·v_25, ·v_6
      ·op_mul 2, 3, ·v_30

    ·export ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·v_22 = fn {·a_23}, [·b_2], ·v_9:
      ·op_plus ·a_23, ·b_2, ·v_9

    ·foo_0 = ·v_6 = fn [·a_1], ·v_7:
      ·closure ·v_22, ·a_1, ·v_7

    ·export ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·f_0 = ·v_9 = fn [·x_2], ·v_10:
      ·v_10 ·x_2

    ·v_35 = fn {·a_36}, [·b_4], ·v_18:
      ·op_plus ·a_36, ·b_4, ·v_18

    ·g_1 = ·v_15 = fn [·a_3], ·v_16:
      ·closure ·v_35, ·a_3, ·v_16

    ·export ·f_0, ·g_1


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·v_48 = fn {·c_49, ·v_51}, [·v_15]:
      ·op_plus ·v_15, ·c_49, ·v_51

    ·v_39 = fn {·a_40, ·b_42}, [·c_3], ·v_12:
      ·v_55 = ·closure ·v_48, ·c_3, ·v_12
      ·op_plus ·a_40, ·b_42, ·v_55

    ·v_32 = fn {·a_33}, [·b_2], ·v_10:
      ·closure ·v_39, ·a_33, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn [·a_1], ·v_8:
      ·closure ·v_32, ·a_1, ·v_8

    ·export ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·v_34 = fn {·a_35, ·b_37}, [·c_3], ·v_12:
      ·op_plus ·a_35, ·b_37, ·v_12

    ·v_27 = fn {·a_28}, [·b_2], ·v_10:
      ·closure ·v_34, ·a_28, ·b_2, ·v_10

    ·foo_0 = ·v_7 = fn [·a_1], ·v_8:
      ·closure ·v_27, ·a_1, ·v_8

    ·export ·foo_0


test 'yield — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      q = yield 42
      1 + q

  | equals ƒink:
    ·v_24 = fn {·v_25}, [·v_8]:
      ·q_1 = ·v_8
      ·op_plus 1, ·q_1, ·v_25

    ·main_0 = ·v_5 = fn ·v_6:
      ·v_29 = ·closure ·v_24, ·v_6
      ·yield 42, ·v_29

    ·export ·main_0


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·add_0 = ·v_8 = fn [·a_2, ·b_3], ·v_9:
      ·op_plus ·a_2, ·b_3, ·v_9

    ·main_1 = ·v_16 = fn ·v_17:
      ·add_0 3, 4, ·v_17

    ·export ·add_0, ·main_1

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·double_0 = ·v_11 = fn [·x_3], ·v_12:
      ·op_mul ·x_3, 2, ·v_12

    ·inc_1 = ·v_19 = fn [·x_4], ·v_20:
      ·op_plus ·x_4, 1, ·v_20

    ·v_55 = fn {·v_56}, [·v_31]:
      ·x_5 = ·v_31
      ·inc_1 ·x_5, ·v_56

    ·main_2 = ·v_27 = fn ·v_28:
      ·v_60 = ·closure ·v_55, ·v_28
      ·double_0 5, ·v_60

    ·export ·double_0, ·inc_1, ·main_2

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·v_50 = fn {·v_51}, [·v_12]:
      ·a_2 = ·v_12
      ·op_plus ·a_2, 1, ·v_51

    ·v_69 = fn {·v_70, ·v_72, ·v_74}, [·v_19]:
      if ·v_19,
        fn:
          ·v_70 ·v_72
        fn:
          ·v_74 _

    ·v_58 = fn {·v_59, ·v_61}, [·v_12, ·v_16]:
      ·v_78 = ·closure ·v_69, ·v_59, ·v_12, ·v_61
      ·empty ·v_16, ·v_78

    ·v_27 = fn [·v_9, ·v_10], ·v_11:
      ·v_65 = ·closure ·v_58, ·v_10, ·v_11
      ·seq_pop ·v_9, ·v_11, ·v_65

    ·main_0 = ·v_6 = fn [·foo_1], ·v_7:
      ·v_53 = ·closure ·v_50, ·v_7
      ·v_27 ·foo_1, ·v_53, panic

    ·export ·main_0


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·v_44 = fn {·v_45}, [·v_12]:
      ·x_2 = ·v_12
      ·op_plus ·x_2, 1, ·v_45

    ·v_52 = fn {·v_53}, [·v_12, ·v_16]:
      ·v_53 ·v_12

    ·v_21 = fn [·v_9, ·v_10], ·v_11:
      ·v_57 = ·closure ·v_52, ·v_10
      ·rec_pop ·v_9, 'x', ·v_11, ·v_57

    ·main_0 = ·v_6 = fn [·foo_1], ·v_7:
      ·v_47 = ·closure ·v_44, ·v_7
      ·v_21 ·foo_1, ·v_47, panic

    ·export ·main_0


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·v_32 = fn ·v_28:
      ·v_28 42

    ·v_75 = fn {·v_76}:
      ·v_32 ·v_76

    ·v_83 = fn {·v_84, ·v_86}, [·v_17]:
      if ·v_17,
        fn:
          ·v_84 _
        fn:
          ·v_86 _

    ·v_25 = fn [·v_12, ·v_13], ·v_14:
      ·v_90 = ·closure ·v_83, ·v_13, ·v_14
      ·op_eq ·v_12, 0, ·v_90

    ·v_44 = fn [·v_8, ·v_9], ·v_10:
      ·v_78 = ·closure ·v_75, ·v_9
      ·v_25 ·v_8, ·v_78, ·v_10

    ·v_72 = fn:
      panic _

    ·v_53 = fn [·v_45], ·v_46:
      ·v_44 ·v_45, ·v_46, ·v_72

    ·foo_0 = ·v_5 = fn [·n_1], ·v_6:
      ·v_53 ·n_1, ·v_6

    ·export ·foo_0


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·v_77 = fn {·n_78}, ·v_29:
      ·op_plus ·n_78, 1, ·v_29

    ·v_98 = fn {·v_99, ·v_101}:
      ·v_99 ·v_101

    ·v_120 = fn {·v_121, ·v_123}, [·v_18]:
      if ·v_18,
        fn:
          ·v_121 _
        fn:
          ·v_123 _

    ·v_26 = fn [·v_13, ·v_14], ·v_15:
      ·v_127 = ·closure ·v_120, ·v_14, ·v_15
      ·op_eq ·v_13, 0, ·v_127

    ·v_84 = fn {·v_85}, [·v_9, ·v_10], ·v_11:
      ·v_103 = ·closure ·v_98, ·v_85, ·v_10
      ·v_26 ·v_9, ·v_103, ·v_11

    ·v_116 = fn:
      panic _

    ·v_91 = fn {·v_92}, [·v_48], ·v_49:
      ·v_92 ·v_48, ·v_49, ·v_116

    ·v_107 = fn {·v_108}, [·v_57]:
      ·r_2 = ·v_57
      ·v_108 ·r_2

    ·foo_0 = ·v_6 = fn [·n_1], ·v_7:
      ·v_80 = ·closure ·v_77, ·n_1
      ·v_87 = ·closure ·v_84, ·v_80
      ·v_94 = ·closure ·v_91, ·v_87
      ·v_112 = ·closure ·v_107, ·v_7
      ·v_94 ·n_1, ·v_112

    ·export ·foo_0


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·v_33 = fn ·v_29:
      ·v_29 1

    ·v_129 = fn {·v_130}:
      ·v_33 ·v_130

    ·v_166 = fn {·v_167, ·v_169}, [·v_18]:
      if ·v_18,
        fn:
          ·v_167 _
        fn:
          ·v_169 _

    ·v_26 = fn [·v_13, ·v_14], ·v_15:
      ·v_173 = ·closure ·v_166, ·v_14, ·v_15
      ·op_eq ·v_13, 0, ·v_173

    ·v_45 = fn [·v_9, ·v_10], ·v_11:
      ·v_132 = ·closure ·v_129, ·v_10
      ·v_26 ·v_9, ·v_132, ·v_11

    ·v_120 = fn {·v_121}, [·v_54]:
      ·fib_0 ·v_54, ·v_121

    ·v_104 = fn {·n_105}, ·v_50:
      ·v_125 = ·closure ·v_120, ·v_50
      ·op_plus ·n_105, 1, ·v_125

    ·v_113 = fn {·v_114}, [·v_46, ·v_47], ·v_48:
      ·v_114 ·v_47

    ·v_177 = fn:
      panic _

    ·v_153 = fn {·v_154, ·v_156, ·v_158}:
      ·v_154 ·v_156, ·v_158, ·v_177

    ·v_136 = fn {·v_137}, [·v_67], ·v_68:
      ·v_162 = ·closure ·v_153, ·v_137, ·v_67, ·v_68
      ·v_45 ·v_67, ·v_68, ·v_162

    ·v_144 = fn {·v_145}, [·v_80]:
      ·r_2 = ·v_80
      ·v_145 ·r_2

    ·fib_0 = ·v_6 = fn [·n_1], ·v_7:
      ·v_107 = ·closure ·v_104, ·n_1
      ·v_116 = ·closure ·v_113, ·v_107
      ·v_139 = ·closure ·v_136, ·v_116
      ·v_149 = ·closure ·v_144, ·v_7
      ·v_139 ·n_1, ·v_149

    ·export ·fib_0


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn ·v_5:
      ·op_eq 'hello', 'hello', ·v_5

    ·export ·main_0


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn ·v_5:
      ·v_5 'hello'

    ·export ·main_0
