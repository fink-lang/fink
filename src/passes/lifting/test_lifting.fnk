---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Test format:
#   test 'name', fn:
#     expect lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected lifted CPS>

{test, equals, expect, fink, lift} = import 'fake!'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift fink":
    f = fn x: x

  | equals fink":
    f = ·v_1 = fn x, ·v_3:
      ·v_5 = x
      ·v_3 ·v_5

    ·v_0 f


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·v_4 = fn b, ·v_6:
      ·v_8 = b
      ·v_6 ·v_8

    foo = ·v_1 = fn a, ·v_3:
      ·v_3 ·v_4

    ·v_0 foo


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_23 = fn ·v_24, ·v_5:
      x = ·v_5
      ·op_plus x, 4, ·v_24

    main = ·v_1 = fn ·v_2:
      ·v_28 = ·closure ·v_23, ·v_2
      ·op_mul 2, 3, ·v_28

    ·v_0 main


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_20 = fn a, b, ·v_6:
      ·op_plus a, b, ·v_6

    foo = ·v_1 = fn a, ·v_3:
      ·closure ·v_20, a, ·v_3

    ·v_0 foo


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift fink":
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_3 = fn x, ·v_5:
      ·v_7 = x
      ·v_5 ·v_7

    ·v_38 = fn a, b, ·v_16:
      ·op_plus a, b, ·v_16

    ·v_11 = fn a, ·v_13:
      ·closure ·v_38, a, ·v_13

    ·v_1 = fn ·v_2:
      f = ·v_3
      g = ·v_11
      ·v_2 g

    ·v_0 ·v_1


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_46 = fn c, ·v_49, ·v_12:
      ·op_plus ·v_12, c, ·v_49

    ·v_37 = fn a, b, c, ·v_9:
      ·v_53 = ·closure ·v_46, c, ·v_9
      ·op_plus a, b, ·v_53

    ·v_30 = fn a, b, ·v_6:
      ·closure ·v_37, a, b, ·v_6

    foo = ·v_1 = fn a, ·v_3:
      ·closure ·v_30, a, ·v_3

    ·v_0 foo


test 'multiple captures at depth-2', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_32 = fn a, b, c, ·v_9:
      ·op_plus a, b, ·v_9

    ·v_25 = fn a, b, ·v_6:
      ·closure ·v_32, a, b, ·v_6

    foo = ·v_1 = fn a, ·v_3:
      ·closure ·v_25, a, ·v_3

    ·v_0 foo


test 'yield — cont body lifted', fn:
  expect lift fink":
    main = fn:
      q = yield 42
      1 + q

  | equals fink":
    ·v_22 = fn ·v_23, ·v_4:
      q = ·v_4
      ·op_plus 1, q, ·v_23

    main = ·v_1 = fn ·v_2:
      ·v_27 = ·closure ·v_22, ·v_2
      ·yield 42, ·v_27

    ·v_0 main


---
pattern matching
---

test 'seq destructure', fn:
  expect lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_53 = fn a, ·v_56, ·v_11:
      ·op_plus a, 1, ·v_56

    ·v_44 = fn ·v_45, ·v_6, ·v_7:
      a = ·v_6
      ·v_60 = ·closure ·v_53, a, ·v_45
      ·match_done ·v_7, panic, ·v_60

    ·v_35 = fn ·v_36, ·v_5:
      ·v_49 = ·closure ·v_44, ·v_36
      ·match_next ·v_5, panic, ·v_49

    main = ·v_1 = fn foo, ·v_3:
      ·v_40 = ·closure ·v_35, ·v_3
      ·match_seq foo, panic, ·v_40

    ·v_0 main


test 'record destructure', fn:
  expect lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_41 = fn ·v_42, ·v_6, ·v_7:
      x = ·v_6
      ·op_plus x, 1, ·v_42

    ·v_32 = fn ·v_33, ·v_5:
      ·v_46 = ·closure ·v_41, ·v_33
      ·match_field ·v_5, 'x', panic, ·v_46

    main = ·v_1 = fn foo, ·v_3:
      ·v_37 = ·closure ·v_32, ·v_3
      ·match_rec foo, panic, ·v_37

    ·v_0 main


test 'match — no forward refs after lift', fn:
  expect lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·v_31 = fn n, ·v_34, ·v_18:
      ·match_block n, ·v_18, ·v_34

    ·v_45 = fn ·v_11:
      ·v_13 = 42
      ·v_11 ·v_13

    ·v_48 = fn ·v_8, ·v_6, ·v_7:
      ·match_value ·v_8, 0, ·v_6, ·v_7

    ·v_42 = fn ·v_38:
      ·match_arm ·v_48, ·v_45, ·v_38

    foo = ·v_1 = fn n, ·v_3:
      ·closure ·v_31, n, ·v_3, ·v_42

    ·v_0 foo



test 'match with binding', fn:
  expect lift fink":
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals fink":
    ·v_57 = fn ·v_58, ·v_22:
      r = ·v_22
      ·v_58 r

    ·v_37 = fn n, ·v_40, ·v_20:
      ·v_62 = ·closure ·v_57, ·v_40
      ·match_block n, ·v_20, ·v_62

    ·v_48 = fn n, ·v_11:
      ·op_plus n, 1, ·v_11

    ·v_66 = fn ·v_8, ·v_6, ·v_7:
      ·match_value ·v_8, 0, ·v_6, ·v_7

    foo = ·v_1 = fn n, ·v_3:
      ·v_44 = ·closure ·v_37, n, ·v_3
      ·v_53 = ·closure ·v_48, n
      ·match_arm ·v_66, ·v_53, ·v_44

    ·v_0 foo


test 'recursive fn in match', fn:
  expect lift fink":
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals fink":
    ·v_95 = fn ·v_96, ·v_39:
      r = ·v_39
      ·v_96 r

    ·v_70 = fn n, ·v_73, ·v_75, ·v_37:
      ·v_100 = ·closure ·v_95, ·v_75
      ·match_block n, ·v_73, ·v_37, ·v_100

    ·v_110 = fn ·v_111, ·v_28:
      fib ·v_28, ·v_111

    ·v_86 = fn n, ·v_24:
      ·v_115 = ·closure ·v_110, ·v_24
      ·op_plus n, 1, ·v_115

    ·v_107 = fn ·v_22, ·v_20, ·v_21:
      ·v_21 _

    ·v_56 = fn n, ·v_59, ·v_18:
      ·v_79 = ·closure ·v_70, n, ·v_18, ·v_59
      ·v_91 = ·closure ·v_86, n
      ·match_arm ·v_107, ·v_91, ·v_79

    ·v_83 = fn ·v_11:
      ·v_13 = 1
      ·v_11 ·v_13

    ·v_104 = fn ·v_8, ·v_6, ·v_7:
      ·match_value ·v_8, 0, ·v_6, ·v_7

    ·v_67 = fn ·v_63:
      ·match_arm ·v_104, ·v_83, ·v_63

    fib = ·v_1 = fn n, ·v_3:
      ·closure ·v_56, n, ·v_3, ·v_67

    ·v_0 fib
