  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_18, ·ƒret_2:
      ·f_0 = ·v_3 = fn [·ƒctx_20, ·ƒret_4, ·x_1]:
        ·ƒret_4 ·ƒctx_20, ·x_1
      ·ƒpub ·f_0
      ·ƒret_2 ·ƒctx_18, ·f_0
