---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module,·import,·ƒpub, ·closure, ·if, ·panic
  ·op_plus
  ·op_mul
  ·op_eq
  ·empty
  ·is_seq_like
  ·is_rec_like
  ·seq_pop
  ·seq_prepend
  ·rec_put
  ·rec_pop
  ·spawn
  ·await
  ·channel
  ·receive
} = import '@fink/compile/builtins'




test 'single module expr', fn:
  expect lift ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 42
    # sm:BwAAAAAkABIACAAAABQA


test 'single binding export', fn:
  expect lift ƒink:
    foo = fn: 123
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0
      ·ƒret_1 ·foo_0
    # sm:GgAAAAAkABIACAAAAAABAAMQAAQADAAEAAYAAAACABIAAAACAAwAAAAUAAwAAAAQAQADFAAAABQBAAM

test 'single binding export with trailing expr', fn:
  expect lift ƒink:
    foo = fn: 123
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0
      ·ƒret_1 42
    # sm:GgAAAAAkABIACAAAAAABAAMQAAQADAAEAAYAAAACABIAAAACAAwAAAAUAAwAAAAQAQADFAAAABQA



test 'two fn exports', fn:
  expect lift ƒink:
    foo = fn: 123
    bar = fn: 345
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·foo_0 = ·v_3 = fn [·ƒret_4]:
        ·ƒret_4 123
      ·ƒpub ·foo_0
      ·bar_1 = ·v_9 = fn [·ƒret_10]:
        ·ƒret_10 345
      ·ƒpub ·bar_1
      ·ƒret_2 ·bar_1
    # sm:LQAAAAAkABIACAAAAAABAAMQAAQADAAEAAYAAAACABIAAAACAAwAAAAUAAwAAAAQAQADFAAAAAABHAMQAAQADAAEAAYAAAACABQAAAACAAwAAAAWAAwAAAAQAQADFAAAABQBAAM

test 'fooobar — multi fn with calls', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒret_8:
      ·v_9 = fn [·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_76 = fn {·ƒret_77}, [·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3
        ·ƒret_77 ·p_3
      ·v_63 = fn {·ƒret_64}, [·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1
        ·mul_2 = ·v_22
        ·ƒpub ·mul_2
        ·v_81 = ·closure ·v_76, ·ƒret_64
        ·mul_2 ·v_81, ·s_1, 3
      ·add_0 = ·v_9
      ·ƒpub ·add_0
      ·ƒret_73 = fn [·v_68]:
        ·add_0 ·v_68, 1, 2
      ·closure ·v_63, ·ƒret_8, ·ƒret_73
    # sm:


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·f_0 = ·v_3 = fn [·ƒret_4, ·x_1]:
        ·ƒret_4 ·x_1
      ·ƒpub ·f_0
      ·ƒret_2 ·f_0
    # sm:HAAAAAAkABIACAAAAAABAAEMAAQADAAEAAYAAAACABIABAEOAQoAAAACAAwAAAAUAQYBEAAAABABEwEQAAAAFAEAAQ


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_6 = fn [·ƒret_7, ·b_2]:
        ·ƒret_7 ·b_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·ƒret_5 ·v_6
      ·ƒpub ·foo_0
      ·ƒret_3 ·foo_0
    # sm:KwAAAAAkABIACAAAAAwABAAGAAAAAgASAAQBIgEKAAAAAgAMAAAAFAEGARAAAAAAAScDEAAEAAwABAAGAAAAAgASAAQBEgEKAAAAAgAMAAAAFAAQAAAAEAERAxQAAAAUAQAD


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'fn call result bound at module level', fn:
  expect lift ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·v_34 = fn {·ƒret_35}, [·v_16]:
        ·x_1 = ·v_16
        ·ƒpub ·x_1
        ·ƒret_35 ·x_1
      ·add_0 = ·v_5
      ·ƒpub ·add_0
      ·ƒret_44 = fn [·v_39]:
        ·add_0 ·v_39, 1, 2
      ·closure ·v_34, ·ƒret_4, ·ƒret_44
    # sm:UQAAAAAkABIACAAAAAwABAAGAAAAAgASAAQBEgEKAAQBBgEKAAAAAgAMAAAAFAEGAQoABAEIAQoABAAYAAAADgAEAAYAAAACABQAAAAGAAAAAgAMAAAAAgAMAAABBAEMAAQAFgAAABABAAEUAAAAFgEAARAAAAEpAxAABAAQAAAAEAEAAxQAAAAWAAQABgAAAAIADAAAAAIADAAAATIDEAAMAAQAAgAEAAgAAAAUAAwABAASAAQA


test 'chained ops at module level', fn:
  expect lift ƒink:
    2 * 3 + 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·v_12 = fn {·ƒret_13}, [·v_3]:
        ·op_plus ·v_3, 4, ·ƒret_13
      ·v_17 = ·closure ·v_12, ·ƒret_0
      ·op_mul 2, 3, ·v_17
    # sm:KQAAAAAkABIACAAAAA4ABAAGAAAAAgAUAAAABgAAAAIACgAAAAIADAAAABQACgAEAAIABAAaAAAADgAEAAAAFAAMAAQAGAAAABIAAgAEAAIABAA


test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    x = 2 * 3
    x + 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·v_18 = fn {·ƒret_19}, [·v_4]:
        ·x_0 = ·v_4
        ·ƒpub ·x_0
        ·op_plus ·x_0, 4, ·ƒret_19
      ·v_23 = ·closure ·v_18, ·ƒret_1
      ·op_mul 2, 3, ·v_23
    # sm:MAAAAAAkABIACAAAAA4ABAAGAAAAAgAUAAAABgAAAAIACgAAAAIADAAAAQABDAAEABQAAAAQAQABFAAAABQBFAEKAAQAAgAEABoAAAAOAAQAAAAUAAwABAAYAAAAEgACAAQAAgAEAA


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_27 = fn {·a_28}, [·ƒret_7, ·b_2]:
        ·op_plus ·a_28, ·b_2, ·ƒret_7
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·closure ·v_27, ·a_1, ·ƒret_5
      ·ƒpub ·foo_0
      ·ƒret_3 ·foo_0
    # sm:OAAAAAAkABIACAAAAA4ABAAGAAAAAgESAQwAAAAGAAAAAgASAAQBEAEKAAAAAgAMAAAAFAEOAQwABAEIAQoABAAYAAAAAAE3AxAABAAMAAQABgAAAAIAEgAEARIBCgAAAAIADAAAABQADAAEAQABCgAEABgAAAAQAREDFAAAABQBAAM


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_5:
      ·v_6 = fn [·ƒret_7, ·x_2]:
        ·ƒret_7 ·x_2
      ·v_42 = fn {·a_43}, [·ƒret_15, ·b_4]:
        ·op_plus ·a_43, ·b_4, ·ƒret_15
      ·v_12 = fn [·ƒret_13, ·a_3]:
        ·closure ·v_42, ·a_3, ·ƒret_13
      ·f_0 = ·v_6
      ·ƒpub ·f_0
      ·g_1 = ·v_12
      ·ƒpub ·g_1
      ·ƒret_5 ·g_1
    # sm:TwAAAAAkABIACAAAAAwABAAGAAAAAgASAAQBDgEKAAAAAgAMAAAAFAEKARAAAAAOAAQABgAAAAIBEgEMAAAABgAAAAIAFAAEARABCgAAAAIADAAAABQBDgEMAAQBCAEKAAQAGgAAAA4ABAAGAAAAAgAUAAQBJQEKAAAAAgAMAAAAFAAMAAQBAAEKAAQAGgAAASkBDAAEABAAAAAQAQABEAAAARwBDAAEABIAAAAQAQABEAAAABQBAAE

---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_58 = fn {·c_59, ·ƒret_61}, [·v_13]:
        ·op_plus ·v_13, ·c_59, ·ƒret_61
      ·v_46 = fn {·a_47, ·b_49}, [·ƒret_10, ·c_3]:
        ·v_65 = ·closure ·v_58, ·c_3, ·ƒret_10
        ·op_plus ·a_47, ·b_49, ·v_65
      ·v_37 = fn {·a_38}, [·ƒret_8, ·b_2]:
        ·closure ·v_46, ·a_38, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_37, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·foo_0
    # sm:


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_41 = fn {·a_42, ·b_44}, [·ƒret_10, ·c_3]:
        ·op_plus ·a_42, ·b_44, ·ƒret_10
      ·v_32 = fn {·a_33}, [·ƒret_8, ·b_2]:
        ·closure ·v_41, ·a_33, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_32, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·foo_0
    # sm:VAAAAAAkABIACAAAAA4ABAAGAAAAAgESAQwABAEQAQwAAAAGAAAAAgAUAAQBFAEKAAAAAgAMAAAAFAESAQwABAEIAQwABAAaAAAADgAEAAYAAAACAT0BDAAAAAYAAAACABIABAEQAQoAAAACAAwAAAAUAAwABAEPAQwABAEQAQoABAAYAAAAAAEhAxAABAAMAAQABgAAAAIAEgAEARIBCgAAAAIADAAAABQADAAEAQABCgAEABgAAAAQAREDFAAAABQBAAM


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    foo = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·add_0 = ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·ƒpub ·add_0
      ·foo_1 = ·v_13 = fn [·ƒret_14]:
        ·add_0 ·ƒret_14, 3, 4
      ·ƒpub ·foo_1
      ·ƒret_4 ·foo_1
    # sm:OQAAAAAkABIACAAAAAABAAMQAAQADAAEAAYAAAACABIABAESAQoABAEGAQoAAAACAAwAAAAUAQoBCgAEAQgBCgAEABgAAAAQASkDFAAAAAABMAMQAAQADgAEAAYAAAACABQAAAACAAwAAAEYAxAAFAAEAAIABAAIAAAAEAEXAxQAAAAUAQAD

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_6:
      ·v_7 = fn [·ƒret_8, ·x_3]:
        ·op_mul ·x_3, 2, ·ƒret_8
      ·v_15 = fn [·ƒret_16, ·x_4]:
        ·op_plus ·x_4, 1, ·ƒret_16
      ·v_75 = fn {·inc_76, ·ƒret_78}, [·v_27]:
        ·x_5 = ·v_27
        ·inc_76 ·ƒret_78, ·x_5
      ·v_61 = fn {·double_62, ·inc_64}, [·ƒret_24]:
        ·v_82 = ·closure ·v_75, ·inc_64, ·ƒret_24
        ·double_62 ·v_82, 5
      ·double_0 = ·v_7
      ·ƒpub ·double_0
      ·ƒret_72 = fn [·v_66]:
        ·foo_2 = ·v_66
        ·ƒpub ·foo_2
        ·ƒret_6 ·foo_2
      ·inc_1 = ·v_15
      ·ƒpub ·inc_1
      ·closure ·v_61, ·double_0, ·inc_1, ·ƒret_72
    # sm:

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_60 = fn {·ƒret_61}, [·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, 1, ·ƒret_61
      ·v_73 = fn {·ƒfail_74}:
        ·ƒfail_74 _
      ·v_119 = fn {·ƒsucc_120, ·v_122, ·ƒfail_124}, [·v_17]:
        ·if ·v_17,
          fn:
            ·ƒsucc_120 ·v_122
          fn:
            ·ƒfail_124 _
      ·v_102 = fn {·ƒsucc_103, ·ƒfail_105}, [·v_10, ·v_14]:
        ·v_128 = ·closure ·v_119, ·ƒsucc_103, ·v_10, ·ƒfail_105
        ·empty ·v_14, ·v_128
      ·v_86 = fn {·ƒfail_87, ·ƒsucc_89}, [·v_22]:
        ·v_109 = ·closure ·v_102, ·ƒsucc_89, ·ƒfail_87
        ·seq_pop ·v_22, ·ƒfail_87, ·v_109
      ·v_30 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_78 = ·closure ·v_73, ·ƒfail_9
        ·v_93 = ·closure ·v_86, ·ƒfail_9, ·ƒsucc_8
        ·is_seq_like ·v_7, ·v_93, ·v_78
      ·spam_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_63 = ·closure ·v_60, ·ƒret_5
        ·v_30 ·v_63, ·panic, ·foo_1
      ·ƒpub ·spam_0
      ·ƒret_3 ·spam_0
    # sm:


test 'record destructure', fn:
  expect lift ƒink:
    ham = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_54 = fn {·ƒret_55}, [·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, 1, ·ƒret_55
      ·v_67 = fn {·ƒfail_68}:
        ·ƒfail_68 _
      ·v_96 = fn {·ƒsucc_97}, [·v_10, ·v_14]:
        ·ƒsucc_97 ·v_10
      ·v_80 = fn {·ƒfail_81, ·ƒsucc_83}, [·v_15]:
        ·v_101 = ·closure ·v_96, ·ƒsucc_83
        ·rec_pop ·v_15, 'x', ·ƒfail_81, ·v_101
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_72 = ·closure ·v_67, ·ƒfail_9
        ·v_87 = ·closure ·v_80, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_87, ·v_72
      ·ham_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_57 = ·closure ·v_54, ·ƒret_5
        ·v_24 ·v_57, ·panic, ·foo_1
      ·ƒpub ·ham_0
      ·ƒret_3 ·ham_0
    # sm:


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_29 = fn [·ƒret_25]:
        ·ƒret_25 42
      ·v_82 = fn {·ƒsucc_83}:
        ·v_29 ·ƒsucc_83
      ·v_103 = fn {·ƒsucc_104, ·ƒfail_106}, [·v_15]:
        ·if ·v_15,
          fn:
            ·ƒsucc_104 _
          fn:
            ·ƒfail_106 _
      ·v_23 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_110 = ·closure ·v_103, ·ƒsucc_11, ·ƒfail_12
        ·op_eq ·v_10, 0, ·v_110
      ·v_41 = fn [·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_85 = ·closure ·v_82, ·ƒsucc_7
        ·v_23 ·v_85, ·ƒfail_8, ·v_6
      ·ƒret_79 = fn:
        ·panic _
      ·v_49 = fn [·ƒret_43, ·v_42]:
        ·v_41 ·ƒret_43, ·ƒret_79, ·v_42
      ·foo_0 = ·v_3 = fn [·ƒret_4, ·n_1]:
        ·v_49 ·ƒret_4, ·n_1
      ·ƒpub ·foo_0
      ·ƒret_2 ·foo_0
    # sm:


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_80 = fn {·n_81}, [·ƒret_26]:
        ·op_plus ·n_81, 1, ·ƒret_26
      ·v_106 = fn {·v_107, ·ƒsucc_109}:
        ·v_107 ·ƒsucc_109
      ·v_141 = fn {·ƒsucc_142, ·ƒfail_144}, [·v_16]:
        ·if ·v_16,
          fn:
            ·ƒsucc_142 _
          fn:
            ·ƒfail_144 _
      ·v_24 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_148 = ·closure ·v_141, ·ƒsucc_12, ·ƒfail_13
        ·op_eq ·v_11, 0, ·v_148
      ·v_89 = fn {·v_90}, [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_111 = ·closure ·v_106, ·v_90, ·ƒsucc_8
        ·v_24 ·v_111, ·ƒfail_9, ·v_7
      ·ƒret_129 = fn:
        ·panic _
      ·v_99 = fn {·v_100}, [·ƒret_46, ·v_45]:
        ·v_100 ·ƒret_46, ·ƒret_129, ·v_45
      ·v_120 = fn {·ƒret_121}, [·v_53]:
        ·r_2 = ·v_53
        ·ƒret_121 ·r_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·n_1]:
        ·v_83 = ·closure ·v_80, ·n_1
        ·v_92 = ·closure ·v_89, ·v_83
        ·v_102 = ·closure ·v_99, ·v_92
        ·v_125 = ·closure ·v_120, ·ƒret_5
        ·v_102 ·v_125, ·n_1
      ·ƒpub ·foo_0
      ·ƒret_3 ·foo_0
