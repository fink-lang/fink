---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·f_0 = ·v_5 = fn [·ƒret_6, ·x_1]:
      ·ƒret_6 ·x_1

    ·export ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·v_8 = fn [·ƒret_9, ·b_2]:
      ·ƒret_9 ·b_2

    ·foo_0 = ·v_6 = fn [·ƒret_7, ·a_1]:
      ·ƒret_7 ·v_8

    ·export ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·v_25 = fn {·ƒret_26}, [·v_9]:
      ·x_1 = ·v_9
      ·op_plus ·x_1, 4, ·ƒret_26

    ·main_0 = ·v_5 = fn [·ƒret_6]:
      ·v_30 = ·closure ·v_25, ·ƒret_6
      ·op_mul 2, 3, ·v_30

    ·export ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·v_22 = fn {·a_23}, [·ƒret_9, ·b_2]:
      ·op_plus ·a_23, ·b_2, ·ƒret_9

    ·foo_0 = ·v_6 = fn [·ƒret_7, ·a_1]:
      ·closure ·v_22, ·a_1, ·ƒret_7

    ·export ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·f_0 = ·v_9 = fn [·ƒret_10, ·x_2]:
      ·ƒret_10 ·x_2

    ·v_35 = fn {·a_36}, [·ƒret_18, ·b_4]:
      ·op_plus ·a_36, ·b_4, ·ƒret_18

    ·g_1 = ·v_15 = fn [·ƒret_16, ·a_3]:
      ·closure ·v_35, ·a_3, ·ƒret_16

    ·export ·f_0, ·g_1


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·v_48 = fn {·c_49, ·ƒret_51}, [·v_15]:
      ·op_plus ·v_15, ·c_49, ·ƒret_51

    ·v_39 = fn {·a_40, ·b_42}, [·ƒret_12, ·c_3]:
      ·v_55 = ·closure ·v_48, ·c_3, ·ƒret_12
      ·op_plus ·a_40, ·b_42, ·v_55

    ·v_32 = fn {·a_33}, [·ƒret_10, ·b_2]:
      ·closure ·v_39, ·a_33, ·b_2, ·ƒret_10

    ·foo_0 = ·v_7 = fn [·ƒret_8, ·a_1]:
      ·closure ·v_32, ·a_1, ·ƒret_8

    ·export ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·v_34 = fn {·a_35, ·b_37}, [·ƒret_12, ·c_3]:
      ·op_plus ·a_35, ·b_37, ·ƒret_12

    ·v_27 = fn {·a_28}, [·ƒret_10, ·b_2]:
      ·closure ·v_34, ·a_28, ·b_2, ·ƒret_10

    ·foo_0 = ·v_7 = fn [·ƒret_8, ·a_1]:
      ·closure ·v_27, ·a_1, ·ƒret_8

    ·export ·foo_0


test 'yield — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      q = yield 42
      1 + q

  | equals ƒink:
    ·v_24 = fn {·ƒret_25}, [·v_8]:
      ·q_1 = ·v_8
      ·op_plus 1, ·q_1, ·ƒret_25

    ·main_0 = ·v_5 = fn [·ƒret_6]:
      ·v_29 = ·closure ·v_24, ·ƒret_6
      ·yield 42, ·v_29

    ·export ·main_0


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·add_0 = ·v_8 = fn [·ƒret_9, ·a_2, ·b_3]:
      ·op_plus ·a_2, ·b_3, ·ƒret_9

    ·main_1 = ·v_16 = fn [·ƒret_17]:
      ·add_0 ·ƒret_17, 3, 4

    ·export ·add_0, ·main_1

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·double_0 = ·v_11 = fn [·ƒret_12, ·x_3]:
      ·op_mul ·x_3, 2, ·ƒret_12

    ·inc_1 = ·v_19 = fn [·ƒret_20, ·x_4]:
      ·op_plus ·x_4, 1, ·ƒret_20

    ·v_55 = fn {·ƒret_56}, [·v_31]:
      ·x_5 = ·v_31
      ·inc_1 ·ƒret_56, ·x_5

    ·main_2 = ·v_27 = fn [·ƒret_28]:
      ·v_60 = ·closure ·v_55, ·ƒret_28
      ·double_0 ·v_60, 5

    ·export ·double_0, ·inc_1, ·main_2

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·v_50 = fn {·ƒret_51}, [·v_12]:
      ·a_2 = ·v_12
      ·op_plus ·a_2, 1, ·ƒret_51

    ·v_69 = fn {·ƒsucc_70, ·v_72, ·ƒfail_74}, [·v_19]:
      if ·v_19,
        fn:
          ·ƒsucc_70 ·v_72
        fn:
          ·ƒfail_74 _

    ·v_58 = fn {·ƒsucc_59, ·ƒfail_61}, [·v_12, ·v_16]:
      ·v_78 = ·closure ·v_69, ·ƒsucc_59, ·v_12, ·ƒfail_61
      ·empty ·v_16, ·v_78

    ·v_27 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_65 = ·closure ·v_58, ·ƒsucc_10, ·ƒfail_11
      ·seq_pop ·v_9, ·ƒfail_11, ·v_65

    ·main_0 = ·v_6 = fn [·ƒret_7, ·foo_1]:
      ·v_53 = ·closure ·v_50, ·ƒret_7
      ·v_27 ·v_53, panic, ·foo_1

    ·export ·main_0


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·v_44 = fn {·ƒret_45}, [·v_12]:
      ·x_2 = ·v_12
      ·op_plus ·x_2, 1, ·ƒret_45

    ·v_52 = fn {·ƒsucc_53}, [·v_12, ·v_16]:
      ·ƒsucc_53 ·v_12

    ·v_21 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_57 = ·closure ·v_52, ·ƒsucc_10
      ·rec_pop ·v_9, 'x', ·ƒfail_11, ·v_57

    ·main_0 = ·v_6 = fn [·ƒret_7, ·foo_1]:
      ·v_47 = ·closure ·v_44, ·ƒret_7
      ·v_21 ·v_47, panic, ·foo_1

    ·export ·main_0


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·v_31 = fn [·ƒret_27]:
      ·ƒret_27 42

    ·v_74 = fn {·ƒsucc_75}:
      ·v_31 ·ƒsucc_75

    ·v_82 = fn {·ƒsucc_83, ·ƒfail_85}, [·v_17]:
      if ·v_17,
        fn:
          ·ƒsucc_83 _
        fn:
          ·ƒfail_85 _

    ·v_25 = fn [·ƒsucc_13, ·ƒfail_14, ·v_12]:
      ·v_89 = ·closure ·v_82, ·ƒsucc_13, ·ƒfail_14
      ·op_eq ·v_12, 0, ·v_89

    ·v_43 = fn [·ƒsucc_9, ·ƒfail_10, ·v_8]:
      ·v_77 = ·closure ·v_74, ·ƒsucc_9
      ·v_25 ·v_77, ·ƒfail_10, ·v_8

    ·ƒret_71 = fn:
      panic _

    ·v_52 = fn [·ƒret_45, ·v_44]:
      ·v_43 ·ƒret_45, ·ƒret_71, ·v_44

    ·foo_0 = ·v_5 = fn [·ƒret_6, ·n_1]:
      ·v_52 ·ƒret_6, ·n_1

    ·export ·foo_0


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·v_76 = fn {·n_77}, [·ƒret_28]:
      ·op_plus ·n_77, 1, ·ƒret_28

    ·v_97 = fn {·v_98, ·ƒsucc_100}:
      ·v_98 ·ƒsucc_100

    ·v_119 = fn {·ƒsucc_120, ·ƒfail_122}, [·v_18]:
      if ·v_18,
        fn:
          ·ƒsucc_120 _
        fn:
          ·ƒfail_122 _

    ·v_26 = fn [·ƒsucc_14, ·ƒfail_15, ·v_13]:
      ·v_126 = ·closure ·v_119, ·ƒsucc_14, ·ƒfail_15
      ·op_eq ·v_13, 0, ·v_126

    ·v_83 = fn {·v_84}, [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_102 = ·closure ·v_97, ·v_84, ·ƒsucc_10
      ·v_26 ·v_102, ·ƒfail_11, ·v_9

    ·ƒret_115 = fn:
      panic _

    ·v_90 = fn {·v_91}, [·ƒret_48, ·v_47]:
      ·v_91 ·ƒret_48, ·ƒret_115, ·v_47

    ·v_106 = fn {·ƒret_107}, [·v_56]:
      ·r_2 = ·v_56
      ·ƒret_107 ·r_2

    ·foo_0 = ·v_6 = fn [·ƒret_7, ·n_1]:
      ·v_79 = ·closure ·v_76, ·n_1
      ·v_86 = ·closure ·v_83, ·v_79
      ·v_93 = ·closure ·v_90, ·v_86
      ·v_111 = ·closure ·v_106, ·ƒret_7
      ·v_93 ·v_111, ·n_1

    ·export ·foo_0


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·v_32 = fn [·ƒret_28]:
      ·ƒret_28 1

    ·v_128 = fn {·ƒsucc_129}:
      ·v_32 ·ƒsucc_129

    ·v_165 = fn {·ƒsucc_166, ·ƒfail_168}, [·v_18]:
      if ·v_18,
        fn:
          ·ƒsucc_166 _
        fn:
          ·ƒfail_168 _

    ·v_26 = fn [·ƒsucc_14, ·ƒfail_15, ·v_13]:
      ·v_172 = ·closure ·v_165, ·ƒsucc_14, ·ƒfail_15
      ·op_eq ·v_13, 0, ·v_172

    ·v_44 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_131 = ·closure ·v_128, ·ƒsucc_10
      ·v_26 ·v_131, ·ƒfail_11, ·v_9

    ·v_119 = fn {·ƒret_120}, [·v_53]:
      ·fib_0 ·ƒret_120, ·v_53

    ·v_103 = fn {·n_104}, [·ƒret_49]:
      ·v_124 = ·closure ·v_119, ·ƒret_49
      ·op_plus ·n_104, 1, ·v_124

    ·v_112 = fn {·v_113}, [·ƒsucc_46, ·ƒfail_47, ·v_45]:
      ·v_113 ·ƒsucc_46

    ·ƒret_176 = fn:
      panic _

    ·v_152 = fn {·v_153, ·ƒret_155, ·v_157}:
      ·v_153 ·ƒret_155, ·ƒret_176, ·v_157

    ·v_135 = fn {·v_136}, [·ƒret_67, ·v_66]:
      ·v_161 = ·closure ·v_152, ·v_136, ·ƒret_67, ·v_66
      ·v_44 ·ƒret_67, ·v_161, ·v_66

    ·v_143 = fn {·ƒret_144}, [·v_79]:
      ·r_2 = ·v_79
      ·ƒret_144 ·r_2

    ·fib_0 = ·v_6 = fn [·ƒret_7, ·n_1]:
      ·v_106 = ·closure ·v_103, ·n_1
      ·v_115 = ·closure ·v_112, ·v_106
      ·v_138 = ·closure ·v_135, ·v_115
      ·v_148 = ·closure ·v_143, ·ƒret_7
      ·v_138 ·v_148, ·n_1

    ·export ·fib_0


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn [·ƒret_5]:
      ·op_eq 'hello', 'hello', ·ƒret_5

    ·export ·main_0


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·main_0 = ·v_4 = fn [·ƒret_5]:
      ·ƒret_5 'hello'

    ·export ·main_0

# TODO not sure this is correct
test 'match — seq literal guard', fn:
  expect lift ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        _: 0

  | equals ƒink:
    ·v_63 = fn [·ƒret_59, ·val_1]:
      ·ƒret_59 ·val_1

    ·v_183 = fn {·v_184, ·ƒsucc_186}:
      ·val_1 = ·v_184
      ·v_63 ·ƒsucc_186, ·v_184

    ·v_217 = fn {·ƒsucc_218, ·ƒfail_220}, [·v_47]:
      if ·v_47,
        fn:
          ·ƒsucc_218 _
        fn:
          ·ƒfail_220 _

    ·v_55 = fn [·ƒsucc_43, ·ƒfail_44, ·v_42]:
      ·v_224 = ·closure ·v_217, ·ƒsucc_43, ·ƒfail_44
      ·op_eq ·v_42, 1, ·v_224

    ·v_170 = fn {·ƒsucc_171, ·ƒfail_173}, [·v_21, ·v_22]:
      ·v_188 = ·closure ·v_183, ·v_22, ·ƒsucc_171
      ·v_55 ·v_188, ·ƒfail_173, ·v_21

    ·v_228 = fn {·ƒsucc_229, ·v_231, ·v_233}, [·v_29, ·v_30]:
      ·ƒsucc_229 ·v_231, ·v_233

    ·v_204 = fn {·ƒfail_205, ·ƒsucc_207, ·v_209}, [·v_22, ·v_27]:
      ·v_237 = ·closure ·v_228, ·ƒsucc_207, ·v_209, ·v_22
      ·seq_pop ·v_27, ·ƒfail_205, ·v_237

    ·v_192 = fn {·ƒfail_193, ·ƒsucc_195}, [·v_21, ·v_33]:
      ·v_213 = ·closure ·v_204, ·ƒfail_193, ·ƒsucc_195, ·v_21
      ·seq_pop ·v_33, ·ƒfail_193, ·v_213

    ·v_40 = fn [·ƒsucc_19, ·ƒfail_20, ·v_18]:
      ·v_199 = ·closure ·v_192, ·ƒfail_20, ·ƒsucc_19
      ·seq_pop ·v_18, ·ƒfail_20, ·v_199

    ·v_85 = fn [·ƒsucc_15, ·ƒfail_16, ·v_14]:
      ·v_175 = ·closure ·v_170, ·ƒsucc_15, ·ƒfail_16
      ·v_40 ·v_175, ·ƒfail_16, ·v_14

    ·v_94 = fn [·ƒret_90]:
      ·ƒret_90 0

    ·v_99 = fn [·ƒsucc_87, ·ƒfail_88, ·v_86]:
      ·v_94 ·ƒsucc_87

    ·ƒret_179 = fn:
      panic _

    ·v_159 = fn {·ƒret_160, ·v_162}:
      ·v_99 ·ƒret_160, ·ƒret_179, ·v_162

    ·v_112 = fn [·ƒret_101, ·v_100]:
      ·v_166 = ·closure ·v_159, ·ƒret_101, ·v_100
      ·v_85 ·ƒret_101, ·v_166, ·v_100

    ·v_145 = fn {·ƒret_146}, [·v_12]:
      ·v_112 ·ƒret_146, ·v_12

    ·v_136 = fn {·ƒret_137}, [·v_9]:
      ·v_150 = ·closure ·v_145, ·ƒret_137
      ·seq_prepend 1, ·v_9, ·v_150

    ·main_0 = ·v_5 = fn [·ƒret_6]:
      ·v_141 = ·closure ·v_136, ·ƒret_6
      ·seq_prepend 42, [], ·v_141

    ·export ·main_0

# TODO not sure this is correct
test 'match — rec literal guard', fn:
  expect lift ƒink:
    main = fn:
      match {kind: 1, val: 42}:
        {kind: 1, val}: val
        _: 0

  | equals ƒink:
    ·v_62 = fn [·ƒret_58, ·val_1]:
      ·ƒret_58 ·val_1

    ·v_182 = fn {·v_183, ·ƒsucc_185}:
      ·val_1 = ·v_183
      ·v_62 ·ƒsucc_185, ·v_183

    ·v_214 = fn {·ƒsucc_215, ·ƒfail_217}, [·v_46]:
      if ·kind_46,
        fn:
          ·ƒsucc_215 _
        fn:
          ·ƒfail_217 _

    ·v_54 = fn [·ƒsucc_42, ·ƒfail_43, ·v_41]:
      ·v_221 = ·closure ·v_214, ·ƒsucc_42, ·ƒfail_43
      ·op_eq ·kind_41, 1, ·v_221

    ·v_169 = fn {·ƒsucc_170, ·ƒfail_172}, [·v_23, ·v_24]:
      ·v_187 = ·closure ·v_182, ·v_24, ·ƒsucc_170
      ·kind_54 ·v_187, ·ƒfail_172, ·v_23

    ·v_203 = fn {·ƒsucc_204, ·v_206}, [·v_24, ·v_29]:
      ·ƒsucc_204 ·v_206, ·v_24

    ·v_191 = fn {·ƒfail_192, ·ƒsucc_194}, [·v_23, ·v_30]:
      ·v_210 = ·closure ·v_203, ·ƒsucc_194, ·v_23
      ·rec_pop ·v_30, 'val', ·ƒfail_192, ·v_210

    ·v_39 = fn [·ƒsucc_21, ·ƒfail_22, ·v_20]:
      ·v_198 = ·closure ·v_191, ·ƒfail_22, ·ƒsucc_21
      ·rec_pop ·v_20, 'kind', ·ƒfail_22, ·v_198

    ·v_84 = fn [·ƒsucc_17, ·ƒfail_18, ·v_16]:
      ·v_174 = ·closure ·v_169, ·ƒsucc_17, ·ƒfail_18
      ·v_39 ·v_174, ·ƒfail_18, ·v_16

    ·v_93 = fn [·ƒret_89]:
      ·ƒret_89 0

    ·v_98 = fn [·ƒsucc_86, ·ƒfail_87, ·v_85]:
      ·v_93 ·ƒsucc_86

    ·ƒret_178 = fn:
      panic _

    ·v_158 = fn {·ƒret_159, ·v_161}:
      ·v_98 ·ƒret_159, ·ƒret_178, ·v_161

    ·v_111 = fn [·ƒret_100, ·v_99]:
      ·v_165 = ·closure ·v_158, ·ƒret_100, ·v_99
      ·v_84 ·ƒret_100, ·v_165, ·v_99

    ·v_144 = fn {·ƒret_145}, [·v_14]:
      ·v_111 ·ƒret_145, ·v_14

    ·v_135 = fn {·ƒret_136}, [·v_10]:
      ·v_149 = ·closure ·v_144, ·ƒret_136
      ·rec_put ·v_10, 'val', 42, ·v_149

    ·main_0 = ·v_5 = fn [·ƒret_6]:
      ·v_140 = ·closure ·v_135, ·ƒret_6
      ·rec_put {}, 'kind', 1, ·v_140

    ·export ·main_0
