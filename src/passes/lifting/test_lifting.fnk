test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_23, ·ƒret_3:
      ·v_6 = fn [·ƒret_7, ·b_2]:
        ·ƒret_7 ·b_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·ƒret_5 ·v_6
      ·ƒpub ·foo_0
      ·ƒret_3 ·foo_0
