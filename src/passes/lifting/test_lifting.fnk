---
pattern matching — the main bug surface for forward refs
---

test 'match — no forward refs after lift', fn:
  expect lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·f_31 = fn ·f_11:
      ·v_13 = 42
      ·f_11 ·v_13

    foo = ·v_1 = fn n, ·f_3:
      ·match_arm fn ·v_8, ·f_6, ·f_7:
        ·match_value ·v_8, 0, ·f_6, ·f_7, ·f_31, fn ·v_18:
        ·match_block n, ·v_18, ·f_3

    ·f_0 foo


test 'seq destructure', fn:
  expect lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_35 = fn ·f_36, ·v_6, ·v_7:
      a = ·v_6
      ·match_done ·v_7, panic, fn ·v_11:
        ·op_plus a, 1, ·f_36

    ·f_43 = fn ·v_5:
      ·v_40 = ·fn_closure ·v_35, ·f_3
      ·match_next ·v_5, panic, ·f_40

    main = ·v_1 = fn foo, ·f_3:
      ·match_seq foo, panic, ·f_43

    ·f_0 main


test 'record destructure', fn:
  expect lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_32 = fn ·f_33, ·v_6, ·v_7:
      x = ·v_6
      ·op_plus x, 1, ·f_33

    ·f_40 = fn ·v_5:
      ·v_37 = ·fn_closure ·v_32, ·f_3
      ·match_field ·v_5, 'x', panic, ·f_37

    main = ·v_1 = fn foo, ·f_3:
      ·match_rec foo, panic, ·f_40

    ·f_0 main


test 'match with binding', fn:
  expect lift fink":
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals fink":
    ·v_37 = fn ·f_38, ·v_22:
      r = ·v_22
      ·f_38 r

    ·v_45 = fn n, ·v_20:
      ·v_42 = ·fn_closure ·v_37, ·f_3
      ·match_block n, ·v_20, ·f_42

    ·v_55 = fn n, ·v_50:
      ·match_arm fn ·v_8, ·f_6, ·f_7:
        ·match_value ·v_8, 0, ·f_6, ·f_7, fn ·f_11:
        ·op_plus n, 1, ·f_11, ·f_50

    foo = ·v_1 = fn n, ·f_3:
      ·v_60 = ·fn_closure ·v_55, n
      ·fn_closure ·v_45, n, ·f_60

    ·f_0 foo


test 'recursive fn in match', fn:
  expect lift fink":
    fib = fn n:
      r = match n:
        0: 1
        _: fib (n + 1)
      r

  | equals fink":
    ·v_56 = fn ·f_57, ·v_39:
      r = ·v_39
      ·f_57 r

    ·v_64 = fn n, ·v_37:
      ·v_61 = ·fn_closure ·v_56, ·f_3
      ·match_block n, ·v_18, ·v_37, ·f_61

    ·v_89 = fn n, ·f_24:
      ·op_plus n, 1, fn ·v_28:
        fib ·v_28, ·f_24

    ·v_101 = fn ·f_102, ·v_94:
      ·match_arm fn ·v_22, ·f_20, ·f_21:
        ·f_21 _, ·f_94, ·f_102

    ·f_97 = fn ·v_69:
      ·v_106 = ·fn_closure ·v_101, ·v_69
      ·fn_closure ·v_89, n, ·f_106

    ·v_72 = fn n, ·v_18:
      ·fn_closure ·v_64, n, ·f_97

    ·f_83 = fn ·f_11:
      ·v_13 = 1
      ·f_11 ·v_13

    ·f_85 = fn ·v_77:
      ·match_arm fn ·v_8, ·f_6, ·f_7:
        ·match_value ·v_8, 0, ·f_6, ·f_7, ·f_83, ·f_77

    fib = ·v_1 = fn n, ·f_3:
      ·fn_closure ·v_72, n, ·f_85

    ·f_0 fib
