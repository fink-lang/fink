---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Test format:
#   test 'name', fn:
#     expect lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected lifted CPS>

{test, equals, expect, fink, lift} = import 'fake!'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift fink":
    f = fn x: x

  | equals fink":
    ·f_0 = ·v_3 = fn ·x_1, ·v_4:
      ·v_6 = ·x_1
      ·v_4 ·v_6

    ·v_2 ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·v_6 = fn ·b_2, ·v_7:
      ·v_9 = ·b_2
      ·v_7 ·v_9

    ·foo_0 = ·v_4 = fn ·a_1, ·v_5:
      ·v_5 ·v_6

    ·v_3 ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_23 = fn ·v_24, ·v_7:
      ·x_1 = ·v_7
      ·op_plus ·x_1, 4, ·v_24

    ·main_0 = ·v_3 = fn ·v_4:
      ·v_28 = ·closure ·v_23, ·v_4
      ·op_mul 2, 3, ·v_28

    ·v_2 ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_20 = fn ·a_21, ·b_2, ·v_7:
      ·op_plus ·a_21, ·b_2, ·v_7

    ·foo_0 = ·v_4 = fn ·a_1, ·v_5:
      ·closure ·v_20, ·a_1, ·v_5

    ·v_3 ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift fink":
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_8 = fn ·x_2, ·v_9:
      ·v_11 = ·x_2
      ·v_9 ·v_11

    ·v_38 = fn ·a_39, ·b_4, ·v_17:
      ·op_plus ·a_39, ·b_4, ·v_17

    ·v_14 = fn ·a_3, ·v_15:
      ·closure ·v_38, ·a_3, ·v_15

    ·v_6 = fn ·v_7:
      ·f_0 = ·v_8
      ·g_1 = ·v_14
      ·v_7 ·g_1

    ·v_5 ·v_6


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_46 = fn ·c_47, ·v_49, ·v_13:
      ·op_plus ·v_13, ·c_47, ·v_49

    ·v_37 = fn ·a_38, ·b_40, ·c_3, ·v_10:
      ·v_53 = ·closure ·v_46, ·c_3, ·v_10
      ·op_plus ·a_38, ·b_40, ·v_53

    ·v_30 = fn ·a_31, ·b_2, ·v_8:
      ·closure ·v_37, ·a_31, ·b_2, ·v_8

    ·foo_0 = ·v_5 = fn ·a_1, ·v_6:
      ·closure ·v_30, ·a_1, ·v_6

    ·v_4 ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_32 = fn ·a_33, ·b_35, ·c_3, ·v_10:
      ·op_plus ·a_33, ·b_35, ·v_10

    ·v_25 = fn ·a_26, ·b_2, ·v_8:
      ·closure ·v_32, ·a_26, ·b_2, ·v_8

    ·foo_0 = ·v_5 = fn ·a_1, ·v_6:
      ·closure ·v_25, ·a_1, ·v_6

    ·v_4 ·foo_0


test 'yield — cont body lifted', fn:
  expect lift fink":
    main = fn:
      q = yield 42
      1 + q

  | equals fink":
    ·v_22 = fn ·v_23, ·v_6:
      ·q_1 = ·v_6
      ·op_plus 1, ·q_1, ·v_23

    ·main_0 = ·v_3 = fn ·v_4:
      ·v_27 = ·closure ·v_22, ·v_4
      ·yield 42, ·v_27

    ·v_2 ·main_0


test 'multi-fn module — add and main', fn:
  expect lift fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    ·v_7 = fn ·a_2, ·b_3, ·v_8:
      ·op_plus ·a_2, ·b_3, ·v_8

    ·v_15 = fn ·v_16:
      ·add_0 3, 4, ·v_16

    ·v_5 = fn ·v_6:
      ·add_0 = ·v_7
      ·main_1 = ·v_15
      ·v_6 ·main_1

    ·v_4 ·v_5

---
pattern matching
---

test 'seq destructure', fn:
  expect lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_53 = fn ·a_54, ·v_56, ·v_12:
      ·op_plus ·a_54, 1, ·v_56

    ·v_44 = fn ·v_45, ·v_8, ·v_9:
      ·a_2 = ·v_8
      ·v_60 = ·closure ·v_53, ·a_2, ·v_45
      ·match_done ·v_9, panic, ·v_60

    ·v_35 = fn ·v_36, ·v_7:
      ·v_49 = ·closure ·v_44, ·v_36
      ·match_next ·v_7, panic, ·v_49

    ·main_0 = ·v_4 = fn ·foo_1, ·v_5:
      ·v_40 = ·closure ·v_35, ·v_5
      ·match_seq ·foo_1, panic, ·v_40

    ·v_3 ·main_0


test 'record destructure', fn:
  expect lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_41 = fn ·v_42, ·v_8, ·v_9:
      ·x_2 = ·v_8
      ·op_plus ·x_2, 1, ·v_42

    ·v_32 = fn ·v_33, ·v_7:
      ·v_46 = ·closure ·v_41, ·v_33
      ·match_field ·v_7, 'x', panic, ·v_46

    ·main_0 = ·v_4 = fn ·foo_1, ·v_5:
      ·v_37 = ·closure ·v_32, ·v_5
      ·match_rec ·foo_1, panic, ·v_37

    ·v_3 ·main_0


test 'match — no forward refs after lift', fn:
  expect lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·v_31 = fn ·n_32, ·v_34, ·v_19:
      ·match_block ·n_32, ·v_19, ·v_34

    ·v_45 = fn ·v_12:
      ·v_14 = 42
      ·v_12 ·v_14

    ·v_48 = fn ·v_9, ·v_7, ·v_8:
      ·match_value ·v_9, 0, ·v_7, ·v_8

    ·v_42 = fn ·v_38:
      ·match_arm ·v_48, ·v_45, ·v_38

    ·foo_0 = ·v_3 = fn ·n_1, ·v_4:
      ·closure ·v_31, ·n_1, ·v_4, ·v_42

    ·v_2 ·foo_0



test 'match with binding', fn:
  expect lift fink":
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals fink":
    ·v_57 = fn ·v_58, ·v_24:
      ·r_2 = ·v_24
      ·v_58 ·r_2

    ·v_37 = fn ·n_38, ·v_40, ·v_22:
      ·v_62 = ·closure ·v_57, ·v_40
      ·match_block ·n_38, ·v_22, ·v_62

    ·v_48 = fn ·n_49, ·v_13:
      ·op_plus ·n_49, 1, ·v_13

    ·v_66 = fn ·v_10, ·v_8, ·v_9:
      ·match_value ·v_10, 0, ·v_8, ·v_9

    ·foo_0 = ·v_4 = fn ·n_1, ·v_5:
      ·v_44 = ·closure ·v_37, ·n_1, ·v_5
      ·v_53 = ·closure ·v_48, ·n_1
      ·match_arm ·v_66, ·v_53, ·v_44

    ·v_3 ·foo_0


test 'recursive fn in match', fn:
  expect lift fink":
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals fink":
    ·v_95 = fn ·v_96, ·v_41:
      ·r_2 = ·v_41
      ·v_96 ·r_2

    ·v_70 = fn ·n_71, ·v_73, ·v_75, ·v_39:
      ·v_100 = ·closure ·v_95, ·v_75
      ·match_block ·n_71, ·v_73, ·v_39, ·v_100

    ·v_110 = fn ·v_111, ·v_30:
      ·fib_0 ·v_30, ·v_111

    ·v_86 = fn ·n_87, ·v_26:
      ·v_115 = ·closure ·v_110, ·v_26
      ·op_plus ·n_87, 1, ·v_115

    ·v_107 = fn ·v_24, ·v_22, ·v_23:
      ·v_23 _

    ·v_56 = fn ·n_57, ·v_59, ·v_20:
      ·v_79 = ·closure ·v_70, ·n_57, ·v_20, ·v_59
      ·v_91 = ·closure ·v_86, ·n_57
      ·match_arm ·v_107, ·v_91, ·v_79

    ·v_83 = fn ·v_13:
      ·v_15 = 1
      ·v_13 ·v_15

    ·v_104 = fn ·v_10, ·v_8, ·v_9:
      ·match_value ·v_10, 0, ·v_8, ·v_9

    ·v_67 = fn ·v_63:
      ·match_arm ·v_104, ·v_83, ·v_63

    ·fib_0 = ·v_4 = fn ·n_1, ·v_5:
      ·closure ·v_56, ·n_1, ·v_5, ·v_67

    ·v_3 ·fib_0
