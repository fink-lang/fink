        ·foo_0 = ·v_10
        ·ƒret_51 ·foo_0
      ·v_67 = fn {·ƒfail_68}:
        ·ƒfail_68 _
      ·v_98 = fn {·ƒsucc_99}, [·v_10, ·v_14]:
        ·ƒsucc_99 ·v_10
      ·v_81 = fn {·ƒfail_82, ·ƒsucc_84}, [·v_15]:
        ·v_103 = ·closure ·v_98, ·ƒsucc_84
        ·rec_pop ·v_15, 'foo', ·ƒfail_82, ·v_103
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_72 = ·closure ·v_67, ·ƒfail_9
        ·v_88 = ·closure ·v_81, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_88, ·v_72
      ·v_41 = fn {·ƒret_42}, [·v_5]:
        ·v_53 = ·closure ·v_50, ·ƒret_42
        ·v_24 ·v_53, ·panic, ·v_5
      ·ƒret_57 = fn [·v_46]:
        ·import './bar.fnk', ·v_46
      ·closure ·v_41, ·ƒret_2, ·ƒret_57
    # sm:


---
Regression test for the fooobar lifting bug — module with multiple
top-level fns where the results of calls are bound to names. Previously
downstream wasm emit panicked with `unknown local: add_0` because capture
analysis didn't track LetVal names that aliased hoisted fn references
(`add_0 = v_14` where v_14 is the hoisted add-fn). Nested inline conts
referencing `add_0` couldn't see it in scope_binds and therefore didn't
capture it. Fixed by always adding LetVal names to scope_binds during
extraction, regardless of whether the val aliases a hoisted fn.
---

test 'multiple top-level fns with bound call results', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_62, ·ƒret_8:
      ·v_9 = fn [·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_77 = fn {·ƒret_78}, [·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3
        ·ƒret_78 ·p_3
      ·v_64 = fn {·ƒret_65}, [·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1
        ·mul_2 = ·v_22
        ·ƒpub ·mul_2
        ·v_82 = ·closure ·v_77, ·ƒret_65
        ·mul_2 ·v_82, ·s_1, (i8 3)
      ·add_0 = ·v_9
      ·ƒpub ·add_0
      ·ƒret_74 = fn [·v_69]:
        ·add_0 ·v_69, (i8 1), (i8 2)
      ·closure ·v_64, ·ƒret_8, ·ƒret_74
    # sm:



test 'spawn with closure over channel', fn:
  expect lift ƒink:
    ch = channel 0
    fut = spawn fn:
      receive ch
    77 >> ch
    result = await fut
    result

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_7:
      ·v_69 = fn {·ch_70}, [·ƒret_14]:
        ·receive ·ch_70, ·ƒret_14
      ·v_112 = fn {·ƒret_113}, [·v_30]:
        ·result_2 = ·v_30
        ·ƒpub ·result_2
        ·ƒret_113 ·result_2
      ·v_96 = fn {·fut_97, ·ƒret_99}, [·v_25]:
        ·v_27 = ·v_25
        ·v_117 = ·closure ·v_112, ·ƒret_99
        ·await ·fut_97, ·v_117
      ·v_81 = fn {·ch_82, ·ƒret_84}, [·v_21]:
        ·fut_1 = ·v_21
        ·ƒpub ·fut_1
        ·v_103 = ·closure ·v_96, ·fut_1, ·ƒret_84
        ·op_shr (i8 77), ·ch_82, ·v_103
      ·v_60 = fn {·ƒret_61}, [·v_10]:
        ·ch_0 = ·v_10
        ·ƒpub ·ch_0
        ·v_72 = ·closure ·v_69, ·ch_0
        ·v_88 = ·closure ·v_81, ·ch_0, ·ƒret_61
        ·spawn ·v_72, ·v_88
      ·ƒret_76 = fn [·v_65]:
        ·channel (i8 0), ·v_65
      ·closure ·v_60, ·ƒret_7, ·ƒret_76
    # sm:

AA

