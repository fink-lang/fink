test 'match arm refs top-level binding', fn:
  expect lift ƒink:
    x = 5
    match x:
      0: 0
      _: x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_86, ·ƒret_1:
      ·v_27 = fn [·ƒret_23]:
        ·ƒret_23 (i8 0)
      ·v_115 = fn {·ƒsucc_116}:
        ·v_27 ·ƒsucc_116
      ·v_148 = fn {·ƒsucc_149, ·ƒfail_151}, [·v_13]:
        ·if ·v_13,
          fn:
            ·ƒsucc_149 _
          fn:
            ·ƒfail_151 _
      ·v_21 = fn [·ƒsucc_9, ·ƒfail_10, ·v_8]:
        ·v_155 = ·closure ·v_148, ·ƒsucc_9, ·ƒfail_10
        ·op_eq ·v_8, (i8 0), ·v_155
      ·v_39 = fn [·ƒsucc_5, ·ƒfail_6, ·v_4]:
        ·v_118 = ·closure ·v_115, ·ƒsucc_5
        ·v_21 ·v_118, ·ƒfail_6, ·v_4
