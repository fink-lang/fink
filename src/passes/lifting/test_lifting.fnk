---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·v_5 = fn [·ƒret_6, ·x_1]:
      ·ƒret_6 ·x_1

    ·v_15 = fn:
      ·f_0 = ·v_5
      ·export ·f_0

    ·module_init ·v_15


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·v_8 = fn [·ƒret_9, ·b_2]:
      ·ƒret_9 ·b_2

    ·v_6 = fn [·ƒret_7, ·a_1]:
      ·ƒret_7 ·v_8

    ·v_20 = fn:
      ·foo_0 = ·v_6
      ·export ·foo_0

    ·module_init ·v_20


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·v_30 = fn {·ƒret_31}, [·v_9]:
      ·x_1 = ·v_9
      ·op_plus ·x_1, 4, ·ƒret_31

    ·v_5 = fn [·ƒret_6]:
      ·v_35 = ·closure ·v_30, ·ƒret_6
      ·op_mul 2, 3, ·v_35

    ·v_25 = fn:
      ·main_0 = ·v_5
      ·export ·main_0

    ·module_init ·v_25


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·v_27 = fn {·a_28}, [·ƒret_9, ·b_2]:
      ·op_plus ·a_28, ·b_2, ·ƒret_9

    ·v_6 = fn [·ƒret_7, ·a_1]:
      ·closure ·v_27, ·a_1, ·ƒret_7

    ·v_22 = fn:
      ·foo_0 = ·v_6
      ·export ·foo_0

    ·module_init ·v_22


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·v_9 = fn [·ƒret_10, ·x_2]:
      ·ƒret_10 ·x_2

    ·v_41 = fn {·a_42}, [·ƒret_18, ·b_4]:
      ·op_plus ·a_42, ·b_4, ·ƒret_18

    ·v_15 = fn [·ƒret_16, ·a_3]:
      ·closure ·v_41, ·a_3, ·ƒret_16

    ·v_35 = fn:
      ·f_0 = ·v_9
      ·g_1 = ·v_15
      ·export ·f_0, ·g_1

    ·module_init ·v_35


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·v_53 = fn {·c_54, ·ƒret_56}, [·v_15]:
      ·op_plus ·v_15, ·c_54, ·ƒret_56

    ·v_44 = fn {·a_45, ·b_47}, [·ƒret_12, ·c_3]:
      ·v_60 = ·closure ·v_53, ·c_3, ·ƒret_12
      ·op_plus ·a_45, ·b_47, ·v_60

    ·v_37 = fn {·a_38}, [·ƒret_10, ·b_2]:
      ·closure ·v_44, ·a_38, ·b_2, ·ƒret_10

    ·v_7 = fn [·ƒret_8, ·a_1]:
      ·closure ·v_37, ·a_1, ·ƒret_8

    ·v_32 = fn:
      ·foo_0 = ·v_7
      ·export ·foo_0

    ·module_init ·v_32


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·v_39 = fn {·a_40, ·b_42}, [·ƒret_12, ·c_3]:
      ·op_plus ·a_40, ·b_42, ·ƒret_12

    ·v_32 = fn {·a_33}, [·ƒret_10, ·b_2]:
      ·closure ·v_39, ·a_33, ·b_2, ·ƒret_10

    ·v_7 = fn [·ƒret_8, ·a_1]:
      ·closure ·v_32, ·a_1, ·ƒret_8

    ·v_27 = fn:
      ·foo_0 = ·v_7
      ·export ·foo_0

    ·module_init ·v_27


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·v_8 = fn [·ƒret_9, ·a_2, ·b_3]:
      ·op_plus ·a_2, ·b_3, ·ƒret_9

    ·v_37 = fn {·add_38}, [·ƒret_17]:
      ·add_38 ·ƒret_17, 3, 4

    ·v_33 = fn:
      ·add_0 = ·v_8
      ·v_40 = ·closure ·v_37, ·add_0
      ·main_1 = ·v_40
      ·export ·add_0, ·main_1

    ·module_init ·v_33

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·v_11 = fn [·ƒret_12, ·x_3]:
      ·op_mul ·x_3, 2, ·ƒret_12

    ·v_19 = fn [·ƒret_20, ·x_4]:
      ·op_plus ·x_4, 1, ·ƒret_20

    ·v_70 = fn {·inc_71, ·ƒret_73}, [·v_31]:
      ·x_5 = ·v_31
      ·inc_71 ·ƒret_73, ·x_5

    ·v_59 = fn {·double_60, ·inc_62}, [·ƒret_28]:
      ·v_77 = ·closure ·v_70, ·inc_62, ·ƒret_28
      ·double_60 ·v_77, 5

    ·v_55 = fn:
      ·double_0 = ·v_11
      ·inc_1 = ·v_19
      ·v_64 = ·closure ·v_59, ·double_0, ·inc_1
      ·main_2 = ·v_64
      ·export ·double_0, ·inc_1, ·main_2

    ·module_init ·v_55

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·v_60 = fn {·ƒret_61}, [·v_12]:
      ·a_2 = ·v_12
      ·op_plus ·a_2, 1, ·ƒret_61

    ·v_68 = fn {·ƒfail_69}:
      ·ƒfail_69 _

    ·v_99 = fn {·ƒsucc_100, ·v_102, ·ƒfail_104}, [·v_19]:
      if ·v_19,
        fn:
          ·ƒsucc_100 ·v_102
        fn:
          ·ƒfail_104 _

    ·v_88 = fn {·ƒsucc_89, ·ƒfail_91}, [·v_12, ·v_16]:
      ·v_108 = ·closure ·v_99, ·ƒsucc_89, ·v_12, ·ƒfail_91
      ·empty ·v_16, ·v_108

    ·v_77 = fn {·ƒfail_78, ·ƒsucc_80}, [·v_24]:
      ·v_95 = ·closure ·v_88, ·ƒsucc_80, ·ƒfail_78
      ·seq_pop ·v_24, ·ƒfail_78, ·v_95

    ·v_32 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_73 = ·closure ·v_68, ·ƒfail_11
      ·v_84 = ·closure ·v_77, ·ƒfail_11, ·ƒsucc_10
      ·is_seq_like ·v_9, ·v_84, ·v_73

    ·v_6 = fn [·ƒret_7, ·foo_1]:
      ·v_63 = ·closure ·v_60, ·ƒret_7
      ·v_32 ·v_63, panic, ·foo_1

    ·v_55 = fn:
      ·main_0 = ·v_6
      ·export ·main_0

    ·module_init ·v_55


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·v_54 = fn {·ƒret_55}, [·v_12]:
      ·x_2 = ·v_12
      ·op_plus ·x_2, 1, ·ƒret_55

    ·v_62 = fn {·ƒfail_63}:
      ·ƒfail_63 _

    ·v_82 = fn {·ƒsucc_83}, [·v_12, ·v_16]:
      ·ƒsucc_83 ·v_12

    ·v_71 = fn {·ƒfail_72, ·ƒsucc_74}, [·v_17]:
      ·v_87 = ·closure ·v_82, ·ƒsucc_74
      ·rec_pop ·v_17, 'x', ·ƒfail_72, ·v_87

    ·v_26 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_67 = ·closure ·v_62, ·ƒfail_11
      ·v_78 = ·closure ·v_71, ·ƒfail_11, ·ƒsucc_10
      ·is_rec_like ·v_9, ·v_78, ·v_67

    ·v_6 = fn [·ƒret_7, ·foo_1]:
      ·v_57 = ·closure ·v_54, ·ƒret_7
      ·v_26 ·v_57, panic, ·foo_1

    ·v_49 = fn:
      ·main_0 = ·v_6
      ·export ·main_0

    ·module_init ·v_49


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·v_31 = fn [·ƒret_27]:
      ·ƒret_27 42

    ·v_79 = fn {·ƒsucc_80}:
      ·v_31 ·ƒsucc_80

    ·v_87 = fn {·ƒsucc_88, ·ƒfail_90}, [·v_17]:
      if ·v_17,
        fn:
          ·ƒsucc_88 _
        fn:
          ·ƒfail_90 _

    ·v_25 = fn [·ƒsucc_13, ·ƒfail_14, ·v_12]:
      ·v_94 = ·closure ·v_87, ·ƒsucc_13, ·ƒfail_14
      ·op_eq ·v_12, 0, ·v_94

    ·v_43 = fn [·ƒsucc_9, ·ƒfail_10, ·v_8]:
      ·v_82 = ·closure ·v_79, ·ƒsucc_9
      ·v_25 ·v_82, ·ƒfail_10, ·v_8

    ·ƒret_76 = fn:
      panic _

    ·v_52 = fn [·ƒret_45, ·v_44]:
      ·v_43 ·ƒret_45, ·ƒret_76, ·v_44

    ·v_5 = fn [·ƒret_6, ·n_1]:
      ·v_52 ·ƒret_6, ·n_1

    ·v_68 = fn:
      ·foo_0 = ·v_5
      ·export ·foo_0

    ·module_init ·v_68


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·v_81 = fn {·n_82}, [·ƒret_28]:
      ·op_plus ·n_82, 1, ·ƒret_28

    ·v_102 = fn {·v_103, ·ƒsucc_105}:
      ·v_103 ·ƒsucc_105

    ·v_124 = fn {·ƒsucc_125, ·ƒfail_127}, [·v_18]:
      if ·v_18,
        fn:
          ·ƒsucc_125 _
        fn:
          ·ƒfail_127 _

    ·v_26 = fn [·ƒsucc_14, ·ƒfail_15, ·v_13]:
      ·v_131 = ·closure ·v_124, ·ƒsucc_14, ·ƒfail_15
      ·op_eq ·v_13, 0, ·v_131

    ·v_88 = fn {·v_89}, [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_107 = ·closure ·v_102, ·v_89, ·ƒsucc_10
      ·v_26 ·v_107, ·ƒfail_11, ·v_9

    ·ƒret_120 = fn:
      panic _

    ·v_95 = fn {·v_96}, [·ƒret_48, ·v_47]:
      ·v_96 ·ƒret_48, ·ƒret_120, ·v_47

    ·v_111 = fn {·ƒret_112}, [·v_56]:
      ·r_2 = ·v_56
      ·ƒret_112 ·r_2

    ·v_6 = fn [·ƒret_7, ·n_1]:
      ·v_84 = ·closure ·v_81, ·n_1
      ·v_91 = ·closure ·v_88, ·v_84
      ·v_98 = ·closure ·v_95, ·v_91
      ·v_116 = ·closure ·v_111, ·ƒret_7
      ·v_98 ·v_116, ·n_1

    ·v_76 = fn:
      ·foo_0 = ·v_6
      ·export ·foo_0

    ·module_init ·v_76


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·v_32 = fn [·ƒret_28]:
      ·ƒret_28 1

    ·v_133 = fn {·ƒsucc_134}:
      ·v_32 ·ƒsucc_134

    ·v_170 = fn {·ƒsucc_171, ·ƒfail_173}, [·v_18]:
      if ·v_18,
        fn:
          ·ƒsucc_171 _
        fn:
          ·ƒfail_173 _

    ·v_26 = fn [·ƒsucc_14, ·ƒfail_15, ·v_13]:
      ·v_177 = ·closure ·v_170, ·ƒsucc_14, ·ƒfail_15
      ·op_eq ·v_13, 0, ·v_177

    ·v_44 = fn [·ƒsucc_10, ·ƒfail_11, ·v_9]:
      ·v_136 = ·closure ·v_133, ·ƒsucc_10
      ·v_26 ·v_136, ·ƒfail_11, ·v_9

    ·v_124 = fn {·ƒret_125}, [·v_53]:
      ·fib_0 ·ƒret_125, ·v_53

    ·v_108 = fn {·n_109}, [·ƒret_49]:
      ·v_129 = ·closure ·v_124, ·ƒret_49
      ·op_plus ·n_109, 1, ·v_129

    ·v_117 = fn {·v_118}, [·ƒsucc_46, ·ƒfail_47, ·v_45]:
      ·v_118 ·ƒsucc_46

    ·ƒret_181 = fn:
      panic _

    ·v_157 = fn {·v_158, ·ƒret_160, ·v_162}:
      ·v_158 ·ƒret_160, ·ƒret_181, ·v_162

    ·v_140 = fn {·v_141}, [·ƒret_67, ·v_66]:
      ·v_166 = ·closure ·v_157, ·v_141, ·ƒret_67, ·v_66
      ·v_44 ·ƒret_67, ·v_166, ·v_66

    ·v_148 = fn {·ƒret_149}, [·v_79]:
      ·r_2 = ·v_79
      ·ƒret_149 ·r_2

    ·v_6 = fn [·ƒret_7, ·n_1]:
      ·v_111 = ·closure ·v_108, ·n_1
      ·v_120 = ·closure ·v_117, ·v_111
      ·v_143 = ·closure ·v_140, ·v_120
      ·v_153 = ·closure ·v_148, ·ƒret_7
      ·v_143 ·v_153, ·n_1

    ·v_103 = fn:
      ·fib_0 = ·v_6
      ·export ·fib_0

    ·module_init ·v_103


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·v_4 = fn [·ƒret_5]:
      ·op_eq 'hello', 'hello', ·ƒret_5

    ·v_16 = fn:
      ·main_0 = ·v_4
      ·export ·main_0

    ·module_init ·v_16


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·v_4 = fn [·ƒret_5]:
      ·ƒret_5 'hello'

    ·v_14 = fn:
      ·main_0 = ·v_4
      ·export ·main_0

    ·module_init ·v_14

test 'match — seq literal guard', fn:
  expect lift ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        _: 0

  | equals ƒink:
    ·v_68 = fn [·ƒret_64, ·val_1]:
      ·ƒret_64 ·val_1

    ·v_193 = fn {·v_194, ·ƒsucc_196}:
      ·val_1 = ·v_194
      ·v_68 ·ƒsucc_196, ·v_194

    ·v_223 = fn {·ƒsucc_224, ·ƒfail_226}, [·v_52]:
      if ·v_52,
        fn:
          ·ƒsucc_224 _
        fn:
          ·ƒfail_226 _

    ·v_60 = fn [·ƒsucc_48, ·ƒfail_49, ·v_47]:
      ·v_230 = ·closure ·v_223, ·ƒsucc_48, ·ƒfail_49
      ·op_eq ·v_47, 1, ·v_230

    ·v_180 = fn {·ƒsucc_181, ·ƒfail_183}, [·v_21, ·v_22]:
      ·v_198 = ·closure ·v_193, ·v_22, ·ƒsucc_181
      ·v_60 ·v_198, ·ƒfail_183, ·v_21

    ·v_202 = fn {·ƒfail_203}:
      ·ƒfail_203 _

    ·v_258 = fn {·ƒsucc_259, ·v_261, ·v_263}, [·v_29, ·v_30]:
      ·ƒsucc_259 ·v_261, ·v_263

    ·v_245 = fn {·ƒfail_246, ·ƒsucc_248, ·v_250}, [·v_22, ·v_27]:
      ·v_267 = ·closure ·v_258, ·ƒsucc_248, ·v_250, ·v_22
      ·seq_pop ·v_27, ·ƒfail_246, ·v_267

    ·v_234 = fn {·ƒfail_235, ·ƒsucc_237}, [·v_21, ·v_34]:
      ·v_254 = ·closure ·v_245, ·ƒfail_235, ·ƒsucc_237, ·v_21
      ·seq_pop ·v_34, ·ƒfail_235, ·v_254

    ·v_212 = fn {·ƒfail_213, ·ƒsucc_215}, [·v_33]:
      ·v_241 = ·closure ·v_234, ·ƒfail_213, ·ƒsucc_215
      ·seq_pop ·v_33, ·ƒfail_213, ·v_241

    ·v_45 = fn [·ƒsucc_19, ·ƒfail_20, ·v_18]:
      ·v_207 = ·closure ·v_202, ·ƒfail_20
      ·v_219 = ·closure ·v_212, ·ƒfail_20, ·ƒsucc_19
      ·is_seq_like ·v_18, ·v_219, ·v_207

    ·v_90 = fn [·ƒsucc_15, ·ƒfail_16, ·v_14]:
      ·v_185 = ·closure ·v_180, ·ƒsucc_15, ·ƒfail_16
      ·v_45 ·v_185, ·ƒfail_16, ·v_14

    ·v_99 = fn [·ƒret_95]:
      ·ƒret_95 0

    ·v_104 = fn [·ƒsucc_92, ·ƒfail_93, ·v_91]:
      ·v_99 ·ƒsucc_92

    ·ƒret_189 = fn:
      panic _

    ·v_169 = fn {·ƒret_170, ·v_172}:
      ·v_104 ·ƒret_170, ·ƒret_189, ·v_172

    ·v_117 = fn [·ƒret_106, ·v_105]:
      ·v_176 = ·closure ·v_169, ·ƒret_106, ·v_105
      ·v_90 ·ƒret_106, ·v_176, ·v_105

    ·v_155 = fn {·ƒret_156}, [·v_12]:
      ·v_117 ·ƒret_156, ·v_12

    ·v_146 = fn {·ƒret_147}, [·v_9]:
      ·v_160 = ·closure ·v_155, ·ƒret_147
      ·seq_prepend 1, ·v_9, ·v_160

    ·v_5 = fn [·ƒret_6]:
      ·v_151 = ·closure ·v_146, ·ƒret_6
      ·seq_prepend 42, [], ·v_151

    ·v_141 = fn:
      ·main_0 = ·v_5
      ·export ·main_0

    ·module_init ·v_141

test 'match — rec literal guard', fn:
  expect lift ƒink:
    main = fn:
      match {kind: 1, val: 42}:
        {kind: 1, val}: val
        _: 0

  | equals ƒink:
    ·v_67 = fn [·ƒret_63, ·val_1]:
      ·ƒret_63 ·val_1

    ·v_192 = fn {·v_193, ·ƒsucc_195}:
      ·val_1 = ·v_193
      ·v_67 ·ƒsucc_195, ·v_193

    ·v_222 = fn {·ƒsucc_223, ·ƒfail_225}, [·v_51]:
      if ·kind_51,
        fn:
          ·ƒsucc_223 _
        fn:
          ·ƒfail_225 _

    ·v_59 = fn [·ƒsucc_47, ·ƒfail_48, ·v_46]:
      ·v_229 = ·closure ·v_222, ·ƒsucc_47, ·ƒfail_48
      ·op_eq ·kind_46, 1, ·v_229

    ·v_179 = fn {·ƒsucc_180, ·ƒfail_182}, [·v_23, ·v_24]:
      ·v_197 = ·closure ·v_192, ·v_24, ·ƒsucc_180
      ·kind_59 ·v_197, ·ƒfail_182, ·v_23

    ·v_201 = fn {·ƒfail_202}:
      ·ƒfail_202 _

    ·v_244 = fn {·ƒsucc_245, ·v_247}, [·v_24, ·v_29]:
      ·ƒsucc_245 ·v_247, ·v_24

    ·v_233 = fn {·ƒfail_234, ·ƒsucc_236}, [·v_23, ·v_31]:
      ·v_251 = ·closure ·v_244, ·ƒsucc_236, ·v_23
      ·rec_pop ·v_31, 'val', ·ƒfail_234, ·v_251

    ·v_211 = fn {·ƒfail_212, ·ƒsucc_214}, [·v_30]:
      ·v_240 = ·closure ·v_233, ·ƒfail_212, ·ƒsucc_214
      ·rec_pop ·v_30, 'kind', ·ƒfail_212, ·v_240

    ·v_44 = fn [·ƒsucc_21, ·ƒfail_22, ·v_20]:
      ·v_206 = ·closure ·v_201, ·ƒfail_22
      ·v_218 = ·closure ·v_211, ·ƒfail_22, ·ƒsucc_21
      ·is_rec_like ·v_20, ·v_218, ·v_206

    ·v_89 = fn [·ƒsucc_17, ·ƒfail_18, ·v_16]:
      ·v_184 = ·closure ·v_179, ·ƒsucc_17, ·ƒfail_18
      ·v_44 ·v_184, ·ƒfail_18, ·v_16

    ·v_98 = fn [·ƒret_94]:
      ·ƒret_94 0

    ·v_103 = fn [·ƒsucc_91, ·ƒfail_92, ·v_90]:
      ·v_98 ·ƒsucc_91

    ·ƒret_188 = fn:
      panic _

    ·v_168 = fn {·ƒret_169, ·v_171}:
      ·v_103 ·ƒret_169, ·ƒret_188, ·v_171

    ·v_116 = fn [·ƒret_105, ·v_104]:
      ·v_175 = ·closure ·v_168, ·ƒret_105, ·v_104
      ·v_89 ·ƒret_105, ·v_175, ·v_104

    ·v_154 = fn {·ƒret_155}, [·v_14]:
      ·v_116 ·ƒret_155, ·v_14

    ·v_145 = fn {·ƒret_146}, [·v_10]:
      ·v_159 = ·closure ·v_154, ·ƒret_146
      ·rec_put ·v_10, 'val', 42, ·v_159

    ·v_5 = fn [·ƒret_6]:
      ·v_150 = ·closure ·v_145, ·ƒret_6
      ·rec_put {}, 'kind', 1, ·v_150

    ·v_140 = fn:
      ·main_0 = ·v_5
      ·export ·main_0

    ·module_init ·v_140


# BROKEN: lift panics with "did not converge after 20 rounds" when a
# top-level pattern destructure's RHS lowers to sub-expressions. The
# pass structurally converges around round 4 but the `needs_lifting`
# predicate keeps reporting more work until the round cap trips.
#
# Ident RHS (e.g. `[a, b] = foo`) does NOT trigger this — the subject
# is a pre-existing value ref and no sub-lowering is needed.
#
# Expected outputs marked TODO — update each once the bug is fixed.

test 'top-level seq destructure with literal rhs — lift non-convergence', fn:
  expect lift ƒink:
    [a, b] = [1, 2]

  | equals ƒink:
    ·v_49 = fn [·v_14, ·v_15]:
      ·a_0 = ·v_14
      ·b_1 = ·v_15
      ·export _

    ·v_72 = fn {·ƒfail_73}:
      ·ƒfail_73 _

    ·v_116 = fn {·ƒsucc_117, ·v_119, ·v_121, ·ƒfail_123}, [·v_23]:
      if ·v_23,
        fn:
          ·ƒsucc_117 ·v_119, ·v_121
        fn:
          ·ƒfail_123 _

    ·v_103 = fn {·ƒsucc_104, ·v_106, ·ƒfail_108}, [·v_15, ·v_20]:
      ·v_127 = ·closure ·v_116, ·ƒsucc_104, ·v_106, ·v_15, ·ƒfail_108
      ·empty ·v_20, ·v_127

    ·v_92 = fn {·ƒfail_93, ·ƒsucc_95}, [·v_14, ·v_29]:
      ·v_112 = ·closure ·v_103, ·ƒsucc_95, ·v_14, ·ƒfail_93
      ·seq_pop ·v_29, ·ƒfail_93, ·v_112

    ·v_81 = fn {·ƒfail_82, ·ƒsucc_84}, [·v_28]:
      ·v_99 = ·closure ·v_92, ·ƒfail_82, ·ƒsucc_84
      ·seq_pop ·v_28, ·ƒfail_82, ·v_99

    ·v_40 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
      ·v_77 = ·closure ·v_72, ·ƒfail_13
      ·v_88 = ·closure ·v_81, ·ƒfail_13, ·ƒsucc_12
      ·is_seq_like ·v_11, ·v_88, ·v_77

    ·ƒret_67 = fn [·v_9]:
      ·v_40 ·v_49, panic, ·v_9

    ·ƒret_64 = fn [·v_6]:
      ·seq_prepend 1, ·v_6, ·ƒret_67

    ·v_60 = fn:
      ·seq_prepend 2, [], ·ƒret_64

    ·module_init ·v_60


