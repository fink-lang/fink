# BROKEN: lift panics with "did not converge after 20 rounds" when a
# top-level pattern destructure's RHS lowers to sub-expressions. The
# pass structurally converges around round 4 but the `needs_lifting`
# predicate keeps reporting more work until the round cap trips.
#
# Ident RHS (e.g. `[a, b] = foo`) does NOT trigger this — the subject
# is a pre-existing value ref and no sub-lowering is needed.
#
# Expected outputs marked TODO — update each once the bug is fixed.

test 'top-level seq destructure with literal rhs — lift non-convergence', fn:
  expect lift ƒink:
    [a, b] = [1, 2]

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_83 = fn {·ƒret_84}, [·v_13, ·v_14]:
        ·a_0 = ·v_13
        ·b_1 = ·v_14
        ·ƒret_84 ·b_1
      ·v_100 = fn {·ƒfail_101}:
        ·ƒfail_101 _
      ·v_174 = fn {·ƒsucc_175, ·v_177, ·v_179, ·ƒfail_181}, [·v_22]:
        ·if ·v_22,
          fn:
            ·ƒsucc_175 ·v_177, ·v_179
          fn:
            ·ƒfail_181 _
      ·v_152 = fn {·ƒsucc_153, ·v_155, ·ƒfail_157}, [·v_14, ·v_19]:
        ·v_185 = ·closure ·v_174, ·ƒsucc_153, ·v_155, ·v_14, ·ƒfail_157
        ·empty ·v_19, ·v_185
      ·v_133 = fn {·ƒfail_134, ·ƒsucc_136}, [·v_13, ·v_28]:
        ·v_161 = ·closure ·v_152, ·ƒsucc_136, ·v_13, ·ƒfail_134
        ·seq_pop ·v_28, ·ƒfail_134, ·v_161
      ·v_115 = fn {·ƒfail_116, ·ƒsucc_118}, [·v_27]:
        ·v_140 = ·closure ·v_133, ·ƒfail_116, ·ƒsucc_118
        ·seq_pop ·v_27, ·ƒfail_116, ·v_140
      ·v_39 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_105 = ·closure ·v_100, ·ƒfail_12
        ·v_122 = ·closure ·v_115, ·ƒfail_12, ·ƒsucc_11
        ·is_seq_like ·v_10, ·v_122, ·v_105
      ·v_69 = fn {·ƒret_70}, [·v_8]:
        ·v_86 = ·closure ·v_83, ·ƒret_70
        ·v_39 ·v_86, ·panic, ·v_8
      ·v_60 = fn {·ƒret_61}, [·v_5]:
        ·v_74 = ·closure ·v_69, ·ƒret_61
        ·seq_prepend 1, ·v_5, ·v_74
      ·ƒret_78 = fn [·v_65]:
        ·seq_prepend 2, [], ·v_65
      ·closure ·v_60, ·ƒret_2, ·ƒret_78


