---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module,·import,·ƒpub, ·closure, ·if, ·panic
  ·op_plus
  ·op_mul
  ·op_eq
  ·empty
  ·is_seq_like
  ·is_rec_like
  ·seq_pop
  ·seq_prepend
  ·rec_put
  ·rec_pop
} = import '@fink/compile/builtins'




test 'single module expr', fn:
  expect lift ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 42


test 'single binding export', fn:
  expect lift ƒink:
    foo = fn: 123
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0, fn:
        ·ƒret_1 ·foo_0

test 'single binding export with trailing expr', fn:
  expect lift ƒink:
    foo = fn: 123
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0, fn:
        ·ƒret_1 42



test 'two fn exports', fn:
  expect lift ƒink:
    foo = fn: 123
    bar = fn: 345
  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_3 = fn [·ƒret_4]:
        ·ƒret_4 123
      ·v_9 = fn [·ƒret_10]:
        ·ƒret_10 345
      ·foo_0 = ·v_3
      ·ƒpub ·foo_0, fn:
        ·bar_1 = ·v_9
        ·ƒpub ·bar_1, fn:
          ·ƒret_2 ·bar_1

test 'fooobar — multi fn with calls', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒret_8:
      ·v_9 = fn [·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_73 = fn {·ƒret_74}, [·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3, fn:
          ·ƒret_74 ·p_3
      ·v_63 = fn {·ƒret_64}, [·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1, fn:
          ·mul_2 = ·v_22
          ·ƒpub ·mul_2, fn:
            ·v_78 = ·closure ·v_73, ·ƒret_64
            ·mul_2 ·v_78, ·s_1, 3
      ·add_0 = ·v_9
      ·ƒpub ·add_0, fn:
        ·v_68 = ·closure ·v_63, ·ƒret_8
        ·add_0 ·v_68, 1, 2


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·f_0 = ·v_3 = fn [·ƒret_4, ·x_1]:
        ·ƒret_4 ·x_1
      ·ƒpub ·f_0, fn:
        ·ƒret_2 ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_6 = fn [·ƒret_7, ·b_2]:
        ·ƒret_7 ·b_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·ƒret_5 ·v_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained ops at module level', fn:
  expect lift ƒink:
    2 * 3 + 4
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·v_12 = fn {·ƒret_13}, [·v_3]:
        ·op_plus ·v_3, 4, ·ƒret_13
      ·v_17 = ·closure ·v_12, ·ƒret_0
      ·op_mul 2, 3, ·v_17


test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_30 = fn {·ƒret_31}, [·v_7]:
        ·x_1 = ·v_7
        ·op_plus ·x_1, 4, ·ƒret_31
      ·main_0 = ·v_3 = fn [·ƒret_4]:
        ·v_35 = ·closure ·v_30, ·ƒret_4
        ·op_mul 2, 3, ·v_35
      ·ƒpub ·main_0, fn:
        ·ƒret_2 ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_27 = fn {·a_28}, [·ƒret_7, ·b_2]:
        ·op_plus ·a_28, ·b_2, ·ƒret_7
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·closure ·v_27, ·a_1, ·ƒret_5
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_5:
      ·v_6 = fn [·ƒret_7, ·x_2]:
        ·ƒret_7 ·x_2
      ·v_42 = fn {·a_43}, [·ƒret_15, ·b_4]:
        ·op_plus ·a_43, ·b_4, ·ƒret_15
      ·v_12 = fn [·ƒret_13, ·a_3]:
        ·closure ·v_42, ·a_3, ·ƒret_13
      ·f_0 = ·v_6
      ·ƒpub ·f_0, fn:
        ·g_1 = ·v_12
        ·ƒpub ·g_1, fn:
          ·ƒret_5 ·g_1

---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_58 = fn {·c_59, ·ƒret_61}, [·v_13]:
        ·op_plus ·v_13, ·c_59, ·ƒret_61
      ·v_46 = fn {·a_47, ·b_49}, [·ƒret_10, ·c_3]:
        ·v_65 = ·closure ·v_58, ·c_3, ·ƒret_10
        ·op_plus ·a_47, ·b_49, ·v_65
      ·v_37 = fn {·a_38}, [·ƒret_8, ·b_2]:
        ·closure ·v_46, ·a_38, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_37, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_4 ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_41 = fn {·a_42, ·b_44}, [·ƒret_10, ·c_3]:
        ·op_plus ·a_42, ·b_44, ·ƒret_10
      ·v_32 = fn {·a_33}, [·ƒret_8, ·b_2]:
        ·closure ·v_41, ·a_33, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_32, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_4 ·foo_0


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·v_38 = fn {·add_39}, [·ƒret_14]:
        ·add_39 ·ƒret_14, 3, 4
      ·add_0 = ·v_5
      ·ƒpub ·add_0, fn:
        ·v_41 = ·closure ·v_38, ·add_0
        ·main_1 = ·v_41
        ·ƒpub ·main_1, fn:
          ·ƒret_4 ·main_1

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_6:
      ·v_7 = fn [·ƒret_8, ·x_3]:
        ·op_mul ·x_3, 2, ·ƒret_8
      ·v_15 = fn [·ƒret_16, ·x_4]:
        ·op_plus ·x_4, 1, ·ƒret_16
      ·v_72 = fn {·inc_73, ·ƒret_75}, [·v_27]:
        ·x_5 = ·v_27
        ·inc_73 ·ƒret_75, ·x_5
      ·v_61 = fn {·double_62, ·inc_64}, [·ƒret_24]:
        ·v_79 = ·closure ·v_72, ·inc_64, ·ƒret_24
        ·double_62 ·v_79, 5
      ·double_0 = ·v_7
      ·ƒpub ·double_0, fn:
        ·inc_1 = ·v_15
        ·ƒpub ·inc_1, fn:
          ·v_66 = ·closure ·v_61, ·double_0, ·inc_1
          ·main_2 = ·v_66
          ·ƒpub ·main_2, fn:
            ·ƒret_6 ·main_2

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_60 = fn {·ƒret_61}, [·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, 1, ·ƒret_61
      ·v_73 = fn {·ƒfail_74}:
        ·ƒfail_74 _
      ·v_119 = fn {·ƒsucc_120, ·v_122, ·ƒfail_124}, [·v_17]:
        ·if ·v_17,
          fn:
            ·ƒsucc_120 ·v_122
          fn:
            ·ƒfail_124 _
      ·v_102 = fn {·ƒsucc_103, ·ƒfail_105}, [·v_10, ·v_14]:
        ·v_128 = ·closure ·v_119, ·ƒsucc_103, ·v_10, ·ƒfail_105
        ·empty ·v_14, ·v_128
      ·v_86 = fn {·ƒfail_87, ·ƒsucc_89}, [·v_22]:
        ·v_109 = ·closure ·v_102, ·ƒsucc_89, ·ƒfail_87
        ·seq_pop ·v_22, ·ƒfail_87, ·v_109
      ·v_30 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_78 = ·closure ·v_73, ·ƒfail_9
        ·v_93 = ·closure ·v_86, ·ƒfail_9, ·ƒsucc_8
        ·is_seq_like ·v_7, ·v_93, ·v_78
      ·main_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_63 = ·closure ·v_60, ·ƒret_5
        ·v_30 ·v_63, ·panic, ·foo_1
      ·ƒpub ·main_0, fn:
        ·ƒret_3 ·main_0


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_54 = fn {·ƒret_55}, [·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, 1, ·ƒret_55
      ·v_67 = fn {·ƒfail_68}:
        ·ƒfail_68 _
      ·v_96 = fn {·ƒsucc_97}, [·v_10, ·v_14]:
        ·ƒsucc_97 ·v_10
      ·v_80 = fn {·ƒfail_81, ·ƒsucc_83}, [·v_15]:
        ·v_101 = ·closure ·v_96, ·ƒsucc_83
        ·rec_pop ·v_15, 'x', ·ƒfail_81, ·v_101
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_72 = ·closure ·v_67, ·ƒfail_9
        ·v_87 = ·closure ·v_80, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_87, ·v_72
      ·main_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_57 = ·closure ·v_54, ·ƒret_5
        ·v_24 ·v_57, ·panic, ·foo_1
      ·ƒpub ·main_0, fn:
        ·ƒret_3 ·main_0


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_29 = fn [·ƒret_25]:
        ·ƒret_25 42
      ·v_83 = fn {·ƒsucc_84}:
        ·v_29 ·ƒsucc_84
      ·v_104 = fn {·ƒsucc_105, ·ƒfail_107}, [·v_15]:
        ·if ·v_15,
          fn:
            ·ƒsucc_105 _
          fn:
            ·ƒfail_107 _
      ·v_23 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_111 = ·closure ·v_104, ·ƒsucc_11, ·ƒfail_12
        ·op_eq ·v_10, 0, ·v_111
      ·v_41 = fn [·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_86 = ·closure ·v_83, ·ƒsucc_7
        ·v_23 ·v_86, ·ƒfail_8, ·v_6
      ·ƒret_80 = fn:
        ·panic _
      ·v_50 = fn [·ƒret_43, ·v_42]:
        ·v_41 ·ƒret_43, ·ƒret_80, ·v_42
      ·foo_0 = ·v_3 = fn [·ƒret_4, ·n_1]:
        ·v_50 ·ƒret_4, ·n_1
      ·ƒpub ·foo_0, fn:
        ·ƒret_2 ·foo_0


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_81 = fn {·n_82}, [·ƒret_26]:
        ·op_plus ·n_82, 1, ·ƒret_26
      ·v_107 = fn {·v_108, ·ƒsucc_110}:
        ·v_108 ·ƒsucc_110
      ·v_142 = fn {·ƒsucc_143, ·ƒfail_145}, [·v_16]:
        ·if ·v_16,
          fn:
            ·ƒsucc_143 _
          fn:
            ·ƒfail_145 _
      ·v_24 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_149 = ·closure ·v_142, ·ƒsucc_12, ·ƒfail_13
        ·op_eq ·v_11, 0, ·v_149
      ·v_90 = fn {·v_91}, [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_112 = ·closure ·v_107, ·v_91, ·ƒsucc_8
        ·v_24 ·v_112, ·ƒfail_9, ·v_7
      ·ƒret_130 = fn:
        ·panic _
      ·v_100 = fn {·v_101}, [·ƒret_46, ·v_45]:
        ·v_101 ·ƒret_46, ·ƒret_130, ·v_45
      ·v_121 = fn {·ƒret_122}, [·v_54]:
        ·r_2 = ·v_54
        ·ƒret_122 ·r_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·n_1]:
        ·v_84 = ·closure ·v_81, ·n_1
        ·v_93 = ·closure ·v_90, ·v_84
        ·v_103 = ·closure ·v_100, ·v_93
        ·v_126 = ·closure ·v_121, ·ƒret_5
        ·v_103 ·v_126, ·n_1
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_30 = fn [·ƒret_26]:
        ·ƒret_26 1
      ·v_137 = fn {·ƒsucc_138}:
        ·v_30 ·ƒsucc_138
      ·v_190 = fn {·ƒsucc_191, ·ƒfail_193}, [·v_16]:
        ·if ·v_16,
          fn:
            ·ƒsucc_191 _
          fn:
            ·ƒfail_193 _
      ·v_24 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_197 = ·closure ·v_190, ·ƒsucc_12, ·ƒfail_13
        ·op_eq ·v_11, 0, ·v_197
      ·v_42 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_140 = ·closure ·v_137, ·ƒsucc_8
        ·v_24 ·v_140, ·ƒfail_9, ·v_7
      ·v_128 = fn {·ƒret_129}, [·v_51]:
        ·fib_0 ·ƒret_129, ·v_51
      ·v_108 = fn {·n_109}, [·ƒret_47]:
        ·v_133 = ·closure ·v_128, ·ƒret_47
        ·op_plus ·n_109, 1, ·v_133
      ·v_121 = fn {·v_122}, [·ƒsucc_44, ·ƒfail_45, ·v_43]:
        ·v_122 ·ƒsucc_44
      ·ƒret_213 = fn:
        ·panic _
      ·v_177 = fn {·v_178, ·ƒret_180, ·v_182}:
        ·v_178 ·ƒret_180, ·ƒret_213, ·v_182
      ·v_151 = fn {·v_152}, [·ƒret_65, ·v_64]:
        ·v_186 = ·closure ·v_177, ·v_152, ·ƒret_65, ·v_64
        ·v_42 ·ƒret_65, ·v_186, ·v_64
      ·v_168 = fn {·ƒret_169}, [·v_77]:
        ·r_2 = ·v_77
        ·ƒret_169 ·r_2
      ·fib_0 = ·v_4 = fn [·ƒret_5, ·n_1]:
        ·v_111 = ·closure ·v_108, ·n_1
        ·v_124 = ·closure ·v_121, ·v_111
        ·v_154 = ·closure ·v_151, ·v_124
        ·v_173 = ·closure ·v_168, ·ƒret_5
        ·v_154 ·v_173, ·n_1
      ·ƒpub ·fib_0, fn:
        ·ƒret_3 ·fib_0


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·main_0 = ·v_2 = fn [·ƒret_3]:
        ·op_eq 'hello', 'hello', ·ƒret_3
      ·ƒpub ·main_0, fn:
        ·ƒret_1 ·main_0


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·main_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 'hello'
      ·ƒpub ·main_0, fn:
        ·ƒret_1 ·main_0

test 'match — seq literal guard', fn:
  expect lift ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        _: 0

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_66 = fn [·ƒret_62, ·val_1]:
        ·ƒret_62 ·val_1
      ·v_216 = fn {·v_217, ·ƒsucc_219}:
        ·val_1 = ·v_217
        ·v_66 ·ƒsucc_219, ·v_217
      ·v_274 = fn {·ƒsucc_275, ·ƒfail_277}, [·v_50]:
        ·if ·v_50,
          fn:
            ·ƒsucc_275 _
          fn:
            ·ƒfail_277 _
      ·v_58 = fn [·ƒsucc_46, ·ƒfail_47, ·v_45]:
        ·v_281 = ·closure ·v_274, ·ƒsucc_46, ·ƒfail_47
        ·op_eq ·v_45, 1, ·v_281
      ·v_193 = fn {·ƒsucc_194, ·ƒfail_196}, [·v_19, ·v_20]:
        ·v_221 = ·closure ·v_216, ·v_20, ·ƒsucc_194
        ·v_58 ·v_221, ·ƒfail_196, ·v_19
      ·v_238 = fn {·ƒfail_239}:
        ·ƒfail_239 _
      ·v_363 = fn {·ƒsucc_364, ·v_366, ·v_368}, [·v_27, ·v_28]:
        ·ƒsucc_364 ·v_366, ·v_368
      ·v_331 = fn {·ƒfail_332, ·ƒsucc_334, ·v_336}, [·v_20, ·v_25]:
        ·v_372 = ·closure ·v_363, ·ƒsucc_334, ·v_336, ·v_20
        ·seq_pop ·v_25, ·ƒfail_332, ·v_372
      ·v_302 = fn {·ƒfail_303, ·ƒsucc_305}, [·v_19, ·v_32]:
        ·v_340 = ·closure ·v_331, ·ƒfail_303, ·ƒsucc_305, ·v_19
        ·seq_pop ·v_32, ·ƒfail_303, ·v_340
      ·v_263 = fn {·ƒfail_264, ·ƒsucc_266}, [·v_31]:
        ·v_309 = ·closure ·v_302, ·ƒfail_264, ·ƒsucc_266
        ·seq_pop ·v_31, ·ƒfail_264, ·v_309
      ·v_43 = fn [·ƒsucc_17, ·ƒfail_18, ·v_16]:
        ·v_243 = ·closure ·v_238, ·ƒfail_18
        ·v_270 = ·closure ·v_263, ·ƒfail_18, ·ƒsucc_17
        ·is_seq_like ·v_16, ·v_270, ·v_243
      ·v_88 = fn [·ƒsucc_13, ·ƒfail_14, ·v_12]:
        ·v_198 = ·closure ·v_193, ·ƒsucc_13, ·ƒfail_14
        ·v_43 ·v_198, ·ƒfail_14, ·v_12
      ·v_97 = fn [·ƒret_93]:
        ·ƒret_93 0
