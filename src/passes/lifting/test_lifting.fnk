  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_4:
      ·v_46 = fn {·a_47, ·b_49}, [·ƒctx_34, ·ƒret_10, ·c_3]:
        ·op_plus ·a_47, ·b_49, ·ƒret_10
      ·v_37 = fn {·a_38}, [·ƒctx_33, ·ƒret_8, ·b_2]:
        ·closure ·v_46, ·a_38, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒctx_32, ·ƒret_6, ·a_1]:
        ·closure ·v_37, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·ƒctx_30, ·foo_0
    # sm:


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    foo = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·add_0 = ·v_5 = fn [·ƒctx_39, ·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·ƒpub ·add_0
      ·foo_1 = ·v_13 = fn [·ƒctx_40, ·ƒret_14]:
        ·add_0 ·ƒctx_40, ·ƒret_14, (i8 3), (i8 4)
      ·ƒpub ·foo_1
      ·ƒret_4 ·ƒctx_37, ·foo_1
    # sm:TQABACwAAQAsJAAYABIAAgAGAQwQAAAAAQsDEAAEAQwQDAAEAQAQBgAAAAIAFAAEABIABAEGAQoABAEGAQoAAAACAAIACgEKBQABAAUUAQABCgAEAQgBCgAEABIABgEpAwABAAMQAQADDgAGATwOAAAAAQsDEAAEAQwODgAEAQAOBgAAAAIAFAAEABQAAAACAAIACgEMCAABAAMQABQABAAUAAYBCAEAAQABBgEAAQQABgEGAQABAAEGAQABBAAGASUDAAEAAxABAAMOAAYBAAMAAQADFAAUAAQBAAM

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_60, ·ƒret_6:
      ·v_7 = fn [·ƒctx_62, ·ƒret_8, ·x_3]:
        ·op_mul ·x_3, (i8 2), ·ƒret_8
      ·v_15 = fn [·ƒctx_63, ·ƒret_16, ·x_4]:
        ·op_plus ·x_4, (i8 1), ·ƒret_16
      ·v_80 = fn {·inc_81, ·ƒret_83}, [·ƒctx_66, ·v_27]:
        ·x_5 = ·v_27
        ·inc_81 ·ƒctx_66, ·ƒret_83, ·x_5
      ·v_69 = fn {·double_70, ·inc_72}, [·ƒctx_64, ·ƒret_24]:
        ·v_87 = ·closure ·v_80, ·inc_72, ·ƒret_24
        ·double_70 ·ƒctx_64, ·v_87, (i8 5)
      ·double_0 = ·v_7
      ·ƒpub ·double_0
      ·inc_1 = ·v_15
      ·ƒpub ·inc_1
      ·v_74 = ·closure ·v_69, ·double_0, ·inc_1
      ·foo_2 = ·v_74
      ·ƒpub ·foo_2
      ·ƒret_6 ·ƒctx_60, ·foo_2
    # sm:

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_3:
      ·v_69 = fn {·ƒret_70}, [·ƒctx_61, ·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, (i8 1), ·ƒret_70
      ·v_82 = fn {·ƒfail_83, ·v_85}:
        ·ƒfail_83 ·ƒctx_85
      ·v_134 = fn {·ƒsucc_135, ·v_137, ·v_139, ·ƒfail_141}, [·v_17]:
        ·if ·v_17,
          fn:
            ·ƒsucc_135 ·ƒctx_137, ·v_139
          fn:
            ·ƒfail_141 ·ƒctx_137
      ·v_115 = fn {·ƒsucc_116, ·v_118, ·ƒfail_120}, [·v_10, ·v_14]:
        ·v_145 = ·closure ·v_134, ·ƒsucc_116, ·ƒctx_118, ·v_10, ·ƒfail_120
        ·empty ·v_14, ·v_145
      ·v_97 = fn {·ƒfail_98, ·ƒsucc_100, ·v_102}, [·v_22]:
        ·v_124 = ·closure ·v_115, ·ƒsucc_100, ·ƒctx_102, ·ƒfail_98
        ·seq_pop ·v_22, ·ƒfail_98, ·v_124
      ·v_30 = fn [·ƒctx_62, ·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_89 = ·closure ·v_82, ·ƒfail_9, ·ƒctx_62
        ·v_106 = ·closure ·v_97, ·ƒfail_9, ·ƒsucc_8, ·ƒctx_62
        ·is_seq_like ·v_7, ·v_106, ·v_89
      ·spam_0 = ·v_4 = fn [·ƒctx_60, ·ƒret_5, ·foo_1]:
        ·v_72 = ·closure ·v_69, ·ƒret_5
        ·v_30 ·ƒctx_60, ·v_72, ·panic, ·foo_1
      ·ƒpub ·spam_0
      ·ƒret_3 ·ƒctx_58, ·spam_0
    # sm:


test 'record destructure', fn:
  expect lift ƒink:
    ham = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_52, ·ƒret_3:
      ·v_62 = fn {·ƒret_63}, [·ƒctx_55, ·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, (i8 1), ·ƒret_63
      ·v_75 = fn {·ƒfail_76, ·v_78}:
        ·ƒfail_76 ·ƒctx_78
      ·v_108 = fn {·ƒsucc_109, ·v_111}, [·v_10, ·v_14]:
        ·ƒsucc_109 ·ƒctx_111, ·v_10
      ·v_90 = fn {·ƒfail_91, ·ƒsucc_93, ·v_95}, [·v_15]:
        ·v_115 = ·closure ·v_108, ·ƒsucc_93, ·ƒctx_95
        ·rec_pop ·v_15, 'x', ·ƒfail_91, ·v_115
      ·v_24 = fn [·ƒctx_56, ·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_82 = ·closure ·v_75, ·ƒfail_9, ·ƒctx_56
        ·v_99 = ·closure ·v_90, ·ƒfail_9, ·ƒsucc_8, ·ƒctx_56
        ·is_rec_like ·v_7, ·v_99, ·v_82
      ·ham_0 = ·v_4 = fn [·ƒctx_54, ·ƒret_5, ·foo_1]:
        ·v_65 = ·closure ·v_62, ·ƒret_5
        ·v_24 ·ƒctx_54, ·v_65, ·panic, ·foo_1
      ·ƒpub ·ham_0
      ·ƒret_3 ·ƒctx_52, ·ham_0
    # sm:


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_70, ·ƒret_2:
      ·v_29 = fn [·ƒctx_73, ·ƒret_25]:
        ·ƒret_25 ·ƒctx_73, (i8 42)
      ·v_98 = fn {·ƒsucc_99}, [·ƒctx_76]:
        ·v_29 ·ƒctx_76, ·ƒsucc_99
      ·v_119 = fn {·ƒsucc_120, ·v_122, ·ƒfail_124}, [·v_15]:
        ·if ·v_15,
          fn:
            ·ƒsucc_120 ·ƒctx_122
          fn:
            ·ƒfail_124 ·ƒctx_122
      ·v_23 = fn [·ƒctx_78, ·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_128 = ·closure ·v_119, ·ƒsucc_11, ·ƒctx_78, ·ƒfail_12
        ·op_eq ·v_10, (i8 0), ·v_128
      ·v_41 = fn [·ƒctx_75, ·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_101 = ·closure ·v_98, ·ƒsucc_7
        ·v_23 ·ƒctx_75, ·v_101, ·ƒfail_8, ·v_6
      ·ƒret_95 = fn [·ƒctx_84]:
        ·panic _
      ·v_49 = fn [·ƒctx_82, ·ƒret_43, ·v_42]:
        ·v_41 ·ƒctx_82, ·ƒret_43, ·ƒret_95, ·v_42
      ·foo_0 = ·v_3 = fn [·ƒctx_72, ·ƒret_4, ·n_1]:
        ·v_49 ·ƒctx_72, ·ƒret_4, ·n_1
      ·ƒpub ·foo_0
      ·ƒret_2 ·ƒctx_70, ·foo_0
    # sm:


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_78, ·ƒret_3:
      ·v_97 = fn {·n_98}, [·ƒctx_81, ·ƒret_26]:
        ·op_plus ·n_98, (i8 1), ·ƒret_26
      ·v_123 = fn {·v_124, ·ƒsucc_126}, [·ƒctx_83]:
        ·v_124 ·ƒctx_83, ·ƒsucc_126
      ·v_158 = fn {·ƒsucc_159, ·v_161, ·ƒfail_163}, [·v_16]:
        ·if ·v_16,
          fn:
            ·ƒsucc_159 ·ƒctx_161
          fn:
            ·ƒfail_163 ·ƒctx_161
      ·v_24 = fn [·ƒctx_85, ·ƒsucc_12, ·ƒfail_13, ·v_11]:
