---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Test format:
#   test 'name', fn:
#     expect lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected lifted CPS>

{test, equals, expect, fink, lift} = import 'fake!'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift fink":
    f = fn x: x

  | equals fink":
    ·f_0 = ·v_3 = fn ·x_1, ·v_4:
      ·v_4 ·x_1

    ·v_2 ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·v_6 = fn ·b_2, ·v_7:
      ·v_7 ·b_2

    ·foo_0 = ·v_4 = fn ·a_1, ·v_5:
      ·v_5 ·v_6

    ·v_3 ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_23 = fn ·v_24, ·v_7:
      ·x_1 = ·v_7
      ·op_plus ·x_1, 4, ·v_24

    ·main_0 = ·v_3 = fn ·v_4:
      ·v_28 = ·closure ·v_23, ·v_4
      ·op_mul 2, 3, ·v_28

    ·v_2 ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_20 = fn ·a_21, ·b_2, ·v_7:
      ·op_plus ·a_21, ·b_2, ·v_7

    ·foo_0 = ·v_4 = fn ·a_1, ·v_5:
      ·closure ·v_20, ·a_1, ·v_5

    ·v_3 ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift fink":
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_8 = fn ·x_2, ·v_9:
      ·v_9 ·x_2

    ·v_38 = fn ·a_39, ·b_4, ·v_17:
      ·op_plus ·a_39, ·b_4, ·v_17

    ·v_14 = fn ·a_3, ·v_15:
      ·closure ·v_38, ·a_3, ·v_15

    ·v_6 = fn ·v_7:
      ·f_0 = ·v_8
      ·g_1 = ·v_14
      ·v_7 ·g_1

    ·v_5 ·v_6


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_46 = fn ·c_47, ·v_49, ·v_13:
      ·op_plus ·v_13, ·c_47, ·v_49

    ·v_37 = fn ·a_38, ·b_40, ·c_3, ·v_10:
      ·v_53 = ·closure ·v_46, ·c_3, ·v_10
      ·op_plus ·a_38, ·b_40, ·v_53

    ·v_30 = fn ·a_31, ·b_2, ·v_8:
      ·closure ·v_37, ·a_31, ·b_2, ·v_8

    ·foo_0 = ·v_5 = fn ·a_1, ·v_6:
      ·closure ·v_30, ·a_1, ·v_6

    ·v_4 ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_32 = fn ·a_33, ·b_35, ·c_3, ·v_10:
      ·op_plus ·a_33, ·b_35, ·v_10

    ·v_25 = fn ·a_26, ·b_2, ·v_8:
      ·closure ·v_32, ·a_26, ·b_2, ·v_8

    ·foo_0 = ·v_5 = fn ·a_1, ·v_6:
      ·closure ·v_25, ·a_1, ·v_6

    ·v_4 ·foo_0


test 'yield — cont body lifted', fn:
  expect lift fink":
    main = fn:
      q = yield 42
      1 + q

  | equals fink":
    ·v_22 = fn ·v_23, ·v_6:
      ·q_1 = ·v_6
      ·op_plus 1, ·q_1, ·v_23

    ·main_0 = ·v_3 = fn ·v_4:
      ·v_27 = ·closure ·v_22, ·v_4
      ·yield 42, ·v_27

    ·v_2 ·main_0


test 'multi-fn module — add and main', fn:
  expect lift fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    ·v_7 = fn ·a_2, ·b_3, ·v_8:
      ·op_plus ·a_2, ·b_3, ·v_8

    ·v_15 = fn ·v_16:
      ·add_0 3, 4, ·v_16

    ·v_5 = fn ·v_6:
      ·add_0 = ·v_7
      ·main_1 = ·v_15
      ·v_6 ·main_1

    ·v_4 ·v_5

test 'chained module-fn calls via let — no spurious closure', fn:
  # TODO: lifting incorrectly wraps cont in ·closure when the cont references a
  # module-level fn (e.g. inc_1). Module-level refs are global; they should not
  # be treated as captures. Expected: no ·closure allocation for the let cont.
  expect lift fink":
    double = fn x:
      x * 2
    inc = fn x:
      x + 1
    main = fn:
      x = double 5
      inc x
  | equals fink":
    TODO

---
pattern matching
---

test 'seq destructure', fn:
  expect lift fink":
    main = fn foo:
      [a] = foo
      a + 1

  | equals fink":
    ·v_53 = fn ·a_54, ·v_56, ·v_12:
      ·op_plus ·a_54, 1, ·v_56

    ·v_44 = fn ·v_45, ·v_8, ·v_9:
      ·a_2 = ·v_8
      ·v_60 = ·closure ·v_53, ·a_2, ·v_45
      ·match_done ·v_9, panic, ·v_60

    ·v_35 = fn ·v_36, ·v_7:
      ·v_49 = ·closure ·v_44, ·v_36
      ·match_next ·v_7, panic, ·v_49

    ·main_0 = ·v_4 = fn ·foo_1, ·v_5:
      ·v_40 = ·closure ·v_35, ·v_5
      ·match_seq ·foo_1, panic, ·v_40

    ·v_3 ·main_0


test 'record destructure', fn:
  expect lift fink":
    main = fn foo:
      {x} = foo
      x + 1

  | equals fink":
    ·v_41 = fn ·v_42, ·v_8, ·v_9:
      ·x_2 = ·v_8
      ·op_plus ·x_2, 1, ·v_42

    ·v_32 = fn ·v_33, ·v_7:
      ·v_46 = ·closure ·v_41, ·v_33
      ·match_field ·v_7, 'x', panic, ·v_46

    ·main_0 = ·v_4 = fn ·foo_1, ·v_5:
      ·v_37 = ·closure ·v_32, ·v_5
      ·match_rec ·foo_1, panic, ·v_37

    ·v_3 ·main_0


test 'match — no forward refs after lift', fn:
  expect lift fink":
    foo = fn n:
      match n:
        0: 42

  | equals fink":
    ·v_31 = fn ·n_32, ·v_34, ·v_19:
      ·match_block ·n_32, ·v_19, ·v_34

    ·v_45 = fn ·v_12:
      ·v_12 42

    ·v_48 = fn ·v_9, ·v_7, ·v_8:
      ·match_value ·v_9, 0, ·v_7, ·v_8

    ·v_42 = fn ·v_38:
      ·match_arm ·v_48, ·v_45, ·v_38

    ·foo_0 = ·v_3 = fn ·n_1, ·v_4:
      ·closure ·v_31, ·n_1, ·v_4, ·v_42

    ·v_2 ·foo_0


test 'match with binding', fn:
  expect lift fink":
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals fink":
    ·v_59 = fn ·v_60, ·v_24:
      ·r_2 = ·v_24
      ·v_60 ·r_2

    ·v_39 = fn ·n_40, ·v_42, ·v_22:
      ·v_64 = ·closure ·v_59, ·v_42
      ·match_block ·n_40, ·v_22, ·v_64

    ·v_50 = fn ·n_51, ·v_13:
      ·op_plus ·n_51, 1, ·v_13

    ·v_68 = fn ·v_10, ·v_8, ·v_9:
      ·match_value ·v_10, 0, ·v_8, ·v_9

    ·foo_0 = ·v_4 = fn ·n_1, ·v_5:
      ·v_46 = ·closure ·v_39, ·n_1, ·v_5
      ·v_55 = ·closure ·v_50, ·n_1
      ·match_arm ·v_68, ·v_55, ·v_46

    ·v_3 ·foo_0


test 'recursive fn in match', fn:
  expect lift fink":
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals fink":
    ·v_97 = fn ·v_98, ·v_41:
      ·r_2 = ·v_41
      ·v_98 ·r_2

    ·v_72 = fn ·n_73, ·v_75, ·v_77, ·v_39:
      ·v_102 = ·closure ·v_97, ·v_77
      ·match_block ·n_73, ·v_75, ·v_39, ·v_102

    ·v_112 = fn ·v_113, ·v_30:
      ·fib_0 ·v_30, ·v_113

    ·v_88 = fn ·n_89, ·v_26:
      ·v_117 = ·closure ·v_112, ·v_26
      ·op_plus ·n_89, 1, ·v_117

    ·v_109 = fn ·v_24, ·v_22, ·v_23:
      ·v_23 _

    ·v_58 = fn ·n_59, ·v_61, ·v_20:
      ·v_81 = ·closure ·v_72, ·n_59, ·v_20, ·v_61
      ·v_93 = ·closure ·v_88, ·n_59
      ·match_arm ·v_109, ·v_93, ·v_81

    ·v_85 = fn ·v_13:
      ·v_13 1

    ·v_106 = fn ·v_10, ·v_8, ·v_9:
      ·match_value ·v_10, 0, ·v_8, ·v_9

    ·v_69 = fn ·v_65:
      ·match_arm ·v_106, ·v_85, ·v_65

    ·fib_0 = ·v_4 = fn ·n_1, ·v_5:
      ·closure ·v_58, ·n_1, ·v_5, ·v_69

    ·v_3 ·fib_0
