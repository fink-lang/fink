---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'fn call result bound at module level', fn:
  expect lift ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_4:
      ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·v_35 = fn {·ƒret_36}, [·v_16]:
        ·x_1 = ·v_16
        ·ƒpub ·x_1
        ·ƒret_36 ·x_1
      ·add_0 = ·v_5
      ·ƒpub ·add_0
      ·ƒret_45 = fn [·v_40]:
        ·add_0 ·v_40, (i8 1), (i8 2)
      ·closure ·v_35, ·ƒret_4, ·ƒret_45
    # sm:


test 'chained ops at module level', fn:
  expect lift ƒink:
    2 * 3 + 4
  | equals ƒink:
