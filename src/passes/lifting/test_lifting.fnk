---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·fn_closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Test format:
#   test 'name', fn:
#     expect lift fink":
#       <fink source>
#
#     | equals fink":
#       <expected lifted CPS>

{test, equals, expect, fink, lift} = import 'fake!'


---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift fink":
    f = fn x: x

  | equals fink":
    f = ·v_1 = fn x, ·f_3:
      ·v_5 = x
      ·f_3 ·v_5

    ·f_0 f


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift fink":
    foo = fn a:
      fn b: b

  | equals fink":
    ·v_4 = fn b, ·f_6:
      ·v_8 = b
      ·f_6 ·v_8

    foo = ·v_1 = fn a, ·f_3:
      ·f_3 ·v_4

    ·f_0 foo


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift fink":
    main = fn:
      x = 2 * 3
      x + 4

  | equals fink":
    ·v_23 = fn ·f_24, ·v_5:
      x = ·v_5
      ·op_plus x, 4, ·f_24

    main = ·v_1 = fn ·f_2:
      ·v_28 = ·fn_closure ·v_23, ·f_2
      ·op_mul 2, 3, ·f_28

    ·f_0 main


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_20 = fn a, b, ·f_6:
      ·op_plus a, b, ·f_6

    foo = ·v_1 = fn a, ·f_3:
      ·fn_closure ·v_20, a, ·f_3

    ·f_0 foo


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift fink":
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals fink":
    ·v_3 = fn x, ·f_5:
      ·v_7 = x
      ·f_5 ·v_7

    ·v_36 = fn a, b, ·f_16:
      ·op_plus a, b, ·f_16

    ·v_11 = fn a, ·f_13:
      ·fn_closure ·v_36, a, ·f_13

    ·v_1 = fn ·f_2:
      f = ·v_3
      g = ·v_11
      ·f_2 g

    ·f_0 ·v_1


---
depth-2 closures — multiple nesting levels
---

# BUG: `a` is out of scope in ·v_30 — not captured from foo's params.
# The iterative loop should capture `a` on the next round.
test 'depth-2 closure', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals fink":
    ·v_30 = fn b, c, ·f_9:
      ·op_plus a, b, fn ·v_12:
        ·op_plus ·v_12, c, ·f_9

    ·v_4 = fn b, ·f_6:
      ·fn_closure ·v_30, b, ·f_6

    foo = ·v_1 = fn a, ·f_3:
      ·f_3 ·v_4

    ·f_0 foo


# BUG: same — `a` out of scope in ·v_25.
test 'multiple captures at depth-2', fn:
  expect lift fink":
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals fink":
    ·v_25 = fn b, c, ·f_9:
      ·op_plus a, b, ·f_9

    ·v_4 = fn b, ·f_6:
      ·fn_closure ·v_25, b, ·f_6

    foo = ·v_1 = fn a, ·f_3:
      ·f_3 ·v_4

    ·f_0 foo


