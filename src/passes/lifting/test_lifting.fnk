---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'fn call result bound at module level', fn:
  expect lift ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_33, ·ƒret_4:
      ·v_5 = fn [·ƒctx_35, ·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·v_39 = fn {·ƒret_40}, [·ƒctx_37, ·v_16]:
        ·x_1 = ·v_16
        ·ƒpub ·x_1
        ·ƒret_40 ·ƒctx_37, ·x_1
      ·add_0 = ·v_5
      ·ƒpub ·add_0
      ·v_44 = ·closure ·v_39, ·ƒret_4
      ·add_0 ·ƒctx_33, ·v_44, (i8 1), (i8 2)
    # sm:


test 'chained ops at module level', fn:
  expect lift ƒink:
    2 * 3 + 4
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_11, ·ƒret_0:
      ·v_13 = fn {·ƒret_14}, [·v_3]:
        ·op_plus ·v_3, (i8 4), ·ƒret_14
      ·v_18 = ·closure ·v_13, ·ƒret_0
      ·op_mul (i8 2), (i8 3), ·v_18
    # sm:NAABAAkAAQAJJAAYABIAAgAGAQAFAAEABQ4ABAEABQYAAAACABQAAAAGAAAAAgAKAAAAAgACAAoBAAkAAQAJFAEABQoABgEQAQABAAEGAQABBAAEABQABgEPBQAADgAEAQAFAAEABRQBAAUMAAQBAAkSAAYBAAUAAQAFFAEAAQABAAEGAQABBAAGAQgBAAEAAQYBAAEEAAQA


