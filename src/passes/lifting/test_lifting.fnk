---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module} = import '@fink/compile/builtins'




test 'single module expr', fn:
  expect lift ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_0:
      ·ƒret_0 42


test 'single binding export', fn:
  expect lift ƒink:
    foo = fn: 123
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0, fn:
        ·ƒret_1 ·foo_0

test 'single binding export with trailing expr', fn:
  expect lift ƒink:
    foo = fn: 123
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·foo_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 123
      ·ƒpub ·foo_0, fn:
        ·ƒret_1 42



---
pure functions — no captures, unchanged
---

test 'pure fn is unchanged', fn:
  expect lift ƒink:
    f = fn x: x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·f_0 = ·v_3 = fn [·ƒret_4, ·x_1]:
        ·ƒret_4 ·x_1
      ·ƒpub ·f_0, fn:
        ·ƒret_2 ·f_0


test 'pure nested fn — no captures, hoisted to module scope', fn:
  expect lift ƒink:
    foo = fn a:
      fn b: b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_6 = fn [·ƒret_7, ·b_2]:
        ·ƒret_7 ·b_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·ƒret_5 ·v_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


---
continuation lifting — inline Cont::Expr bodies become named fns
---

test 'chained arithmetic — cont body lifted', fn:
  expect lift ƒink:
    main = fn:
      x = 2 * 3
      x + 4

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_29 = fn {·ƒret_30}, [·v_7]:
        ·x_1 = ·v_7
        ·op_plus ·x_1, 4, ·ƒret_30
      ·main_0 = ·v_3 = fn [·ƒret_4]:
        ·v_34 = ·closure ·v_29, ·ƒret_4
        ·op_mul 2, 3, ·v_34
      ·ƒpub ·main_0, fn:
        ·ƒret_2 ·main_0


---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_26 = fn {·a_27}, [·ƒret_7, ·b_2]:
        ·op_plus ·a_27, ·b_2, ·ƒret_7
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·a_1]:
        ·closure ·v_26, ·a_1, ·ƒret_5
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_5:
      ·f_0 = ·v_6 = fn [·ƒret_7, ·x_2]:
        ·ƒret_7 ·x_2
      ·ƒpub ·f_0, fn:
        ·v_40 = fn {·a_41}, [·ƒret_15, ·b_4]:
          ·op_plus ·a_41, ·b_4, ·ƒret_15
        ·g_1 = ·v_12 = fn [·ƒret_13, ·a_3]:
          ·closure ·v_40, ·a_3, ·ƒret_13
        ·ƒpub ·g_1, fn:
          ·ƒret_5 ·g_1


---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_52 = fn {·c_53, ·ƒret_55}, [·v_13]:
        ·op_plus ·v_13, ·c_53, ·ƒret_55
      ·v_43 = fn {·a_44, ·b_46}, [·ƒret_10, ·c_3]:
        ·v_59 = ·closure ·v_52, ·c_3, ·ƒret_10
        ·op_plus ·a_44, ·b_46, ·v_59
      ·v_36 = fn {·a_37}, [·ƒret_8, ·b_2]:
        ·closure ·v_43, ·a_37, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_36, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_4 ·foo_0


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·v_38 = fn {·a_39, ·b_41}, [·ƒret_10, ·c_3]:
        ·op_plus ·a_39, ·b_41, ·ƒret_10
      ·v_31 = fn {·a_32}, [·ƒret_8, ·b_2]:
        ·closure ·v_38, ·a_32, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒret_6, ·a_1]:
        ·closure ·v_31, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0, fn:
        ·ƒret_4 ·foo_0


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒret_4:
      ·add_0 = ·v_5 = fn [·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·ƒpub ·add_0, fn:
        ·main_1 = ·v_13 = fn [·ƒret_14]:
          ·add_0 ·ƒret_14, 3, 4
        ·ƒpub ·main_1, fn:
          ·ƒret_4 ·main_1

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    main = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒret_6:
      ·double_0 = ·v_7 = fn [·ƒret_8, ·x_3]:
        ·op_mul ·x_3, 2, ·ƒret_8
      ·ƒpub ·double_0, fn:
        ·inc_1 = ·v_15 = fn [·ƒret_16, ·x_4]:
          ·op_plus ·x_4, 1, ·ƒret_16
        ·ƒpub ·inc_1, fn:
          ·v_61 = fn {·ƒret_62}, [·v_27]:
            ·x_5 = ·v_27
            ·inc_1 ·ƒret_62, ·x_5
          ·main_2 = ·v_23 = fn [·ƒret_24]:
            ·v_66 = ·closure ·v_61, ·ƒret_24
            ·double_0 ·v_66, 5
          ·ƒpub ·main_2, fn:
            ·ƒret_6 ·main_2

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    main = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_59 = fn {·ƒret_60}, [·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, 1, ·ƒret_60
      ·v_67 = fn {·ƒfail_68}:
        ·ƒfail_68 _
      ·v_98 = fn {·ƒsucc_99, ·v_101, ·ƒfail_103}, [·v_17]:
        if ·v_17,
          fn:
            ·ƒsucc_99 ·v_101
          fn:
            ·ƒfail_103 _
      ·v_87 = fn {·ƒsucc_88, ·ƒfail_90}, [·v_10, ·v_14]:
        ·v_107 = ·closure ·v_98, ·ƒsucc_88, ·v_10, ·ƒfail_90
        ·empty ·v_14, ·v_107
      ·v_76 = fn {·ƒfail_77, ·ƒsucc_79}, [·v_22]:
        ·v_94 = ·closure ·v_87, ·ƒsucc_79, ·ƒfail_77
        ·seq_pop ·v_22, ·ƒfail_77, ·v_94
      ·v_30 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_72 = ·closure ·v_67, ·ƒfail_9
        ·v_83 = ·closure ·v_76, ·ƒfail_9, ·ƒsucc_8
        ·is_seq_like ·v_7, ·v_83, ·v_72
      ·main_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_62 = ·closure ·v_59, ·ƒret_5
        ·v_30 ·v_62, panic, ·foo_1
      ·ƒpub ·main_0, fn:
        ·ƒret_3 ·main_0


test 'record destructure', fn:
  expect lift ƒink:
    main = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_53 = fn {·ƒret_54}, [·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, 1, ·ƒret_54
      ·v_61 = fn {·ƒfail_62}:
        ·ƒfail_62 _
      ·v_81 = fn {·ƒsucc_82}, [·v_10, ·v_14]:
        ·ƒsucc_82 ·v_10
      ·v_70 = fn {·ƒfail_71, ·ƒsucc_73}, [·v_15]:
        ·v_86 = ·closure ·v_81, ·ƒsucc_73
        ·rec_pop ·v_15, 'x', ·ƒfail_71, ·v_86
      ·v_24 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_66 = ·closure ·v_61, ·ƒfail_9
        ·v_77 = ·closure ·v_70, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_77, ·v_66
      ·main_0 = ·v_4 = fn [·ƒret_5, ·foo_1]:
        ·v_56 = ·closure ·v_53, ·ƒret_5
        ·v_24 ·v_56, panic, ·foo_1
      ·ƒpub ·main_0, fn:
        ·ƒret_3 ·main_0


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_29 = fn [·ƒret_25]:
        ·ƒret_25 42
      ·v_78 = fn {·ƒsucc_79}:
        ·v_29 ·ƒsucc_79
      ·v_86 = fn {·ƒsucc_87, ·ƒfail_89}, [·v_15]:
        if ·v_15,
          fn:
            ·ƒsucc_87 _
          fn:
            ·ƒfail_89 _
      ·v_23 = fn [·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_93 = ·closure ·v_86, ·ƒsucc_11, ·ƒfail_12
        ·op_eq ·v_10, 0, ·v_93
      ·v_41 = fn [·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_81 = ·closure ·v_78, ·ƒsucc_7
        ·v_23 ·v_81, ·ƒfail_8, ·v_6
      ·ƒret_75 = fn:
        panic _
      ·v_50 = fn [·ƒret_43, ·v_42]:
        ·v_41 ·ƒret_43, ·ƒret_75, ·v_42
      ·foo_0 = ·v_3 = fn [·ƒret_4, ·n_1]:
        ·v_50 ·ƒret_4, ·n_1
      ·ƒpub ·foo_0, fn:
        ·ƒret_2 ·foo_0


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_80 = fn {·n_81}, [·ƒret_26]:
        ·op_plus ·n_81, 1, ·ƒret_26
      ·v_101 = fn {·v_102, ·ƒsucc_104}:
        ·v_102 ·ƒsucc_104
      ·v_123 = fn {·ƒsucc_124, ·ƒfail_126}, [·v_16]:
        if ·v_16,
          fn:
            ·ƒsucc_124 _
          fn:
            ·ƒfail_126 _
      ·v_24 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_130 = ·closure ·v_123, ·ƒsucc_12, ·ƒfail_13
        ·op_eq ·v_11, 0, ·v_130
      ·v_87 = fn {·v_88}, [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_106 = ·closure ·v_101, ·v_88, ·ƒsucc_8
        ·v_24 ·v_106, ·ƒfail_9, ·v_7
      ·ƒret_119 = fn:
        panic _
      ·v_94 = fn {·v_95}, [·ƒret_46, ·v_45]:
        ·v_95 ·ƒret_46, ·ƒret_119, ·v_45
      ·v_110 = fn {·ƒret_111}, [·v_54]:
        ·r_2 = ·v_54
        ·ƒret_111 ·r_2
      ·foo_0 = ·v_4 = fn [·ƒret_5, ·n_1]:
        ·v_83 = ·closure ·v_80, ·n_1
        ·v_90 = ·closure ·v_87, ·v_83
        ·v_97 = ·closure ·v_94, ·v_90
        ·v_115 = ·closure ·v_110, ·ƒret_5
        ·v_97 ·v_115, ·n_1
      ·ƒpub ·foo_0, fn:
        ·ƒret_3 ·foo_0


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_30 = fn [·ƒret_26]:
        ·ƒret_26 1
      ·v_132 = fn {·ƒsucc_133}:
        ·v_30 ·ƒsucc_133
      ·v_169 = fn {·ƒsucc_170, ·ƒfail_172}, [·v_16]:
        if ·v_16,
          fn:
            ·ƒsucc_170 _
          fn:
            ·ƒfail_172 _
      ·v_24 = fn [·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_176 = ·closure ·v_169, ·ƒsucc_12, ·ƒfail_13
        ·op_eq ·v_11, 0, ·v_176
      ·v_42 = fn [·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_135 = ·closure ·v_132, ·ƒsucc_8
        ·v_24 ·v_135, ·ƒfail_9, ·v_7
      ·v_123 = fn {·ƒret_124}, [·v_51]:
        ·fib_0 ·ƒret_124, ·v_51
      ·v_107 = fn {·n_108}, [·ƒret_47]:
        ·v_128 = ·closure ·v_123, ·ƒret_47
        ·op_plus ·n_108, 1, ·v_128
      ·v_116 = fn {·v_117}, [·ƒsucc_44, ·ƒfail_45, ·v_43]:
        ·v_117 ·ƒsucc_44
      ·ƒret_180 = fn:
        panic _
      ·v_156 = fn {·v_157, ·ƒret_159, ·v_161}:
        ·v_157 ·ƒret_159, ·ƒret_180, ·v_161
      ·v_139 = fn {·v_140}, [·ƒret_65, ·v_64]:
        ·v_165 = ·closure ·v_156, ·v_140, ·ƒret_65, ·v_64
        ·v_42 ·ƒret_65, ·v_165, ·v_64
      ·v_147 = fn {·ƒret_148}, [·v_77]:
        ·r_2 = ·v_77
        ·ƒret_148 ·r_2
      ·fib_0 = ·v_4 = fn [·ƒret_5, ·n_1]:
        ·v_110 = ·closure ·v_107, ·n_1
        ·v_119 = ·closure ·v_116, ·v_110
        ·v_142 = ·closure ·v_139, ·v_119
        ·v_152 = ·closure ·v_147, ·ƒret_5
        ·v_142 ·v_152, ·n_1
      ·ƒpub ·fib_0, fn:
        ·ƒret_3 ·fib_0


test 'str eq', fn:
  expect lift ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·main_0 = ·v_2 = fn [·ƒret_3]:
        ·op_eq 'hello', 'hello', ·ƒret_3
      ·ƒpub ·main_0, fn:
        ·ƒret_1 ·main_0


test 'str literal', fn:
  expect lift ƒink:
    main = fn:
      'hello'
  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·main_0 = ·v_2 = fn [·ƒret_3]:
        ·ƒret_3 'hello'
      ·ƒpub ·main_0, fn:
        ·ƒret_1 ·main_0

test 'match — seq literal guard', fn:
  expect lift ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        _: 0

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_66 = fn [·ƒret_62, ·val_1]:
        ·ƒret_62 ·val_1
      ·v_192 = fn {·v_193, ·ƒsucc_195}:
        ·val_1 = ·v_193
        ·v_66 ·ƒsucc_195, ·v_193
      ·v_222 = fn {·ƒsucc_223, ·ƒfail_225}, [·v_50]:
        if ·v_50,
          fn:
            ·ƒsucc_223 _
          fn:
            ·ƒfail_225 _
      ·v_58 = fn [·ƒsucc_46, ·ƒfail_47, ·v_45]:
        ·v_229 = ·closure ·v_222, ·ƒsucc_46, ·ƒfail_47
        ·op_eq ·v_45, 1, ·v_229
      ·v_179 = fn {·ƒsucc_180, ·ƒfail_182}, [·v_19, ·v_20]:
        ·v_197 = ·closure ·v_192, ·v_20, ·ƒsucc_180
        ·v_58 ·v_197, ·ƒfail_182, ·v_19
      ·v_201 = fn {·ƒfail_202}:
        ·ƒfail_202 _
      ·v_257 = fn {·ƒsucc_258, ·v_260, ·v_262}, [·v_27, ·v_28]:
        ·ƒsucc_258 ·v_260, ·v_262
      ·v_244 = fn {·ƒfail_245, ·ƒsucc_247, ·v_249}, [·v_20, ·v_25]:
        ·v_266 = ·closure ·v_257, ·ƒsucc_247, ·v_249, ·v_20
        ·seq_pop ·v_25, ·ƒfail_245, ·v_266
      ·v_233 = fn {·ƒfail_234, ·ƒsucc_236}, [·v_19, ·v_32]:
        ·v_253 = ·closure ·v_244, ·ƒfail_234, ·ƒsucc_236, ·v_19
        ·seq_pop ·v_32, ·ƒfail_234, ·v_253
      ·v_211 = fn {·ƒfail_212, ·ƒsucc_214}, [·v_31]:
        ·v_240 = ·closure ·v_233, ·ƒfail_212, ·ƒsucc_214
        ·seq_pop ·v_31, ·ƒfail_212, ·v_240
      ·v_43 = fn [·ƒsucc_17, ·ƒfail_18, ·v_16]:
        ·v_206 = ·closure ·v_201, ·ƒfail_18
        ·v_218 = ·closure ·v_211, ·ƒfail_18, ·ƒsucc_17
        ·is_seq_like ·v_16, ·v_218, ·v_206
      ·v_88 = fn [·ƒsucc_13, ·ƒfail_14, ·v_12]:
        ·v_184 = ·closure ·v_179, ·ƒsucc_13, ·ƒfail_14
        ·v_43 ·v_184, ·ƒfail_14, ·v_12
      ·v_97 = fn [·ƒret_93]:
        ·ƒret_93 0
      ·v_102 = fn [·ƒsucc_90, ·ƒfail_91, ·v_89]:
        ·v_97 ·ƒsucc_90
      ·ƒret_188 = fn:
        panic _
      ·v_168 = fn {·ƒret_169, ·v_171}:
        ·v_102 ·ƒret_169, ·ƒret_188, ·v_171
      ·v_115 = fn [·ƒret_104, ·v_103]:
        ·v_175 = ·closure ·v_168, ·ƒret_104, ·v_103
        ·v_88 ·ƒret_104, ·v_175, ·v_103
      ·v_154 = fn {·ƒret_155}, [·v_10]:
        ·v_115 ·ƒret_155, ·v_10
      ·v_145 = fn {·ƒret_146}, [·v_7]:
        ·v_159 = ·closure ·v_154, ·ƒret_146
        ·seq_prepend 1, ·v_7, ·v_159
      ·main_0 = ·v_3 = fn [·ƒret_4]:
        ·v_150 = ·closure ·v_145, ·ƒret_4
        ·seq_prepend 42, [], ·v_150
      ·ƒpub ·main_0, fn:
        ·ƒret_2 ·main_0

test 'match — rec literal guard', fn:
  expect lift ƒink:
    main = fn:
      match {kind: 1, val: 42}:
        {kind: 1, val}: val
        _: 0

  | equals ƒink:
    ·ƒink_module fn ·ƒret_2:
      ·v_65 = fn [·ƒret_61, ·val_1]:
        ·ƒret_61 ·val_1
      ·v_191 = fn {·v_192, ·ƒsucc_194}:
        ·val_1 = ·v_192
        ·v_65 ·ƒsucc_194, ·v_192
      ·v_221 = fn {·ƒsucc_222, ·ƒfail_224}, [·v_49]:
        if ·kind_49,
          fn:
            ·ƒsucc_222 _
          fn:
            ·ƒfail_224 _
      ·v_57 = fn [·ƒsucc_45, ·ƒfail_46, ·v_44]:
        ·v_228 = ·closure ·v_221, ·ƒsucc_45, ·ƒfail_46
        ·op_eq ·kind_44, 1, ·v_228
      ·v_178 = fn {·ƒsucc_179, ·ƒfail_181}, [·v_21, ·v_22]:
        ·v_196 = ·closure ·v_191, ·v_22, ·ƒsucc_179
        ·kind_57 ·v_196, ·ƒfail_181, ·v_21
      ·v_200 = fn {·ƒfail_201}:
        ·ƒfail_201 _
      ·v_243 = fn {·ƒsucc_244, ·v_246}, [·v_22, ·v_27]:
        ·ƒsucc_244 ·v_246, ·v_22
      ·v_232 = fn {·ƒfail_233, ·ƒsucc_235}, [·v_21, ·v_29]:
        ·v_250 = ·closure ·v_243, ·ƒsucc_235, ·v_21
        ·rec_pop ·v_29, 'val', ·ƒfail_233, ·v_250
      ·v_210 = fn {·ƒfail_211, ·ƒsucc_213}, [·v_28]:
