test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_25, ·ƒret_3:
      ·v_31 = fn {·a_32}, [·ƒctx_28, ·ƒret_7, ·b_2]:
        ·op_plus ·a_32, ·b_2, ·ƒret_7
      ·foo_0 = ·v_4 = fn [·ƒctx_27, ·ƒret_5, ·a_1]:
        ·closure ·v_31, ·a_1, ·ƒret_5
      ·ƒpub ·foo_0
      ·ƒret_3 ·ƒctx_25, ·foo_0
    # sm:RQABAB0AAQAdJAAYABIAAgAGARwPAAEADw4ABAEADwYAAAACAQkBDAAAAAYAAAACABQABAASAAQBEAEKAAAAAgACAAoBDgUAAQAFFAEAAQwABAEIAQoABAASAAYBKxcAAAABCwMQAAQBDBcMAAQBABcGAAAAAgAUAAQAEgAEAQYBCgAAAAIAAgAKAQoPAAEADxQBAA8MAAQBCQEKAAQAEgAGAREDAAEAAxABAAMOAAYBAAMAAQADFAAUAAQBAAM


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_5:
      ·v_6 = fn [·ƒctx_41, ·ƒret_7, ·x_2]:
        ·ƒret_7 ·ƒctx_41, ·x_2
      ·v_48 = fn {·a_49}, [·ƒctx_44, ·ƒret_15, ·b_4]:
        ·op_plus ·a_49, ·b_4, ·ƒret_15
      ·v_12 = fn [·ƒctx_43, ·ƒret_13, ·a_3]:
        ·closure ·v_48, ·a_3, ·ƒret_13
      ·f_0 = ·v_6
      ·ƒpub ·f_0
      ·g_1 = ·v_12
      ·ƒpub ·g_1
      ·ƒret_5 ·ƒctx_39, ·g_1
    # sm:

---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_4:
      ·v_63 = fn {·c_64, ·ƒret_66}, [·v_13]:
        ·op_plus ·v_13, ·c_64, ·ƒret_66
      ·v_51 = fn {·a_52, ·b_54}, [·ƒctx_39, ·ƒret_10, ·c_3]:
        ·v_70 = ·closure ·v_63, ·c_3, ·ƒret_10
        ·op_plus ·a_52, ·b_54, ·v_70
      ·v_42 = fn {·a_43}, [·ƒctx_38, ·ƒret_8, ·b_2]:
        ·closure ·v_51, ·a_43, ·b_2, ·ƒret_8
      ·foo_0 = ·v_5 = fn [·ƒctx_37, ·ƒret_6, ·a_1]:
        ·closure ·v_42, ·a_1, ·ƒret_6
      ·ƒpub ·foo_0
      ·ƒret_4 ·ƒctx_35, ·foo_0
    # sm:


