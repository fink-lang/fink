test 'match arm refs top-level binding', fn:
  expect lift ƒink:
    x = 5
    match x:
      0: 0
      _: x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒret_1:
      ·v_27 = fn [·ƒret_23]:
        ·ƒret_23 0
      ·v_114 = fn {·ƒsucc_115}:
        ·v_27 ·ƒsucc_115
      ·v_147 = fn {·ƒsucc_148, ·ƒfail_150}, [·v_13]:
        ·if ·v_13,
          fn:
            ·ƒsucc_148 _
          fn:
            ·ƒfail_150 _
      ·v_21 = fn [·ƒsucc_9, ·ƒfail_10, ·v_8]:
        ·v_154 = ·closure ·v_147, ·ƒsucc_9, ·ƒfail_10
        ·op_eq ·v_8, 0, ·v_154
      ·v_39 = fn [·ƒsucc_5, ·ƒfail_6, ·v_4]:
        ·v_117 = ·closure ·v_114, ·ƒsucc_5
        ·v_21 ·v_117, ·ƒfail_6, ·v_4
      ·v_87 = fn {·x_88}, [·ƒret_44]:
        ·op_plus ·x_88, 1, ·ƒret_44
      ·v_96 = fn {·v_97}, [·ƒsucc_41, ·ƒfail_42, ·v_40]:
        ·v_97 ·ƒsucc_41
      ·ƒret_134 = fn:
        ·panic _
      ·v_121 = fn {·v_122}, [·ƒret_104, ·v_106]:
        ·v_122 ·ƒret_104, ·ƒret_134, ·v_106
      ·v_67 = fn [·ƒret_57, ·v_56]:
        ·v_110 = ·closure ·v_121, ·ƒret_57, ·v_56
        ·v_39 ·ƒret_57, ·v_110, ·v_56
      ·x_0 = 5
      ·ƒpub ·x_0
      ·v_90 = ·closure ·v_87, ·x_0
      ·v_99 = ·closure ·v_96, ·v_90
      ·v_124 = ·closure ·v_121, ·v_99
      ·v_67 ·ƒret_1, ·x_0
    # sm:


test 'recursive fn in match', fn:
  expect lift ƒink:
    fib = fn n:
      r = match n:
        0: 1
        _: fib n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒret_3:
      ·v_30 = fn [·ƒret_26]:
