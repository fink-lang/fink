---
depth-1 closures — single level of capture
---

test 'captured binding becomes leading param', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_25, ·ƒret_3:
      ·v_34 = fn {·a_35}, [·ƒctx_28, ·ƒret_7, ·b_2]:
        ·op_plus ·a_35, ·b_2, ·ƒret_7
      ·v_4 = fn [·ƒctx_27, ·ƒret_5, ·a_1]:
        ·closure ·v_34, ·a_1, ·ƒret_5
      ·foo_0 = ·v_4
      ·ƒpub ·foo_0
      ·ƒret_3 ·ƒctx_31, ·foo_0
    # sm:RwABAB0AAQAdJAAYABIAAgAGARwPAAEADw4ABAEADwYAAAACAQkBDAAAAAYAAAACABQABAASAAQBEAEKAAAAAgACAAoBDgUAAQAFFAEAAQwABAEIAQoABAASAAYBKxcAAQAXDAAEAQAXBgAAAAIAFAAEABIABAEGAQoAAAACAAIACgEKDwABAA8UAQAPDAAEAQkBCgAEABIABgERHQABAAMQAAQBDBcKAAYBCwMAAQADEAEAAw4ABgEAAwABAAMUABQABAEAAw


test 'two module-level bindings — closure hoisted, pure fn unchanged', fn:
  expect lift ƒink:
    f = fn x:
      x
    g = fn a:
      fn b:
        a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_39, ·ƒret_5:
      ·v_6 = fn [·ƒctx_41, ·ƒret_7, ·x_2]:
        ·ƒret_7 ·ƒctx_41, ·x_2
      ·v_54 = fn {·a_55}, [·ƒctx_47, ·ƒret_15, ·b_4]:
        ·op_plus ·a_55, ·b_4, ·ƒret_15
      ·v_12 = fn [·ƒctx_46, ·ƒret_13, ·a_3]:
        ·closure ·v_54, ·a_3, ·ƒret_13
      ·f_0 = ·v_6
      ·ƒpub ·f_0
      ·g_1 = ·v_12
      ·ƒpub ·g_1
      ·ƒret_5 ·ƒctx_50, ·g_1
    # sm:

---
depth-2 closures — multiple nesting levels
---

test 'depth-2 closure', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b + c

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_35, ·ƒret_4:
      ·v_67 = fn {·c_68, ·ƒret_70}, [·ƒctx_40, ·v_13]:
        ·op_plus ·v_13, ·c_68, ·ƒret_70
      ·v_55 = fn {·a_56, ·b_58}, [·ƒctx_39, ·ƒret_10, ·c_3]:
        ·v_74 = ·closure ·v_67, ·c_3, ·ƒret_10
        ·op_plus ·a_56, ·b_58, ·v_74
      ·v_46 = fn {·a_47}, [·ƒctx_38, ·ƒret_8, ·b_2]:
        ·closure ·v_55, ·a_47, ·b_2, ·ƒret_8
      ·v_5 = fn [·ƒctx_37, ·ƒret_6, ·a_1]:
        ·closure ·v_46, ·a_1, ·ƒret_6
      ·foo_0 = ·v_5
      ·ƒpub ·foo_0
      ·ƒret_4 ·ƒctx_43, ·foo_0
    # sm:


test 'multiple captures at depth-2', fn:
  expect lift ƒink:
    foo = fn a:
      fn b:
        fn c:
          a + b

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_4:
      ·v_49 = fn {·a_50, ·b_52}, [·ƒctx_34, ·ƒret_10, ·c_3]:
        ·op_plus ·a_50, ·b_52, ·ƒret_10
      ·v_40 = fn {·a_41}, [·ƒctx_33, ·ƒret_8, ·b_2]:
        ·closure ·v_49, ·a_41, ·b_2, ·ƒret_8
      ·v_5 = fn [·ƒctx_32, ·ƒret_6, ·a_1]:
        ·closure ·v_40, ·a_1, ·ƒret_6
      ·foo_0 = ·v_5
      ·ƒpub ·foo_0
      ·ƒret_4 ·ƒctx_37, ·foo_0
    # sm:


test 'multi-fn module — add and main', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    foo = fn:
      add 3, 4

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_37, ·ƒret_4:
      ·v_5 = fn [·ƒctx_39, ·ƒret_6, ·a_2, ·b_3]:
        ·op_plus ·a_2, ·b_3, ·ƒret_6
      ·add_0 = ·v_5
      ·ƒpub ·add_0
      ·v_13 = fn [·ƒctx_43, ·ƒret_14]:
        ·add_0 ·ƒctx_43, ·ƒret_14, (i8 3), (i8 4)
      ·foo_1 = ·v_13
      ·ƒpub ·foo_1
      ·ƒret_4 ·ƒctx_47, ·foo_1
    # sm:

test 'chained module-fn calls via let — cont closes over outer cont', fn:
  # The cont ·v_55 closes over ·v_28 (the outer cont param) via ·closure.
  # This is correct and necessary: ·double_0 calls its cont with one arg (the
  # result), so ·v_28 must be baked into the cont beforehand.
  # The ·closure could be eliminated by threading ·v_28 as an extra param
  # through ·double_0 — see the "closure elimination" note in lifting/mod.rs.
  expect lift ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1

    foo = fn:
      x = double 5
      inc x

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_60, ·ƒret_6:
      ·v_7 = fn [·ƒctx_62, ·ƒret_8, ·x_3]:
        ·op_mul ·x_3, (i8 2), ·ƒret_8
      ·v_15 = fn [·ƒctx_66, ·ƒret_16, ·x_4]:
        ·op_plus ·x_4, (i8 1), ·ƒret_16
      ·v_90 = fn {·inc_91, ·ƒret_93}, [·ƒctx_72, ·v_27]:
        ·x_5 = ·v_27
        ·inc_91 ·ƒctx_73, ·ƒret_93, ·x_5
      ·v_79 = fn {·double_80, ·inc_82}, [·ƒctx_70, ·ƒret_24]:
        ·v_97 = ·closure ·v_90, ·inc_82, ·ƒret_24
        ·double_80 ·ƒctx_70, ·v_97, (i8 5)
      ·double_0 = ·v_7
      ·ƒpub ·double_0
      ·inc_1 = ·v_15
      ·ƒpub ·inc_1
      ·v_84 = ·closure ·v_79, ·double_0, ·inc_1
      ·foo_2 = ·v_84
      ·ƒpub ·foo_2
      ·ƒret_6 ·ƒctx_77, ·foo_2
    # sm:

---
pattern matching
---

test 'seq destructure', fn:
  expect lift ƒink:
    spam = fn foo:
      [a] = foo
      a + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_3:
      ·v_79 = fn {·ƒret_80}, [·ƒctx_61, ·v_10]:
        ·a_2 = ·v_10
        ·op_plus ·a_2, (i8 1), ·ƒret_80
      ·v_92 = fn {·ƒfail_93}, [·ƒctx_70]:
        ·ƒfail_93 ·ƒctx_70
      ·v_138 = fn {·ƒsucc_139, ·v_141, ·ƒfail_143}, [·ƒctx_67, ·v_17]:
        ·if ·v_17,
          fn:
            ·ƒsucc_139 ·ƒctx_67, ·v_141
          fn:
            ·ƒfail_143 ·ƒctx_67
      ·v_121 = fn {·ƒsucc_122, ·ƒfail_124}, [·ƒctx_66, ·v_10, ·v_14]:
        ·v_147 = ·closure ·v_138, ·ƒsucc_122, ·v_10, ·ƒfail_124
        ·empty ·v_14, ·v_147
      ·v_105 = fn {·ƒfail_106, ·ƒsucc_108}, [·ƒctx_65, ·v_22]:
        ·v_128 = ·closure ·v_121, ·ƒsucc_108, ·ƒfail_106
        ·seq_pop ·v_22, ·ƒfail_106, ·v_128
      ·v_30 = fn [·ƒctx_64, ·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_97 = ·closure ·v_92, ·ƒfail_9
        ·v_112 = ·closure ·v_105, ·ƒfail_9, ·ƒsucc_8
        ·is_seq_like ·v_7, ·v_112, ·v_97
      ·v_4 = fn [·ƒctx_60, ·ƒret_5, ·foo_1]:
        ·v_82 = ·closure ·v_79, ·ƒret_5
        ·v_30 ·ƒctx_72, ·v_82, ·panic, ·foo_1
      ·spam_0 = ·v_4
      ·ƒpub ·spam_0
      ·ƒret_3 ·ƒctx_76, ·spam_0
    # sm:


test 'record destructure', fn:
  expect lift ƒink:
    ham = fn foo:
      {x} = foo
      x + 1

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_52, ·ƒret_3:
      ·v_71 = fn {·ƒret_72}, [·ƒctx_55, ·v_10]:
        ·x_2 = ·v_10
        ·op_plus ·x_2, (i8 1), ·ƒret_72
      ·v_84 = fn {·ƒfail_85}, [·ƒctx_62]:
        ·ƒfail_85 ·ƒctx_62
      ·v_113 = fn {·ƒsucc_114}, [·ƒctx_60, ·v_10, ·v_14]:
        ·ƒsucc_114 ·ƒctx_60, ·v_10
      ·v_97 = fn {·ƒfail_98, ·ƒsucc_100}, [·ƒctx_59, ·v_15]:
        ·v_118 = ·closure ·v_113, ·ƒsucc_100
        ·rec_pop ·v_15, 'x', ·ƒfail_98, ·v_118
      ·v_24 = fn [·ƒctx_58, ·ƒsucc_8, ·ƒfail_9, ·v_7]:
        ·v_89 = ·closure ·v_84, ·ƒfail_9
        ·v_104 = ·closure ·v_97, ·ƒfail_9, ·ƒsucc_8
        ·is_rec_like ·v_7, ·v_104, ·v_89
      ·v_4 = fn [·ƒctx_54, ·ƒret_5, ·foo_1]:
        ·v_74 = ·closure ·v_71, ·ƒret_5
        ·v_24 ·ƒctx_64, ·v_74, ·panic, ·foo_1
      ·ham_0 = ·v_4
      ·ƒpub ·ham_0
      ·ƒret_3 ·ƒctx_68, ·ham_0
    # sm:


test 'match — no forward refs after lift', fn:
  expect lift ƒink:
    foo = fn n:
      match n:
        0: 42

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_70, ·ƒret_2:
      ·v_29 = fn [·ƒctx_73, ·ƒret_25]:
        ·ƒret_25 ·ƒctx_73, (i8 42)
      ·v_107 = fn {·ƒsucc_108}, [·ƒctx_77]:
        ·v_29 ·ƒctx_77, ·ƒsucc_108
      ·v_128 = fn {·ƒsucc_129, ·ƒfail_131}, [·ƒctx_81, ·v_15]:
        ·if ·v_15,
          fn:
            ·ƒsucc_129 ·ƒctx_81
          fn:
            ·ƒfail_131 ·ƒctx_81
      ·v_23 = fn [·ƒctx_80, ·ƒsucc_11, ·ƒfail_12, ·v_10]:
        ·v_135 = ·closure ·v_128, ·ƒsucc_11, ·ƒfail_12
        ·op_eq ·v_10, (i8 0), ·v_135
      ·v_41 = fn [·ƒctx_76, ·ƒsucc_7, ·ƒfail_8, ·v_6]:
        ·v_110 = ·closure ·v_107, ·ƒsucc_7
        ·v_23 ·ƒctx_84, ·v_110, ·ƒfail_8, ·v_6
      ·ƒret_104 = fn [·ƒctx_89]:
        ·panic _
      ·v_49 = fn [·ƒctx_87, ·ƒret_43, ·v_42]:
        ·v_41 ·ƒctx_87, ·ƒret_43, ·ƒret_104, ·v_42
      ·v_3 = fn [·ƒctx_72, ·ƒret_4, ·n_1]:
        ·v_49 ·ƒctx_90, ·ƒret_4, ·n_1
      ·foo_0 = ·v_3
      ·ƒpub ·foo_0
      ·ƒret_2 ·ƒctx_94, ·foo_0
    # sm:


test 'match with binding', fn:
  expect lift ƒink:
    foo = fn n:
      r = match n:
        0: n + 1
      r

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_78, ·ƒret_3:
      ·v_107 = fn {·n_108}, [·ƒctx_81, ·ƒret_26]:
        ·op_plus ·n_108, (i8 1), ·ƒret_26
      ·v_133 = fn {·v_134, ·ƒsucc_136}, [·ƒctx_84]:
        ·v_134 ·ƒctx_84, ·ƒsucc_136
      ·v_168 = fn {·ƒsucc_169, ·ƒfail_171}, [·ƒctx_88, ·v_16]:
        ·if ·v_16,
          fn:
            ·ƒsucc_169 ·ƒctx_88
          fn:
            ·ƒfail_171 ·ƒctx_88
      ·v_24 = fn [·ƒctx_87, ·ƒsucc_12, ·ƒfail_13, ·v_11]:
        ·v_175 = ·closure ·v_168, ·ƒsucc_12, ·ƒfail_13
