---
Regression test for the fooobar lifting bug — module with multiple
top-level fns where the results of calls are bound to names. Previously
downstream wasm emit panicked with `unknown local: add_0` because capture
analysis didn't track LetVal names that aliased hoisted fn references
(`add_0 = v_14` where v_14 is the hoisted add-fn). Nested inline conts
referencing `add_0` couldn't see it in scope_binds and therefore didn't
capture it. Fixed by always adding LetVal names to scope_binds during
extraction, regardless of whether the val aliases a hoisted fn.
---

test 'multiple top-level fns with bound call results', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_62, ·ƒret_8:
      ·v_9 = fn [·ƒctx_64, ·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒctx_72, ·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_91 = fn {·ƒret_92}, [·ƒctx_77, ·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3
        ·ƒret_92 ·ƒctx_79, ·p_3
      ·v_81 = fn {·ƒret_82}, [·ƒctx_69, ·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1
        ·mul_2 = ·v_22
        ·ƒpub ·mul_2
        ·v_96 = ·closure ·v_91, ·ƒret_82
        ·mul_2 ·ƒctx_75, ·v_96, ·s_1, (i8 3)
      ·add_0 = ·v_9
      ·ƒpub ·add_0
      ·v_86 = ·closure ·v_81, ·ƒret_8
      ·add_0 ·ƒctx_67, ·v_86, (i8 1), (i8 2)
    # sm:



test 'spawn with closure over channel', fn:
  expect lift ƒink:
    ch = channel 0
    fut = spawn fn:
      receive ch
    77 >> ch
    result = await fut
    result

  | equals ƒink:
    ·ƒink_module fn ·ƒctx_58, ·ƒret_7:
      ·v_83 = fn {·ch_84}, [·ƒctx_63, ·ƒret_14]:
        ·receive ·ch_84, ·ƒret_14
      ·v_126 = fn {·ƒret_127}, [·ƒctx_70, ·v_30]:
        ·result_2 = ·v_30
        ·ƒpub ·result_2
        ·ƒret_127 ·ƒctx_72, ·result_2
      ·v_110 = fn {·fut_111, ·ƒret_113}, [·ƒctx_68, ·v_25]:
        ·v_27 = ·v_25
        ·v_131 = ·closure ·v_126, ·ƒret_113
        ·await ·fut_111, ·v_131
      ·v_95 = fn {·ch_96, ·ƒret_98}, [·ƒctx_65, ·v_21]:
        ·fut_1 = ·v_21
        ·ƒpub ·fut_1
        ·v_117 = ·closure ·v_110, ·fut_1, ·ƒret_98
        ·op_shr (i8 77), ·ch_96, ·v_117
      ·v_74 = fn {·ƒret_75}, [·ƒctx_60, ·v_10]:
        ·ch_0 = ·v_10
        ·ƒpub ·ch_0
        ·v_86 = ·closure ·v_83, ·ch_0
        ·v_102 = ·closure ·v_95, ·ch_0, ·ƒret_75
        ·spawn ·v_86, ·v_102
      ·ƒret_90 = fn [·v_79]:
        ·channel (i8 0), ·v_79
      ·closure ·v_74, ·ƒret_7, ·ƒret_90
    # sm:

