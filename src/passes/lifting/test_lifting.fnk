---
unified lifting tests
---

# Unified closure/continuation lifting — lifts nested fns one level at a time,
# threading captured bindings as explicit params via ·closure.
#
# After lifting, no fn should reference bindings from outer scopes — all values
# are passed explicitly as params. No forward references to sibling-scope binds.
#
# Param display format (purely visual — the IR is a flat param list):
#   {·a_1, ·b_2}     captures — closed-over variables threaded by lifting
#   [·x_3, ·y_4]     user params — original function arguments
#   ·v_5              cont — the return continuation (bare, no brackets)
#
# Capture names use the source name from the original binding (via AST origin)
# paired with the capture param's own CpsId, so they match body refs.
#
# Test format:
#   test 'name', fn:
#     expect lift ƒink:
#       <fink source>
#
#     | equals ƒink:
#       <expected lifted CPS>

{test, skip, equals, expect, lift} = import 'fake!'
{ƒink} = import '@fink/parse/blocks.fnk'
{·ƒink_module,·import,·ƒpub, ·closure, ·if, ·panic
  ·op_plus
  ·op_mul
  ·op_eq
  ·empty
  ·is_seq_like
  ·is_rec_like
  ·seq_pop
  ·seq_prepend
  ·rec_put
  ·rec_pop
  ·spawn
  ·await
  ·channel
  ·receive
} = import '@fink/compile/builtins'




test 'single module expr', fn:
  expect lift ƒink:
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_4, ·ƒret_0:
      ·ƒret_0 ·ƒctx_4, (i8 42)
    # sm:DQABAAIAAQACJAAWABIAAgAGAQACAAEAAhQAEgAGAQACAAEAAgYBAAI


test 'single binding export', fn:
  expect lift ƒink:
    foo = fn: 123
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_17, ·ƒret_1:
      ·v_2 = fn [·ƒctx_19, ·ƒret_3]:
        ·ƒret_3 ·ƒctx_19, (i8 123)
      ·foo_0 = ·v_2
      ·ƒpub ·foo_0
      ·ƒret_1 ·ƒctx_23, ·foo_0
    # sm:KQABAA0AAQANJAAYABIAAgAGAQwHAAEABwwABAEABwYAAAACABQABAASAAAAAgACAAoBCAMAAQADFAAUAAYBAAMAAQADBgEAAwgABgETDQABAAMQAAQBDAcKAAYBCwMAAQADEAEAAw4ABgEAAwABAAMUABQABAEAAw

test 'single binding export with trailing expr', fn:
  expect lift ƒink:
    foo = fn: 123
    42
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_16, ·ƒret_1:
      ·v_2 = fn [·ƒctx_18, ·ƒret_3]:
        ·ƒret_3 ·ƒctx_18, (i8 123)
      ·foo_0 = ·v_2
      ·ƒpub ·foo_0
      ·ƒret_1 ·ƒctx_22, (i8 42)
    # sm:KwABABAAAQAQJAAYABIAAgAGAQwHAAEABwwABAEABwYAAAACABQABAASAAAAAgACAAoBCAMAAQADFAAUAAYBAAMAAQADBgEAAwgABgETDQABAAMQAAQBDAcKAAYBCwMAAQADEAEAAw4ABgEcAgABAAIUABQABgEAAgABAAIGAQAC



test 'two fn exports', fn:
  expect lift ƒink:
    foo = fn: 123
    bar = fn: 345
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_30, ·ƒret_2:
      ·v_3 = fn [·ƒctx_32, ·ƒret_4]:
        ·ƒret_4 ·ƒctx_32, (i8 123)
      ·foo_0 = ·v_3
      ·ƒpub ·foo_0
      ·v_9 = fn [·ƒctx_37, ·ƒret_10]:
        ·ƒret_10 ·ƒctx_37, (i16 345)
      ·bar_1 = ·v_9
      ·ƒpub ·bar_1
      ·ƒret_2 ·ƒctx_41, ·bar_1
    # sm:RwABABsAAQAbJAAYABIAAgAGAQwHAAEABwwABAEABwYAAAACABQABAASAAAAAgACAAoBCAMAAQADFAAUAAYBAAMAAQADBgEAAwgABgETDQABAAMQAAQBDAcKAAYBCwMAAQADEAEAAw4ABgEoBwABAAcMAAQBAAcGAAAAAgAUAAQAFAAAAAIAAgAKAQgDAAEAAxYAFAAGAQADAAEAAwgBAAMIAAYBEw0AAQADEAAEAQwHCgAGAQsDAAEAAxABAAMOAAYBAAMAAQADFAAUAAQBAAM

test 'fooobar — multi fn with calls', fn:
  expect lift ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3
  | equals ƒink:
    ·ƒink_module fn ·ƒctx_62, ·ƒret_8:
      ·v_9 = fn [·ƒctx_64, ·ƒret_10, ·a_4, ·b_5]:
        ·op_plus ·a_4, ·b_5, ·ƒret_10
      ·v_22 = fn [·ƒctx_72, ·ƒret_23, ·a_6, ·b_7]:
        ·op_mul ·a_6, ·b_7, ·ƒret_23
      ·v_91 = fn {·ƒret_92}, [·ƒctx_77, ·v_33]:
        ·p_3 = ·v_33
        ·ƒpub ·p_3
        ·ƒret_92 ·ƒctx_79, ·p_3
      ·v_81 = fn {·ƒret_82}, [·ƒctx_69, ·v_20]:
        ·s_1 = ·v_20
        ·ƒpub ·s_1
        ·mul_2 = ·v_22
        ·ƒpub ·mul_2
        ·v_96 = ·closure ·v_91, ·ƒret_82
        ·mul_2 ·ƒctx_75, ·v_96, ·s_1, (i8 3)
      ·add_0 = ·v_9
      ·ƒpub ·add_0
      ·v_86 = ·closure ·v_81, ·ƒret_8
      ·add_0 ·ƒctx_67, ·v_86, (i8 1), (i8 2)
    # sm:


