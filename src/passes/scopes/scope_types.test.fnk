{test, equals: eq} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{scope} = import 'fink/compile.fnk'


equals = fn expected: fn actual:
  eq actual, expected


# union members are references to existing types (unresolved here in isolation).
test 'union members are references', fn:
  scope ƒink:
    Int = union:
      SignedInt
      UnsignedInt
  | equals ƒink:
    scope 10, 'module',

      scope 4, 'union',
        unresolved 'SignedInt'
        unresolved 'UnsignedInt'
      bind 0, 'Int'


# record field names are declarations, not references; only the field type
# resolves (unresolved here in isolation).
test 'record field names are not references', fn:
  scope ƒink:
    Foo = type:
      shrub: u8
  | equals ƒink:
    scope 11, 'module',

      scope 5, 'type',
        unresolved 'u8'
      bind 0, 'Foo'


# enum member names do NOT leak as lexical bindings (reached via Enum.Some /
# destructure, a type-system concern). The lexical-scopes pass treats the
# constructor name like a record field name: not bound, not resolved. Only the
# generic param binds and the payload type resolves against it.
test 'enum member names are not lexical binds', fn:
  scope ƒink:
    Option = enum T:
      Some T
      None
  | equals ƒink:
    scope 13, 'module',

      scope 7, 'enum',
        bind 1, 'T'
        ref 'T', 1
      bind 0, 'Option'
