test 'single binding', fn:
  expect scope fink":
    x = 1
  | equals fink":
    TODO


test 'fn params in scope', fn:
  expect scope fink":
    f = fn a, b:
      a + b
  | equals fink":
    TODO


---
module level — mutual recursion
---

test 'two fns — main refs add', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    TODO


test 'mutual recursion — is-even refs is-odd', fn:
  expect scope fink":
    is-even = fn n:
      match n:
        0: true
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: false
        _: is-even n - 1

  | equals fink":
    TODO


---
shadowing
---

test 'inner binding shadows outer', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    sub = fn a, b:
      add = fn foo:
        foo
      a - add b

    main = fn: add 3, 4

  | equals fink":
    TODO

