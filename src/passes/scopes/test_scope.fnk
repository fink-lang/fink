---
scope analysis tests
---

# AST-level scope analysis — resolves identifiers to bindings.
#
# Output: nested scope tree with bindings and references in source order.
# Scopes nest to show parent-child relationships. Bindings and references
# appear in the scope where they are defined/used, in source order.
#
# Scope kinds:
#   module  — all bindings mutually recursive (forward refs allowed)
#   fn      — sequential (binding visible to subsequent siblings)
#   match   — per-arm, pattern bindings visible in arm body
#
# Reference kinds:
#   ref 'name', 'B0'             — normal ref to binding B0
#   ref 'name', 'B0', depth 1    — captured from parent scope (1 level up)
#   fwd_ref 'name', 'B0'         — forward ref in module scope (mutual recursion)
#   self_ref 'name', 'B0'        — recursive self-reference
#
# Example output:
#   scope 'S0', 'module':
#     bind 'add', 'B0'
#     bind 'main', 'B1'
#
#     scope 'S1', 'fn add':
#       bind 'a', 'B2'
#       bind 'b', 'B3'
#       ref 'a', 'B2'
#       ref 'b', 'B3'
#
#     scope 'S2', 'fn main':
#       ref 'add', 'B0', depth 1


{test, expect, equals, fink, scope} = import '!fake'


---
basic bindings
---

test 'single binding', fn:
  expect scope fink":
    x = 1
  | equals fink":
    scope 3, 'module':
      bind 0, 'x'


test 'fn params in scope', fn:
  expect scope fink":
    f = fn a, b:
      a + b
  | equals fink":
    scope 11, 'module':
      bind 0, 'f'

      scope 9, 'fn':
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4


---
module level — mutual recursion
---

test 'two fns — main refs add', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    scope 19, 'module':
      bind 0, 'add'
      bind 11, 'main'

      scope 9, 'fn':
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4

      scope 17, 'fn':
        ref 'add', 0, depth 1


test 'mutual recursion — is-even refs is-odd', fn:
  expect scope fink":
    is-even = fn n:
      match n:
        0: true
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: false
        _: is-even n - 1

  | equals fink":
    scope 44, 'module':
      bind 0, 'is-even'
      bind 22, 'is-odd'

      scope 20, 'fn':
        bind 2, 'n'

        scope 10, 'arm':

        scope 18, 'arm':
          fwd_ref 'is-odd', 22, depth 2
          ref 'n', 2, depth 1
        ref 'n', 2

      scope 42, 'fn':
        bind 24, 'n'

        scope 32, 'arm':

        scope 40, 'arm':
          ref 'is-even', 0, depth 2
          ref 'n', 24, depth 1
        ref 'n', 24


---
shadowing
---

test 'inner binding shadows outer', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    sub = fn a, b:
      add = fn foo:
        foo
      a - add b

    main = fn: add 3, 4

  | equals fink":
    scope 38, 'module':
      bind 0, 'add'
      bind 11, 'sub'
      bind 30, 'main'

      scope 9, 'fn':
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4

      scope 28, 'fn':
        bind 13, 'a'
        bind 15, 'b'
        bind 17, 'add'

        scope 22, 'fn':
          bind 19, 'foo'
          ref 'foo', 19
        ref 'a', 13
        ref 'add', 17
        ref 'b', 15

      scope 36, 'fn':
        ref 'add', 0, depth 1

