---
scope analysis tests
---

# AST-level scope analysis — resolves identifiers to bindings.
#
# Output: nested scope tree with bindings and references in source order.
# Scopes nest to show parent-child relationships. Bindings and references
# appear in the scope where they are defined/used, in source order.
#
# Scope kinds:
#   module  — all bindings mutually recursive (forward refs allowed)
#   fn      — sequential (binding visible to subsequent siblings)
#   match   — per-arm, pattern bindings visible in arm body
#
# Reference kinds:
#   ref 'name', 'B0'             — normal ref to binding B0
#   ref 'name', 'B0', depth 1    — captured from parent scope (1 level up)
#   fwd_ref 'name', 'B0'         — forward ref in module scope (mutual recursion)
#   self_ref 'name', 'B0'        — recursive self-reference
#
# Example output:
#   scope 'S0', 'module':
#     bind 'add', 'B0'
#     bind 'main', 'B1'
#
#     scope 'S1', 'fn add':
#       bind 'a', 'B2'
#       bind 'b', 'B3'
#       ref 'a', 'B2'
#       ref 'b', 'B3'
#
#     scope 'S2', 'fn main':
#       ref 'add', 'B0', depth 1


{test, expect, equals, fink, scope} = import '!fake'


---
basic bindings
