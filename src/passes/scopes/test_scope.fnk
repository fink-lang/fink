---
scope analysis tests
---

# AST-level scope analysis — resolves identifiers to bindings.
#
# Output: nested scope tree with bindings and references in source order.
# Scopes nest to show parent-child relationships. Bindings and references
# appear in the scope where they are defined/used, in source order.
#
# Scope kinds:
#   module  — all bindings mutually recursive (forward refs allowed)
#   fn      — sequential (binding visible to subsequent siblings)
#   match   — per-arm, pattern bindings visible in arm body
#
# Reference kinds:
#   ref 'name', 'B0'             — normal ref to binding B0
#   ref 'name', 'B0', depth 1    — captured from parent scope (1 level up)
#   fwd_ref 'name', 'B0'         — forward ref in module scope (mutual recursion)
#   self_ref 'name', 'B0'        — recursive self-reference
#
# Example output:
#   scope 'S0', 'module',
#     bind 'add', 'B0'
#     bind 'main', 'B1'
#
#     scope 'S1', 'fn add',
#       bind 'a', 'B2'
#       bind 'b', 'B3'
#       ref 'a', 'B2'
#       ref 'b', 'B3'
#
#     scope 'S2', 'fn main',
#       ref 'add', 'B0', depth 1


{test, skip, expect, equals, scope} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
basic bindings
---

test 'single binding', fn:
  expect scope ƒink:
    x = 1
  | equals ƒink:
    scope 3, 'module',
      bind 0, 'x'


test 'nested bind in rhs is sequential', fn:
  expect scope ƒink:
    foo = spam = 1
  | equals ƒink:
    scope 5, 'module',
      bind 1, 'spam'
      bind 0, 'foo'


test 'guard pattern bind', fn:
  expect scope ƒink:
    a > 0 = foo
  | equals ƒink:
    scope 5, 'module',
      unresolved 'foo'
      bind 0, 'a'
      ref 'a', 0


test 'fn params in scope', fn:
  expect scope ƒink:
    f = fn a, b:
      a + b
  | equals ƒink:
    scope 11, 'module',

      scope 9, 'fn',
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4
      bind 0, 'f'


test 'partial application', fn:
  expect scope ƒink:
    foo = 2 + ?
  | equals ƒink:
    scope 13, 'module',

      scope 11, 'fn',
        bind 9, '·$_0'
        ref '·$_0', 9
      bind 0, 'foo'


test 'multiple partials — same param', fn:
  expect scope ƒink:
    foo = ? + ?
  | equals ƒink:
    scope 14, 'module',

      scope 12, 'fn',
        bind 10, '·$_0'
        ref '·$_0', 10
        ref '·$_0', 10
      bind 0, 'foo'


test 'wildcard _ does not bind', fn:
  expect scope ƒink:
    f = fn _: 42
  | equals ƒink:
    scope 6, 'module',

      scope 4, 'fn'
      bind 0, 'f'


test 'wildcard in destructure', fn:
  expect scope ƒink:
    [_, b] = [1, 2]
    b
  | equals ƒink:
    scope 8, 'module',
      bind 1, 'b'
      ref 'b', 1


test 'wildcard in match arm', fn:
  expect scope ƒink:
    f = fn x:
      match x:
        _: 42
  | equals ƒink:
    scope 14, 'module',

      scope 12, 'fn',
        bind 2, 'x'
        ref 'x', 2

        scope 10, 'arm'
      bind 0, 'f'


test 'sequential bindings in fn body', fn:
  expect scope ƒink:
    f = fn:
      x = 1
      y = x + 1
      y
  | equals ƒink:
    scope 13, 'module',

      scope 11, 'fn',
        bind 2, 'x'
        ref 'x', 2
        bind 5, 'y'
        ref 'y', 5
      bind 0, 'f'


test 'self-recursion', fn:
  expect scope ƒink:
    fib = fn n:
      fib n - 1
  | equals ƒink:
    scope 11, 'module',

      scope 9, 'fn',
        bind 2, 'n'
        self_ref 'fib', 0, depth 1
        ref 'n', 2
      bind 0, 'fib'


test 'nested fn — closure depth', fn:
  expect scope ƒink:
    f = fn a:
      fn b:
        a + b
  | equals ƒink:
    scope 13, 'module',

      scope 11, 'fn',
        bind 2, 'a'

        scope 10, 'fn',
          bind 5, 'b'
          ref 'a', 2, depth 1
          ref 'b', 5
      bind 0, 'f'


---
unresolved
---

test 'unresolved ref', fn:
  expect scope ƒink:
    ni = spam
    spam = ni
    bar = spam

    main = fn:
      foo 1

  | equals ƒink:
    scope 16, 'module',
      unresolved 'spam'
      bind 0, 'ni'
      ref 'ni', 0
      bind 3, 'spam'
      ref 'spam', 3
      bind 6, 'bar'

      scope 14, 'fn',
        unresolved 'foo'
      bind 9, 'main'



---
module level — mutual recursion
---

test 'two fns — main refs add', fn:
  expect scope ƒink:
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals ƒink:
    scope 19, 'module',

      scope 9, 'fn',
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4
      bind 0, 'add'

      scope 17, 'fn',
        ref 'add', 0, depth 1
      bind 11, 'main'


test 'mutual recursion — is-even refs is-odd', fn:
  expect scope ƒink:
    is-even = fn n:
      match n:
        0: true
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: false
        _: is-even n - 1

  | equals ƒink:
    scope 44, 'module',

      scope 20, 'fn',
        bind 2, 'n'
        ref 'n', 2

        scope 10, 'arm'

        scope 18, 'arm',
          fwd_ref 'is-odd', 22, depth 2
          ref 'n', 2, depth 1
      bind 0, 'is-even'

      scope 42, 'fn',
        bind 24, 'n'
        ref 'n', 24

        scope 32, 'arm'

        scope 40, 'arm',
          ref 'is-even', 0, depth 2
          ref 'n', 24, depth 1
      bind 22, 'is-odd'


test 'match with binding in arm', fn:
  expect scope ƒink:
    f = fn x:
      match x:
        0: 42
        n: n + 1
  | equals ƒink:
    scope 21, 'module',

      scope 19, 'fn',
        bind 2, 'x'
        ref 'x', 2

        scope 10, 'arm'

        scope 17, 'arm',
          bind 12, 'n'
          ref 'n', 12
      bind 0, 'f'


test 'pipe — refs to fns', fn:
  expect scope ƒink:
    double = fn x: x * 2
    inc = fn x: x + 1
    main = fn: 5 | double | inc
  | equals ƒink:
    scope 26, 'module',

      scope 7, 'fn',
        bind 2, 'x'
        ref 'x', 2
      bind 0, 'double'

      scope 16, 'fn',
        bind 11, 'x'
        ref 'x', 11
      bind 9, 'inc'

      scope 24, 'fn',
        ref 'double', 0, depth 1
        ref 'inc', 9, depth 1
      bind 18, 'main'


---
shadowing
---

test 'inner binding shadows outer', fn:
  expect scope ƒink:
    add = fn a, b:
      a + b

    sub = fn a, b:
      add = fn foo:
        foo
      a - add b

    main = fn: add 3, 4

  | equals ƒink:
    scope 40, 'module',

      scope 9, 'fn',
        bind 2, 'a'
        bind 4, 'b'
        ref 'a', 2
        ref 'b', 4
      bind 0, 'add'

      scope 30, 'fn',
        bind 13, 'a'
        bind 15, 'b'

        scope 22, 'fn',
          bind 19, 'foo'
          ref 'foo', 19
        bind 17, 'add'
        ref 'a', 13
        ref 'add', 17
        ref 'b', 15
      bind 11, 'sub'

      scope 38, 'fn',
        ref 'add', 0, depth 1
      bind 32, 'main'


---
destructuring
---

test 'seq destructure', fn:
  expect scope ƒink:
    [a, b] = [1, 2]
    a + b
  | equals ƒink:
    scope 10, 'module',
      bind 0, 'a'
      bind 1, 'b'
      ref 'a', 0
      ref 'b', 1


test 'nested seq destructure', fn:
  expect scope ƒink:
    [a, [b, c]] = [1, [2, 3]]
    a + b + c
  | equals ƒink:
    scope 16, 'module',
      bind 0, 'a'
      bind 1, 'b'
      bind 2, 'c'
      ref 'a', 0
      ref 'b', 1
      ref 'c', 2


test 'record destructure', fn:
  expect scope ƒink:
    {x, y} = {x: 1, y: 2}
    x + y
  | equals ƒink:
    scope 14, 'module',
      bind 0, 'x'
      bind 1, 'y'
      ref 'x', 0
      ref 'y', 1


test 'fn with destructured params', fn:
  expect scope ƒink:
    f = fn [a, b]: a + b
  | equals ƒink:
    scope 10, 'module',

      scope 8, 'fn',
        bind 1, 'a'
        bind 2, 'b'
        ref 'a', 1
        ref 'b', 2
      bind 0, 'f'


test 'spread in seq destructure', fn:
  expect scope ƒink:
    [a, ..rest] = [1, 2, 3]
    a + rest
  | equals ƒink:
    scope 12, 'module',
      bind 0, 'a'
      bind 1, 'rest'
      ref 'a', 0
      ref 'rest', 1


test 'bind-right destructure in seq pattern', fn:
  expect scope ƒink:
    [foo |= [bar, spam]] = [[1, 2]]
    foo + bar + spam
  | equals ƒink:
    scope 16, 'module',
      bind 0, 'foo'
      bind 1, 'bar'
      bind 2, 'spam'
      ref 'foo', 0
      ref 'bar', 1
      ref 'spam', 2

# TODO
test 'bind-right at statement top', fn:
  expect scope ƒink:
    foo arg1
      arg2
    |= result
    result
  | equals ƒink:
    scope 9, 'module',
      unresolved 'foo'
      unresolved 'arg1'
      unresolved 'arg2'
      bind 6, 'result'
      ref 'result', 6


test 'record destructure with field rename', fn:
  expect scope ƒink:
    {x, y: z} = point
  | equals ƒink:
    scope 7, 'module',
      bind 0, 'x'
      bind 2, 'z'
      unresolved 'point'


test 'predicate guard in seq pattern', fn:
  expect scope ƒink:
    [a, is_even b] = foo
  | equals ƒink:
    scope 8, 'module',
      bind 0, 'a'
      bind 3, 'b'
      unresolved 'foo'
      unresolved 'is_even'


test 'str templ pattern', fn:
  expect scope ƒink:
    'foo${bar}spam' = val
    bar
  | equals ƒink:
    scope 9, 'module',
      unresolved 'val'
      ref 'bar', 2

test 'str templ pattern capture all', fn:
  expect scope ƒink:
    '${x}' = val
    x
  | equals ƒink:
    scope 5, 'module',
      unresolved 'val'
      ref 'x', 0

test 'str templ pattern in match', fn:
  expect scope ƒink:
    match val:
      'foo${x}bar': x
      _: 0
  | equals ƒink:
    scope 17, 'module',
      unresolved 'val'

      scope 11, 'arm',
        bind 5, 'x'
        ref 'x', 5

      scope 15, 'arm'


---
prelude
---

test 'import resolves to prelude', fn:
  expect scope ƒink:
    {foo} = import './bar.fnk'
  | equals ƒink:
    scope 8, 'module',
      bind 0, 'foo'
      ref 'import', builtin 0

