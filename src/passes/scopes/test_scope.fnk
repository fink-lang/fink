---
scope analysis tests
---

# AST-level scope analysis — resolves identifiers to bindings.
#
# Output: nested scope tree with bindings and references in source order.
# Scopes nest to show parent-child relationships. Bindings and references
# appear in the scope where they are defined/used, in source order.
#
# Scope kinds:
#   module  — all bindings mutually recursive (forward refs allowed)
#   fn      — sequential (binding visible to subsequent siblings)
#   match   — per-arm, pattern bindings visible in arm body
#
# Reference kinds:
#   ref 'name', 'B0'             — normal ref to binding B0
#   ref 'name', 'B0', depth 1    — captured from parent scope (1 level up)
#   fwd_ref 'name', 'B0'         — forward ref in module scope (mutual recursion)
#   self_ref 'name', 'B0'        — recursive self-reference
#
# Example output:
#   scope 'S0', 'module':
#     bind 'add', 'B0'
#     bind 'main', 'B1'
#
#     scope 'S1', 'fn add':
#       bind 'a', 'B2'
#       bind 'b', 'B3'
#       ref 'a', 'B2'
#       ref 'b', 'B3'
#
#     scope 'S2', 'fn main':
#       ref 'add', 'B0', depth 1


{test, expect, equals, fink, scope} = import '!fake'


---
basic bindings
---

test 'single binding', fn:
  expect scope fink":
    x = 1
  | equals fink":
    scope 'S0', 'module':
      bind 'x', 'B0'


test 'fn params in scope', fn:
  expect scope fink":
    f = fn a, b:
      a + b
  | equals fink":
    scope 'S0', 'module':
      bind 'f', 'B0'

      scope 'S1', 'fn':
        bind 'a', 'B1'
        bind 'b', 'B2'
        ref 'a', 'B1'
        ref 'b', 'B2'


---
module level — mutual recursion
---

test 'two fns — main refs add', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    main = fn:
      add 3, 4

  | equals fink":
    scope 'S0', 'module':
      bind 'add', 'B0'
      bind 'main', 'B1'

      scope 'S1', 'fn':
        bind 'a', 'B2'
        bind 'b', 'B3'
        ref 'a', 'B2'
        ref 'b', 'B3'

      scope 'S2', 'fn':
        ref 'add', 'B0', depth 1


test 'mutual recursion — is-even refs is-odd', fn:
  expect scope fink":
    is-even = fn n:
      match n:
        0: true
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: false
        _: is-even n - 1

  | equals fink":
    scope 'S0', 'module':
      bind 'is-even', 'B0'
      bind 'is-odd', 'B1'

      scope 'S1', 'fn':
        bind 'n', 'B2'

        scope 'S2', 'arm':

        scope 'S3', 'arm':
          fwd_ref 'is-odd', 'B1', depth 2
          ref 'n', 'B2', depth 1
        ref 'n', 'B2'

      scope 'S4', 'fn':
        bind 'n', 'B3'

        scope 'S5', 'arm':

        scope 'S6', 'arm':
          ref 'is-even', 'B0', depth 2
          ref 'n', 'B3', depth 1
        ref 'n', 'B3'


---
shadowing
---

test 'inner binding shadows outer', fn:
  expect scope fink":
    add = fn a, b:
      a + b

    sub = fn a, b:
      add = fn foo:
        foo
      a - add b

    main = fn: add 3, 4

  | equals fink":
    scope 'S0', 'module':
      bind 'add', 'B0'
      bind 'sub', 'B1'
      bind 'main', 'B2'

      scope 'S1', 'fn':
        bind 'a', 'B3'
        bind 'b', 'B4'
        ref 'a', 'B3'
        ref 'b', 'B4'

      scope 'S2', 'fn':
        bind 'a', 'B5'
        bind 'b', 'B6'
        bind 'add', 'B8'

        scope 'S3', 'fn':
          bind 'foo', 'B7'
          ref 'foo', 'B7'
        ref 'a', 'B5'
        ref 'add', 'B8'
        ref 'b', 'B6'

      scope 'S4', 'fn':
        ref 'add', 'B0', depth 1

