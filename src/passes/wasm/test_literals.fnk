{skip, skip-ir, test, expect, equals, wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'literal bool', fn:
  expect wat ƒink:
    true
  | equals wat":
    (module
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref null any))
        (local $:args (ref null any))
        (local.set $v_0 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $v_1 (ref.i31 (i32.const 1)))
        (local.set $:args (call $std/fn.fnk:args_empty))
        (local.set $:args (call $std/fn.fnk:args_prepend (local.get $v_1) (local.get $:args)))
        (return_call $rt/apply.wat:apply (local.get $:args) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
      (func $_host_wrapper (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $:wrap_cont (ref null any))
        (local $:wrap_key (ref null any))
        (local $:wrap_url (ref null any))
        (local $:wrap_caps_arg (ref null $rt/types.wat:Captures))
        (local $:wrap_mod_clos (ref null any))
        (local.set $:wrap_cont (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:params (call $std/fn.fnk:args_tail (local.get $:params)))
        (local.set $:wrap_key (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:wrap_url (call $std/str.fnk:str (data.ref $d_0 0)))
        (local.set $:wrap_caps_arg (ref.null $rt/types.wat:Captures))
        (local.set $:wrap_mod_clos (struct.new $rt/types.wat:Closure (ref.func $fink_module) (local.get $:wrap_caps_arg)))
        (return_call $std/modules.fnk:init_module (local.get $:wrap_url) (local.get $:wrap_mod_clos) (local.get $:wrap_key) (local.get $:wrap_cont))
      )
      (export "_host_wrapper" (func $_host_wrapper))
      (data $d_0 "")
    )
    ;; sm:DMADAI4BAQAEWgBqALYBAJYHAJwBAJYBAJoBAIoBAIQBAO4BAA


