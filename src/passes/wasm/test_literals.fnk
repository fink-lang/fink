{skip, test, expect, equals, gen_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'literal bool', fn:
  expect gen_wat ƒink:
    true
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (type $Fn1 (func (param (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $local_3 (ref any))
        (local.set $v_0 (call $_list_head_any (local.get $_args)))
        (local.set $local_3 (call $_list_nil))
        (local.set $local_3 (call $_list_prepend_any (ref.i31 (i32.const 1)) (local.get $local_3)))
        (return_call $__apply (local.get $local_3) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsidHJ1ZSJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTtBOztBOztBO0E7Ozs7O0E7O0EiCn0=


