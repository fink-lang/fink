{test, expect, equals, gen_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

# Round-trip tests: CPS → emit (WASM binary) → format (WAT text + source map)
# These validate the full pipeline produces correct, readable WAT.

test 'literal int', fn:
  expect gen_wat ƒink:
    main = fn:
      42
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_1 (ref any))
        (local $v_10 (ref any))
        (local $main_0 (ref any))
        (local $local_5 (ref any))
        (local.set $v_1 (call $_list_head_any (local.get $_args)))
        (local.set $main_0 (struct.new $Closure (ref.func $v_2) (ref.null $Captures)))
        (global.set $main (struct.new $Closure (global.get $main_0) (ref.null $Captures)))
        (local.set $local_5 (call $_list_nil))
        (local.set $local_5 (call $_list_prepend_any (struct.new $Closure (global.get $main_0) (ref.null $Captures)) (local.get $local_5)))
        (return_call $__apply (local.get $local_5) (local.get $v_1))
      )
      (global $main_0 (ref $Fn2) (ref.func $v_2))
      (func $v_2 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_3 (ref any))
        (local $local_3 (ref any))
        (local.set $v_3 (call $_list_head_any (local.get $_args)))
        (local.set $local_3 (call $_list_nil))
        (local.set $local_3 (call $_list_prepend_any (struct.new $Num (f64.const 42)) (local.get $local_3)))
        (return_call $__apply (local.get $local_3) (local.get $v_3))
      )
      (global $main (mut (ref null any)) (ref.null any))
      (export "main" (global $main))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICA0MiJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTs7QTs7QTtBO0E7QTs7Ozs7OztBOzs7QTtBOzs7OztBOztBQUFBO0EiCn0=


