  expect gen_wat ƒink:
    ''
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (type $Fn1 (func (param (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $local_3 (ref any))
        (local.set $v_0 (call $_list_head_any (local.get $_args)))
        (local.set $local_3 (call $_list_nil))
        (local.set $local_3 (call $_list_prepend_any (call $_str_empty) (local.get $local_3)))
        (return_call $__apply (local.get $local_3) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiJyciXSwKICAibWFwcGluZ3MiOiAiQTtBO0E7QTs7QTs7QTtBOzs7OztBOztBIgp9



