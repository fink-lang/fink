{test, expect, equals, fink, run} = import '!fake'



test 'literal int', fn:
  expect run fink":
    main = fn:
      42
  | equals fink":
    42

test 'let binding', fn:
  expect run fink":
    main = fn:
      x = 42
      x
  | equals fink":
    42

test 'add two literals', fn:
  expect run fink":
    main = fn:
      2 + 3
  | equals fink":
    5

test 'chained arithmetic', fn:
  expect run fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    10

test 'multiple let bindings used', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      x + y
  | equals fink":
    5

test 'user fn call', fn:
  expect run fink":
    add = fn a, b: a + b
    main = fn: add 3, 4
  | equals fink":
    7

# blocked: chained fn calls need closures-as-values (cont fn has captures
# that can't be passed as $Cont funcref). See name_res: cont param not in
# fn scope → captured cont not threaded → wrong result (10 instead of 11).
#
# test 'chained fn calls', fn:
#   expect run fink":
#     double = fn x: x * 2
#     inc = fn x: x + 1
#     main = fn:
#       x = double 5
#       inc x
#   | equals fink":
#     11
#
# test 'pipe unary', fn:
#   expect run fink":
#     double = fn x: x * 2
#     inc = fn x: x + 1
#     main = fn:
#       5 | double | inc
#   | equals fink":
#     11

# --- match ---

test 'match literal first arm', fn:
  expect run fink":
    main = fn:
      match 0:
        0: 42
        _: 99
  | equals fink":
    42

test 'match literal fallthrough', fn:
  expect run fink":
    main = fn:
      match 1:
        0: 42
        _: 99
  | equals fink":
    99

test 'match with binding', fn:
  expect run fink":
    main = fn:
      x = 5
      match x:
        0: 0
        _: x + 1
  | equals fink":
    6

# --- recursion ---

test 'simple recursion', fn:
  expect run fink":
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5
  | equals fink":
    42

test 'recursive countdown', fn:
  expect run fink":
    count = fn a, n:
      match n:
        0: a
        _: count a + 1, n - 1
    main = fn:
      count 0, 10
  | equals fink":
    10

test 'mutual recursion', fn:
  expect run fink":
    is-even = fn n:
      match n:
        0: 1
        _: is-odd n - 1

    is-odd = fn n:
      match n:
        0: 0
        _: is-even n - 1

    main = fn:
      is-even 10
  | equals fink":
    1

# --- arithmetic ---

test 'division', fn:
  expect run fink":
    main = fn:
      10 / 4
  | equals fink":
    2

test 'integer division', fn:
  expect run fink":
    main = fn:
      10 // 3
  | equals fink":
    3

test 'modulo', fn:
  expect run fink":
    main = fn:
      10 %% 3
  | equals fink":
    1

# --- comparison ---

test 'equals true', fn:
  expect run fink":
    main = fn:
      5 == 5
  | equals fink":
    1

test 'equals false', fn:
  expect run fink":
    main = fn:
      5 == 3
  | equals fink":
    0

test 'less than', fn:
  expect run fink":
    main = fn:
      3 < 5
  | equals fink":
    1

test 'greater than or equal', fn:
  expect run fink":
    main = fn:
      5 >= 5
  | equals fink":
    1

# --- float ---

test 'float arithmetic', fn:
  expect run fink":
    main = fn:
      1.5 + 2.5
  | equals fink":
    4

test 'float division', fn:
  expect run fink":
    main = fn:
      7.0 / 2.0
  | equals fink":
    3

# --- logical ---

test 'logical and', fn:
  expect run fink":
    main = fn:
      1 and 1
  | equals fink":
    1

test 'logical or', fn:
  expect run fink":
    main = fn:
      0 or 1
  | equals fink":
    1

test 'logical not', fn:
  expect run fink":
    main = fn:
      not 0
  | equals fink":
    1

test 'logical not truthy', fn:
  expect run fink":
    main = fn:
      not 5
  | equals fink":
    0

# --- bitwise ---

test 'bitwise and', fn:
  expect run fink":
    main = fn:
      12 & 10
  | equals fink":
    8

test 'shift left', fn:
  expect run fink":
    main = fn:
      1 << 4
  | equals fink":
    16

# --- existing ---

test 'chained let', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      y
  | equals fink":
    3
