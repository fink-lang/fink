{test, expect, equals, fink, run} = import '!fake'



test 'literal int', fn:
  expect run fink":
    main = fn:
      42
  | equals fink":
    42

test 'let binding', fn:
  expect run fink":
    main = fn:
      x = 42
      x
  | equals fink":
    42

test 'add two literals', fn:
  expect run fink":
    main = fn:
      2 + 3
  | equals fink":
    5

test 'chained arithmetic', fn:
  expect run fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    10

test 'multiple let bindings used', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      x + y
  | equals fink":
    5

# TODO: user fn call — $__main's collect_letval_locals only finds 1 local
# for the multi-LetFn root chain. The remaining LetFn→LetVal entries
# don't get locals allocated, so refs to module-level bindings fail.
# test 'user fn call', fn:
#   expect run fink":
#     add = fn a, b: a + b
#     main = fn: add 3, 4
#   | equals fink":
#     7

test 'chained let', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      y
  | equals fink":
    3
