{test, expect, equals, fink, run} = import '!fake'



test 'literal int', fn:
  expect run fink":
    main = fn:
      42
  | equals fink":
    42

test 'let binding', fn:
  expect run fink":
    main = fn:
      x = 42
      x
  | equals fink":
    42

test 'add two literals', fn:
  expect run fink":
    main = fn:
      2 + 3
  | equals fink":
    5

test 'chained arithmetic', fn:
  expect run fink":
    main = fn:
      x = 2 * 3
      x + 4
  | equals fink":
    10

test 'multiple let bindings used', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      x + y
  | equals fink":
    5

test 'user fn call', fn:
  expect run fink":
    add = fn a, b: a + b
    main = fn: add 3, 4
  | equals fink":
    7

# --- match ---

test 'match literal first arm', fn:
  expect run fink":
    main = fn:
      match 0:
        0: 42
        _: 99
  | equals fink":
    42

test 'match literal fallthrough', fn:
  expect run fink":
    main = fn:
      match 1:
        0: 42
        _: 99
  | equals fink":
    99

test 'match with binding', fn:
  expect run fink":
    main = fn:
      x = 5
      match x:
        0: 0
        _: x + 1
  | equals fink":
    6

# --- recursion ---

test 'simple recursion', fn:
  expect run fink":
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5
  | equals fink":
    42

test 'recursive countdown', fn:
  expect run fink":
    count = fn a, n:
      match n:
        0: a
        _: count a + 1, n - 1
    main = fn:
      count 0, 10
  | equals fink":
    10

# --- existing ---

test 'chained let', fn:
  expect run fink":
    main = fn:
      x = 2
      y = 3
      y
  | equals fink":
    3
