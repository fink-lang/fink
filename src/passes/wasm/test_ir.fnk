{skip, test, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
Tracer-phase tests for the new CPS → IR Fragment → WAT pipeline.

Runtime imports live at the reserved module root `rt/*` — the
compiler-level ABI, distinct from the user-facing `std/*` root.
Cross-fragment identifiers render as `$<module>.<name>` so local
and imported names never collide.

Per-function signature types are declared locally in the fragment
with the naming convention `$rt.Fn_<fnname>` — monomorphic-first,
mirroring how type inference would start before generalising
identical signatures into shared types. Reusable calling-
convention signatures (`rt.Fn2`) stay as value-type imports.

Each fixture grows by demand: re-bless when lowering reaches the
right shape for a new CPS construct.
---


test 'ir: int literal', fn:
  expect ir_wat ƒink:
    42
  | equals wat":
    (module
      (import "rt" "Num" (type $rt.Num (sub any)))
      (import "rt" "Fn2" (type $rt.Fn2 (sub func)))
      (type $rt.Fn_list_head_any (func (param (ref null any)) (result (ref null any))))
      (type $rt.Fn_list_nil (func (result (ref null any))))
      (type $rt.Fn_list_prepend_any (func (param (ref null any) (ref null any)) (result (ref null any))))
      (import "rt" "list_head_any" (func $rt.list_head_any (type $rt.Fn_list_head_any)))
      (import "rt" "list_nil" (func $rt.list_nil (type $rt.Fn_list_nil)))
      (import "rt" "list_prepend_any" (func $rt.list_prepend_any (type $rt.Fn_list_prepend_any)))
      (import "rt" "_apply" (func $rt._apply (type $rt.Fn2)))
      (func $fink_module (type $rt.Fn2) (param $_caps (ref null any)) (param $_args (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref $rt.Num))
        (local $args (ref null any))
        (local.set $v_0 (call $rt.list_head_any (local.get $_args)))
        (local.set $v_1 (struct.new $rt.Num (f64.const 42)))
        (local.set $args (call $rt.list_nil))
        (local.set $args (call $rt.list_prepend_any (local.get $v_1) (local.get $args)))
        (return_call $rt._apply (local.get $args) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BaANAIIBAQACcgBUAKoBAA


test 'ir: int sum', fn:
  expect ir_wat ƒink:
    42 + 123
  | equals wat":
    (module
      (import "rt" "Num" (type $rt.Num (sub any)))
      (import "rt" "Fn2" (type $rt.Fn2 (sub func)))
      (type $rt.Fn_list_head_any (func (param (ref null any)) (result (ref null any))))
      (type $rt.Fn_op_plus (func (param (ref null any) (ref null any) (ref null any))))
      (import "rt" "list_head_any" (func $rt.list_head_any (type $rt.Fn_list_head_any)))
      (import "rt" "op_plus" (func $rt.op_plus (type $rt.Fn_op_plus)))
      (func $fink_module (type $rt.Fn2) (param $_caps (ref null any)) (param $_args (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref $rt.Num))
        (local $v_2 (ref $rt.Num))
        (local.set $v_0 (call $rt.list_head_any (local.get $_args)))
        (local.set $v_1 (struct.new $rt.Num (f64.const 42)))
        (local.set $v_2 (struct.new $rt.Num (f64.const 123)))
        (return_call $rt.op_plus (local.get $v_1) (local.get $v_2) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BNIJAIIBAQACcgEKA3QBCQg
