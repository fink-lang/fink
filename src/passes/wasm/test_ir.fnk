{skip, test, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
Tracer-phase tests for the new CPS → IR Fragment → WAT pipeline.

Runtime imports live at the reserved module root `rt/*` — the
compiler-level ABI, distinct from the user-facing `std/*` root.
Cross-fragment identifiers render as `$<module>.<name>` so local
and imported names never collide.

Per-function signature types are declared locally in the fragment
with the naming convention `$rt.Fn_<fnname>` — monomorphic-first,
mirroring how type inference would start before generalising
identical signatures into shared types. Reusable calling-
convention signatures (`rt.Fn2`) stay as value-type imports.

Each fixture grows by demand: re-bless when lowering reaches the
right shape for a new CPS construct.
---


test 'ir: int literal', fn:
  expect ir_wat ƒink:
    42
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $std/list.wat:Fn_args_empty (func (result (ref null any))))
      (type $std/list.wat:Fn_args_prepend (func (param (ref null any) (ref null any)) (result (ref null any))))
      (import "std/list.wat" "args_head" (func $std/list.wat:args_head (type $std/list.wat:Fn_args_head)))
      (import "std/list.wat" "args_empty" (func $std/list.wat:args_empty (type $std/list.wat:Fn_args_empty)))
      (import "std/list.wat" "args_prepend" (func $std/list.wat:args_prepend (type $std/list.wat:Fn_args_prepend)))
      (import "rt/apply.wat" "_apply" (func $rt/apply.wat:_apply (type $rt/types.wat:Fn2)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $_caps (ref null any)) (param $_args (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref $rt/types.wat:Num))
        (local $args (ref null any))
        (local.set $v_0 (call $std/list.wat:args_head (local.get $_args)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 42)))
        (local.set $args (call $std/list.wat:args_empty))
        (local.set $args (call $std/list.wat:args_prepend (local.get $v_1) (local.get $args)))
        (return_call $rt/apply.wat:_apply (local.get $args) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BZQQAI4BAQAChgEAbAC2AQA


test 'ir: int sum', fn:
  expect ir_wat ƒink:
    42 + 123
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $rt/protocols.wat:Fn_op_plus (func (param (ref null any) (ref null any) (ref null any))))
      (import "std/list.wat" "args_head" (func $std/list.wat:args_head (type $std/list.wat:Fn_args_head)))
      (import "rt/protocols.wat" "op_plus" (func $rt/protocols.wat:op_plus (type $rt/protocols.wat:Fn_op_plus)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $_caps (ref null any)) (param $_args (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref $rt/types.wat:Num))
        (local $v_2 (ref $rt/types.wat:Num))
        (local.set $v_0 (call $std/list.wat:args_head (local.get $_args)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 42)))
        (local.set $v_2 (struct.new $rt/types.wat:Num (f64.const 123)))
        (return_call $rt/protocols.wat:op_plus (local.get $v_1) (local.get $v_2) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BP4LAI4BAQAChgEBCgOIAQEJCA
