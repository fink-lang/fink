{skip, test, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
Tracer-phase tests for the new CPS → IR Fragment → WAT pipeline.

Runtime imports live at the reserved module root `rt.*` — the
compiler-level ABI, distinct from the user-facing `std/*` root.
Cross-fragment identifiers render as `$<module>:<name>` so local
and imported names never collide.

Each fixture grows by demand: re-bless when lowering reaches the
right shape for a new CPS construct.
---


test 'ir: int literal', fn:
  expect ir_wat ƒink:
    42
  | equals wat":
    (module
      (import "rt" "Num" (type $rt.Num (sub any)))
      (import "rt" "Fn2" (type $rt.Fn2 (sub func)))
      (import "rt" "FnAnyToAny" (type $rt.FnAnyToAny (sub func)))
      (import "rt" "FnNilToList" (type $rt.FnNilToList (sub func)))
      (import "rt" "FnPrependAny" (type $rt.FnPrependAny (sub func)))
      (import "rt" "list_head_any" (func $rt.list_head_any (type $rt.FnAnyToAny)))
      (import "rt" "list_nil" (func $rt.list_nil (type $rt.FnNilToList)))
      (import "rt" "list_prepend_any" (func $rt.list_prepend_any (type $rt.FnPrependAny)))
      (import "rt" "_apply" (func $rt._apply (type $rt.Fn2)))
      (func $fink_module (type $rt.Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $v_1 (ref $rt.Num))
        (local $args (ref any))
        (local.set $v_0 (call $rt.list_head_any (local.get $_args)))
        (local.set $v_1 (struct.new $rt.Num (f64.const 42)))
        (local.set $args (call $rt.list_nil))
        (local.set $args (call $rt.list_prepend_any (local.get $v_1) (local.get $args)))
        (return_call $rt._apply (local.get $args) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
