  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_2 (ref any))
        (local $x_0 (ref any))
        (local $v_12 (ref any))
        (local $y_1 (ref any))
        (local $v_10 (ref any))
        (local $local_7 (ref any))
        (local.set $v_2 (call $_list_head_any (local.get $_args)))
        (local.set $x_0 (struct.new $Num (f64.const 2)))
        (global.set $x (local.get $x_0))
        (local.set $y_1 (struct.new $Num (f64.const 3)))
        (global.set $y (local.get $y_1))
        (return_call $_op_plus (local.get $x_0) (local.get $y_1) (local.get $v_2))
