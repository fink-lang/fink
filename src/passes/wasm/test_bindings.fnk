test 'binding rhs is a call', fn:
  expect gen_wat ƒink:
    add = fn a, b: a + b
    x = add 1, 2
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_4 (ref any))
        (local $v_24 (ref any))
        (local $v_37 (ref any))
        (local $add_0 (ref any))
        (local $v_22 (ref any))
        (local $v_45 (ref any))
        (local $local_8 (ref any))
        (local.set $v_4 (call $_list_head_any (local.get $_args)))
        (local.set $add_0 (struct.new $Closure (ref.func $v_5) (ref.null $Captures)))
        (global.set $add (struct.new $Closure (global.get $add_0) (ref.null $Captures)))
        (return_call $__apply (call $_list_prepend_any (struct.new $Closure (ref.func $v_34) (array.new_fixed $Captures 1 (local.get $v_4))) (call $_list_nil)) (struct.new $Closure (ref.func $v_44) (ref.null $Captures)))
      )
      (global $add_0 (ref $Fn2) (ref.func $v_5))
      (func $v_5 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_6 (ref any))
        (local $a_2 (ref any))
        (local $b_3 (ref any))
        (local $local_5 (ref any))
        (local.set $v_6 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $a_2 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $b_3 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (local.get $a_2) (local.get $b_3) (local.get $v_6))
      )
      (func $v_34 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_35 (ref any))
        (local $v_16 (ref any))
        (local $x_1 (ref any))
        (local $local_5 (ref any))
        (local.set $v_35 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 0)))
        (local.set $v_16 (call $_list_head_any (local.get $_args)))
        (local.set $x_1 (local.get $v_16))
        (global.set $x (local.get $x_1))
        (local.set $local_5 (call $_list_nil))
        (local.set $local_5 (call $_list_prepend_any (local.get $x_1) (local.get $local_5)))
        (return_call $__apply (local.get $local_5) (local.get $v_35))
      )
      (func $v_44 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_39 (ref any))
        (local $local_3 (ref any))
        (local.set $v_39 (call $_list_head_any (local.get $_args)))
        (local.set $local_3 (call $_list_nil))
        (local.set $local_3 (call $_list_prepend_any (struct.new $Num (f64.const 2)) (local.get $local_3)))
        (local.set $local_3 (call $_list_prepend_any (struct.new $Num (f64.const 1)) (local.get $local_3)))
        (local.set $local_3 (call $_list_prepend_any (local.get $v_39) (local.get $local_3)))
        (return_call $__apply (local.get $local_3) (struct.new $Closure (global.get $add_0) (ref.null $Captures)))
      )
      (global $x (mut (ref null any)) (ref.null any))
      (global $add (mut (ref null any)) (ref.null any))
      (export "x" (global $x))
      (export "add" (global $add))
    )
