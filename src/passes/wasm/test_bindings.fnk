test 'multiple let bindings used', fn:
  expect gen_wat ƒink:
    x = 2
    y = 3
    x + y
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_2 (ref any))
        (local $x_0 (ref any))
        (local $v_12 (ref any))
        (local $y_1 (ref any))
        (local $v_10 (ref any))
        (local $local_7 (ref any))
        (local.set $v_2 (call $_list_head_any (local.get $_args)))
        (local.set $x_0 (struct.new $Num (f64.const 2)))
        (global.set $x (local.get $x_0))
        (local.set $y_1 (struct.new $Num (f64.const 3)))
        (global.set $y (local.get $y_1))
        (return_call $_op_plus (local.get $x_0) (local.get $y_1) (local.get $v_2))
      )
      (global $x (mut (ref null any)) (ref.null any))
      (global $y (mut (ref null any)) (ref.null any))
      (export "x" (global $x))
      (export "y" (global $y))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsieCA9IDJcbnkgPSAzXG54ICsgeSJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTs7QTs7QTtBO0E7QTtBO0E7Ozs7Ozs7QTs7O0FBQUE7QUFDQTtBIgp9




