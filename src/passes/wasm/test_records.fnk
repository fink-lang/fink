test 'recursive list sum', fn:
  expect gen_wat ƒink:
    sum = fn items, c:
      match items:
        []: c
        [a, ..rest]: sum rest, c + a

    main = fn:
      sum [1, 2, 3, 4], 0
  | equals wat":
    PANIC: unknown local: main_1


