        (local.set $:wrap_caps_arg (ref.null $rt/types.wat:Captures))
        (local.set $:wrap_mod_clos (struct.new $rt/types.wat:Closure (ref.func $fink_module) (local.get $:wrap_caps_arg)))
        (return_call $std/modules.fnk:init_module (local.get $:wrap_url) (local.get $:wrap_mod_clos) (local.get $:wrap_key) (local.get $:wrap_cont))
      )
      (export "_host_wrapper" (func $_host_wrapper))
      (data $d_0 "")
    )
