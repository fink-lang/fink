{test, expect, equals, gen_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'add two literals', fn:
  expect gen_wat ƒink:
    2 + 3
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (type $Fn1 (func (param (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $local_3 (ref any))
        (local.set $v_0 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiMiArIDMiXSwKICAibWFwcGluZ3MiOiAiQTtBO0E7QTs7QTs7QTtBOzs7QTs7QSIKfQ==



test 'chained arithmetic', fn:
  expect gen_wat ƒink:
    2 * 3 + 4
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (type $Fn1 (func (param (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $v_15 (ref any))
        (local $v_17 (ref any))
        (local $local_5 (ref any))
        (local.set $v_0 (call $_list_head_any (local.get $_args)))
        (local.set $v_17 (struct.new $Closure (ref.func $v_12) (array.new_fixed $Captures 1 (local.get $v_0))))
        (return_call $_op_mul (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_17))
      )
      (func $v_12 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_13 (ref any))
        (local $v_3 (ref any))
        (local $local_4 (ref any))
        (local.set $v_13 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 0)))
        (local.set $v_3 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (local.get $v_3) (struct.new $Num (f64.const 4)) (local.get $v_13))
      )
      (export "fink_module" (func $fink_module))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiMiAqIDMgKyA0Il0sCiAgIm1hcHBpbmdzIjogIkE7QTtBO0E7O0E7O0E7QTtBO0E7Ozs7QTs7QTtBO0E7Ozs7QTs7QSIKfQ==


