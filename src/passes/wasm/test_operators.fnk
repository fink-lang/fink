test 'range in', fn:
  expect wat ƒink:
    5 in 0..10
  | equals wat":
    (module
      (func $v_12 (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $:caps_cast (ref $rt/types.wat:Captures))
        (local $v_13 (ref null any))
        (local $v_4 (ref null any))
        (local $v_1 (ref null any))
        (local.set $:caps_cast (ref.cast (ref $rt/types.wat:Captures) (local.get $:caps_param)))
        (local.set $v_13 (array.get $rt/types.wat:Captures (local.get $:caps_cast) (i32.const 0)))
        (local.set $v_4 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 5)))
        (return_call $std/operators.fnk:op_in (local.get $v_1) (local.get $v_4) (local.get $v_13))
