{test, skip, skip-ir, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
IR-WAT shadow for cooperative multitasking — yield, spawn, await, channels.
Mirrors src/runner/test_tasks.fnk; verifies the lowered shape.
---

