        (local.set $:mod_reg_url (call $rt/str.wat:from_data (data.ref $d_0 4)))
        (call $rt/modules.wat:register_module (i32.const 0) (local.get $:mod_reg_url))
        (local.set $:ret_0 (call $rt/apply.wat:args_head (local.get $:params)))
        (local.set $:lit_1 (struct.new $rt/int.wat:I64 (i64.const 0)))
        (local.set $:lit_2 (struct.new $rt/int.wat:I64 (i64.const 10)))
        (return_call $rt/range.wat:cps_excl (local.get $:ctx_param) (local.get $:lit_1) (local.get $:lit_2) (local.get $:ret_0))
