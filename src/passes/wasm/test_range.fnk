test 'range in', fn:
  expect wat ƒink:
    5 in 0..10
  | equals wat":
    (module
      (type $test::Fn_host_wrapper (func (param (ref null any))))
      (func $test:v_13 (type $rt/apply.wat:Fn3) (param $:caps_param (ref null any)) (param $:ctx_param (ref null any)) (param $:params (ref null any))
        (local $:caps_cast (ref $rt/apply.wat:Captures))
        (local $v_14 (ref null any))
        (local $v_4 (ref null any))
        (local $v_1 (ref null any))
        (local.set $:caps_cast (ref.cast (ref $rt/apply.wat:Captures) (local.get $:caps_param)))
        (local.set $v_14 (array.get $rt/apply.wat:Captures (local.get $:caps_cast) (i32.const 0)))
        (local.set $v_4 (call $rt/apply.wat:args_head (local.get $:params)))
        (local.set $v_1 (struct.new $std/int.wat:I64 (i64.const 5)))
        (return_call $std/operators.fnk:op_in (local.get $v_1) (local.get $v_4) (local.get $v_14))
      )
      (func $test::fink_module (type $rt/apply.wat:Fn3) (param $:caps_param (ref null any)) (param $:ctx_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_18 (ref null any))
        (local $:caps_arg (ref null $rt/apply.wat:Captures))
        (local $v_2 (ref null any))
        (local $v_3 (ref null any))
        (local.set $v_0 (call $rt/apply.wat:args_head (local.get $:params)))
        (local.set $:caps_arg (array.new_fixed $rt/apply.wat:Captures 1 (local.get $v_0)))
        (local.set $v_18 (struct.new $rt/apply.wat:Closure (ref.func $test:v_13) (local.get $:caps_arg)))
        (local.set $v_2 (struct.new $std/int.wat:I64 (i64.const 0)))
        (local.set $v_3 (struct.new $std/int.wat:I64 (i64.const 10)))
        (return_call $std/range.fnk:excl (local.get $v_2) (local.get $v_3) (local.get $v_18))
      )
      (func $test::host_wrapper (export "test") (type $test::Fn_host_wrapper) (param $:cont (ref null any))
        (local $:caps_arg (ref null $rt/apply.wat:Captures))
        (local $:mod_clos (ref null any))
        (local $:ctx_arg (ref null any))
        (local $:args (ref any))
        (local.set $:caps_arg (ref.null $rt/apply.wat:Captures))
        (local.set $:mod_clos (struct.new $rt/apply.wat:Closure (ref.func $test::fink_module) (local.get $:caps_arg)))
        (local.set $:ctx_arg (ref.i31 (i32.const 42)))
        (local.set $:args (call $rt/apply.wat:args_empty))
        (local.set $:args (call $rt/apply.wat:args_prepend (local.get $:cont) (local.get $:args)))
        (return_call $rt/apply.wat:apply_3 (local.get $:args) (local.get $:ctx_arg) (local.get $:mod_clos))
      )
    )
    ;; sm:EeYFALoBAL4BAJIBAQABggEBAArwBgCSAQCuAQDMAQEKAYIBAQYChAEBBQXOBQB6AOYBAGYAbgC-AQA
