        (local $:args (ref null any))
        (local.set $v_3 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:caps_arg (ref.null $rt/types.wat:Captures))
        (local.set $add_0 (struct.new $rt/types.wat:Closure (ref.func $test:v_4) (local.get $:caps_arg)))
        (global.set $test:add (local.get $add_0))
        (local.set $:pub_url (call $std/str.fnk:str (data.ref $d_0 4)))
        (local.set $:pub_name (call $std/str.fnk:str (data.ref $d_1 3)))
        (call $std/modules.fnk:pub (local.get $:pub_url) (local.get $:pub_name) (local.get $add_0))
        (local.set $v_13 (struct.new $rt/types.wat:Num (f64.const 3)))
        (local.set $v_14 (struct.new $rt/types.wat:Num (f64.const 4)))
        (local.set $:args (call $std/fn.fnk:args_empty))
        (local.set $:args (call $std/fn.fnk:args_prepend (local.get $v_14) (local.get $:args)))
        (local.set $:args (call $std/fn.fnk:args_prepend (local.get $v_13) (local.get $:args)))
        (local.set $:args (call $std/fn.fnk:args_prepend (local.get $v_3) (local.get $:args)))
        (return_call $rt/apply.wat:apply (local.get $:args) (local.get $add_0))
      )
