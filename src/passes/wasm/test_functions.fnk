{test, expect, equals, gen_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'

test 'user fn call', fn:
  expect gen_wat ƒink:
    add = fn a, b:
      a + b
    main = fn:
      add 3, 4
  | equals wat":
    PANIC: unknown local: main_1


test 'chained fn calls', fn:
  expect gen_wat ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1
    main = fn:
      x = double 5
      inc x
  | equals wat":
    PANIC: unknown local: inc_1


test 'pipe unary', fn:
  expect gen_wat ƒink:
    double = fn x:
      x * 2
    inc = fn x:
      x + 1
    main = fn:
      5 | double | inc
  | equals wat":
    PANIC: unknown local: inc_1


