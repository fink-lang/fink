test 'simple recursion', fn:
  expect gen_wat ƒink:
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5
  | equals wat":
    PANIC: unknown local: recurse_0


test 'closure construction and call', fn:
