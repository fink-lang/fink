test 'user fn call', fn:
  expect wat ƒink:
    add = fn a, b:
      a + b
    add 3, 4
  | equals wat":
    (module
      (func $test:v_4 (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_5 (ref null any))
        (local $a_1 (ref null any))
        (local $b_2 (ref null any))
        (local.set $v_5 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:params (call $std/fn.fnk:args_tail (local.get $:params)))
        (local.set $a_1 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:params (call $std/fn.fnk:args_tail (local.get $:params)))
        (local.set $b_2 (call $std/fn.fnk:args_head (local.get $:params)))
        (return_call $std/operators.fnk:op_plus (local.get $a_1) (local.get $b_2) (local.get $v_5))
      )
      (func $test::fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_3 (ref null any))
        (local $add_0 (ref null any))
