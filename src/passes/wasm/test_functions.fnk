test 'mutual recursion — is_even / is_odd', fn:
  expect wat ƒink:
    is_even = fn n:
      match n:
        0: true
        _: is_odd n - 1
    is_odd = fn n:
      match n:
        0: false
        _: is_even n - 1
    is_even 4
