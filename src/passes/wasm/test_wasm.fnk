      (type $Fn1 (func (param (ref $Any))))

      (global $main_0 (ref $Fn1) (ref.func $v_6))
      (func $v_6 (type $Fn1) (param $v_7 (ref $Any))
        (local $x_1 (ref $Any))
        (local $y_2 (ref $Any))
