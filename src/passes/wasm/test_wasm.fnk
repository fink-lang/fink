        (local.set $local_3 (call $_list_nil))
        (local.set $local_3 (call $_list_prepend_any (struct.new $Num (f64.const 42)) (local.get $local_3)))
        (return_call $__apply (local.get $local_3) (local.get $v_5))
      )
      (export "main" (func $v_4))
    )
