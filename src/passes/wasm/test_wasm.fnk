{test, expect, equals, fink, gen_wat, wat} = import '!fake'

# Round-trip tests: CPS → emit (WASM binary) → format (WAT text + source map)
# These validate the full pipeline produces correct, readable WAT.

test 'literal int', fn:
  expect gen_wat fink":
    main = fn:
      42
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))

      (global $main_0 (ref $Fn1) (ref.func $v_4))
      (func $v_4 (type $Fn1) (param $v_5 (ref $Any))
        (return_call_ref $Fn1 (local.get $v_5) (struct.new $Num (f64.const 42)))
      )
      (export "main" (func $v_4))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICA0MiJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTtBO0E7QUFBQTtBQUFPLHlCQUFBO0FBQ0wsMkNBQUE7QTtBQURGO0EiCn0=


test 'let binding', fn:
  expect gen_wat fink":
    main = fn:
      x = 42
      x
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))

      (global $main_0 (ref $Fn1) (ref.func $v_5))
      (func $v_5 (type $Fn1) (param $v_6 (ref $Any))
        (local $x_1 (ref $Any))
        (local.set $x_1 (struct.new $Num (f64.const 42)))
        (return_call_ref $Fn1 (local.get $v_6) (local.get $x_1))
      )
      (export "main" (func $v_5))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICB4ID0gNDJcbiAgeCJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTtBO0E7QUFBQTtBQUFPLHlCQUFBO0E7QUFDTCxvQkFBSTtBQUNKLDJDQUFBO0E7QUFGRjtBIgp9


test 'add two literals', fn:
  expect gen_wat fink":
    main = fn:
      2 + 3
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Fn1 (func (param (ref $Any))))
      (type $Fn3 (func (param (ref $Any) (ref $Any) (ref $Any))))

      (global $main_0 (ref $Fn1) (ref.func $v_4))
      (func $v_4 (type $Fn1) (param $v_5 (ref $Any))
        (return_call $op_plus (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_5))
      )
      (export "main" (func $v_4))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICAyICsgMyJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTtBO0E7QTtBQUFBO0FBQU8seUJBQUE7QUFDSCwwQkFBRixnQ0FBSSxnQ0FBRjtBO0FBREo7QSIKfQ==


# TODO: chained arithmetic panics with "unknown local: v_25" — emitter needs
# to handle non-global function references (lifted continuations) as ref.func
# or globals. Currently only aliased functions get globals.
