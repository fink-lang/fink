test 'simple recursion', fn:
  expect gen_wat fink":
    recurse = fn n:
      match n:
        0: 42
        _: recurse n - 1
    main = fn:
      recurse 5
  | equals wat":
    (module
      (type $Any (sub (struct)))
      (type $Num (sub $Any (struct (field f64))))
      (type $Bool (sub $Any (struct (field i32))))
      (type $Fn0 (func))
      (type $Fn1 (func (param (ref $Any))))
