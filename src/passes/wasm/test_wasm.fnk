{test, expect, equals, fink, gen_wat, wat} = import '!fake'

# Round-trip tests: CPS → emit (WASM binary) → format (WAT text + source map)
# These validate the full pipeline produces correct, readable WAT.

test 'literal int', fn:
  expect gen_wat fink":
    main = fn:
      42
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn0 (func))
      (type $Fn1 (func (param (ref any))))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (global $main_0 (ref $Fn1) (ref.func $v_4))
      (func $v_4 (type $Fn1) (param $v_5 (ref any))
        (return_call_ref $Fn1 (ref.cast (ref null $Fn1) (struct.get $Closure 0 (ref.cast (ref null $Closure) (local.get $v_5)))) (struct.new $Num (f64.const 42)))
      )
      (export "main" (func $v_4))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsibWFpbiA9IGZuOlxuICA0MiJdLAogICJtYXBwaW5ncyI6ICJBO0E7QTtBO0E7O0E7Ozs7QTtBQUFBO0EiCn0=


