{test, skip-ir, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'add two literals', fn:
  expect ir_wat ƒink:
    2 + 3
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $rt/protocols.wat:Fn_op_binary (func (param (ref null any) (ref null any) (ref null any))))
      (import "std/list.wat" "std/fn.fnk:args_head" (func $std/fn.fnk:args_head (type $std/list.wat:Fn_args_head)))
      (import "rt/protocols.wat" "std/operators.fnk:op_plus" (func $std/operators.fnk:op_plus (type $rt/protocols.wat:Fn_op_binary)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref null any))
        (local $v_2 (ref null any))
        (local.set $v_0 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 2)))
        (local.set $v_2 (struct.new $rt/types.wat:Num (f64.const 3)))
        (return_call $std/operators.fnk:op_plus (local.get $v_1) (local.get $v_2) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BKoMAI4BAQABhAEBCAGEAQEHBQ



test 'chained arithmetic', fn:
  expect ir_wat ƒink:
    2 * 3 + 4
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (import "rt/types.wat" "Captures" (type $rt/types.wat:Captures (sub any)))
      (import "rt/types.wat" "Closure" (type $rt/types.wat:Closure (sub any)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $rt/protocols.wat:Fn_op_binary (func (param (ref null any) (ref null any) (ref null any))))
      (import "std/list.wat" "std/fn.fnk:args_head" (func $std/fn.fnk:args_head (type $std/list.wat:Fn_args_head)))
      (import "rt/protocols.wat" "std/operators.fnk:op_plus" (func $std/operators.fnk:op_plus (type $rt/protocols.wat:Fn_op_binary)))
      (import "rt/protocols.wat" "std/operators.fnk:op_mul" (func $std/operators.fnk:op_mul (type $rt/protocols.wat:Fn_op_binary)))
      (func $v_12 (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $:caps_cast (ref $rt/types.wat:Captures))
        (local $v_13 (ref null any))
        (local $v_3 (ref null any))
        (local $v_5 (ref null any))
        (local.set $:caps_cast (ref.cast (ref $rt/types.wat:Captures) (local.get $:caps_param)))
        (local.set $v_13 (array.get $rt/types.wat:Captures (local.get $:caps_cast) (i32.const 0)))
        (local.set $v_3 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $v_5 (struct.new $rt/types.wat:Num (f64.const 4)))
        (return_call $std/operators.fnk:op_plus (local.get $v_3) (local.get $v_5) (local.get $v_13))
      )
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_17 (ref null any))
        (local $:caps_arg (ref null $rt/types.wat:Captures))
        (local $v_1 (ref null any))
        (local $v_2 (ref null any))
        (local.set $v_0 (call $std/fn.fnk:args_head (local.get $:params)))
        (local.set $:caps_arg (array.new_fixed $rt/types.wat:Captures 1 (local.get $v_0)))
        (local.set $v_17 (struct.new $rt/types.wat:Closure (ref.func $v_12) (local.get $:caps_arg)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 2)))
        (local.set $v_2 (struct.new $rt/types.wat:Num (f64.const 3)))
        (return_call $std/operators.fnk:op_mul (local.get $v_1) (local.get $v_2) (local.get $v_17))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:C7gRALoBAL4BAI4BARABhAEBDwmiBgCOAQCuAQDCAQEAAYQBAQgBhAEBBwU


