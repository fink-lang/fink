{test, skip-ir, expect, equals, ir_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'add two literals', fn:
  expect ir_wat ƒink:
    2 + 3
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $rt/protocols.wat:Fn_op_binary (func (param (ref null any) (ref null any) (ref null any))))
      (import "std/list.wat" "args_head" (func $std/list.wat:args_head (type $std/list.wat:Fn_args_head)))
      (import "rt/protocols.wat" "op_plus" (func $rt/protocols.wat:op_plus (type $rt/protocols.wat:Fn_op_binary)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref null any))
        (local $v_2 (ref null any))
        (local.set $v_0 (call $std/list.wat:args_head (local.get $:params)))
        (local.set $v_1 (struct.new $rt/types.wat:Num (f64.const 2)))
        (local.set $v_2 (struct.new $rt/types.wat:Num (f64.const 3)))
        (return_call $rt/protocols.wat:op_plus (local.get $v_1) (local.get $v_2) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BPILAJIBAQABhAEBCAGEAQEHBQ



skip-ir test 'chained arithmetic', fn:
  expect ir_wat ƒink:
    2 * 3 + 4
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_0 (ref any))
        (local $v_15 (ref any))
        (local $v_17 (ref any))
        (local $local_5 (ref any))
        (local.set $v_0 (call $_list_head_any (local.get $_args)))
        (local.set $v_17 (struct.new $Closure (ref.func $v_12) (array.new_fixed $Captures 1 (local.get $v_0))))
        (return_call $_op_mul (struct.new $Num (f64.const 2)) (struct.new $Num (f64.const 3)) (local.get $v_17))
      )
      (func $v_12 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_13 (ref any))
        (local $v_3 (ref any))
        (local $local_4 (ref any))
        (local.set $v_13 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 0)))
        (local.set $v_3 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (local.get $v_3) (struct.new $Num (f64.const 4)) (local.get $v_13))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:DgAAEABGAHwAqAEANgA4ADgA7gQAoAEAOAA2AMoEAGIA


test 'unary not', fn:
