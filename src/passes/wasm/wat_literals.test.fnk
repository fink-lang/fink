{test, equals, snapshot} = import 'std/testing.fnk'
{ƒink} = import 'fink/blocks.fnk'
{wat, compile_wat} = import 'fink/compile.fnk'


test 'literal bool', fn:
  compile_wat ƒink:
    true
  | equals ?, snapshot wat":
    (module
      (type $test::Fn_host_wrapper (func (param (ref null any))))
      (func $test::fink_module (type $rt/apply.wat:Fn3) (param $:caps_param (ref null any)) (param $:ctx_param (ref null any)) (param $:params (ref null any))
        (local $:ret_0 (ref null any))
        (local $:lit_1 (ref null any))
        (local $:args (ref any))
        (local $:mod_reg_url (ref null any))
        (local.set $:mod_reg_url (call $rt/str.wat:from_data (data.ref $d_0 4)))
        (call $rt/modules.wat:register_module (i32.const 0) (local.get $:mod_reg_url))
        (local.set $:ret_0 (call $rt/apply.wat:args_head (local.get $:params)))
        (local.set $:lit_1 (ref.i31 (i32.const 1)))
        (local.set $:args (call $rt/apply.wat:args_empty))
        (local.set $:args (call $rt/apply.wat:args_prepend (local.get $:lit_1) (local.get $:args)))
        (return_call $rt/apply.wat:apply_3 (local.get $:args) (local.get $:ctx_param) (local.get $:ret_0))
      )
      (func $test::host_wrapper (export "test") (type $test::Fn_host_wrapper) (param $:cont (ref null any))
        (local $:caps_arg (ref null $rt/apply.wat:Captures))
        (local $:mod_clos (ref null any))
        (local $:url (ref null any))
        (local.set $:caps_arg (ref.null $rt/apply.wat:Captures))
        (local.set $:mod_clos (struct.new $rt/apply.wat:Closure (ref.func $test::fink_module) (local.get $:caps_arg)))
        (local.set $:url (call $rt/str.wat:from_data (data.ref $d_0 4)))
        (return_call $rt/modules.wat:init_module (local.get $:url) (local.get $:mod_clos) (local.get $:cont))
      )
      (data $d_0 "test")
    )
    ;; sm:C-IFAJoBAKYBAJgBAQAEYABuAMABAKYFAHoA5gEAigEA


