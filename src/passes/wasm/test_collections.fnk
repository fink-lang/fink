{ƒink} = import '@fink/parse/blocks.fnk'


# WAT-snapshot tests for list construction with spread. The CPS layer
# tests this shape in src/passes/cps/test_collections.fnk; this file
# mirrors at the wasm-lower layer so the seq_concat lowering is
# locked down.

