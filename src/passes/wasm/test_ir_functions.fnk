      (import "rt/protocols.wat" "rt/protocols.wat:op_plus" (func $rt/protocols.wat:rt/protocols.wat:op_plus (type $rt/protocols.wat:Fn_op_binary)))
      (func $v_4 (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_5 (ref null any))
        (local $a_1 (ref null any))
        (local $b_2 (ref null any))
        (local.set $v_5 (call $std/list.wat:args_head (local.get $:params)))
        (local.set $:params (call $std/list.wat:args_tail (local.get $:params)))
        (local.set $a_1 (call $std/list.wat:args_head (local.get $:params)))
        (local.set $:params (call $std/list.wat:args_tail (local.get $:params)))
