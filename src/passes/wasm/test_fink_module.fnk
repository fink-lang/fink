---
_fink_module — treat the module root as a regular CPS function

These tests pin the new export model: the CPS root is compiled to a single
WASM function named $_fink_module, handled by the same emit path as any other
lifted fn. ·export inside that body becomes slot-writes into per-export module
globals, and exported user names become thin wrapper fns that read those slots
and forward via _apply.

This is a work-in-progress scratchpad. Tests here drive the implementation
one step at a time. Existing tests in test_literals.fnk etc. are expected to
fail during this work and will be re-blessed once the new model is in place.
---

{test, expect, equals, gen_wat, wat} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'single binding export with trailing expr', fn:
  expect gen_wat ƒink:
    foo = 1
    42
  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_1 (ref any))
        (local $foo_0 (ref any))
        (local $local_4 (ref any))
        (local.set $v_1 (call $_list_head_any (local.get $_args)))
        (local.set $foo_0 (struct.new $Num (f64.const 1)))
        (global.set $foo (local.get $foo_0))
        (local.set $local_4 (call $_list_nil))
        (local.set $local_4 (call $_list_prepend_any (struct.new $Num (f64.const 42)) (local.get $local_4)))
        (return_call $__apply (local.get $local_4) (local.get $v_1))
      )
      (global $foo (mut (ref null any)) (ref.null any))
      (export "foo" (global $foo))
      (export "fink_module" (func $fink_module))
    )
    ;;sourcemaps:ewogICJ2ZXJzaW9uIjogMywKICAic291cmNlcyI6IFsidGVzdCJdLAogICJzb3VyY2VzQ29udGVudCI6IFsiZm9vID0gMVxuNDIiXSwKICAibWFwcGluZ3MiOiAiQTtBO0E7O0E7O0E7QTtBOzs7Ozs7O0E7O0FBQUE7O0EiCn0=



