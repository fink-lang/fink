test 'minimal module exports', fn:
  expect gen_wat ƒink:
    foo = fn: 123
    bar = fn: 345

  | equals wat":
    PANIC: unknown local: bar_1

---
simple main: module has a $_fink_module function whose body contains
the module's top-level CPS.
---
test 'minimal error calling same local func twice', fn:
  expect gen_wat ƒink:
    foo = fn:
      ni = fn a: a
      na = ni 2
      ni na

  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_4 (ref any))
        (local $v_28 (ref any))
        (local $v_46 (ref any))
        (local $v_33 (ref any))
        (local $foo_0 (ref any))
        (local $local_7 (ref any))
        (local.set $v_4 (call $_list_head_any (local.get $_args)))
        (local.set $foo_0 (struct.new $Closure (ref.func $v_5) (ref.null $Captures)))
        (global.set $foo (struct.new $Closure (global.get $foo_0) (ref.null $Captures)))
        (local.set $local_7 (call $_list_nil))
        (local.set $local_7 (call $_list_prepend_any (struct.new $Closure (global.get $foo_0) (ref.null $Captures)) (local.get $local_7)))
        (return_call $__apply (local.get $local_7) (local.get $v_4))
      )
      (func $v_7 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_8 (ref any))
        (local $a_1 (ref any))
        (local $local_4 (ref any))
        (local.set $v_8 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $a_1 (call $_list_head_any (local.get $_args)))
        (local.set $local_4 (call $_list_nil))
        (local.set $local_4 (call $_list_prepend_any (local.get $a_1) (local.get $local_4)))
        (return_call $__apply (local.get $local_4) (local.get $v_8))
      )
      (func $v_41 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $ni_42 (ref any))
        (local $v_44 (ref any))
        (local $v_15 (ref any))
        (local $na_3 (ref any))
        (local $v_22 (ref any))
        (local $local_7 (ref any))
        (local.set $ni_42 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 0)))
        (local.set $v_44 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 1)))
        (local.set $v_15 (call $_list_head_any (local.get $_args)))
        (local.set $na_3 (local.get $v_15))
        (local.set $local_7 (call $_list_nil))
        (local.set $local_7 (call $_list_prepend_any (local.get $na_3) (local.get $local_7)))
        (local.set $local_7 (call $_list_prepend_any (local.get $v_44) (local.get $local_7)))
        (return_call $__apply (local.get $local_7) (local.get $ni_42))
      )
      (global $foo_0 (ref $Fn2) (ref.func $v_5))
      (func $v_5 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_6 (ref any))
        (local $ni_2 (ref any))
        (local $v_26 (ref any))
        (local $v_48 (ref any))
        (local $local_6 (ref any))
        (local.set $v_6 (call $_list_head_any (local.get $_args)))
        (local.set $ni_2 (struct.new $Closure (ref.func $v_7) (ref.null $Captures)))
        (local.set $v_48 (struct.new $Closure (ref.func $v_41) (array.new_fixed $Captures 2 (local.get $ni_2) (local.get $v_6))))
        (local.set $local_6 (call $_list_nil))
        (local.set $local_6 (call $_list_prepend_any (struct.new $Num (f64.const 2)) (local.get $local_6)))
        (local.set $local_6 (call $_list_prepend_any (local.get $v_48) (local.get $local_6)))
        (return_call $__apply (local.get $local_6) (local.get $ni_2))
      )
      (global $foo (mut (ref null any)) (ref.null any))
      (export "foo" (global $foo))
    )
