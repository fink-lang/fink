test 'fooobar', fn:
  expect gen_wat ƒink:
    add = fn a, b:
      a + b

    s = add 1, 2

    mul = fn a, b:
      a * b

    p = mul s, 3

  | equals wat":
    (module
      (type $Num (struct (field f64)))
      (type $Fn2 (func (param (ref any) (ref any))))
      (memory 1)

      (func $fink_module (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_8 (ref any))
        (local $v_49 (ref any))
        (local $add_0 (ref any))
        (local $v_47 (ref any))
        (local $local_6 (ref any))
        (local.set $v_8 (call $_list_head_any (local.get $_args)))
        (local.set $add_0 (struct.new $Closure (ref.func $v_9) (ref.null $Captures)))
        (global.set $add (struct.new $Closure (global.get $add_0) (ref.null $Captures)))
        (local.set $local_6 (call $_list_nil))
        (local.set $local_6 (call $_list_prepend_any (struct.new $Num (f64.const 2)) (local.get $local_6)))
        (local.set $local_6 (call $_list_prepend_any (struct.new $Num (f64.const 1)) (local.get $local_6)))
        unreachable
        (local.set $local_6 (call $_list_prepend_any (local.get $local_6)))
        (return_call $__apply (local.get $local_6) (struct.new $Closure (global.get $add_0) (ref.null $Captures)))
      )
      (global $add_0 (ref $Fn2) (ref.func $v_9))
      (func $v_9 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_10 (ref any))
        (local $a_4 (ref any))
        (local $b_5 (ref any))
        (local $local_5 (ref any))
        (local.set $v_10 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $a_4 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $b_5 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (local.get $a_4) (local.get $b_5) (local.get $v_10))
      )
      (global $add (mut (ref null any)) (ref.null any))
      (global $s (mut (ref null any)) (ref.null any))
      (global $mul (mut (ref null any)) (ref.null any))
      (global $p (mut (ref null any)) (ref.null any))
      (export "add" (global $add))
      (export "s" (global $s))
      (export "mul" (global $mul))
      (export "p" (global $p))
    )
    ;;sourcemaps:
