        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $b_5 (call $_list_head_any (local.get $_args)))
        (return_call $_op_plus (local.get $a_4) (local.get $b_5) (local.get $v_15))
      )
      (func $v_27 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $v_28 (ref any))
        (local $a_6 (ref any))
        (local $b_7 (ref any))
        (local $local_5 (ref any))
        (local.set $v_28 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $a_6 (call $_list_head_any (local.get $_args)))
        (local.set $_args (call $_list_tail_any (local.get $_args)))
        (local.set $b_7 (call $_list_head_any (local.get $_args)))
        (return_call $_op_mul (local.get $a_6) (local.get $b_7) (local.get $v_28))
      )
      (func $v_70 (type $Fn2) (param $_caps (ref any)) (param $_args (ref any))
        (local $add_71 (ref any))
        (local $s_73 (ref any))
        (local $mul_75 (ref any))
        (local $v_38 (ref any))
        (local $p_3 (ref any))
        (local $local_7 (ref any))
        (local.set $add_71 (array.get $Captures (ref.cast (ref $Captures) (local.get $_caps)) (i32.const 0)))
