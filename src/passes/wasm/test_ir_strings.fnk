test 'empty string literal', fn:
  expect ir_wat ƒink:
    ''
  | equals wat":
    (module
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $std/list.wat:Fn_args_empty (func (result (ref null any))))
      (type $std/list.wat:Fn_args_prepend (func (param (ref null any) (ref null any)) (result (ref null any))))
      (type $std/str.wat:Fn_str_empty (func (result (ref null any))))
      (import "std/list.wat" "std/list.wat:args_head" (func $std/list.wat:args_head (type $std/list.wat:Fn_args_head)))
      (import "std/list.wat" "std/list.wat:args_empty" (func $std/list.wat:args_empty (type $std/list.wat:Fn_args_empty)))
      (import "std/list.wat" "std/list.wat:args_prepend" (func $std/list.wat:args_prepend (type $std/list.wat:Fn_args_prepend)))
      (import "rt/apply.wat" "rt/apply.wat:apply" (func $rt/apply.wat:apply (type $rt/types.wat:Fn2)))
      (import "std/str.wat" "std/str.wat:str_empty" (func $std/str.wat:str_empty (type $std/str.wat:Fn_str_empty)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_0 (ref null any))
        (local $v_1 (ref null any))
        (local $:args (ref null any))
        (local.set $v_0 (call $std/list.wat:args_head (local.get $:params)))
        (local.set $v_1 (call $std/str.wat:str_empty))
        (local.set $:args (call $std/list.wat:args_empty))
        (local.set $:args (call $std/list.wat:args_prepend (local.get $v_1) (local.get $:args)))
        (return_call $rt/apply.wat:apply (local.get $:args) (local.get $v_0))
      )
      (export "fink_module" (func $fink_module))
    )
    ;; sm:BdYSAJIBAQACZgBuALoBAA



test 'string literal', fn:
