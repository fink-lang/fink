test 'str templ two exprs', fn:
  expect ir_wat ƒink:
    a = 1
    b = 2
    '${a} and ${b}'
  | equals wat":
    (module
      (import "rt/types.wat" "Num" (type $rt/types.wat:Num (sub any)))
      (import "rt/types.wat" "Fn2" (type $rt/types.wat:Fn2 (sub func)))
      (import "rt/types.wat" "VarArgs" (type $rt/types.wat:VarArgs (sub any)))
      (type $std/list.wat:Fn_args_head (func (param (ref null any)) (result (ref null any))))
      (type $std/str.wat:Fn_str (func (param i32 i32) (result (ref null any))))
      (type $rt/protocols.wat:Fn_op_unary (func (param (ref null any) (ref null any))))
      (import "std/list.wat" "std/list.wat:args_head" (func $std/list.wat:args_head (type $std/list.wat:Fn_args_head)))
      (import "std/str.wat" "std/str.wat:str" (func $std/str.wat:str (type $std/str.wat:Fn_str)))
      (import "std/str.wat" "std/str.wat:str_fmt" (func $std/str.wat:str_fmt (type $rt/protocols.wat:Fn_op_unary)))
      (func $fink_module (type $rt/types.wat:Fn2) (param $:caps_param (ref null any)) (param $:params (ref null any))
        (local $v_2 (ref null any))
        (local $a_0 (ref null any))
        (local $b_1 (ref null any))
        (local $v_6 (ref null any))
        (local $:varargs (ref null $rt/types.wat:VarArgs))
        (local.set $v_2 (call $std/list.wat:args_head (local.get $:params)))
        (local.set $a_0 (struct.new $rt/types.wat:Num (f64.const 1)))
        (global.set $a (local.get $a_0))
        (local.set $b_1 (struct.new $rt/types.wat:Num (f64.const 2)))
        (global.set $b (local.get $b_1))
        (local.set $v_6 (call $std/str.wat:str (data.ref $d_0 5)))
        (local.set $:varargs (array.new_fixed $rt/types.wat:VarArgs 3 (local.get $a_0) (local.get $v_6) (local.get $b_1)))
        (return_call $std/str.wat:str_fmt (local.get $:varargs) (local.get $v_2))
      )
      (export "fink_module" (func $fink_module))
      (global $a (mut (ref null any)) (ref.null any))
      (export "a" (global $a))
      (global $b (mut (ref null any)) (ref.null any))
      (export "b" (global $b))
      (data $d_0 " and ")
    )
    ;; sm:CIYRAJIBAQABhAEASgEMAYQBAEoBFgV-AO4BAQkP


