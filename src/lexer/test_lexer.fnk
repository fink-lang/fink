  BracketClose ']', loc (1, 1, 1), (2, 1, 2)
  BlockCont loc (2, 1, 2), (3, 2, 0)
  BracketOpen '{', loc (3, 2, 0), (4, 2, 1)
  BracketClose '}', loc (4, 2, 1), (5, 2, 2)
