test 'comment', fn:
  expect tokenize 'foo # a comment'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    Comment '# a comment', loc [4, 1, 4], [15, 1, 15]
    BlockEnd loc [15, 1, 15], [15, 1, 15]


test 'doc_comment', fn:
  expect tokenize
    '---
    doc
    ---'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText '\n', loc [3, 1, 3], [4, 2, 0]
    CommentText 'doc\n', loc [4, 2, 0], [8, 3, 0]
    CommentEnd '---', loc [8, 3, 0], [11, 3, 3]
    BlockEnd loc [11, 3, 3], [11, 3, 3]


test 'block_comment_inline', fn:
  expect tokenize '---foo---'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText 'foo', loc [3, 1, 3], [6, 1, 6]
    CommentEnd '---', loc [6, 1, 6], [9, 1, 9]
    BlockEnd loc [9, 1, 9], [9, 1, 9]


test 'block_comment_multiline', fn:
  expect tokenize
    '---foo
        bar
      spam
    ---'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText 'foo\n', loc [3, 1, 3], [7, 2, 0]
    CommentText '    bar\n', loc [7, 2, 0], [15, 3, 0]
    CommentText '  spam\n', loc [15, 3, 0], [22, 4, 0]
    CommentEnd '---', loc [22, 4, 0], [25, 4, 3]
    BlockEnd loc [25, 4, 3], [25, 4, 3]


test 'block_comment_indent_error', fn:
  expect tokenize
    'log
      ---foo
    bar
    ---'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'log', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    CommentStart '---', loc [6, 2, 2], [9, 2, 5]
    CommentText 'foo\n', loc [9, 2, 5], [13, 3, 0]
    BlockEnd loc [13, 3, 0], [13, 3, 0]
    Err 'unterminated block comment - unexpected dedent', loc [13, 3, 0], [13, 3, 0]
    Ident 'bar', loc [13, 3, 0], [16, 3, 3]
    BlockCont loc [16, 3, 3], [17, 4, 0]
    CommentStart '---', loc [17, 4, 0], [20, 4, 3]
    Err 'unterminated block comment', loc [20, 4, 3], [20, 4, 3]
    BlockEnd loc [20, 4, 3], [20, 4, 3]


test 'block_comment_closing_indent_error', fn:
  expect tokenize
    'foo
      ---bar
    ---'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    CommentStart '---', loc [6, 2, 2], [9, 2, 5]
    CommentText 'bar\n', loc [9, 2, 5], [13, 3, 0]
    BlockEnd loc [13, 3, 0], [13, 3, 0]
    Err 'unterminated block comment - unexpected dedent', loc [13, 3, 0], [13, 3, 0]
    CommentStart '---', loc [13, 3, 0], [16, 3, 3]
    Err 'unterminated block comment', loc [16, 3, 3], [16, 3, 3]
    BlockEnd loc [16, 3, 3], [16, 3, 3]


test 'block_trailing_blank_lines', fn:
  expect tokenize text fn:
    foo
      bar

  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]


test 'err_str_eof', fn:
  expect tokenize '\'hello'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    StrStart '\'', loc [0, 1, 0], [1, 1, 1]
    StrText 'hello', loc [1, 1, 1], [6, 1, 6]
    Err 'unterminated string', loc [6, 1, 6], [6, 1, 6]
    BlockEnd loc [6, 1, 6], [6, 1, 6]


test 'err_doc_comment_eof', fn:
  expect tokenize
    '---
    hello'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    CommentStart '---', loc [0, 1, 0], [3, 1, 3]
    CommentText '\n', loc [3, 1, 3], [4, 2, 0]
    CommentText 'hello', loc [4, 2, 0], [9, 2, 5]
    Err 'unterminated block comment', loc [9, 2, 5], [9, 2, 5]
    BlockEnd loc [9, 2, 5], [9, 2, 5]


test 'err_bracket_eof', fn:
  expect tokenize '[foo'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '[', loc [0, 1, 0], [1, 1, 1]
    Ident 'foo', loc [1, 1, 1], [4, 1, 4]
    Err 'unclosed bracket', loc [4, 1, 4], [4, 1, 4]
    BlockEnd loc [4, 1, 4], [4, 1, 4]


test 'err_bracket_mismatch', fn:
  expect tokenize '{foo]'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
    Ident 'foo', loc [1, 1, 1], [4, 1, 4]
    Err ']', loc [4, 1, 4], [5, 1, 5]
    Err 'unclosed bracket', loc [5, 1, 5], [5, 1, 5]
    BlockEnd loc [5, 1, 5], [5, 1, 5]


test 'err_unexpected_dedent', fn:
  expect tokenize
    'foo
      bar
        ni
     ham
    '
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockStart loc [9, 2, 5], [14, 3, 4]
    Ident 'ni', loc [14, 3, 4], [16, 3, 6]
    BlockEnd loc [16, 3, 6], [16, 3, 6]
    Err 'unexpected dedent', loc [16, 3, 6], [18, 4, 1]
    Ident 'ham', loc [18, 4, 1], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]
    BlockEnd loc [22, 5, 0], [22, 5, 0]


test 'err_unexpected_dedent2', fn:
  expect tokenize 'foo\n  bar\n    ni\n ham'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    BlockStart loc [3, 1, 3], [6, 2, 2]
    Ident 'bar', loc [6, 2, 2], [9, 2, 5]
    BlockStart loc [9, 2, 5], [14, 3, 4]
    Ident 'ni', loc [14, 3, 4], [16, 3, 6]
    BlockEnd loc [16, 3, 6], [16, 3, 6]
    Err 'unexpected dedent', loc [16, 3, 6], [18, 4, 1]
    Ident 'ham', loc [18, 4, 1], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]
    BlockEnd loc [21, 4, 4], [21, 4, 4]



test 'err_tab', fn:
  expect tokenize 'a\tb'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'a', loc [0, 1, 0], [1, 1, 1]
    Err 'tab character not allowed', loc [1, 1, 1], [2, 1, 2]
    Ident 'b', loc [2, 1, 2], [3, 1, 3]
    BlockEnd loc [3, 1, 3], [3, 1, 3]


test 'bracket_multiline_flat', fn:
  expect tokenize text fn:
    {
      foo: 1
      bar: 2
    }
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
    BlockStart loc [1, 1, 1], [4, 2, 2]
    Ident 'foo', loc [4, 2, 2], [7, 2, 5]
    Colon ':', loc [7, 2, 5], [8, 2, 6]
    Int '1', loc [9, 2, 7], [10, 2, 8]
    BlockCont loc [10, 2, 8], [13, 3, 2]
    Ident 'bar', loc [13, 3, 2], [16, 3, 5]
    Colon ':', loc [16, 3, 5], [17, 3, 6]
    Int '2', loc [18, 3, 7], [19, 3, 8]
    BlockEnd loc [19, 3, 8], [19, 3, 8]
    BracketClose '}', loc [20, 4, 0], [21, 4, 1]
    BlockEnd loc [21, 4, 1], [21, 4, 1]


test 'bracket_multiline_nested', fn:
  expect tokenize text fn:
    {
      foo: {
        bar: 1
      }
    }
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    BracketOpen '{', loc [0, 1, 0], [1, 1, 1]
    BlockStart loc [1, 1, 1], [4, 2, 2]
    Ident 'foo', loc [4, 2, 2], [7, 2, 5]
    Colon ':', loc [7, 2, 5], [8, 2, 6]
    BracketOpen '{', loc [9, 2, 7], [10, 2, 8]
    BlockStart loc [10, 2, 8], [15, 3, 4]
    Ident 'bar', loc [15, 3, 4], [18, 3, 7]
    Colon ':', loc [18, 3, 7], [19, 3, 8]
    Int '1', loc [20, 3, 9], [21, 3, 10]
    BlockEnd loc [21, 3, 10], [21, 3, 10]
    BracketClose '}', loc [24, 4, 2], [25, 4, 3]
    BlockEnd loc [25, 4, 3], [25, 4, 3]
    BracketClose '}', loc [26, 5, 0], [27, 5, 1]
    BlockEnd loc [27, 5, 1], [27, 5, 1]



test 'err_unknown_char', fn:
  expect tokenize 'foo @ bar'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    Ident 'foo', loc [0, 1, 0], [3, 1, 3]
    Err '@', loc [4, 1, 4], [5, 1, 5]
    Ident 'bar', loc [6, 1, 6], [9, 1, 9]
    BlockEnd loc [9, 1, 9], [9, 1, 9]


test 'raw_block_contains_raw_keyword', fn:
  expect tokenize 'raw:\n  raw:\n    foo\n'
  | equals text fn:
    BlockStart loc [0, 1, 0], [0, 1, 0]
    StrStart 'raw:', loc [0, 1, 0], [4, 1, 4]
    StrText 'raw:\n', loc [7, 2, 2], [12, 3, 0]
    StrText '  foo', loc [14, 3, 2], [19, 3, 7]
    StrEnd '', loc [20, 4, 0], [20, 4, 0]
    BlockEnd loc [20, 4, 0], [20, 4, 0]
