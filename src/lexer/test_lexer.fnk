  StrStart "'", loc (0, 1, 0), (1, 1, 1)
    StrText "hello", loc (1, 1, 1), (6, 1, 6)
  StrEnd "'", loc (6, 1, 6), (7, 1, 7)
  BlockCont loc (7, 1, 7), (8, 2, 0)
  StrStart "'", loc (8, 2, 0), (9, 2, 1)
    StrText "hello ", loc (9, 2, 1), (15, 2, 7)
    StrExprStart '\${', loc (15, 2, 7), (17, 2, 9)
      Ident 'name', loc (17, 2, 9), (21, 2, 13)
    StrExprEnd '}', loc (21, 2, 13), (22, 2, 14)
  StrEnd "'", loc (22, 2, 14), (23, 2, 15)
BlockEnd loc (23, 2, 15), (23, 2, 15)


