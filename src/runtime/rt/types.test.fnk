{test, equals, not_equals, skip} = import 'std/testing.fnk'

{u8} = import 'std/int.fnk'



test 'type alias equality', fn:
  Foo = type _
  Bar = Foo

  equals
    Foo
    Bar


test 'type equality', fn:
  Foo = type _
  Bar = type _

  not_equals
    Foo
    Bar


test 'union alias', fn:
  Foo = type _
  Bar = type _

  FooBar = union:
    Foo
    Bar

  Spam = FooBar

  equals
    FooBar
    Spam


test 'union equality', fn:
  Foo = type _
  Bar = type _

  FooBar = union:
    Foo
    Bar

  Spam = union:
    Bar
    Foo

  equals
    FooBar
    Spam


test 'enum aliasing', fn:
  Foo = enum:
    Bar {a: u8}
    Spam u8

  Ham = Foo

  equals
    Foo
    Ham


test 'enum equality', fn:
  Foo = enum:
    Bar {a: u8}
    Spam u8

  Ham = enum:
    Bar {a: u8}
    Spam u8

  not_equals
    Foo
    Ham



test 'typed rec equality', fn:
  Foo = type:
    bar: u8
    spam: u8

  equals
    Foo {bar: 1, spam: 2}
    Foo {bar: 1, spam: 2}

  not_equals
    Foo {bar: 1, spam: 2}
    {bar: 1, spam: 2}



test 'typed rec destructure', fn:
  Foo = type:
    bar: u8

  {bar} = Foo {bar: 1}

  equals bar, 1


test 'typed rec guard', fn:
  Foo = type:
    bar: u8

  Foo foo = Foo {bar: 1}

  equals
    foo
    Foo {bar: 1}


test 'typed rec guard destructure', fn:
  Foo = type:
    bar: u8

  Foo {bar} = Foo {bar: 42}

  equals bar, 42


test 'typed rec guard destructured with projection to base type', fn:
  Foo = type:
    bar: u8

  FooBar = type:
    ..Foo
    spam: u8

  Foo foo = FooBar {bar: 1, spam: 2}

  equals
    foo
    Foo {bar: 1}


test 'typed rec match on type', fn:
  Foo = type:
    bar: u8

  result = match Foo {bar: 1}:
    Foo foo: foo
    _: false

  equals
    result
    Foo {bar: 1}


test 'typed rec match on type with destructure', fn:
  Foo = type:
    bar: u8

  result = match Foo {bar: 42}:
    Foo {bar}: bar
    _: 0

  equals result, 42


test 'typed rec match selects by type', fn:
  Foo = type:
    bar: u8

  Spam = type:
    ham: u8

  classify = fn val:
    match val:
      Foo _: 'foo'
      Spam _: 'spam'
      _: 'other'

  equals
    [classify Foo {bar: 1}; classify Spam {ham: 2}; classify {x: 3}]
    ['foo'; 'spam'; 'other']


test 'typed rec match projects to base type', fn:
  Foo = type:
    bar: u8

  FooBar = type:
    ..Foo
    spam: u8

  result = match FooBar {bar: 1, spam: 2}:
    Foo foo: foo
    _: false

  equals
    result
    Foo {bar: 1}


test 'typed rec dot op', fn:
  Foo = type:
    bar: u8

  foo = Foo {bar: 1}

  equals foo.bar, 1


test 'typed rec destructure spread', fn:
  Foo = type:
    bar: u8
    spam: u8

  {..foo} = Foo {bar: 1, spam: 2}

  equals
    foo
    {bar: 1, spam: 2}



test 'typed tuple equality', fn:
  Foo = type: u8, u8

  equals
    Foo 1, 2
    Foo 1, 2

  not_equals
    Foo 1, 2
    [1, 2]



test 'typed tuple destructure', fn:
  Foo = type: u8

  [bar] = Foo 1

  equals bar, 1


test 'typed tuple dot op', fn:
  Foo = type: u8

  foo = Foo 1

  equals foo.(0), 1


test 'typed tuple destructure spread', fn:
  Foo = type: u8, u8

  [..foo] = Foo 1, 2

  equals
    foo
    [1, 2]



skip test 'TODO support typed fn', fn:
  Foo = type:
    # fn u8, i16: i8
    u8



