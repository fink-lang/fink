{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'multi-param fn called in same scope', fn:
  expect run ƒink:
    add = fn a, b:
      a + b
    add 3, 4
  | equals ƒink:
    7


test 'pipe with fn call', fn:
  expect run ƒink:
    add = fn a, b: a + b
    2
    | add 3, ?
  | equals ƒink:
    5


test 'match literal first arm', fn:
  expect run ƒink:
    match 0:
      0: 42
      _: 99
  | equals ƒink:
    42


test 'match literal second arm', fn:
  expect run ƒink:
    match 1:
      0: 42
      _: 99
  | equals ƒink:
    99


test 'match wildcard binding', fn:
  expect run ƒink:
    match 5:
      0: 0
      x: x + 1
  | equals ƒink:
    6


test 'factorial', fn:
  expect run ƒink:
    fac = fn n:
      match n:
        0: 1
        n: n * fac n - 1
    fac 5
  | equals ƒink:
    120


test 'add list items', fn:
  expect run ƒink:
    sum = fn items, c:
      match items:
        []: c
        [a, ..rest]: sum rest, c + a

    sum [1, 2, 3, 4], 0

  | equals ƒink:
    10


test 'varargs first', fn:
  expect run ƒink:
    first = fn ..args:
      match args:
        [a, ..]: a

    first ..[42, 99]
  | equals ƒink:
    42


test 'varargs identity', fn:
  expect run ƒink:
    identity = fn ..args: args

    match (identity ..[10, 20, 30]):
      [a, ..]: a
  | equals ƒink:
    10


test 'tagged template varargs', fn:
  expect run ƒink:
    first = fn ..parts:
      match parts:
        [a, ..]: a

    x = 42
    y = first'hello ${x} world'
    y == 'hello '
  | equals ƒink:
    true


test 'varargs mixed fixed and rest', fn:
  expect run ƒink:
    head-and-rest = fn a, ..rest:
      match rest:
        [b, ..]: a + b

    head-and-rest 10, ..[20, 30]
  | equals ƒink:
    30


test 'mutual recursion at module scope', fn:
  expect run ƒink:
    is_even = fn n:
      match n:
        0: true
        _: is_odd  n - 1

    is_odd = fn n:
      match n:
        0: false
        _: is_even n - 1

    is_even 4
  | equals ƒink:
    true


test 'fn equality — same fn', fn:
  expect run ƒink:
    foo = fn: 123
    foo == foo
  | equals ƒink:
    true


test 'fn equality — different fns', fn:
  expect run ƒink:
    foo = fn: 123
    bar = fn: 456
    foo == bar
  | equals ƒink:
    false


test 'fn equality — distinct closures from same fn', fn:
  expect run ƒink:
    spam = fn: fn: 789
    f1 = spam _
    f2 = spam _
    f1 != f2
  | equals ƒink:
    true


# Inner-let fn referencing its own binding lexically. Self-recursive
# closures are constructed with the recursive slot patched via array.set
# after the closure value is bound, so the captures array sees the
# closure itself by reference (see passes/wasm/lower.rs:emit_closure_construction_inner).
test 'self-recursive fn defined inside another fn', fn:
  expect run ƒink:
    outer = fn x:
      inner = fn n:
        match n:
          0: x
          _: inner n - 1
      inner 3

    outer 42
  | equals ƒink:
    42
