{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


# Operator behaviour per type lives in the type's own tests (num/int/
# float/bool/...). What remains here are trap-behaviour tests: a trap is
# a runtime abort only the expect-run-fink harness can observe -- the
# fink-native suite has no trap-catching assertion.


# Mixing signed (math family) with unsigned (bits family) is rejected
# at runtime — there's no implicit conversion across families.
test 'mix signed and unsigned traps', fn:
  expect run ƒink:
    1 + 0xFF
  | equals ":
    1 + 0xFF
    ^
    trap: unreachable code reached
    ./test.fnk:1:1
