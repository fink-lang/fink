{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'add two literals', fn:
  expect run ƒink:
    main = fn:
      2 + 3
  | equals ":
    5


test 'subtraction', fn:
  expect run ƒink:
    main = fn:
      10 - 3
  | equals ":
    7


test 'multiplication', fn:
  expect run ƒink:
    main = fn:
      4 * 5
  | equals ":
    20


test 'division', fn:
  expect run ƒink:
    main = fn:
      10 / 4
  | equals ":
    2.5


test 'integer division', fn:
  expect run ƒink:
    main = fn:
      7 // 2
  | equals ":
    3


test 'modulo', fn:
  expect run ƒink:
    main = fn:
      10 %% 3
  | equals ":
    1


test 'equal', fn:
  expect run ƒink:
    main = fn:
      3 == 3
  | equals ":
    true


test 'not equal', fn:
  expect run ƒink:
    main = fn:
      3 != 4
  | equals ":
    true


test 'less than', fn:
  expect run ƒink:
    main = fn:
      3 < 4
  | equals ":
    true


test 'less than or equal', fn:
  expect run ƒink:
    main = fn:
      3 <= 3
  | equals ":
    true


test 'greater than', fn:
  expect run ƒink:
    main = fn:
      4 > 3
  | equals ":
    true


test 'greater than or equal', fn:
  expect run ƒink:
    main = fn:
      3 >= 3
  | equals ":
    true


test 'not', fn:
  expect run ƒink:
    main = fn:
      not true
  | equals ":
    false


test 'and', fn:
  expect run ƒink:
    main = fn:
      true and false
  | equals ":
    false


test 'or', fn:
  expect run ƒink:
    main = fn:
      true or false
  | equals ":
    true


test 'xor', fn:
  expect run ƒink:
    main = fn:
      true xor true
  | equals ":
    false


test 'chain with bool', fn:
  expect run ƒink:
    main = fn:
      x = 3 > 2
      x and true
  | equals ":
    true


# --- Bitwise operators ---

test 'bitwise and', fn:
  expect run ƒink:
    main = fn:
      0xFF and 0x0F
  | equals ƒink:
    15

test 'bitwise or', fn:
  expect run ƒink:
    main = fn:
      0xFF or 0x0F
  | equals ƒink:
    255

test 'bitwise xor', fn:
  expect run ƒink:
    main = fn:
      0xFF xor 0x0F
  | equals ƒink:
    240

test 'bitwise not', fn:
  expect run ƒink:
    main = fn:
      not 0
  | equals ƒink:
    -1

test 'bitwise shift left', fn:
  expect run ƒink:
    main = fn:
      1 << 8
  | equals ƒink:
    256

test 'bitwise shift right', fn:
  expect run ƒink:
    main = fn:
      256 >> 4
  | equals ƒink:
    16
