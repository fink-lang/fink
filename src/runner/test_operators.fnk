{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'add two literals', fn:
  expect run ƒink:
    2 + 3
  | equals ƒink:
    5


test 'subtraction', fn:
  expect run ƒink:
    10 - 3
  | equals ƒink:
    7


test 'multiplication', fn:
  expect run ƒink:
    4 * 5
  | equals ƒink:
    20


test 'division', fn:
  expect run ƒink:
    10 / 4
  | equals ƒink:
    2.5


test 'power', fn:
  expect run ƒink:
    2 ** 8
  | equals ƒink:
    256


skip test 'power float', fn:
  expect run ƒink:
    2.0 ** 0.5
  | equals ƒink:
    1.4142135623730951


test 'integer division', fn:
  expect run ƒink:
    7 // 2
  | equals ƒink:
    3


test 'divmod', fn:
  expect run ƒink:
    [q, r] = 10 /% 3
    '${q}, ${r}'
  | equals ƒink:
    3, 1


test 'modulo', fn:
  expect run ƒink:
    10 %% 3
  | equals ƒink:
    1


test 'equal', fn:
  expect run ƒink:
    3 == 3
  | equals ƒink:
    true


test 'not equal', fn:
  expect run ƒink:
    3 != 4
  | equals ƒink:
    true


test 'less than', fn:
  expect run ƒink:
    3 < 4
  | equals ƒink:
    true


test 'less than or equal', fn:
  expect run ƒink:
    3 <= 3
  | equals ƒink:
    true


test 'greater than', fn:
  expect run ƒink:
    4 > 3
  | equals ƒink:
    true


test 'greater than or equal', fn:
  expect run ƒink:
    3 >= 3
  | equals ƒink:
    true


test 'not', fn:
  expect run ƒink:
    not true
  | equals ƒink:
    false


test 'and', fn:
  expect run ƒink:
    true and false
  | equals ƒink:
    false


test 'or', fn:
  expect run ƒink:
    true or false
  | equals ƒink:
    true


test 'xor', fn:
  expect run ƒink:
    true xor true
  | equals ƒink:
    false


test 'chain with bool', fn:
  expect run ƒink:
    x = 3 > 2
    x and true
  | equals ƒink:
    true


# --- Bitwise operators ---

test 'bitwise and', fn:
  expect run ƒink:
    0xFF and 0x0F
  | equals ƒink:
    15

test 'bitwise or', fn:
  expect run ƒink:
    0xFF or 0x0F
  | equals ƒink:
    255

test 'bitwise xor', fn:
  expect run ƒink:
    0xFF xor 0x0F
  | equals ƒink:
    240

# `not 0x0` flips all 64 bits → max-u64. Skipped while u64 formatting
# still goes through the f64 printer.
skip test 'bitwise not', fn:
  expect run ƒink:
    not 0x0
  | equals ƒink:
    18446744073709551615

test 'bitwise shift left', fn:
  expect run ƒink:
    0x1 << 8
  | equals ƒink:
    256

test 'bitwise shift right', fn:
  expect run ƒink:
    0x100 >> 4
  | equals ƒink:
    16

test 'rotate left', fn:
  expect run ƒink:
    0x1 <<< 4
  | equals ƒink:
    16


test 'rotate right', fn:
  expect run ƒink:
    0x10 >>> 4
  | equals ƒink:
    1



# Mixing signed (math family) with unsigned (bits family) is rejected
# at runtime — there's no implicit conversion across families.
test 'mix signed and unsigned traps', fn:
  expect run ƒink:
    1 + 0xFF
  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:    0xe5f - <unknown>!std/num.wat:check_compat
        1:    0xeba - <unknown>!std/num.wat:op_plus
        2:   0x5284 - <unknown>!rt/protocols.wat:op_plus: wasm trap: wasm `unreachable` instruction executed
