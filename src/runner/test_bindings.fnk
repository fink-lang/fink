{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'let binding', fn:
  expect run ƒink:
    main = fn:
      x = 42
      x
  | equals ":
    42


test 'let alias', fn:
  expect run ƒink:
    main = fn:
      x = 42
      y = x
      y
  | equals ":
    42


test 'chained arithmetic', fn:
  expect run ƒink:
    main = fn:
      x = 2 * 3
      x + 4
  | equals ":
    10


test 'multiple let bindings', fn:
  expect run ƒink:
    main = fn:
      x = 2
      y = 3
      x + y
  | equals ":
    5


test 'nested chains', fn:
  expect run ƒink:
    main = fn:
      x = 2 + 3
      y = x * 2
      y - 1
  | equals ":
    9
