{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'let binding', fn:
  expect run ƒink:
    x = 42
    x
  | equals ƒink:
    42


test 'let alias', fn:
  expect run ƒink:
    x = 42
    y = x
    y
  | equals ƒink:
    42


test 'chained arithmetic', fn:
  expect run ƒink:
    x = 2 * 3
    x + 4
  | equals ƒink:
    10


test 'multiple let bindings', fn:
  expect run ƒink:
    x = 2
    y = 3
    x + y
  | equals ƒink:
    5


skip-ir test 'nested chains', fn:
  expect run ƒink:
    x = 2 + 3
    y = x * 2
    y - 1
  | equals ƒink:
    9


test 'bind-right at statement top', fn:
  expect run ƒink:
    add = fn a, b: a + b
    add
      1
      2
    |= result
    result
  | equals ƒink:
    3
