---
runtime error tests

These pin the user-visible error format for trap/panic conditions.
Goal for every runtime error:
  - source line with caret pointing at the failing expression
  - plain-language description of what failed
  - url:line:col reference

Today's output is wasm backtraces with internal WAT func names; these
tests document where we want to land. They fail until source-map
lookup is wired into the trap-to-error path and compile-time errors
are routed through Diagnostic.
---

{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'runtime error: irrefutable match fails with no matching arm', fn:
  expect run ƒink:
    match 'foo':
      'bar': 1
  | equals ":
    match 'foo':
    ^^^^^^^^^^^^
    match exhausted: no arm matched
    ./test.fnk:1:1


# Same, deeper inside the program — line should point at the match,
# not the module wrapper.
test 'runtime error: irrefutable match in nested fn', fn:
  expect run ƒink:
    f = fn x:
      match x:
        'bar': 1
    f 'foo'
  | equals ":
    f = fn x:
      match x:
      ^^^^^^^^
    match exhausted: no arm matched
    ./test.fnk:2:3


# --- bad destructure --------------------------------------------------

# Destructure a value whose shape doesn't match — irrefutable pattern.
test 'runtime error: rec destructure missing field', fn:
  expect run ƒink:
    {a, b} = {x: 1}
    a + 1
  | equals ":
    {a, b} = {x: 1}
    ^
    irrefutable pattern failed
    ./test.fnk:1:1


# --- type mismatch ----------------------------------------------------

# `1 + 'foo'` traps inside the runtime op_plus dispatcher when the
# string can't cast to $Num. Today's message is generic ("type
# mismatch"); a per-op reason ("op_plus: expected number, got string")
# is a follow-up that requires runtime br_on_cast with reason-tagged
# panics at each cast site.
test 'runtime error: type mismatch on +', fn:
  expect run ƒink:
    1 + 'foo'
  | equals ":
    1 + 'foo'
    ^
    type mismatch
    ./test.fnk:1:1


# --- divide by zero ---------------------------------------------------

test 'runtime error: integer divide by zero', fn:
  expect run ƒink:
    1 // 0
  | equals ":
    1 // 0
    ^
    integer divide by zero
    ./test.fnk:1:1


# --- compile-time errors (should be caught BEFORE runtime) -----------

# Unbound name today panics inside lower.rs with "lower: unbound CpsId
# cps#N" -- internal IDs that mean nothing to the user. This should
# be a scope-time error.
test 'compile error: unbound name', fn:
  expect run ":
    foo bar
  | equals ":
    foo bar
    ^^^
    unbound name 'foo'
    ./test.fnk:1:1
