{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


skip test 'try unwrap ok', fn:
  expect run ƒink:
    test_main = fn:
      x = try Ok 42
      x
  | equals ƒink:
    42

skip test 'try propagate err', fn:
  expect run ƒink:
    fallible = fn:
      try Err 'boom'
      99

    test_main = fn:
      match (fallible ..[]):
        Ok v: v
        Err e: e == 'boom'
  | equals ƒink:
    true

skip test 'match ok err', fn:
  expect run ƒink:
    test_main = fn:
      r = Ok 42
      match r:
        Ok v: v
        Err _: 0
  | equals ƒink:
    42
