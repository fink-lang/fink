{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


skip test 'fn match simple', fn:
  expect run ƒink:
    double = fn match:
      0: 0
      n: n * 2

    main = fn:
      double 5
  | equals ƒink:
    10

skip test 'fn match with rec pattern', fn:
  expect run ƒink:
    get-x = fn match:
      {x, ..}: x

    main = fn:
      get-x {x: 42, y: 99}
  | equals ƒink:
    42
