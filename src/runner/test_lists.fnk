{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'list construct returns without trap', fn:
  expect run ƒink:
    {list} = import 'std/list.fnk'

    '${list 1, 2, 3}'

  | equals ƒink:
    [1, 2, 3]


test 'list construct empty', fn:
  expect run ƒink:
    {list} = import 'std/list.fnk'

    '${list _}'

  | equals ƒink:
    []


test 'list construct with spread args', fn:
  expect run ƒink:
    {list} = import 'std/list.fnk'

    '${list ..[1, 2, 3]}'

  | equals ƒink:
    [1, 2, 3]


test 'list construct destructures via head/tail', fn:
  expect run ƒink:
    {list} = import 'std/list.fnk'

    [h, ..t] = list 10, 20, 30
    '${h} ${t}'

  | equals ":
    10 [20, 30]


# --- List slicing ---

test 'list slice exclusive range', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5].(1..3)}'
  | equals ƒink:
    [2, 3]

test 'list slice inclusive range', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5].(1...3)}'
  | equals ƒink:
    [2, 3, 4]

test 'list slice single index', fn:
  expect run ƒink:
    [10, 20, 30].(0)
  | equals ƒink:
    10

test 'list slice last index', fn:
  expect run ƒink:
    [10, 20, 30].(2)
  | equals ƒink:
    30

test 'list slice full range', fn:
  expect run ƒink:
    '${[1, 2, 3].(0..3)}'
  | equals ƒink:
    [1, 2, 3]

test 'list slice empty range', fn:
  expect run ƒink:
    '${[1, 2, 3].(1..1)}'
  | equals ƒink:
    []

test 'list slice from start', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5].(0..3)}'
  | equals ƒink:
    [1, 2, 3]

test 'list slice to end', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5].(3..5)}'
  | equals ƒink:
    [4, 5]

test 'list slice negative range', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5, 6].(-3..-1)}'
  | equals ƒink:
    [4, 5]

test 'list slice negative single index', fn:
  expect run ƒink:
    [10, 20, 30].(-2)
  | equals ƒink:
    20

test 'list slice open range', fn:
  expect run ƒink:
    '${[1, 2, 3, 4, 5, 6].(-3..)}'
  | equals ƒink:
    [4, 5, 6]
