{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


skip test 'yield value', fn:
  expect run ƒink:
    main = fn:
      x = 1
      y = 2
      x + y
      yield x + y
  | equals ƒink:
    3

skip test 'yield multiple', fn:
  expect run ƒink:
    main = fn:
      yield 1
      yield 2
      yield 3
  | equals ƒink:
    1
    2
    3
