{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'set_ctx threads new universe forward', fn:
  expect run ƒink:
    {set_ctx} = import 'std/effects.fnk'
    set_ctx 'first'
    set_ctx 'second'
  | equals ":
    first


test 'set_ctx survives a builtin op in between', fn:
  expect run ƒink:
    {set_ctx} = import 'std/effects.fnk'
    set_ctx 'foo'
    x = 1 + 2
    set_ctx 'bar ${x}'
  | equals ":
    foo


test 'ctx set in outer scope reads in nested fn', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    # we don't know what the starting point is, 42?
    set_ctx 1

    ni = set_ctx 1

    inner = fn foo:
      x = set_ctx foo + 1
      x

    inner ni
    get_ctx _
  | equals ƒink:
    2


# -- ctx passthrough across runtime boundaries -----------------------
#
# These tests pin down that ctx survives every place where a cont gets
# suspended and later resumed by the runtime: yield, channel I/O, await,
# host stdout. Each test sets a sentinel ctx, crosses the boundary, then
# reads ctx back on the other side -- if any thunk/Waiter on the path
# drops ctx, the resumed value will be the previous (default) ctx
# instead of the sentinel.

test 'ctx survives yield/resume', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'
    set_ctx 'yielded'
    yield 0
    get_ctx _
  | equals ":
    yielded


test 'ctx survives channel receive', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    ch = channel 0
    spawn fn:
      'msg' >> ch

    set_ctx 'receiver-ctx'
    receive ch
    get_ctx _
  | equals ":
    receiver-ctx


test 'ctx survives await of spawned task', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    fut = spawn fn:
      42

    set_ctx 'awaiter-ctx'
    await fut
    get_ctx _
  | equals ":
    awaiter-ctx


test 'ctx survives stdout write', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'writer-ctx'
    write stdout, ''
    get_ctx _
  | equals ":
    writer-ctx


# A spawned task body now runs under the SPAWNER's ctx (we captured it
# in $_spawn_task_fn's captures).
test 'spawned task body inherits spawner ctx', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'spawner-ctx'
    fut = spawn fn:
      get_ctx _

    await fut
  | equals ":
    spawner-ctx


# Protocols dispatchers (op_plus etc.) forward ctx to their cont without
# consulting it for dispatch. After an arbitrary numeric op chain, ctx
# should still be the caller's.
test 'ctx survives arithmetic chain', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'math-ctx'
    foo = 1 + 2 * 3 - 4
    get_ctx _
  | equals ":
    math-ctx


# Pattern match arms are CPS conts under the hood; ctx must survive
# match dispatch.
test 'ctx survives match', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'match-ctx'
    match 'x':
      'x': 1
      _: 0
    get_ctx _
  | equals ":
    match-ctx


# Channel I/O via the host bridge (HostChannel) — write goes through
# interop_channel_send. ctx should survive that too.
test 'ctx survives stderr write', fn:
  expect run ƒink:
    {stderr, write} = import 'std/io.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'stderr-ctx'
    write stderr, ''
    get_ctx _
  | equals ":
    stderr-ctx


# std/math.wat's per-fn closures (abs, sqrt, sin, cos, log, ...) now
# forward the caller's ctx into apply_1 — previously they discarded it.
test 'ctx survives sqrt', fn:
  expect run ƒink:
    {sqrt} = import 'std/math.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'math-fn-ctx'
    sqrt 16.0
    get_ctx _
  | equals ":
    math-fn-ctx


# -- KNOWN ctx-drop sites ----------------------------------------------
#
# Verified gaps that fail today. Skipped so they don't break CI but
# stay visible for the next ctx-threading pass. Un-skip to reproduce.


# `repr x` and `fmt x` as user-imported fns. The bare-@impl wrapper in
# the .wat file returns a no-capture $Closure; the user-import binding
# receives the closure value; apply_3 dispatches with caller's ctx.
test 'ctx survives repr', fn:
  expect run ƒink:
    {repr} = import 'std/repr.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'repr-ctx'
    repr 42
    get_ctx _
  | equals ":
    repr-ctx


# `fmt x` as a direct user-imported call (not template-string interp,
# which goes through the StrFmt builtin sym path with ctx threaded).
test 'ctx survives fmt as imported fn', fn:
  expect run ƒink:
    {fmt} = import 'std/str.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'fmt-ctx'
    fmt 42
    get_ctx _
  | equals ":
    fmt-ctx


# `abort` with no enclosing `with` traps -- there's no frame to jump
# to. The future interop wrapper will install a root frame so this
# becomes unreachable in practice.

test 'abort with no enclosing with traps', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'
    abort 42

  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:  <unknown>!std/effects.wat:abort_apply: wasm trap: null reference


# -- with-block (substrate) -------------------------------------------
#
# `with H: B` lowers to with_invoke(ctx, H, body_fn, k_outer). The
# runtime invokes H with [k_outer, wrapped_body]. H is a
# `fn body: ...` handler; when it calls `body args`, the wrapper
# pushes a frame holding the body-call cont, then runs B. When B
# returns normally OR aborts, control lands at the same place: the
# handler's `body args` call site, with the value. Handler is always
# re-entered uniformly -- can run cleanup, transform the value, or
# decide what the block evaluates to.

test 'with: reader handler returns body value', fn:
  expect run ƒink:
    handler = fn body:
      body _

    with handler:
      42

  | equals ƒink:
    42


test 'with: handler ignoring body returns its own value', fn:
  expect run ƒink:
    handler = fn _: 'handler-result'

    with handler:
      'body-result'

  | equals ":
    handler-result


test 'with: abort in body lands at handler body-call site', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      body _

    with handler:
      abort 'aborted'
      42

  | equals ":
    aborted


# Handler resumes at `body _` site after abort, runs cleanup, then
# returns its own transformed value. Proves abort lands *inside* the
# handler, not at k_outer directly.
test 'with: handler transforms aborted value after cleanup', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      result = body _
      'wrapped: ${result}'

    with handler:
      abort 'inner'
      42

  | equals ":
    wrapped: inner


# -- multishot whole-body replay -------------------------------------
#
# Handler can call `body _` more than once -- each call re-enters the
# body from the top and produces its own value. No `resume` primitive
# today, so multishot is "replay the whole body", not "resume from a
# suspension point". Enough for tests that pin current substrate shape.

test 'with: handler calls body twice, combines results', fn:
  expect run ƒink:
    handler = fn body:
      a = body _
      b = body _
      'a=${a} b=${b}'

    with handler:
      42

  | equals ":
    a=42 b=42


test 'with: handler calls body in a loop, collects results', fn:
  expect run ƒink:
    handler = fn body:
      [
        body _
        body _
        body _
      ]

    ni = with handler:
      7

    '${ni}'
  | equals ":
    [7, 7, 7]


# SKIPPED: `with pick true: B` (partial-applied handler) traps at
# std/list.wat:head_any. `with` lowering currently expects an
# arity-1 handler expression; curried handlers aren't recognised.
test 'with: handler chooses zero vs one shot at runtime', fn:
  expect run ƒink:
    pick = fn flag: fn body:
      match flag:
        1: body _
        2: 'skipped'

    a = with pick 1:
      'ran 1'

    b = with pick 2:
      'ran 2'

    '${a}/${b}'

  | equals ":
    ran 1/skipped


# -- nested with ------------------------------------------------------
#
# Frame stack is LIFO. `with outer: with inner: B` pushes outer's frame
# first, then inner's. abort inside B walks to the nearest frame
# (inner). If inner re-enters cleanly, outer sees inner's value.

test 'with: nested -- inner catches, outer sees transformed value', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    inner = fn body:
      x = body _
      'inner:${x}'

    outer = fn body:
      y = body _
      'outer:${y}'

    with outer:
      with inner:
        abort 'boom'
        42

  | equals ":
    outer:inner:boom


test 'with: nested -- outer abort skips inner frame', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    inner = fn body:
      x = body _
      'inner-saw:${x}'

    outer = fn body:
      y = body _
      'outer-caught:${y}'

    with outer:
      with inner:
        abort 'from-deep'
        42

  | equals ":
    outer-caught:inner-saw:from-deep


# -- frame-stack robustness through call depth -----------------------
#
# Abort from inside a nested fn call walks frames correctly. abort
# inside a match arm likewise -- match arms are CPS conts under the
# hood, but at language level they're just expressions in the body.

test 'with: abort from inside nested fn call in body', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      x = body _
      'caught:${x}'

    boom = fn:
      abort 'deep'
      0

    with handler:
      boom _
      42

  | equals ":
    caught:deep


test 'with: abort from inside match arm in body', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      x = body _
      'caught:${x}'

    with handler:
      match 'go':
        'go': abort 'matched'
        _: 0
      42

  | equals ":
    caught:matched


# -- handler captures outer scope ------------------------------------
#
# Handler is a real closure value; it captures bindings from its
# defining scope and uses them when re-entered at the body-call site.

test 'with: handler captures outer variable', fn:
  expect run ƒink:
    prefix = 'tag'

    handler = fn body:
      x = body _
      '${prefix}:${x}'

    with handler:
      99

  | equals ":
    tag:99


# -- non-scalar body value -------------------------------------------
#
# Body produces a record; handler passes it through via `body _`. Pins
# that body values are not restricted to scalars.

test 'with: body returns a record, handler passes it through', fn:
  expect run ƒink:
    handler = fn body:
      body _

    r = with handler:
      {x: 1, y: 2}

    '${r}'
  | equals ":
    {x: 1, y: 2}


# -- yield2 substrate (step 1) ---------------------------------------
#
# yield2 v captures the caller's continuation and returns an opaque
# $Yield struct {value, resume} to the handler. Handler reads via
# get_yield_value / get_yield_resume; calling resume r re-enters body
# at the yield2 site with r.

test 'with: yield2 zero-shot -- handler ignores resume', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    handler = fn body:
      result = body _
      v = get_yield_value result
      'caught: ${v}'

    with handler:
      yield2 'hello'
      42

  | equals ":
    caught: hello


test 'with: yield2 one-shot -- handler resumes body', fn:
  expect run ƒink:
    {yield2, get_yield_value, get_yield_resume} = import 'std/effects.fnk'

    handler = fn body:
      result = body _
      v = get_yield_value result
      resume = get_yield_resume result
      resume 'got: ${v}'

    with handler:
      r = yield2 'asked'
      'final: ${r}'

  | equals ":
    final: got: asked


test 'with: nested yield2 -- inner handler intercepts', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    outer = fn body:
      r = body _
      'outer saw: ${r}'

    inner = fn body:
      r = body _
      'inner caught: ${get_yield_value r}'

    with outer:
      with inner:
        yield2 'hello'
        42

  | equals ":
    outer saw: inner caught: hello


test 'with: nested yield2 -- inner re-yields to outer', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    outer = fn body:
      r = body _
      'outer caught: ${get_yield_value r}'

    inner = fn body:
      r = body _
      v = get_yield_value r
      yield2 v

    with outer:
      with inner:
        yield2 'propagate'
        42

  | equals ":
    outer caught: propagate


test 'with: nested yield2 -- outer resumes inner handler', fn:
  expect run ƒink:
    {yield2, get_yield_value, get_yield_resume} = import 'std/effects.fnk'

    inner = fn body:
      y = body _
      v = get_yield_value y
      resumed = yield2 v
      'inner done: ${resumed}'

    outer = fn body:
      y = body _
      resume = get_yield_resume y
      resume 'outer-said'

    with outer:
      with inner:
        yield2 'asked'
        42

  | equals ":
    inner done: outer-said


test 'with: yield2 multi-shot -- handler resumes twice', fn:
  expect run ƒink:
    {yield2, get_yield_value, get_yield_resume} = import 'std/effects.fnk'

    handler = fn body:
      y = body _
      v = get_yield_value y
      resume = get_yield_resume y
      a = resume 'first'
      b = resume 'second'
      'a=${a} b=${b} v=${v}'

    with handler:
      r = yield2 'asked'
      'got:${r}'

  | equals ":
    a=got:first b=got:second v=asked


# yield2 with a handler that ignores resume gives abort semantics --
# the value yield2 was called with becomes the with-block's value,
# nothing in body after yield2 runs.
test 'with: yield2 zero-shot equals abort -- value at body site', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    handler = fn body:
      y = body _
      get_yield_value y

    with handler:
      yield2 'aborted'
      42

  | equals ":
    aborted


test 'with: yield2 zero-shot from nested fn call in body', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    handler = fn body:
      y = body _
      'caught: ${get_yield_value y}'

    boom = fn:
      yield2 'deep'
      0

    with handler:
      boom _
      42

  | equals ":
    caught: deep


test 'with: yield2 zero-shot from inside match arm', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    handler = fn body:
      y = body _
      'caught: ${get_yield_value y}'

    with handler:
      match 'go':
        'go': yield2 'matched'
        _: 0
      42

  | equals ":
    caught: matched


# Userland `cancel` / `catch` defined as plain fink against yield2.
# Proves the library pattern: cancel is just `yield2 v`; catch is a
# handler that runs body and returns the cancelled value if body
# yielded, otherwise body's natural value.
test 'userland cancel/catch via yield2', fn:
  expect run ƒink:
    {yield2, get_yield_value} = import 'std/effects.fnk'

    cancel = fn v:
      yield2 v

    catch = fn body:
      y = body _
      get_yield_value y

    a = with catch:
      cancel 'short'
      'unreached'

    b = with catch:
      'normal'

    '${a}/${b}'

  | equals ":
    short/normal


# -- ctx flow through with --------------------------------------------
#
# ctx is monotonic-forward: never travels backward across a
# continuation. Each test builds a trace string by chaining set_ctx
# calls so the final ctx records the path control flowed through.

# Body sets ctx, returns naturally. Handler reads ctx via `body _` --
# but ctx flows through k_outer, not through the handler's caller-ctx,
# so the handler sees the ctx body had at return. After with, ctx is
# what the handler's tail-return produced.
test 'with: ctx set in handler (no body call) persists', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    handler = fn _:
      set_ctx 'H'

    set_ctx 'pre'
    with handler:
      42
    get_ctx _

  | equals ":
    H


test 'with: ctx set in body (handler discards) persists', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    handler = fn body:
      body _

    set_ctx 'pre'
    with handler:
      set_ctx 'B'
    get_ctx _

  | equals ":
    B


test 'with: ctx set in body persists past handler return', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    handler = fn body:
      body _
      set_ctx '${get_ctx _}/H'

    set_ctx 'pre'
    with handler:
      set_ctx 'B'
    get_ctx _

  | equals ":
    B/H


# Body sets ctx, yield2s, handler resumes. After resume, body runs
# more code that reads ctx and yields it again. Proves ctx flows
# forward through the yield2/resume hop. resume gets a dummy value
# rather than `_` -- passing `_` as a resume arg surfaces an unrelated
# arg-shape bug.
test 'with: ctx flows through yield2 and resume', fn:
  expect run ƒink:
    {set_ctx, get_ctx, yield2, get_yield_value, get_yield_resume} = import 'std/effects.fnk'

    handler = fn body:
      y1 = body _
      v1 = get_yield_value y1
      r1 = get_yield_resume y1
      y2 = r1 'go'
      v2 = get_yield_value y2
      '${v1}->${v2}'

    set_ctx 'A'
    with handler:
      yield2 get_ctx _
      set_ctx '${get_ctx _}/post-resume'
      yield2 get_ctx _

  | equals ":
    A->A/post-resume


# -- stored/late resume -----------------------------------------------
#
# Handler returns the captured resume in a rec; outer code fires resume
# AFTER the with-block has already returned. Proves the cont survives
# past handler completion -- the foundation for await/scheduler shapes
# where resumes get parked in queues for later.
test 'with: handler returns resume, outer fires it later', fn:
  expect run ƒink:
    {set_ctx, get_ctx, yield2, get_yield_value, get_yield_resume} = import 'std/effects.fnk'

    handler = fn body:
      y = body _
      v = get_yield_value y
      r = get_yield_resume y
      {value: v, resume: r}

    set_ctx 'pre'
    parked = with handler:
      r = yield2 'paused'
      'final: ${r} ctx=${get_ctx _}'

    set_ctx 'between'
    after = parked.resume 'fired-later'
    '${parked.value} | ${after} | outer-ctx=${get_ctx _}'

  | equals ":
    paused | final: fired-later ctx=between | outer-ctx=between


test 'yield2 with no enclosing with traps', fn:
  expect run ƒink:
    {yield2} = import 'std/effects.fnk'
    yield2 42

  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:  <unknown>!std/effects.wat:yield2_apply: wasm trap: null reference


# Two sequential yield2 calls in body, each producing a distinct
# resume captured by the handler. Both fire in sequence and body
# threads two values through to the final expression.
test 'with: two sequential yield2 in body', fn:
  expect run ƒink:
    {yield2, get_yield_resume} = import 'std/effects.fnk'

    handler = fn body:
      r1 = body _
      resume1 = get_yield_resume r1
      r2 = resume1 'tick-1'
      resume2 = get_yield_resume r2
      resume2 'tick-2'

    with handler:
      a = yield2 'first'
      b = yield2 'second'
      '${a}/${b}'

  | equals ":
    tick-1/tick-2


# Userland scheduler over yield2: a recursive `drive` loop dequeues
# tasks from a ctx-held queue, fires each task's `resume`, and either
# re-enqueues the fresh resume on a yield or drops it on natural
# return. This shape stresses the lifting pass: the deeply destructured
# patterns + nested match + tail recursion produce CPS trees that take
# 20+ rounds of one-level hoisting to flatten. Earlier this hit the
# MAX_ROUNDS=20 panic and forced users to manually split `drive` into
# multiple smaller fns. Keep this test as a regression bound -- if the
# pass starts taking many more rounds for ordinary scheduler code,
# something is wrong.
test 'userland scheduler over yield2 -- single-fn drive loop', fn:
  expect run ƒink:
    {yield2, get_yield_resume, is_yield, get_ctx, set_ctx} = import 'std/effects.fnk'

    dequeue = fn:
      {queue: [task, ..rest]} = get_ctx _
      set_ctx {queue: rest}
      task

    enqueue = fn task:
      {queue} = get_ctx _
      set_ctx {queue: [..queue, task]}

    has_tasks = fn:
      match get_ctx _:
        {queue: []}: false
        _: true

    drive = fn cntr:
      match has_tasks _:
        true:
          {resume, ..task} = dequeue _
          res = resume 'tick'
          match is_yield res:
            true:
              fresh = get_yield_resume res
              enqueue {..task, resume: fresh}
            false: cntr
          drive cntr + 1
        false: cntr

    handler = fn body:
      set_ctx {queue: []}
      r = body _
      enqueue {resume: get_yield_resume r}
      drive 0

    v = with handler:
      yield2 'A'
      yield2 'B'
      'done'
    '${v}'

  | equals ":
    2


# SKIPPED: substrate gap of the untagged yield2 substrate. Body
# returns a closure containing yield2; outer code calls the closure
# after the with-block has exited. Untagged yield2 can't find its
# destination (no frame in ctx, and no way to re-install one from a
# fresh fn call). The tagged-op substrate (perform_op + bind_chain)
# solves this -- see the with_invoke2 tests below.
skip test 'with: body returns yield-fn, called after with exits', fn:
  expect run ƒink:
    {yield2} = import 'std/effects.fnk'

    handler = fn body:
      body _

    parked = with handler:
      fn: yield2 'late'

    parked _

  | equals ":
    late


# -- tagged-op substrate (perform_op / with_invoke2) ----------------
#
# Five primitives:
#   with_invoke2 op_id handler body_fn
#   perform_op op_id value
#   get_resume / get_block_rerun / get_block_return
#   rethrow value           -- forwards current op to outer same-id handler
#   bind_chain fn           -- captures the chain into a closure
#
# Op ids are fink integer literals; tagging means a chain walk
# routes each op to the right handler regardless of nesting.

test 'tagged-op: single handler resumes', fn:
  expect run ƒink:
    {with_invoke2, perform_op, get_resume} = import 'std/effects.fnk'

    pause = fn v: perform_op 1, v
    handler = fn v:
      resume = get_resume _
      resume v + 100

    v = with_invoke2 1, handler, fn:
      r = pause 5
      r

    '${v}'

  | equals ":
    105


test 'tagged-op: block_return exits the with-block', fn:
  expect run ƒink:
    {with_invoke2, perform_op, get_block_return} = import 'std/effects.fnk'

    oops = fn v: perform_op 1, v
    handler = fn v:
      block_return = get_block_return _
      block_return 'caught-${v}'

    v = with_invoke2 1, handler, fn:
      oops 'boom'
      'unreached'

    '${v}'

  | equals ":
    caught-boom


test 'tagged-op: nested handlers with different op ids', fn:
  expect run ƒink:
    {with_invoke2, perform_op, get_resume} = import 'std/effects.fnk'

    pause = fn v: perform_op 1, v
    log = fn v: perform_op 2, v

    handle_pause = fn v:
      resume = get_resume _
      resume 'pause-${v}'

    handle_log = fn v:
      resume = get_resume _
      resume 'log-${v}'

    v = with_invoke2 2, handle_log, fn:
      with_invoke2 1, handle_pause, fn:
        a = pause 'A'
        b = log 'B'
        '${a}/${b}'

    v

  | equals ":
    pause-A/log-B


test 'tagged-op: nested same op id -- inner catches', fn:
  expect run ƒink:
    {with_invoke2, perform_op, get_block_return} = import 'std/effects.fnk'

    pause = fn v: perform_op 1, v

    outer = fn v:
      block_return = get_block_return _
      block_return 'outer-${v}'

    inner = fn v:
      block_return = get_block_return _
      block_return 'inner-${v}'

    v = with_invoke2 1, outer, fn:
      with_invoke2 1, inner, fn:
        pause 'X'

    v

  | equals ":
    inner-X


test 'tagged-op: rethrow forwards to outer same-id handler', fn:
  expect run ƒink:
    {with_invoke2, perform_op, rethrow, get_block_return} = import 'std/effects.fnk'

    pause = fn v: perform_op 1, v

    outer = fn v:
      block_return = get_block_return _
      block_return 'outer-${v}'

    # inner forwards via rethrow (which terminates this handler).
    inner = fn v: rethrow '${v}-fwd'

    v = with_invoke2 1, outer, fn:
      with_invoke2 1, inner, fn:
        pause 'X'

    v

  | equals ":
    outer-X-fwd


test 'tagged-op: fresh fn called from inside handler reaches same handler', fn:
  expect run ƒink:
    {with_invoke2, perform_op, get_resume, get_block_return} = import 'std/effects.fnk'

    pause = fn v: perform_op 1, v
    helper = fn n: pause n

    handler = fn v:
      match v:
        'go':
          # Grab block_return BEFORE calling helper -- once helper's
          # pause fires and gets resumed, our current_op is cleared.
          br = get_block_return _
          v_inner = helper 'inner'
          br v_inner
        _:
          # Inner pause's handler: helper's pause routes here. Resume
          # with the cooked value so helper's pause expression
          # evaluates to it.
          resume = get_resume _
          resume '${v}-handled'

    v = with_invoke2 1, handler, fn:
      pause 'go'

    v

  | equals ":
    inner-handled


# -- suspend (raw cont capture, no handler) ---------------------------
#
# `suspend _` is the lowest-level cont primitive: it captures the
# caller's continuation and returns it as a closure. Calling the
# closure with v re-enters at the suspension point, with the
# `suspend _` expression evaluating to v. No frame, no chain walk
# -- raw delimited cont capture.

# Round-trip: suspend, call cont once with a new value, observe
# control returning. Phase guard avoids infinite loop on re-entry.
test 'suspend: round-trip via captured cont', fn:
  expect run ƒink:
    {suspend, set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx {phase: 'before'}
    r = suspend _
    {phase} = get_ctx _
    match phase:
      'before':
        set_ctx {phase: 'after'}
        r 'fired'
      _: 'final-${r}'

  | equals ":
    final-fired


# The first evaluation of `suspend _` returns the cont closure (a
# fn value), distinct from any later value the cont is fired with.
test 'suspend: first pass returns a closure, second pass receives the value', fn:
  expect run ƒink:
    {suspend, set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx {phase: 'first'}
    v = suspend _
    {phase} = get_ctx _
    match phase:
      'first':
        # v is a closure; fire it with 'payload'
        set_ctx {phase: 'second'}
        v 'payload'
      _:
        # v is now the fired value
        'got: ${v}'

  | equals ":
    got: payload


# Cont can be fired multiple times -- each fire re-enters the
# suspension point fresh. The cont closure must be stashed in ctx
# on first pass (re-entry overwrites `r` with the fired value).
test 'suspend: cont can be fired more than once', fn:
  expect run ƒink:
    {suspend, set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx {count: 0, results: [], k: false}
    r = suspend _
    {count, results, k} = get_ctx _
    match count:
      0:
        # r is the cont -- stash it; fire with first payload.
        set_ctx {count: 1, results: [..results, 'init'], k: r}
        r 'a'
      1:
        # k holds the cont; r is 'a'. Fire k again with 'b'.
        set_ctx {count: 2, results: [..results, r], k}
        k 'b'
      _:
        # r is 'b'. Final pass.
        new_results = [..results, r]
        '${new_results}'

  | equals ":
    ['init', 'a', 'b']

