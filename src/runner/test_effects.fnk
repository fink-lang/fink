{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'set_ctx threads new universe forward', fn:
  expect run ƒink:
    {set_ctx} = import 'std/effects.fnk'
    set_ctx 'first'
    set_ctx 'second'
  | equals ":
    first


test 'set_ctx survives a builtin op in between', fn:
  expect run ƒink:
    {set_ctx} = import 'std/effects.fnk'
    set_ctx 'foo'
    x = 1 + 2
    set_ctx 'bar ${x}'
  | equals ":
    foo


test 'ctx set in outer scope reads in nested fn', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    # we don't know what the starting point is, 42?
    set_ctx 1

    ni = set_ctx 1

    inner = fn foo:
      x = set_ctx foo + 1
      x

    inner ni
    get_ctx _
  | equals ƒink:
    2


# -- ctx passthrough across runtime boundaries -----------------------
#
# These tests pin down that ctx survives every place where a cont gets
# suspended and later resumed by the runtime: yield, channel I/O, await,
# host stdout. Each test sets a sentinel ctx, crosses the boundary, then
# reads ctx back on the other side -- if any thunk/Waiter on the path
# drops ctx, the resumed value will be the previous (default) ctx
# instead of the sentinel.

test 'ctx survives yield/resume', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'
    set_ctx 'yielded'
    yield 0
    get_ctx _
  | equals ":
    yielded


test 'ctx survives channel receive', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    ch = channel 0
    spawn fn:
      'msg' >> ch

    set_ctx 'receiver-ctx'
    receive ch
    get_ctx _
  | equals ":
    receiver-ctx


test 'ctx survives await of spawned task', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    fut = spawn fn:
      42

    set_ctx 'awaiter-ctx'
    await fut
    get_ctx _
  | equals ":
    awaiter-ctx


test 'ctx survives stdout write', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'writer-ctx'
    write stdout, ''
    get_ctx _
  | equals ":
    writer-ctx


# A spawned task body now runs under the SPAWNER's ctx (we captured it
# in $_spawn_task_fn's captures).
test 'spawned task body inherits spawner ctx', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'spawner-ctx'
    fut = spawn fn:
      get_ctx _

    await fut
  | equals ":
    spawner-ctx


# Protocols dispatchers (op_plus etc.) forward ctx to their cont without
# consulting it for dispatch. After an arbitrary numeric op chain, ctx
# should still be the caller's.
test 'ctx survives arithmetic chain', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'math-ctx'
    foo = 1 + 2 * 3 - 4
    get_ctx _
  | equals ":
    math-ctx


# Pattern match arms are CPS conts under the hood; ctx must survive
# match dispatch.
test 'ctx survives match', fn:
  expect run ƒink:
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'match-ctx'
    match 'x':
      'x': 1
      _: 0
    get_ctx _
  | equals ":
    match-ctx


# Channel I/O via the host bridge (HostChannel) — write goes through
# interop_channel_send. ctx should survive that too.
test 'ctx survives stderr write', fn:
  expect run ƒink:
    {stderr, write} = import 'std/io.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'stderr-ctx'
    write stderr, ''
    get_ctx _
  | equals ":
    stderr-ctx


# std/math.wat's per-fn closures (abs, sqrt, sin, cos, log, ...) now
# forward the caller's ctx into apply_1 — previously they discarded it.
test 'ctx survives sqrt', fn:
  expect run ƒink:
    {sqrt} = import 'std/math.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'math-fn-ctx'
    sqrt 16.0
    get_ctx _
  | equals ":
    math-fn-ctx


# -- KNOWN ctx-drop sites ----------------------------------------------
#
# Verified gaps that fail today. Skipped so they don't break CI but
# stay visible for the next ctx-threading pass. Un-skip to reproduce.


# `repr x` and `fmt x` as user-imported fns. The bare-@impl wrapper in
# the .wat file returns a no-capture $Closure; the user-import binding
# receives the closure value; apply_3 dispatches with caller's ctx.
test 'ctx survives repr', fn:
  expect run ƒink:
    {repr} = import 'std/repr.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'repr-ctx'
    repr 42
    get_ctx _
  | equals ":
    repr-ctx


# `fmt x` as a direct user-imported call (not template-string interp,
# which goes through the StrFmt builtin sym path with ctx threaded).
test 'ctx survives fmt as imported fn', fn:
  expect run ƒink:
    {fmt} = import 'std/str.fnk'
    {set_ctx, get_ctx} = import 'std/effects.fnk'

    set_ctx 'fmt-ctx'
    fmt 42
    get_ctx _
  | equals ":
    fmt-ctx


# `abort` with no enclosing `with` traps -- there's no frame to jump
# to. The future interop wrapper will install a root frame so this
# becomes unreachable in practice.

test 'abort with no enclosing with traps', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'
    abort 42

  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:  <unknown>!std/effects.wat:frame_pop
        1:  <unknown>!std/effects.wat:abort_apply: wasm trap: null reference


# -- with-block (substrate) -------------------------------------------
#
# `with H: B` lowers to with_invoke(ctx, H, body_fn, k_outer). The
# runtime invokes H with [k_outer, wrapped_body]. H is a
# `fn body: ...` handler; when it calls `body args`, the wrapper
# pushes a frame holding the body-call cont, then runs B. When B
# returns normally OR aborts, control lands at the same place: the
# handler's `body args` call site, with the value. Handler is always
# re-entered uniformly -- can run cleanup, transform the value, or
# decide what the block evaluates to.

test 'with: reader handler returns body value', fn:
  expect run ƒink:
    handler = fn body:
      body 0

    with handler:
      42

  | equals ƒink:
    42


test 'with: handler ignoring body returns its own value', fn:
  expect run ƒink:
    handler = fn _: 'handler-result'

    with handler:
      'body-result'

  | equals ":
    handler-result


test 'with: abort in body lands at handler body-call site', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      body 0

    with handler:
      abort 'aborted'
      42

  | equals ":
    aborted


# Handler resumes at `body 0` site after abort, runs cleanup, then
# returns its own transformed value. Proves abort lands *inside* the
# handler, not at k_outer directly.
test 'with: handler transforms aborted value after cleanup', fn:
  expect run ƒink:
    {abort} = import 'std/effects.fnk'

    handler = fn body:
      result = body 0
      'wrapped: ${result}'

    with handler:
      abort 'inner'
      42

  | equals ":
    wrapped: inner


