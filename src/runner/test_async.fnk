{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


# Userland scheduler in pure fink against the yield2 substrate.
# Slice 1: cooperative `pause` in a single-body, single-yield context.
# Multi-yield + spawn need a different scheduler shape and are tracked
# separately.

test 'async slice 1: body with no yields returns its value', fn:
  expect run ƒink:
    {run} = import './test_modules/async.fnk'

    run fn:
      42

  | equals ƒink:
    42


test 'async slice 1: body yields once then returns', fn:
  expect run ƒink:
    {run, pause} = import './test_modules/async.fnk'

    run fn:
      pause _
      'done'

  | equals ":
    done
