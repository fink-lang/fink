{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
Scratch fixture for the new IR pipeline's `run` harness
(`src/runner/ir.rs`). Holds tests that belong in the shared
`test_operators.fnk` / `test_bindings.fnk` / ... fixture set but
whose home file isn't `include_fink_tests!`'d into `ir.rs` yet.
As each shared fixture gets included (with appropriate `skip-ir`
tags), tests migrate out of here. Retires when empty.
---


test 'ir: int sum', fn:
  expect run ƒink:
    42 + 123
  | equals ƒink:
    165


# TODO - remove once other tests cover ..rest usecase
test 'ir: spread param', fn:
  expect run ƒink:
    first = fn a, ..rest:
      a
    first 10, 20, 30
  | equals ƒink:
    10
