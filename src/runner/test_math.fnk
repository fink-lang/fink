  | equals ƒink:
    1

test 'math tan zero', fn:
  expect run ƒink:
    {tan} = import 'std/math.fnk'
    tan 0.0
  | equals ƒink:
    0

skip test 'math asin zero', fn:
  expect run ƒink:
    {asin} = import 'std/math.fnk'
    asin 0.0
  | equals ƒink:
    0

skip test 'math acos one', fn:
  expect run ƒink:
    {acos} = import 'std/math.fnk'
    acos 1.0
  | equals ƒink:
    0

skip test 'math atan zero', fn:
  expect run ƒink:
    {atan} = import 'std/math.fnk'
    atan 0.0
  | equals ƒink:
    0

skip test 'math atan2 zero zero', fn:
  expect run ƒink:
    {atan2} = import 'std/math.fnk'
    atan2 0.0, 1.0
  | equals ƒink:
    0


# --- hyperbolic ---

test 'math sinh zero', fn:
  expect run ƒink:
    {sinh} = import 'std/math.fnk'
    sinh 0.0
  | equals ƒink:
    0

test 'math cosh zero', fn:
  expect run ƒink:
    {cosh} = import 'std/math.fnk'
    cosh 0.0
  | equals ƒink:
    1

test 'math tanh zero', fn:
  expect run ƒink:
    {tanh} = import 'std/math.fnk'
    tanh 0.0
  | equals ƒink:
    0

