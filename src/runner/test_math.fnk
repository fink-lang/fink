{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


# TODO open follow-ups for std/math:
#   - Naming: `fract` vs `frac`; `neg` shadows unary `-` operator's role.
#   - `clamp x, lo..hi` form using a `$Range` second arg — blocked on
#     `$Range` over floats.


# --- abs ---

test 'math abs positive', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs 3.5
  | equals ƒink:
    3.5

test 'math abs negative', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs (-3.5)
  | equals ƒink:
    3.5

test 'math abs zero', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs 0.0
  | equals ƒink:
    0


# --- neg ---

test 'math neg positive', fn:
  expect run ƒink:
    {neg} = import 'std/math.fnk'
    neg 4.0
  | equals ƒink:
    -4

test 'math neg negative', fn:
  expect run ƒink:
    {neg} = import 'std/math.fnk'
    neg (-4.0)
  | equals ƒink:
    4


# --- ceil / floor / trunc / round ---

test 'math ceil positive fractional', fn:
  expect run ƒink:
    {ceil} = import 'std/math.fnk'
    ceil 3.2
  | equals ƒink:
    4

test 'math ceil negative fractional', fn:
  expect run ƒink:
    {ceil} = import 'std/math.fnk'
    ceil (-3.2)
  | equals ƒink:
    -3

test 'math floor positive fractional', fn:
  expect run ƒink:
    {floor} = import 'std/math.fnk'
    floor 3.7
  | equals ƒink:
    3

test 'math floor negative fractional', fn:
  expect run ƒink:
    {floor} = import 'std/math.fnk'
    floor (-3.2)
  | equals ƒink:
    -4

test 'math trunc positive', fn:
  expect run ƒink:
    {trunc} = import 'std/math.fnk'
    trunc 3.9
  | equals ƒink:
    3

test 'math trunc negative', fn:
  expect run ƒink:
    {trunc} = import 'std/math.fnk'
    trunc (-3.9)
  | equals ƒink:
    -3

test 'math round half away from zero positive', fn:
  expect run ƒink:
    {round} = import 'std/math.fnk'
    round 2.5
  | equals ƒink:
    3

test 'math round half away from zero negative', fn:
  expect run ƒink:
    {round} = import 'std/math.fnk'
    round (-2.5)
  | equals ƒink:
    -3

test 'math round normal up', fn:
  expect run ƒink:
    {round} = import 'std/math.fnk'
    round 3.7
  | equals ƒink:
    4

test 'math round normal down', fn:
  expect run ƒink:
    {round} = import 'std/math.fnk'
    round 3.2
  | equals ƒink:
    3


# --- round_even (banker's / IEEE half-to-even) ---

test 'math round_even half down to even', fn:
  expect run ƒink:
    {round_even} = import 'std/math.fnk'
    round_even 2.5
  | equals ƒink:
    2

test 'math round_even half up to even', fn:
  expect run ƒink:
    {round_even} = import 'std/math.fnk'
    round_even 3.5
  | equals ƒink:
    4

test 'math round_even normal up', fn:
  expect run ƒink:
    {round_even} = import 'std/math.fnk'
    round_even 3.7
  | equals ƒink:
    4


# --- sqrt ---

test 'math sqrt positive', fn:
  expect run ƒink:
    {sqrt} = import 'std/math.fnk'
    sqrt 9.0
  | equals ƒink:
    3

test 'math sqrt of zero', fn:
  expect run ƒink:
    {sqrt} = import 'std/math.fnk'
    sqrt 0.0
  | equals ƒink:
    0


# --- sign ---

test 'math sign positive', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 42.0
  | equals ƒink:
    1

test 'math sign negative', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign (-42.0)
  | equals ƒink:
    -1

test 'math sign zero', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 0.0
  | equals ƒink:
    0


# --- fract ---

test 'math fract positive', fn:
  expect run ƒink:
    {fract} = import 'std/math.fnk'
    fract 3.25
  | equals ƒink:
    0.25

test 'math fract negative', fn:
  expect run ƒink:
    {fract} = import 'std/math.fnk'
    fract (-3.25)
  | equals ƒink:
    -0.25


# --- min / max ---

test 'math min picks lesser', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 1.5, 2.5
  | equals ƒink:
    1.5

test 'math min picks lesser swapped', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 2.5, 1.5
  | equals ƒink:
    1.5

test 'math max picks greater', fn:
  expect run ƒink:
    {max} = import 'std/math.fnk'
    max 1.5, 2.5
  | equals ƒink:
    2.5

test 'math max picks greater swapped', fn:
  expect run ƒink:
    {max} = import 'std/math.fnk'
    max 2.5, 1.5
  | equals ƒink:
    2.5

test 'math min single arg', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 7.5
  | equals ƒink:
    7.5

test 'math min many args', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 5.5, 1.5, 3.5, 2.5, 4.5
  | equals ƒink:
    1.5

test 'math max many args', fn:
  expect run ƒink:
    {max} = import 'std/math.fnk'
    max 1.5, 5.5, 3.5, 2.5, 4.5
  | equals ƒink:
    5.5


# --- copysign ---

test 'math copysign positive magnitude positive sign', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign 3.0, 2.0
  | equals ƒink:
    3

test 'math copysign positive magnitude negative sign', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign 3.0, -2.0
  | equals ƒink:
    -3

test 'math copysign negative magnitude positive sign', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign -3.0, 2.0
  | equals ƒink:
    3


# --- clamp ---

test 'math clamp within range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0.0, 5.0, 10.0
  | equals ƒink:
    5

test 'math clamp below range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0.0, (-3.0), 10.0
  | equals ƒink:
    0

test 'math clamp above range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0.0, 15.0, 10.0
  | equals ƒink:
    10


# ===========================================================================
# Polymorphic dispatch across $Num — int / uint / mixed-family cases.
# Skipped tests track impl follow-ups; un-skip as each lands.
# ===========================================================================

# --- abs on Int ---

test 'math abs int positive', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs 7
  | equals ƒink:
    7

test 'math abs int negative', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs (-7)
  | equals ƒink:
    7

test 'math abs uint identity', fn:
  expect run ƒink:
    {abs} = import 'std/math.fnk'
    abs 0xff
  | equals ƒink:
    255


# --- neg on Int ---

test 'math neg int positive', fn:
  expect run ƒink:
    {neg} = import 'std/math.fnk'
    neg 5
  | equals ƒink:
    -5

test 'math neg int negative', fn:
  expect run ƒink:
    {neg} = import 'std/math.fnk'
    neg (-5)
  | equals ƒink:
    5

# Negating a $U64 has no signed result — trap (bits family has no sign).
test 'math neg uint traps', fn:
  expect run ƒink:
    {neg} = import 'std/math.fnk'
    neg 0xff
  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:  <unknown>!std/int.wat:neg
        1:  <unknown>!std/math.wat:_neg_apply: wasm trap: wasm `unreachable` instruction executed


# --- sign on Int ---

test 'math sign int positive', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 42
  | equals ƒink:
    1

test 'math sign int negative', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign (-42)
  | equals ƒink:
    -1

test 'math sign int zero', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 0
  | equals ƒink:
    0

test 'math sign uint zero', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 0x0
  | equals ƒink:
    0

test 'math sign uint nonzero', fn:
  expect run ƒink:
    {sign} = import 'std/math.fnk'
    sign 0xff
  | equals ƒink:
    1


# --- floor / ceil / trunc / round / round_even / fract on Int → identity ---

test 'math floor int identity', fn:
  expect run ƒink:
    {floor} = import 'std/math.fnk'
    floor 7
  | equals ƒink:
    7

test 'math ceil int identity', fn:
  expect run ƒink:
    {ceil} = import 'std/math.fnk'
    ceil 7
  | equals ƒink:
    7

test 'math trunc int identity', fn:
  expect run ƒink:
    {trunc} = import 'std/math.fnk'
    trunc 7
  | equals ƒink:
    7

test 'math round int identity', fn:
  expect run ƒink:
    {round} = import 'std/math.fnk'
    round 7
  | equals ƒink:
    7

test 'math round_even int identity', fn:
  expect run ƒink:
    {round_even} = import 'std/math.fnk'
    round_even 7
  | equals ƒink:
    7

test 'math fract int zero', fn:
  expect run ƒink:
    {fract} = import 'std/math.fnk'
    fract 7
  | equals ƒink:
    0


# --- min / max on Int ---

test 'math min int picks lesser', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 3, 7
  | equals ƒink:
    3

test 'math max int picks greater', fn:
  expect run ƒink:
    {max} = import 'std/math.fnk'
    max 3, 7
  | equals ƒink:
    7

test 'math min int many args', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 5, 1, 3, 2, 4
  | equals ƒink:
    1

# U64 comparisons use unsigned ordering (bits-family).
test 'math min uint unsigned ordering', fn:
  expect run ƒink:
    {min} = import 'std/math.fnk'
    min 0x1, 0xff
  | equals ƒink:
    1


# --- copysign on Int ---

test 'math copysign int positive magnitude positive sign', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign 3, 2
  | equals ƒink:
    3

test 'math copysign int positive magnitude negative sign', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign 3, -2
  | equals ƒink:
    -3

test 'math copysign uint traps', fn:
  expect run ƒink:
    {copysign} = import 'std/math.fnk'
    copysign 0x3, 0x2
  | equals ":
    ERROR: entry wrapper: error while executing at wasm backtrace:
        0:  <unknown>!std/int.wat:copysign
        1:  <unknown>!std/math.wat:_copysign_apply: wasm trap: wasm `unreachable` instruction executed


# --- clamp on Int ---

test 'math clamp int within range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0, 5, 10
  | equals ƒink:
    5

test 'math clamp int below range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0, -3, 10
  | equals ƒink:
    0

test 'math clamp int above range', fn:
  expect run ƒink:
    {clamp} = import 'std/math.fnk'
    clamp 0, 15, 10
  | equals ƒink:
    10


# ===========================================================================
# Tier 2 — transcendentals (libm port).
# All skipped while libm.wat stubs trap. Un-skip per function as it lands.
# Reference values are bit-exact from rust-lang/libm.
# ===========================================================================

# --- exp / log ---

test 'math exp zero', fn:
  expect run ƒink:
    {exp} = import 'std/math.fnk'
    exp 0.0
  | equals ƒink:
    1

# exp 1 is irrational; correct-rounded e ≈ 2.718281828459045. Our
# faithfully-rounded impl returns 1 ulp higher (2.7182818284590455).
# Fine for our precision target (~1 ulp).
test 'math exp one', fn:
  expect run ƒink:
    {exp} = import 'std/math.fnk'
    exp 1.0
  | equals ƒink:
    2.7182818284590455

test 'math exp2 zero', fn:
  expect run ƒink:
    {exp2} = import 'std/math.fnk'
    exp2 0.0
  | equals ƒink:
    1

test 'math exp2 ten', fn:
  expect run ƒink:
    {exp2} = import 'std/math.fnk'
    exp2 10.0
  | equals ƒink:
    1024

test 'math expm1 zero', fn:
  expect run ƒink:
    {expm1} = import 'std/math.fnk'
    expm1 0.0
  | equals ƒink:
    0

test 'math log one', fn:
  expect run ƒink:
    {log} = import 'std/math.fnk'
    log 1.0
  | equals ƒink:
    0

test 'math log e', fn:
  expect run ƒink:
    {log} = import 'std/math.fnk'
    log 2.718281828459045
  | equals ƒink:
    1

test 'math log2 one', fn:
  expect run ƒink:
    {log2} = import 'std/math.fnk'
    log2 1.0
  | equals ƒink:
    0

test 'math log2 power of two', fn:
  expect run ƒink:
    {log2} = import 'std/math.fnk'
    log2 1024.0
  | equals ƒink:
    10

test 'math log10 one', fn:
  expect run ƒink:
    {log10} = import 'std/math.fnk'
    log10 1.0
  | equals ƒink:
    0

# log10 1000 should be exactly 3, but our log/ln10 division introduces 1 ulp
# of slop. Faithful precision; revisit if log10 gets a dedicated impl.
test 'math log10 power of ten', fn:
  expect run ƒink:
    {log10} = import 'std/math.fnk'
    log10 1000.0
  | equals ƒink:
    2.9999999999999996

test 'math log1p zero', fn:
  expect run ƒink:
    {log1p} = import 'std/math.fnk'
    log1p 0.0
  | equals ƒink:
    0


# --- pow / cbrt / hypot ---

skip test 'math pow square', fn:
  expect run ƒink:
    {pow} = import 'std/math.fnk'
    pow 3.0, 2.0
  | equals ƒink:
    9

skip test 'math pow zero exponent', fn:
  expect run ƒink:
    {pow} = import 'std/math.fnk'
    pow 5.0, 0.0
  | equals ƒink:
    1

test 'math cbrt cube', fn:
  expect run ƒink:
    {cbrt} = import 'std/math.fnk'
    cbrt 27.0
  | equals ƒink:
    3

test 'math cbrt negative', fn:
  expect run ƒink:
    {cbrt} = import 'std/math.fnk'
    cbrt (-27.0)
  | equals ƒink:
    -3

test 'math hypot 3 4 5', fn:
  expect run ƒink:
    {hypot} = import 'std/math.fnk'
    hypot 3.0, 4.0
  | equals ƒink:
    5


