{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'range exclusive formatting', fn:
  expect run ƒink:
    '${0..10}' == '0..10'
  | equals ƒink:
    true


test 'open range exclusive formatting', fn:
  expect run ƒink:
    '${0..}' == '0..'
  | equals ƒink:
    true


test 'range inclusive formatting', fn:
  expect run ƒink:
    '${0...10}' == '0...10'
  | equals ƒink:
    true


test 'range exclusive construction', fn:
  expect run ƒink:
    r = 2..5
    '${r}' == '2..5'
  | equals ƒink:
    true


test 'range inclusive construction', fn:
  expect run ƒink:
    r = 2...5
    '${r}' == '2...5'
  | equals ƒink:
    true


test 'range in exclusive', fn:
  expect run ƒink:
    5 in 0..10
  | equals ƒink:
    true


test 'range in exclusive upper bound', fn:
  expect run ƒink:
    10 in 0..10
  | equals ƒink:
    false


test 'range in open', fn:
  expect run ƒink:
    1000 in 0..
  | equals ƒink:
    true


test 'range not in open', fn:
  expect run ƒink:
    -1 in 0..
  | equals ƒink:
    false


test 'range in inclusive upper bound', fn:
  expect run ƒink:
    10 in 0...10
  | equals ƒink:
    true


test 'range not in', fn:
  expect run ƒink:
    20 not in 0..10
  | equals ƒink:
    true


test 'range match pattern', fn:
  expect run ƒink:
    x = 5
    match x:
      0..10: true
  | equals ƒink:
    true


# --- Structural equality ---
#
# Two ranges are equal iff same start, same end, same inclusivity.

test 'range equal', fn:
  expect run ƒink:
    (0..10) == (0..10)
  | equals ƒink:
    true

test 'range unequal end', fn:
  expect run ƒink:
    (0..10) == (0..11)
  | equals ƒink:
    false

test 'range unequal start', fn:
  expect run ƒink:
    (0..10) == (1..10)
  | equals ƒink:
    false

test 'range excl vs incl unequal', fn:
  expect run ƒink:
    (0..10) == (0...10)
  | equals ƒink:
    false

test 'range open equal', fn:
  expect run ƒink:
    (0..) == (0..)
  | equals ƒink:
    true

test 'range open vs closed unequal', fn:
  expect run ƒink:
    (0..) == (0..10)
  | equals ƒink:
    false

test 'range nested in rec equal', fn:
  expect run ƒink:
    {r: 0..10} == {r: 0..10}
  | equals ƒink:
    true

test 'range vs num not equal', fn:
  expect run ƒink:
    (0..10) == 5
  | equals ƒink:
    false

test 'range neq', fn:
  expect run ƒink:
    (0..10) != (0..11)
  | equals ƒink:
    true
