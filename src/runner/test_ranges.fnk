{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'range exclusive formatting', fn:
  expect run ƒink:
    '${0..10}' == '0..10'
  | equals ƒink:
    true


test 'range inclusive formatting', fn:
  expect run ƒink:
    '${0...10}' == '0...10'
  | equals ƒink:
    true


test 'range exclusive construction', fn:
  expect run ƒink:
    r = 2..5
    '${r}' == '2..5'
  | equals ƒink:
    true


test 'range inclusive construction', fn:
  expect run ƒink:
    r = 2...5
    '${r}' == '2...5'
  | equals ƒink:
    true


test 'range in exclusive', fn:
  expect run ƒink:
    5 in 0..10
  | equals ƒink:
    true


test 'range in exclusive upper bound', fn:
  expect run ƒink:
    10 in 0..10
  | equals ƒink:
    false


test 'range in inclusive upper bound', fn:
  expect run ƒink:
    10 in 0...10
  | equals ƒink:
    true


test 'range not in', fn:
  expect run ƒink:
    20 not in 0..10
  | equals ƒink:
    true


test 'range match pattern', fn:
  expect run ƒink:
    x = 5
    match x:
      0..10: true
  | equals ƒink:
    true
