{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


---
cooperative multitasking — yield, spawn, await, channels
---

test 'yield suspends and resumes', fn:
  expect run ƒink:
    main = fn:
      yield 0
      42
  | equals ƒink:
    42


test 'spawn and await', fn:
  expect run ƒink:
    main = fn:
      fut = spawn fn:
        42
      result = await fut
      result
  | equals ƒink:
    42


test 'channel send and receive', fn:
  expect run ƒink:
    main = fn:
      ch = channel 0
      send ch, 42
      msg = receive ch
      msg
  | equals ƒink:
    42


test 'channel with spawned sender', fn:
  expect run ƒink:
    main = fn:
      ch = channel 0
      spawn fn:
        send ch, 99
      msg = receive ch
      msg
  | equals ƒink:
    99


test 'channel multiple messages FIFO', fn:
  expect run ƒink:
    main = fn:
      ch = channel 0
      send ch, 1
      send ch, 2
      a = receive ch
      a
  | equals ƒink:
    1


test 'channel receiver waits for sender', fn:
  expect run ƒink:
    main = fn:
      ch = channel 0
      fut = spawn fn:
        receive ch
      send ch, 77
      result = await fut
      result
  | equals ƒink:
    77

