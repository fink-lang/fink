{test, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'literal', fn:
  expect run ƒink:
    main = fn:
      42
  | equals ":
    42


test 'let binding', fn:
  expect run ƒink:
    main = fn:
      x = 42
      x
  | equals ":
    42


test 'float literal', fn:
  expect run ƒink:
    main = fn:
      3.14
  | equals ":
    3.14


test 'let alias', fn:
  expect run ƒink:
    main = fn:
      x = 42
      y = x
      y
  | equals ":
    42


test 'add two literals', fn:
  expect run ƒink:
    main = fn:
      2 + 3
  | equals ":
    5


test 'subtraction', fn:
  expect run ƒink:
    main = fn:
      10 - 3
  | equals ":
    7


test 'multiplication', fn:
  expect run ƒink:
    main = fn:
      4 * 5
  | equals ":
    20


test 'division', fn:
  expect run ƒink:
    main = fn:
      10 / 4
  | equals ":
    2.5


test 'integer division', fn:
  expect run ƒink:
    main = fn:
      7 // 2
  | equals ":
    3


test 'modulo', fn:
  expect run ƒink:
    main = fn:
      10 %% 3
  | equals ":
    1


test 'bool literal true', fn:
  expect run ƒink:
    main = fn:
      true
  | equals ":
    true


test 'bool literal false', fn:
  expect run ƒink:
    main = fn:
      false
  | equals ":
    false


test 'equal', fn:
  expect run ƒink:
    main = fn:
      3 == 3
  | equals ":
    true


test 'not equal', fn:
  expect run ƒink:
    main = fn:
      3 != 4
  | equals ":
    true


test 'less than', fn:
  expect run ƒink:
    main = fn:
      3 < 4
  | equals ":
    true


test 'less than or equal', fn:
  expect run ƒink:
    main = fn:
      3 <= 3
  | equals ":
    true


test 'greater than', fn:
  expect run ƒink:
    main = fn:
      4 > 3
  | equals ":
    true


test 'greater than or equal', fn:
  expect run ƒink:
    main = fn:
      3 >= 3
  | equals ":
    true


test 'not', fn:
  expect run ƒink:
    main = fn:
      not true
  | equals ":
    false


test 'and', fn:
  expect run ƒink:
    main = fn:
      true and false
  | equals ":
    false


test 'or', fn:
  expect run ƒink:
    main = fn:
      true or false
  | equals ":
    true


test 'xor', fn:
  expect run ƒink:
    main = fn:
      true xor true
  | equals ":
    false


test 'chained arithmetic', fn:
  expect run ƒink:
    main = fn:
      x = 2 * 3
      x + 4
  | equals ":
    10


test 'multiple let bindings', fn:
  expect run ƒink:
    main = fn:
      x = 2
      y = 3
      x + y
  | equals ":
    5


test 'nested chains', fn:
  expect run ƒink:
    main = fn:
      x = 2 + 3
      y = x * 2
      y - 1
  | equals ":
    9


test 'chain with bool', fn:
  expect run ƒink:
    main = fn:
      x = 3 > 2
      x and true
  | equals ":
    true


test 'pipe with fn call', fn:
  expect run ƒink:
    add = fn a, b: a + b
    main = fn:
      2
      | add 3, ?
  | equals ":
    5


test 'match literal first arm', fn:
  expect run ƒink:
    main = fn:
      match 0:
        0: 42
        _: 99
  | equals ":
    42


test 'match literal second arm', fn:
  expect run ƒink:
    main = fn:
      match 1:
        0: 42
        _: 99
  | equals ":
    99


test 'match wildcard binding', fn:
  expect run ƒink:
    main = fn:
      match 5:
        0: 0
        x: x + 1
  | equals ":
    6


test 'factorial', fn:
  expect run ƒink:
    fac = fn n:
      match n:
        0: 1
        n: n * fac n - 1
    main = fn:
      fac 5
  | equals ":
    120


test 'add list items', fn:
  expect run ƒink:
    sum = fn items, c:
      match items:
        []: c
        [a, ..rest]: sum rest, c + a

    main = fn:
      sum [1, 2, 3, 4], 0

  | equals ":
    10


test 'string literal', fn:
  expect run ƒink:
    main = fn:
      'hello'
  | equals ":
    hello

test 'string escape newline', fn:
  expect run ƒink:
    main = fn:
      'hello\nworld'
  | equals ":
    hello
    world

test 'string escape tab', fn:
  expect run ƒink:
    main = fn:
      'a\tb'
  | equals ":
    a	b

test 'string escape backslash', fn:
  expect run ƒink:
    main = fn:
      'a\\b'
  | equals ":
    a\b

test 'string escape hex', fn:
  expect run ƒink:
    main = fn:
      '\xE9'
  | equals ":
    é

test 'string escape unicode', fn:
  expect run ƒink:
    main = fn:
      '\u{1F600}'
  | equals ":
    😀

test 'string eq same', fn:
  expect run ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ":
    true


test 'string eq different', fn:
  expect run ƒink:
    main = fn:
      'hello' == 'world'
  | equals ":
    false


test 'string neq', fn:
  expect run ƒink:
    main = fn:
      'hello' != 'world'
  | equals ":
    true


test 'str template string only', fn:
  expect run ƒink:
    main = fn:
      name = 'world'
      'hello ${name}' == 'hello world'
  | equals ƒink:
    true


test 'str template with number', fn:
  expect run ƒink:
    main = fn:
      x = 42
      'value: ${x}' == 'value: 42'
  | equals ƒink:
    true


test 'str template with bool', fn:
  expect run ƒink:
    main = fn:
      'done: ${true}' == 'done: true'
  | equals ƒink:
    true


test 'str template multiple segments', fn:
  expect run ƒink:
    main = fn:
      a = 1
      b = 2
      '${a} + ${b} = ${a + b}' == '1 + 2 = 3'
  | equals ƒink:
    true


test 'str template with float', fn:
  expect run ƒink:
    main = fn:
      'pi: ${3.14}' == 'pi: 3.14'
  | equals ƒink:
    true


test 'str template float arithmetic', fn:
  expect run ƒink:
    main = fn:
      x = 1.5
      y = 2.3
      '${x} + ${y} = ${x + y}' == '1.5 + 2.3 = 3.8'
  | equals ƒink:
    true


test 'rec destructure', fn:
  expect run ƒink:
    main = fn:
      {a, b: c} = {a: 1, b: 2}
      a + c
  | equals ƒink:
    3


test 'varargs first', fn:
  expect run ƒink:
    first = fn ..args:
      match args:
        [a, ..]: a

    main = fn:
      first ..[42, 99]
  | equals ƒink:
    42


test 'varargs identity', fn:
  expect run ƒink:
    identity = fn ..args: args

    main = fn:
      match (identity ..[10, 20, 30]):
        [a, ..]: a
  | equals ƒink:
    10


test 'tagged template varargs', fn:
  expect run ƒink:
    first = fn ..parts:
      match parts:
        [a, ..]: a

    main = fn:
      x = 42
      y = first'hello ${x} world'
      y == 'hello '
  | equals ƒink:
    true


test 'varargs mixed fixed and rest', fn:
  expect run ƒink:
    head-and-rest = fn a, ..rest:
      match rest:
        [b, ..]: a + b

    main = fn:
      head-and-rest 10, ..[20, 30]
  | equals ƒink:
    30


