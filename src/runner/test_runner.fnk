{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'literal', fn:
  expect run ƒink:
    main = fn:
      42
  | equals ":
    42


test 'let binding', fn:
  expect run ƒink:
    main = fn:
      x = 42
      x
  | equals ":
    42


test 'float literal', fn:
  expect run ƒink:
    main = fn:
      3.14
  | equals ":
    3.14


test 'let alias', fn:
  expect run ƒink:
    main = fn:
      x = 42
      y = x
      y
  | equals ":
    42


test 'add two literals', fn:
  expect run ƒink:
    main = fn:
      2 + 3
  | equals ":
    5


test 'subtraction', fn:
  expect run ƒink:
    main = fn:
      10 - 3
  | equals ":
    7


test 'multiplication', fn:
  expect run ƒink:
    main = fn:
      4 * 5
  | equals ":
    20


test 'division', fn:
  expect run ƒink:
    main = fn:
      10 / 4
  | equals ":
    2.5


test 'integer division', fn:
  expect run ƒink:
    main = fn:
      7 // 2
  | equals ":
    3


test 'modulo', fn:
  expect run ƒink:
    main = fn:
      10 %% 3
  | equals ":
    1


test 'bool literal true', fn:
  expect run ƒink:
    main = fn:
      true
  | equals ":
    true


test 'bool literal false', fn:
  expect run ƒink:
    main = fn:
      false
  | equals ":
    false


test 'equal', fn:
  expect run ƒink:
    main = fn:
      3 == 3
  | equals ":
    true


test 'not equal', fn:
  expect run ƒink:
    main = fn:
      3 != 4
  | equals ":
    true


test 'less than', fn:
  expect run ƒink:
    main = fn:
      3 < 4
  | equals ":
    true


test 'less than or equal', fn:
  expect run ƒink:
    main = fn:
      3 <= 3
  | equals ":
    true


test 'greater than', fn:
  expect run ƒink:
    main = fn:
      4 > 3
  | equals ":
    true


test 'greater than or equal', fn:
  expect run ƒink:
    main = fn:
      3 >= 3
  | equals ":
    true


test 'not', fn:
  expect run ƒink:
    main = fn:
      not true
  | equals ":
    false


test 'and', fn:
  expect run ƒink:
    main = fn:
      true and false
  | equals ":
    false


test 'or', fn:
  expect run ƒink:
    main = fn:
      true or false
  | equals ":
    true


test 'xor', fn:
  expect run ƒink:
    main = fn:
      true xor true
  | equals ":
    false


test 'chained arithmetic', fn:
  expect run ƒink:
    main = fn:
      x = 2 * 3
      x + 4
  | equals ":
    10


test 'multiple let bindings', fn:
  expect run ƒink:
    main = fn:
      x = 2
      y = 3
      x + y
  | equals ":
    5


test 'nested chains', fn:
  expect run ƒink:
    main = fn:
      x = 2 + 3
      y = x * 2
      y - 1
  | equals ":
    9


test 'chain with bool', fn:
  expect run ƒink:
    main = fn:
      x = 3 > 2
      x and true
  | equals ":
    true


test 'pipe with fn call', fn:
  expect run ƒink:
    add = fn a, b: a + b
    main = fn:
      2
      | add 3, ?
  | equals ":
    5


test 'match literal first arm', fn:
  expect run ƒink:
    main = fn:
      match 0:
        0: 42
        _: 99
  | equals ":
    42


test 'match literal second arm', fn:
  expect run ƒink:
    main = fn:
      match 1:
        0: 42
        _: 99
  | equals ":
    99


test 'match wildcard binding', fn:
  expect run ƒink:
    main = fn:
      match 5:
        0: 0
        x: x + 1
  | equals ":
    6


test 'factorial', fn:
  expect run ƒink:
    fac = fn n:
      match n:
        0: 1
        n: n * fac n - 1
    main = fn:
      fac 5
  | equals ":
    120


test 'add list items', fn:
  expect run ƒink:
    sum = fn items, c:
      match items:
        []: c
        [a, ..rest]: sum rest, c + a

    main = fn:
      sum [1, 2, 3, 4], 0

  | equals ":
    10


test 'string literal', fn:
  expect run ƒink:
    main = fn:
      'hello'
  | equals ":
    hello

test 'string escape newline', fn:
  expect run ƒink:
    main = fn:
      'hello\nworld'
  | equals ":
    hello
    world

test 'string escape tab', fn:
  expect run ƒink:
    main = fn:
      'a\tb'
  | equals ":
    a	b

test 'string escape backslash', fn:
  expect run ƒink:
    main = fn:
      'a\\b'
  | equals ":
    a\b

test 'string escape hex', fn:
  expect run ƒink:
    main = fn:
      '\xE9'
  | equals ":
    é

test 'string escape unicode', fn:
  expect run ƒink:
    main = fn:
      '\u{1F600}'
  | equals ":
    😀

test 'string eq same', fn:
  expect run ƒink:
    main = fn:
      'hello' == 'hello'
  | equals ":
    true


test 'string eq different', fn:
  expect run ƒink:
    main = fn:
      'hello' == 'world'
  | equals ":
    false


test 'string neq', fn:
  expect run ƒink:
    main = fn:
      'hello' != 'world'
  | equals ":
    true


test 'str template string only', fn:
  expect run ƒink:
    main = fn:
      name = 'world'
      'hello ${name}' == 'hello world'
  | equals ƒink:
    true


test 'str template with number', fn:
  expect run ƒink:
    main = fn:
      x = 42
      'value: ${x}' == 'value: 42'
  | equals ƒink:
    true


test 'str template with bool', fn:
  expect run ƒink:
    main = fn:
      'done: ${true}' == 'done: true'
  | equals ƒink:
    true


test 'str template multiple segments', fn:
  expect run ƒink:
    main = fn:
      a = 1
      b = 2
      '${a} + ${b} = ${a + b}' == '1 + 2 = 3'
  | equals ƒink:
    true


test 'str template with float', fn:
  expect run ƒink:
    main = fn:
      'pi: ${3.14}' == 'pi: 3.14'
  | equals ƒink:
    true


test 'str template float arithmetic', fn:
  expect run ƒink:
    main = fn:
      x = 1.5
      y = 2.3
      '${x} + ${y} = ${x + y}' == '1.5 + 2.3 = 3.8'
  | equals ƒink:
    true


test 'rec destructure', fn:
  expect run ƒink:
    main = fn:
      {a, b: c} = {a: 1, b: 2}
      a + c
  | equals ƒink:
    3


test 'rec single field', fn:
  expect run ƒink:
    main = fn:
      {x} = {x: 42}
      x
  | equals ƒink:
    42


test 'rec three fields', fn:
  expect run ƒink:
    main = fn:
      {a, b, c} = {a: 1, b: 2, c: 3}
      a + b + c
  | equals ƒink:
    6


test 'rec shorthand', fn:
  expect run ƒink:
    main = fn:
      x = 10
      y = 20
      {a, b} = {a: x, b: y}
      a + b
  | equals ƒink:
    30


test 'rec nested', fn:
  expect run ƒink:
    main = fn:
      {a} = {a: {b: 42}}
      {b} = a
      b
  | equals ƒink:
    42


test 'rec spread update', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1, b: 2}
      {a, b} = {..r, b: 10}
      a + b
  | equals ƒink:
    11


test 'rec spread merge', fn:
  expect run ƒink:
    main = fn:
      r1 = {a: 1}
      r2 = {b: 2}
      {a, b} = {..r1, ..r2}
      a + b
  | equals ƒink:
    3


test 'rec in fn arg', fn:
  expect run ƒink:
    sum-fields = fn rec:
      {a, b} = rec
      a + b

    main = fn:
      sum-fields {a: 10, b: 20}
  | equals ƒink:
    30


test 'rec fn return', fn:
  expect run ƒink:
    make-point = fn x, y:
      {x: x, y: y}

    main = fn:
      {x, y} = make-point 3, 4
      x + y
  | equals ƒink:
    7


test 'rec match pattern', fn:
  expect run ƒink:
    main = fn:
      r = {x: 42, y: 99}
      match r:
        {x, ..}: x
  | equals ƒink:
    42


test 'rec match extract field', fn:
  expect run ƒink:
    main = fn:
      r = {a: 5, b: 10}
      match r:
        {a, ..}: a
  | equals ƒink:
    5


test 'rec empty', fn:
  expect run ƒink:
    main = fn:
      r = {}
      {a} = {..r, a: 1}
      a
  | equals ƒink:
    1


test 'rec with bool values', fn:
  expect run ƒink:
    main = fn:
      {a, b} = {a: true, b: false}
      a and (not b)
  | equals ƒink:
    true


test 'rec with string values', fn:
  expect run ƒink:
    main = fn:
      {name} = {name: 'hello'}
      name == 'hello'
  | equals ƒink:
    true


test 'rec format empty', fn:
  expect run ƒink:
    main = fn:
      '${  {}  }' == '{}'
  | equals ƒink:
    true


test 'rec format single field', fn:
  expect run ƒink:
    main = fn:
      '${  {a: 1}  }' == '{a: 1}'
  | equals ƒink:
    true


test 'rec format nested', fn:
  expect run ƒink:
    main = fn:
      '${  {a: {b: 1}}  }' == '{a: {b: 1}}'
  | equals ƒink:
    true


test 'rec format bool value', fn:
  expect run ƒink:
    main = fn:
      '${  {x: true}  }' == '{x: true}'
  | equals ƒink:
    true


test 'rec format string value', fn:
  expect run ƒink:
    main = fn:
      '${  {name: 'hi'}  }' == '{name: hi}'
  | equals ƒink:
    true


test 'rec format number value', fn:
  expect run ƒink:
    main = fn:
      '${  {x: 42}  }' == '{x: 42}'
  | equals ƒink:
    true


test 'rec format float value', fn:
  expect run ƒink:
    main = fn:
      '${  {pi: 3.14}  }' == '{pi: 3.14}'
  | equals ƒink:
    true


test 'rec string key destructure', fn:
  expect run ƒink:
    main = fn:
      {'foo bar': v} = {'foo bar': 42}
      v
  | equals ƒink:
    42


skip test 'rec expr key destructure', fn:
  expect run ƒink:
    main = fn:
      {(4): foo} = {(1 + 3): 42}
      foo
  | equals ƒink:
    42


test 'rec format string key', fn:
  expect run ƒink:
    main = fn:
      '${ {'foo bar': 42} }' == '{\'foo bar\': 42}'
  | equals ƒink:
    true

skip test 'rec format string key', fn:
  expect run ƒink:
    main = fn:
      '${ {(1 + 2): 42} }' == '{(3): 42}'
  | equals ƒink:
    true


test 'rec format in template', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1}
      'got: ${r}' == 'got: {a: 1}'
  | equals ƒink:
    true


test 'rec destructure extra fields', fn:
  expect run ƒink:
    main = fn:
      {a, b} = {a: 1, b: 2, c: 3}
      a + b
  | equals ƒink:
    3


test 'rec spread overwrite', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1, b: 2}
      {a, b} = {..r, a: 99}
      a + b
  | equals ƒink:
    101


test 'rec rest binding', fn:
  expect run ƒink:
    main = fn:
      {a, ..rest} = {a: 1, b: 2, c: 3}
      {b} = rest
      a + b
  | equals ƒink:
    3

test 'rec empty rest exact match', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1}
      match r:
        {a, ..{}}: a
        _: 0
  | equals ƒink:
    1

test 'rec empty rest rejects extra', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1, b: 2}
      match r:
        {a, ..{}}: a
        _: 0
  | equals ƒink:
    0

skip test 'rec guard literal in match', fn:
  expect run ƒink:
    main = fn:
      r = {kind: 1, val: 42}
      match r:
        {kind: 1, val}: val
        {kind: 2, val}: val + 100
        _: 0
  | equals ƒink:
    42

skip test 'rec guard second arm', fn:
  expect run ƒink:
    main = fn:
      r = {kind: 2, val: 10}
      match r:
        {kind: 1, val}: val
        {kind: 2, val}: val + 100
        _: 0
  | equals ƒink:
    110

test 'rec key membership', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1, b: 2}
      'a' in r
  | equals ƒink:
    true

test 'rec key not member', fn:
  expect run ƒink:
    main = fn:
      r = {a: 1, b: 2}
      'c' not in r
  | equals ƒink:
    true

test 'rec with list value', fn:
  expect run ƒink:
    main = fn:
      {items} = {items: [1, 2, 3]}
      match items:
        [a, ..]: a
  | equals ƒink:
    1


test 'varargs first', fn:
  expect run ƒink:
    first = fn ..args:
      match args:
        [a, ..]: a

    main = fn:
      first ..[42, 99]
  | equals ƒink:
    42


test 'varargs identity', fn:
  expect run ƒink:
    identity = fn ..args: args

    main = fn:
      match (identity ..[10, 20, 30]):
        [a, ..]: a
  | equals ƒink:
    10


test 'tagged template varargs', fn:
  expect run ƒink:
    first = fn ..parts:
      match parts:
        [a, ..]: a

    main = fn:
      x = 42
      y = first'hello ${x} world'
      y == 'hello '
  | equals ƒink:
    true


test 'varargs mixed fixed and rest', fn:
  expect run ƒink:
    head-and-rest = fn a, ..rest:
      match rest:
        [b, ..]: a + b

    main = fn:
      head-and-rest 10, ..[20, 30]
  | equals ƒink:
    30


test 'range exclusive formatting', fn:
  expect run ƒink:
    main = fn:
      '${0..10}' == '0..10'
  | equals ƒink:
    true


test 'range inclusive formatting', fn:
  expect run ƒink:
    main = fn:
      '${0...10}' == '0...10'
  | equals ƒink:
    true


test 'range exclusive construction', fn:
  expect run ƒink:
    main = fn:
      r = 2..5
      '${r}' == '2..5'
  | equals ƒink:
    true


test 'range inclusive construction', fn:
  expect run ƒink:
    main = fn:
      r = 2...5
      '${r}' == '2...5'
  | equals ƒink:
    true


test 'range in exclusive', fn:
  expect run ƒink:
    main = fn:
      5 in 0..10
  | equals ƒink:
    true


test 'range in exclusive upper bound', fn:
  expect run ƒink:
    main = fn:
      10 in 0..10
  | equals ƒink:
    false


test 'range in inclusive upper bound', fn:
  expect run ƒink:
    main = fn:
      10 in 0...10
  | equals ƒink:
    true


test 'range not in', fn:
  expect run ƒink:
    main = fn:
      20 not in 0..10
  | equals ƒink:
    true


test 'range match pattern', fn:
  expect run ƒink:
    main = fn:
      x = 5
      match x:
        0..10: true
  | equals ƒink:
    true


# --- Bitwise operators ---

skip test 'bitwise and', fn:
  expect run ƒink:
    main = fn:
      0xFF band 0x0F
  | equals ƒink:
    15

skip test 'bitwise or', fn:
  expect run ƒink:
    main = fn:
      0xF0 bor 0x0F
  | equals ƒink:
    255

skip test 'bitwise xor', fn:
  expect run ƒink:
    main = fn:
      0xFF bxor 0x0F
  | equals ƒink:
    240

skip test 'bitwise not', fn:
  expect run ƒink:
    main = fn:
      bnot 0
  | equals ƒink:
    -1

skip test 'bitwise shift left', fn:
  expect run ƒink:
    main = fn:
      1 bshl 8
  | equals ƒink:
    256

skip test 'bitwise shift right', fn:
  expect run ƒink:
    main = fn:
      256 bshr 4
  | equals ƒink:
    16


# --- Record property access ---

test 'rec dot access', fn:
  expect run ƒink:
    main = fn:
      r = {a: 42}
      r.a
  | equals ƒink:
    42

test 'rec dot access nested', fn:
  expect run ƒink:
    main = fn:
      r = {a: {b: 99}}
      r.a.b
  | equals ƒink:
    99

test 'rec dot access string key', fn:
  expect run ƒink:
    main = fn:
      r = {'foo bar': 42}
      r.('foo bar')
  | equals ƒink:
    42

skip test 'rec dot access string key short', fn:
  expect run ƒink:
    main = fn:
      r = {'foo bar': 42}
      # TODO parser issue r.'foo bar'
  | equals ƒink:
    42


# --- List formatting ---

skip test 'list format empty', fn:
  expect run ƒink:
    main = fn:
      '${  []  }' == '[]'
  | equals ƒink:
    true

skip test 'list format', fn:
  expect run ƒink:
    main = fn:
      '${  [1, 2, 3]  }' == '[1, 2, 3]'
  | equals ƒink:
    true

skip test 'list format nested', fn:
  expect run ƒink:
    main = fn:
      '${  [1, [2, 3]]  }' == '[1, [2, 3]]'
  | equals ƒink:
    true


# --- List patterns ---

skip test 'seq guard literal in match', fn:
  expect run ƒink:
    main = fn:
      match [1, 42]:
        [1, val, ..]: val
        [2, val, ..]: val + 100
        _: 0
  | equals ƒink:
    42

skip test 'seq guard second arm', fn:
  expect run ƒink:
    main = fn:
      match [2, 10]:
        [1, val, ..]: val
        [2, val, ..]: val + 100
        _: 0
  | equals ƒink:
    110

skip test 'list rest in middle', fn:
  expect run ƒink:
    main = fn:
      match [1, 2, 3, 4]:
        [first, ..mid, last]: first + last
  | equals ƒink:
    5


# --- String template patterns ---

skip test 'str template pattern', fn:
  expect run ƒink:
    main = fn:
      match 'hello world':
        'hello ${name}': name == 'world'
  | equals ƒink:
    true


# --- Record empty check ---

skip test 'rec empty check', fn:
  expect run ƒink:
    main = fn:
      r = {}
      match r:
        {}: true
        _: false
  | equals ƒink:
    true


# --- Yield ---

skip test 'yield value', fn:
  expect run ƒink:
    main = fn:
      x = 1
      y = 2
      x + y
      yield x + y
  | equals ƒink:
    3

skip test 'yield multiple', fn:
  expect run ƒink:
    main = fn:
      yield 1
      yield 2
      yield 3
  | equals ƒink:
    1
    2
    3


# --- Error handling ---

skip test 'try unwrap ok', fn:
  expect run ƒink:
    main = fn:
      x = try Ok 42
      x
  | equals ƒink:
    42

skip test 'try propagate err', fn:
  expect run ƒink:
    fallible = fn:
      try Err 'boom'
      99

    main = fn:
      match (fallible ..[]):
        Ok v: v
        Err e: e == 'boom'
  | equals ƒink:
    true

skip test 'match ok err', fn:
  expect run ƒink:
    main = fn:
      r = Ok 42
      match r:
        Ok v: v
        Err _: 0
  | equals ƒink:
    42


# --- fn match sugar ---

skip test 'fn match simple', fn:
  expect run ƒink:
    double = fn match:
      0: 0
      n: n * 2

    main = fn:
      double 5
  | equals ƒink:
    10

skip test 'fn match with rec pattern', fn:
  expect run ƒink:
    get-x = fn match:
      {x, ..}: x

    main = fn:
      get-x {x: 42, y: 99}
  | equals ƒink:
    42


