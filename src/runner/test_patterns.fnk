{test, skip, skip-ir, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'seq guard literal in match', fn:
  expect run ƒink:
    match [1, 42]:
      [1, val, ..rest]: val
      [2, val, ..rest]: val + 100
      _: 0
  | equals ƒink:
    42

test 'seq guard second arm', fn:
  expect run ƒink:
    match [2, 10]:
      [1, val, ..rest]: val
      [2, val, ..rest]: val + 100
      _: 0
  | equals ƒink:
    110

test 'list rest in middle', fn:
  expect run ƒink:
    match [1, 2, 3, 4]:
      [first, ..mid, last]: first + last
  | equals ƒink:
    5


test 'list trailing only — bare spread plus tail', fn:
  expect run ƒink:
    match [1, 2, 3, 4]:
      [.., last]: last
  | equals ƒink:
    4


test 'list trailing only — multiple back elements', fn:
  expect run ƒink:
    match [1, 2, 3, 4, 5]:
      [..rest, x, y, z]: x + y + z
  | equals ƒink:
    12


test 'list front + trailing with named rest', fn:
  expect run ƒink:
    match [1, 2, 3, 4, 5, 6]:
      [a, b, ..mid, x, y]: a + b + x + y
  | equals ƒink:
    14


test 'list rest in middle — empty mid', fn:
  expect run ƒink:
    match [1, 2]:
      [a, ..mid, last]: a + last
      _: 99
  | equals ƒink:
    3


test 'list rest in middle — too few elements', fn:
  expect run ƒink:
    match [1]:
      [a, ..mid, last]: a + last
      _: 99
  | equals ƒink:
    99


test 'list rest in middle — empty list', fn:
  expect run ƒink:
    match []:
      [a, ..mid, last]: a + last
      _: 99
  | equals ƒink:
    99


test 'list rest in middle — literal trailing', fn:
  expect run ƒink:
    match [1, 2, 3, 4]:
      [a, ..mid, 4]: a
      _: 99
  | equals ƒink:
    1


test 'list rest in middle — literal trailing fails', fn:
  expect run ƒink:
    match [1, 2, 3, 4]:
      [a, ..mid, 5]: a
      _: 99
  | equals ƒink:
    99


test 'list rest in middle — nested seq pattern in trailing', fn:
  expect run ƒink:
    match [1, [10, 20], [30, 40]]:
      [first, ..mid, [a, b]]: first + a + b
  | equals ƒink:
    71


test 'rec empty check', fn:
  expect run ƒink:
    r = {}
    match r:
      {}: true
      _: false
  | equals ƒink:
    true


test 'rec pattern rejects empty list', fn:
  expect run ƒink:
    match []:
      {}: true
      _: false
  | equals ƒink:
    false


test 'rec pattern rejects list', fn:
  expect run ƒink:
    match [1, 2]:
      {a, ..}: a
      _: false
  | equals ƒink:
    false


test 'seq pattern rejects empty rec', fn:
  expect run ƒink:
    match {}:
      []: true
      _: false
  | equals ƒink:
    false


test 'seq pattern rejects rec', fn:
  expect run ƒink:
    match {a: 1}:
      [x, ..]: x
      _: false
  | equals ƒink:
    false
