{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'



test 'stdout single message no main', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'

    write stdout, 'hello'
  | equals ":
    stdout == ":
      hello


test 'stdout single message', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'

    main = fn:
      write stdout, 'hello'
      0
  | equals ":
    0
    stdout == ":
      hello


test 'stdout multiple messages', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'

    main = fn:
      write stdout, 'hello'
      write stdout, 'world'
      0
  | equals ":
    0
    stdout == ":
      helloworld


test 'stderr output', fn:
  expect run ƒink:
    {stderr, write} = import 'std/io.fnk'

    main = fn:
      write stderr, 'error'
      1
  | equals ":
    1
    stderr == ":
      error


test 'stdout and stderr', fn:
  expect run ƒink:
    {stdout, stderr, write} = import 'std/io.fnk'

    main = fn:
      write stdout, 'out'
      write stderr, 'err'
      0
  | equals ":
    0
    stdout == ":
      out
    stderr == ":
      err


test 'write returns the stream (chaining)', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'

    main = fn:
      stdout
      | write ?, 'foo'
      | write ?, 'bar'
      0
  | equals ":
    0
    stdout == ":
      foobar


test 'read from stdin', fn:
  expect run ƒink:
    {stdin, stdout, read, write} = import 'std/io.fnk'

    main = fn:
      data = read stdin, 1024
      write stdout, data
      0
  | equals ":
    0
    stdout == ":
      hello from stdin


test 'cli args printed via stdout', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'

    main = fn ..args:
      write stdout, '${args}'
      0
  | equals ":
    0
    stdout == ":
      ['test', 'alpha', 'beta']
