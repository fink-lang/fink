--- --- ---
free variable analysis — input examples and expected output
--- --- ---

# These are Fink source inputs run through:
#   source → partial pass → CPS transform → free var pass
#
# The free var pass annotates each closure's func param with a record
# destructure showing exactly which names are captured from the environment:
#
#   Before:  closure env, fn ·x, env, state, ƒ_cont: ..., fn ·fn_val, _: ...
#   After:   closure env, fn ·x, {..env, ·captured}, state, ƒ_cont: ..., fn ·fn_val, _: ...
#
# Rules:
#   - plain `env` when the closure reads nothing from its env
#   - `{..env, ·a, op_plus}` when it does — lists only direct reads
#   - `..env` preserves the env handle for store calls in the body
#   - load calls disappear — captured names come from the destructure
#   - store calls remain — they settle the env for inner closures
#   - operators (op_plus etc.) are treated identically to user names
#   - only direct captures annotated — transitive carrying is for hoisting
#   - capture order follows load-encounter order in the body
#
# The closure cont fn always renders as `fn ·fn_val, _:` (single line).



{test, expect} = import 'fink/testing.fnk'
{cps_expr, equals_free_vars, closure, store, apply, id, ƒ_cont} = import 'fink/compiler/transform'



--- --- ---
no captures — trivial cases
--- --- ---

# Top-level fn reads op_plus from env (for a + b).
test 'fn with no captures', fn:
  expect cps_expr fn:
    fn a, b:
      a + b

  | equals_free_vars fn:
    closure env,
      fn ·a, ·b, {..env, op_plus}, state, ƒ_cont:
        store env, id'a', ·a, fn ·a, env:
          store env, id'b', ·b, fn ·b, env:
            apply op_plus, ·a, ·b, state, ƒ_cont
      fn ·fn_val, _: ƒ_cont ·fn_val, state


# Fn uses only a literal — no env reads at all.
test 'fn with only literals', fn:
  expect cps_expr fn:
    fn x:
      42

  | equals_free_vars fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          ƒ_cont 42, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


--- --- ---
simple capture — one level of nesting
--- --- ---

# Inner fn reads `op_plus` then `·x` from env (load-encounter order).
test 'closure captures one outer var', fn:
  expect cps_expr fn:
    fn x:
      fn y:
        x + y

  | equals_free_vars fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          closure env,
            fn ·y, {..env, op_plus, ·x}, state, ƒ_cont:
              store env, id'y', ·y, fn ·y, env:
                apply op_plus, ·x, ·y, state, ƒ_cont
            fn ·fn_val, _: ƒ_cont ·fn_val, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


# Inner fn reads `op_plus` then `·z` (a locally bound name).
# Outer reads `op_plus` directly (for the `x + 1` call).
# The intermediate apply result is named `v_0`; stored as `·z`.
test 'closure captures local binding', fn:
  expect cps_expr fn:
    fn x:
      z = x + 1
      fn y:
        z + y

  | equals_free_vars fn:
    closure env,
      fn ·x, {..env, op_plus}, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          apply op_plus, ·x, 1, state, fn ·z, state:
            store env, id'z', ·z, fn ·z, env:
              closure env,
                fn ·y, {..env, op_plus, ·z}, state, ƒ_cont:
                  store env, id'y', ·y, fn ·y, env:
                    apply op_plus, ·z, ·y, state, ƒ_cont
                fn ·fn_val, _: ƒ_cont ·fn_val, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


--- --- ---
named closures — bound with =
--- --- ---

# Outer reads nothing; inner reads `op_plus` then `·x`.
test 'named outer, inner captures param', fn:
  expect cps_expr fn:
    add = fn x:
      fn y:
        x + y

  | equals_free_vars fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          closure env,
            fn ·y, {..env, op_plus, ·x}, state, ƒ_cont:
              store env, id'y', ·y, fn ·y, env:
                apply op_plus, ·x, ·y, state, ƒ_cont
            fn ·fn_val, _: ƒ_cont ·fn_val, state
      fn ·add, chld_env:
        store chld_env, id'add', ·add, fn ·add, env:
          ƒ_cont ·add, state


# Both fns read `op_plus` directly — no user-var captures between siblings.
test 'two named fns no captures', fn:
  expect cps_expr fn:
    double = fn x: x + x
    triple = fn x: x + x + x

  | equals_free_vars fn:
    closure env,
      fn ·x, {..env, op_plus}, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          apply op_plus, ·x, ·x, state, ƒ_cont
      fn ·double, chld_env:
        store chld_env, id'double', ·double, fn ·double, env:
          closure env,
            fn ·x, {..env, op_plus}, state, ƒ_cont:
              store env, id'x', ·x, fn ·x, env:
                apply op_plus, ·x, ·x, state, fn v_0, state:
                  apply op_plus, v_0, ·x, state, ƒ_cont
            fn ·triple, chld_env:
              store chld_env, id'triple', ·triple, fn ·triple, env:
                ƒ_cont ·triple, state


--- --- ---
deep nesting — direct captures only, no transitive propagation
--- --- ---

# Middle reads nothing directly.
# Inner reads `op_plus`, `·a`, `·b` directly (in load-encounter order).
test 'three levels of nesting', fn:
  expect cps_expr fn:
    fn a:
      fn b:
        fn c:
          a + b + c

  | equals_free_vars fn:
    closure env,
      fn ·a, env, state, ƒ_cont:
        store env, id'a', ·a, fn ·a, env:
          closure env,
            fn ·b, env, state, ƒ_cont:
              store env, id'b', ·b, fn ·b, env:
                closure env,
                  fn ·c, {..env, op_plus, ·a, ·b}, state, ƒ_cont:
                    store env, id'c', ·c, fn ·c, env:
                      apply op_plus, ·a, ·b, state, fn v_0, state:
                        apply op_plus, v_0, ·c, state, ƒ_cont
                  fn ·fn_val, _: ƒ_cont ·fn_val, state
            fn ·fn_val, _: ƒ_cont ·fn_val, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


--- --- ---
pattern matching — bound names in arms
--- --- ---

# No closures created inside — no capture annotations needed.
# match 1: compiles to apply op_eq + if (literal match uses equality check).
# op_eq is captured because it's loaded inside the closure body.
test 'match arm bindings are local', fn:
  expect cps_expr fn:
    fn val:
      match val:
        1: 'one'
        n: n

  | equals_free_vars fn:
    closure env,
      fn ·val, {..env, op_eq}, state, ƒ_cont:
        store env, id'val', ·val, fn ·val, env:
          match_block ·val, state,
            match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
              apply op_eq, v, 1, state, fn v_result, state:
                if v_result,
                  fn state: ƒ_ok 'one', state
                  fn state: ƒ_err state
            match_branch env, fn ·n, env, state, ƒ_err, ƒ_ok:
              store env, id'n', ·n, fn ·n, env:
                load env, id'n', fn ·n, env:
                  ƒ_ok ·n, state
            fn state: panic 'no match', state
            fn match_result, state: ƒ_cont match_result, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


# Inner closure reads `op_plus` then `·head` from the arm's env.
test 'closure inside match arm captures arm binding', fn:
  expect cps_expr fn:
    fn val:
      match val:
        [head, ..tail]:
          fn x: head + x

  | equals_free_vars fn:
    closure env,
      fn ·val, env, state, ƒ_cont:
        store env, id'val', ·val, fn ·val, env:
          match_block ·val, state,
            match_branch env, fn seq, env, state, ƒ_err, ƒ_ok:
              seq_matcher seq, state,
                fn m, ƒ_err, state:
                  match_pop_at m, 0, state,
                    fn m, ·head, state:
                      match_rest m, state, fn m, ·tail, state:
                        store env, id'head', ·head, fn ·head, env:
                          store env, id'tail', ·tail, fn ·tail, env:
                            closure env,
                              fn ·x, {..env, op_plus, ·head}, state, ƒ_cont:
                                store env, id'x', ·x, fn ·x, env:
                                  apply op_plus, ·head, ·x, state, ƒ_cont
                              fn ·fn_val, _: ƒ_ok ·fn_val, state
                    fn m, state: ƒ_err state
                fn state: ƒ_err state
            fn state: panic 'no match', state
            fn match_result, state: ƒ_cont match_result, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state
