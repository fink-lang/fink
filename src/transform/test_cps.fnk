--- --- ---

test 'member static', fn:
  expect cps_c_expr fn:
    foo.bar

  | equals_fink fn:
    load scope, op'.', fn op_dot, scope:
      load scope, id'foo', fn ·foo, scope:
        load scope, id'bar', fn ·bar, scope:
          apply op_dot, ·foo, ·bar, state, fn v_0, state:
            ƒ_cont v_0, state


test 'member dynamic', fn:
  expect cps_c_expr fn:
    foo.(key)

  | equals_fink fn:
    load scope, op'.', fn op_dot, scope:
      load scope, id'foo', fn ·foo, scope:
        load scope, id'key', fn ·key, scope:
          apply op_dot, ·foo, ·key, state, fn v_0, state:
            ƒ_cont v_0, state


--- --- ---
spreads in seq and rec literals
--- --- ---

test 'seq spread', fn:
  expect cps_c_expr fn:
    [..xs, 1]

  | equals_fink fn:
    load scope, id'seq_concat', fn ·seq_concat, scope:
      load scope, id'xs', fn ·xs, scope:
        apply ·seq_concat, [], ·xs, state, fn v_0, state:
          load scope, id'seq_append', fn ·seq_append, scope:
            apply ·seq_append, v_0, 1, state, fn v_1, state:
              ƒ_cont v_1, state


test 'rec spread', fn:
  expect cps_c_expr fn:
    {..base, x: 1}

  | equals_fink fn:
    load scope, id'rec_merge', fn ·rec_merge, scope:
      load scope, id'base', fn ·base, scope:
        apply ·rec_merge, {}, ·base, state, fn v_0, state:
          load scope, id'rec_put', fn ·rec_put, scope:
            apply ·rec_put, v_0, 'x', 1, state, fn v_1, state:
              ƒ_cont v_1, state


--- --- ---
try expression
--- --- ---

test 'try', fn:
  expect cps_c_expr fn:
    try foo

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      ƒ_cont ·foo, state


--- --- ---
tagged literals
--- --- ---

test 'tagged literal', fn:
  expect cps_c_expr fn:
    10sec

  | equals_fink fn:
    load scope, id'sec', fn ·sec, scope:
      apply ·sec, 10, state, fn v_0, state:
        ƒ_cont v_0, state


--- --- ---
ported from test_cps — sequential and module-level
--- --- ---

test 'sequential bindings', fn:
  expect cps_c_expr fn:
    foo = 1
    bar = foo + 1

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        store scope, id'foo', 1, fn ·foo, scope:
          load scope, op'+', fn op_plus, scope:
            load scope, id'foo', fn ·foo, scope:
              apply op_plus, ·foo, 1, state, fn v_1, state:
                store scope, id'bar', v_1, fn ·bar, scope:
                  ƒ_cont ·bar, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


test 'binding rhs is a call', fn:
  expect cps_c_expr fn:
    foo = add 1, 2

  | equals_fink fn:
    load scope, id'add', fn ·add, scope:
      apply ·add, 1, 2, state, fn v_0, state:
        store scope, id'foo', v_0, fn ·foo, scope:
          ƒ_cont ·foo, state


test 'expression result discarded', fn:
  expect cps_c_expr fn:
    foo 1
    bar

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        load scope, id'foo', fn ·foo, scope:
          apply ·foo, 1, state, fn v_1, state:
            store scope, id'v_2', v_1, fn v_2, scope:
              load scope, id'bar', fn ·bar, scope:
                ƒ_cont ·bar, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


test 'chained member access', fn:
  expect cps_c_expr fn:
    foo.bar.baz

  | equals_fink fn:
    load scope, op'.', fn op_dot, scope:
      load scope, id'foo', fn ·foo, scope:
        load scope, id'bar', fn ·bar, scope:
          apply op_dot, ·foo, ·bar, state, fn v_0, state:
            load scope, op'.', fn op_dot, scope:
              load scope, id'baz', fn ·baz, scope:
                apply op_dot, v_0, ·baz, state, fn v_1, state:
                  ƒ_cont v_1, state


--- --- ---
ported from test_cps — calls and application
--- --- ---

test 'simple call', fn:
  expect cps_c_expr fn:
    add 1, 2

  | equals_fink fn:
    load scope, id'add', fn ·add, scope:
      apply ·add, 1, 2, state, fn v_0, state:
        ƒ_cont v_0, state


test 'nested call', fn:
  expect cps_c_expr fn:
    add (mul 2, 3), 1

  | equals_fink fn:
    load scope, id'mul', fn ·mul, scope:
      apply ·mul, 2, 3, state, fn v_0, state:
        load scope, id'add', fn ·add, scope:
          apply ·add, v_0, 1, state, fn v_1, state:
            ƒ_cont v_1, state


test 'postfix tag', fn:
  expect cps_c_expr fn:
    (foo bar)tag

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      load scope, id'bar', fn ·bar, scope:
        apply ·foo, ·bar, state, fn v_0, state:
          load scope, id'tag', fn ·tag, scope:
            apply ·tag, v_0, state, fn v_1, state:
              ƒ_cont v_1, state


test 'call with spread', fn:
  expect cps_c_expr fn:
    foo a, ..rest

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      load scope, id'a', fn ·a, scope:
        load scope, id'rest', fn ·rest, scope:
          apply ·foo, ·a, ..·rest, state, fn v_0, state:
            ƒ_cont v_0, state


test 'simple pipe', fn:
  expect cps_c_expr fn:
    x | f

  | equals_fink fn:
    load scope, id'f', fn ·f, scope:
      load scope, id'x', fn ·x, scope:
        apply ·f, ·x, state, fn v_0, state:
          ƒ_cont v_0, state


test 'pipe chain', fn:
  expect cps_c_expr fn:
    x | f | g

  | equals_fink fn:
    load scope, id'f', fn ·f, scope:
      load scope, id'x', fn ·x, scope:
        apply ·f, ·x, state, fn v_0, state:
          load scope, id'g', fn ·g, scope:
            apply ·g, v_0, state, fn v_1, state:
              ƒ_cont v_1, state


--- --- ---
ported from test_cps — functions and closures
--- --- ---

test 'function binding', fn:
  expect cps_c_expr fn:
    inc = fn x: x + 1

  | equals_fink fn:
    closure scope,
      fn ·x, scope, state, ƒ_cont:
        load scope, op'+', fn op_plus, scope:
          load scope, id'x', fn ·x, scope:
            apply op_plus, ·x, 1, state, fn v_1, state:
              ƒ_cont v_1, state
      fn fn_0, chld_scope:
        store scope, id'inc', fn_0, fn ·inc, scope:
          ƒ_cont ·inc, state


test 'closure over outer variable', fn:
  expect cps_c_expr fn:
    foo = fn a:
      ni = fn b:
        a + b
      ni

  | equals_fink fn:
    closure scope,
      fn ·a, scope, state, ƒ_cont:
        closure scope,
          fn ·b, scope, state, ƒ_cont:
            load scope, op'+', fn op_plus, scope:
              load scope, id'a', fn ·a, scope:
                load scope, id'b', fn ·b, scope:
                  apply op_plus, ·a, ·b, state, fn v_2, state:
                    ƒ_cont v_2, state
          fn fn_1, chld_scope:
            store scope, id'ni', fn_1, fn ·ni, scope:
              load scope, id'ni', fn ·ni, scope:
                ƒ_cont ·ni, state
      fn fn_0, chld_scope:
        store scope, id'foo', fn_0, fn ·foo, scope:
          ƒ_cont ·foo, state


test 'three sequential bindings', fn:
  expect cps_c_expr fn:
    a = 1
    b = 2
    c = a + b

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        store scope, id'a', 1, fn ·a, scope:
          store scope, id'b', 2, fn ·b, scope:
            load scope, op'+', fn op_plus, scope:
              load scope, id'a', fn ·a, scope:
                load scope, id'b', fn ·b, scope:
                  apply op_plus, ·a, ·b, state, fn v_1, state:
                    store scope, id'c', v_1, fn ·c, scope:
                      ƒ_cont ·c, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


--- --- ---
ported from test_cps — forward refs and mutual recursion
--- --- ---

test 'forward ref', fn:
  expect cps_c_expr fn:
    foo = fn a: foo a + 1
    foo 1

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        closure scope,
          fn ·a, scope, state, ƒ_cont:
            load scope, op'+', fn op_plus, scope:
              load scope, id'a', fn ·a, scope:
                apply op_plus, ·a, 1, state, fn v_2, state:
                  load scope, id'foo', fn ·foo, scope:
                    apply ·foo, v_2, state, fn v_3, state:
                      ƒ_cont v_3, state
          fn fn_1, chld_scope:
            store scope, id'foo', fn_1, fn ·foo, scope:
              load scope, id'foo', fn ·foo, scope:
                apply ·foo, 1, state, fn v_4, state:
                  ƒ_cont v_4, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


test 'mutual recursion', fn:
  expect cps_c_expr fn:
    ping = fn x: pong x
    pong = fn x: ping x

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        closure scope,
          fn ·x, scope, state, ƒ_cont:
            load scope, id'pong', fn ·pong, scope:
              load scope, id'x', fn ·x, scope:
                apply ·pong, ·x, state, fn v_2, state:
                  ƒ_cont v_2, state
          fn fn_1, chld_scope:
            store scope, id'ping', fn_1, fn ·ping, scope:
              closure scope,
                fn ·x, scope, state, ƒ_cont:
                  load scope, id'ping', fn ·ping, scope:
                    load scope, id'x', fn ·x, scope:
                      apply ·ping, ·x, state, fn v_4, state:
                        ƒ_cont v_4, state
                fn fn_3, chld_scope:
                  store scope, id'pong', fn_3, fn ·pong, scope:
                    ƒ_cont ·pong, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


--- --- ---
pattern bindings (bind-right)
--- --- ---

test 'bind right — simple id', fn:
  expect cps_c_expr fn:
    x = foo

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      store scope, id'x', ·foo, fn ·x, scope:
        ƒ_cont ·x, state


# NOTE: complex patterns ([a,b], {bar}) are bound to a temp at this IR level;
# pattern destructuring is a later lowering pass.

test 'bind right — seq pattern', fn:
  expect cps_c_expr fn:
    [a, b] = foo

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      store scope, id'v_0', ·foo, fn v_0, scope:
        ƒ_cont v_0, state


test 'bind right — rec pattern', fn:
  expect cps_c_expr fn:
    {bar} = foo

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      store scope, id'v_0', ·foo, fn v_0, scope:
        ƒ_cont v_0, state


# NOTE: composite patterns render as _seq_pat/_rec_pat placeholders until
# the pattern-lowering pass expands them to seq_matcher/match_pop_at/etc.

test 'match — seq pattern arm', fn:
  expect cps_c_expr fn:
    match foo:
      [a, b]: a

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      match_block ·foo, state,
        match_branch _seq_pat, fn ·a, ·b, scope, state, ƒ_cont:
          load scope, id'a', fn ·a, scope:
            ƒ_cont ·a, state
        fn v_0, state: ƒ_cont v_0, state

test 'match — rec pattern arm', fn:
  expect cps_c_expr fn:
    match foo:
      {bar}: bar

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      match_block ·foo, state,
        match_branch _rec_pat, fn ·bar, scope, state, ƒ_cont:
          load scope, id'bar', fn ·bar, scope:
            ƒ_cont ·bar, state
        fn v_0, state: ƒ_cont v_0, state


test 'match — expression in arm', fn:
  expect cps_c_expr fn:
    match x:
      true: y + 1
      false: y

  | equals_fink fn:
    load scope, id'x', fn ·x, scope:
      match_block ·x, state,
        match_branch true, fn scope, state, ƒ_cont:
          load scope, op'+', fn op_plus, scope:
            load scope, id'y', fn ·y, scope:
              apply op_plus, ·y, 1, state, fn v_0, state:
                ƒ_cont v_0, state
        match_branch false, fn scope, state, ƒ_cont:
          load scope, id'y', fn ·y, scope:
            ƒ_cont ·y, state
        fn v_1, state: ƒ_cont v_1, state


