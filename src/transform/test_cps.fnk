test 'match with expression in arm', fn:
  expect cps fn:
    match x:
      true: y + 1
      false: y

  , equals fn:
    match_block x, state,
      match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
        load env, op'==', fn op_eq, env:
          apply op_eq, v, true, state, fn v_result, state:
            if v_result,
              fn state:
                load env, op'+', fn op_plus, env:
                  apply op_plus, ·y, 1, state, fn v_result, state:
                    ƒ_ok v_result, state
              fn state: ƒ_err state
      match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
        load env, op'==', fn op_eq, env:
          apply op_eq, v, false, state, fn v_result, state:
            if v_result,
              fn state: ƒ_ok ·y, state
              fn state: ƒ_err state
      fn state: panic 'no match', state
      fn match_result, state: ƒ_cont match_result, state

test 'multi-arm match — ƒ_err chains to next arm', fn:
  expect cps fn:
    match foo:
      [a]: a
      [a, b]: a + b

  , equals fn:
    match_block foo, state,
      match_branch env, fn seq, env, state, ƒ_err, ƒ_ok:
        matcher seq, 'SeqPattern', state,
          fn m, ƒ_err, state:
            match_len m, 1, state,
              fn m, state:
                match_pop_at m, 0, state,
                  fn m, a, state: ƒ_ok ·a, state
                  fn m, state: ƒ_err state
              fn m, state: ƒ_err state
          fn state: ƒ_err state
      match_branch env, fn seq, env, state, ƒ_err, ƒ_ok:
        matcher seq, 'SeqPattern', state,
          fn m, ƒ_err, state:
            match_len m, 2, state,
              fn m, state:
                match_pop_at m, 0, state,
                  fn m, a, state:
                    match_pop_at m, 1, state,
                      fn m, b, state:
                        load env, op'+', fn op_plus, env:
                          apply op_plus, ·a, ·b, state, fn v_result, state:
                            ƒ_ok v_result, state
                      fn m, state: ƒ_err state
                  fn m, state: ƒ_err state
              fn m, state: ƒ_err state
          fn state: ƒ_err state
      fn state: panic 'no match', state
      fn match_result, state: ƒ_cont match_result, state

--- --- ---
multi-arg match
--- --- ---

test 'multi-arg match — fixed arity', fn:
  expect cps fn:
    match a, b:
      1, 2: 'one two'
      _, _: 'other'

  , equals fn:
    load env, id'a', fn ·a, env:
      load env, id'b', fn ·b, env:
        match_block ·a, ·b, state,
          match_branch env, fn v0, v1, env, state, ƒ_err, ƒ_ok:
            load env, op'==', fn op_eq, env:
              apply op_eq, v0, 1, state, fn v_r0, state:
                if v_r0,
                  fn state:
                    apply op_eq, v1, 2, state, fn v_r1, state:
                      if v_r1,
                        fn state: ƒ_ok 'one two', state
                        fn state: ƒ_err state
                  fn state: ƒ_err state
          match_branch env, fn v0, v1, env, state, ƒ_err, ƒ_ok:
            ƒ_ok 'other', state
          fn state: panic 'no match', state
          fn match_result, state: ƒ_cont match_result, state

test 'multi-arg match — varargs arm', fn:
  expect cps fn:
    match a, ..rest:
      x, ..: 'has more'
      x, ..[]: 'exactly one'

  , equals fn:
    load env, id'a', fn ·a, env:
      load env, id'rest', fn ·rest, env:
        match_block ·a, ..·rest, state,
          match_branch env, fn v0, ..vs, env, state, ƒ_err, ƒ_ok:
            match_done vs, state,
              fn vs, state: ƒ_err state
              fn vs, state: ƒ_ok 'has more', state
          match_branch env, fn v0, ..vs, env, state, ƒ_err, ƒ_ok:
            match_len vs, 0, state,
              fn vs, state: ƒ_ok 'exactly one', state
              fn vs, state: ƒ_err state
          fn state: panic 'no match', state
          fn match_result, state: ƒ_cont match_result, state

--- --- ---
module level — settled env is the export; ƒ_cont receives it
--- --- ---

test 'two bindings at module level', fn:
  expect cps fn:
    foo = 1
    bar = 2

  , equals fn:
    store env, id'foo', 1, fn ·foo, env:
      store env, id'bar', 2, fn ·bar, env:
        ƒ_cont ·bar, state

test 'forward ref', fn:
  expect cps fn:
    foo = fn a: foo a + 1
    foo 1

  , equals fn:
    closure env,
      fn ·a, env, state, ƒ_cont:
        load env, op'+', fn op_plus, env:
          load env, id'foo', fn ·foo, env:
            apply op_plus, ·a, 1, state, ƒ_cont
      fn ·foo, chld_env:
        store chld_env, id'foo', ·foo, fn ·foo, env:
          apply ·foo, 1, state, ƒ_cont

test 'mutual recursion', fn:
  expect cps fn:
    is_even = fn n:
      match n:
        0: true
        _: is_odd n - 1

    is_odd  = fn n:
      match n:
        0: false,
        _: is_even n - 1

  , equals fn:
    closure env,
      fn ·n, env, state, ƒ_cont:
        store env, id'n', ·n, fn ·n, env:
          match_block n, state,
            match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
              load env, op'==', fn op_eq, env:
                apply op_eq, v, 0, state, fn v_result, state:
                  if v_result,
                    fn state: ƒ_ok true, state
                    fn state: ƒ_err state
            match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
              load env, op'-', fn op_minus, env:
                apply op_minus, ·n, 1, state, fn v_0, state:
                  load env, id'is_odd', fn ·is_odd, env:
                    apply ·is_odd, v_0, state, ƒ_ok
            fn state: panic 'no match', state
            fn match_result, state: ƒ_cont match_result, state
      fn ·is_even, chld_env:
        closure chld_env,
          fn ·n, env, state, ƒ_cont:
            store env, id'n', ·n, fn ·n, env:
              match_block n, state,
                match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
                  load env, op'==', fn op_eq, env:
                    apply op_eq, v, 0, state, fn v_result, state:
                      if v_result,
                        fn state: ƒ_ok false, state
                        fn state: ƒ_err state
                match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
                  load env, op'-', fn op_minus, env:
                    apply op_minus, ·n, 1, state, fn v_0, state:
                      load env, id'is_even', fn ·is_even, env:
                        apply ·is_even, v_0, state, ƒ_ok
                fn state: panic 'no match', state
                fn match_result, state: ƒ_cont match_result, state
          fn ·is_odd, chld_env:
            store chld_env, id'is_even', ·is_even, fn ·is_even, chld_env:
              store chld_env, id'is_odd', ·is_odd, fn ·is_odd, env:
                ƒ_cont ·is_odd, state