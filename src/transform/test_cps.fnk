test 'member static', fn:
  expect cps_expr fn:
    foo.bar

  | equals_fink fn:
    ·load ·scope, ·op'.', fn ·op_dot, ·scope:
      ·load ·scope, ·id'foo', fn foo, ·scope:
        ·load ·scope, ·id'bar', fn bar, ·scope:
          ·apply ·op_dot, foo, bar, ·state, fn ·v_0, ·state:
            ·ƒ_cont ·v_0, ·state


test 'member dynamic', fn:
  expect cps_expr fn:
    foo.(key)

  | equals_fink fn:
    ·load ·scope, ·op'.', fn ·op_dot, ·scope:
      ·load ·scope, ·id'foo', fn foo, ·scope:
        ·load ·scope, ·id'key', fn key, ·scope:
          ·apply ·op_dot, foo, key, ·state, fn ·v_0, ·state:
            ·ƒ_cont ·v_0, ·state


--- --- ---
spreads in seq and rec literals
--- --- ---

test 'seq spread', fn:
  expect cps_expr fn:
    [..xs, 1]

  | equals_fink fn:
    ·load ·scope, ·id'seq_concat', fn ·seq_concat, ·scope:
      ·load ·scope, ·id'xs', fn xs, ·scope:
        ·apply ·seq_concat, [], xs, ·state, fn ·v_0, ·state:
          ·load ·scope, ·id'seq_append', fn ·seq_append, ·scope:
            ·apply ·seq_append, ·v_0, 1, ·state, fn ·v_1, ·state:
              ·ƒ_cont ·v_1, ·state


test 'rec spread', fn:
  expect cps_expr fn:
    {..base, x: 1}

  | equals_fink fn:
    ·load ·scope, ·id'rec_merge', fn ·rec_merge, ·scope:
      ·load ·scope, ·id'base', fn base, ·scope:
        ·apply ·rec_merge, {}, base, ·state, fn ·v_0, ·state:
          ·load ·scope, ·id'rec_put', fn ·rec_put, ·scope:
            ·apply ·rec_put, ·v_0, 'x', 1, ·state, fn ·v_1, ·state:
              ·ƒ_cont ·v_1, ·state


