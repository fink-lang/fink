# Spread is valid in the CPS IR — apply and fn params can contain ..arg / ..·name.
# The IR stays readable Fink; codegen handles the actual flattening.
# WIP: cps_transform currently drops the spread; these tests define the target shape.

test 'varargs — call site spreads iterable', fn:
  expect cps_c_expr fn:
    foo 1, ..items

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      load scope, id'items', fn ·items, scope:
        apply ·foo, 1, ..·items, state, fn v_0, state:
          ƒ_cont v_0, state


test 'call with spread — trailing iterable', fn:
  expect cps_c_expr fn:
    foo a, ..rest

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      load scope, id'a', fn ·a, scope:
        load scope, id'rest', fn ·rest, scope:
          apply ·foo, ·a, ..·rest, state, fn v_0, state:
            ƒ_cont v_0, state


test 'call with spread — spread only', fn:
  expect cps_c_expr fn:
    foo ..items

  | equals_fink fn:
    load scope, id'foo', fn ·foo, scope:
      load scope, id'items', fn ·items, scope:
        apply ·foo, ..·items, state, fn v_0, state:
          ƒ_cont v_0, state


test 'call with spread — passes through from varargs fn', fn:
  expect cps_c_expr fn:
    fn ..args: foo ..args

  | equals_fink fn:
    closure scope,
      fn ..·args, scope, state, ƒ_cont:
        load scope, id'foo', fn ·foo, scope:
          load scope, id'args', fn ·args, scope:
            apply ·foo, ..·args, state, fn v_1, state:
              ƒ_cont v_1, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps_c_expr fn:
    fn a, [1, ..b]: b

  | equals_fink fn:
    closure scope,
      fn ·a, _seq_pat, scope, state, ƒ_cont:
        store scope, id'a', ·a, fn ·a, scope:
          load scope, id'b', fn ·b, scope:
            ƒ_cont ·b, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state


