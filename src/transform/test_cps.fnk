test 'match with expression in arm', fn:
  expect cps fn:
    match x:
      true: y + 1
      false: y

  , equals fn:
    match_block x, $state,
      match_branch $env, fn v, $env, $fail, $success, $state:
        resolve $env, op'==', fn $eq, $env:
          apply $eq, v, true, $state, fn $result, $state:
            if $result,
              fn $state:
                resolve $env, op'+', fn $plus, $env:
                  apply $plus, y, 1, $state, fn $result, $state:
                    $success $result, $state
              fn $state:
                $fail $state
      match_branch $env, fn v, $env, $fail, $success, $state:
        resolve $env, op'==', fn $eq, $env:
          apply $eq, v, false, $state, fn $result, $state:
            if $result,
              fn $state:
                $success y, $state
              fn $state:
                $fail $state
      fn $state:
        $panic 'no match', $state
      fn match_result, $state:
        $cont match_result, $state

test 'multi-arm match — $fail chains to next arm', fn:
  expect cps fn:
    match foo:
      [a]: a
      [a, b]: a + b

  , equals fn:
    match_block foo, $state,
      match_branch $env, fn seq, $env, $fail, $success, $state:
        get_matcher seq, 'SeqPattern', $state,
          fn m, $fail, $state:
            match_len m, 1, $state,
              fn m, $state:
                match_pop_at m, 0, $state,
                  fn m, a, $state:
                    $success a, $state
                  fn m, $state:
                    $fail $state
              fn m, $state:
                $fail $state
          fn $state:
            $fail $state
      match_branch $env, fn seq, $env, $fail, $success, $state:
        get_matcher seq, 'SeqPattern', $state,
          fn m, $fail, $state:
            match_len m, 2, $state,
              fn m, $state:
                match_pop_at m, 0, $state,
                  fn m, a, $state:
                    match_pop_at m, 1, $state,
                      fn m, b, $state:
                        resolve $env, op'+', fn $plus, $env:
                          apply $plus, a, b, $state, fn $result, $state:
                            $success $result, $state
                      fn m, $state:
                        $fail $state
                  fn m, $state:
                    $fail $state
              fn m, $state:
                $fail $state
          fn $state:
            $fail $state
      fn $state:
        $panic 'no match', $state
      fn match_result, $state:
        $cont match_result, $state

