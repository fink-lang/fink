pattern bindings (bind-right)
--- --- ---

test 'bind right — simple ·id', fn:
  expect cps_expr fn:
    x = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·store ·scope, ·id'x', foo, fn x, ·scope:
        ·ƒ_cont x, ·state


--- --- ---
varargs functions
--- --- ---

test 'multi-param function', fn:
  expect cps_expr fn:
    fn x, y: x + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, y, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'x', fn x, ·scope:
            ·load ·scope, ·id'y', fn y, ·scope:
              ·apply ·op_plus, x, y, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'varargs — collect rest', fn:
  expect cps_expr fn:
    fn a, ..rest: rest

  | equals_fink fn:
    ·closure ·scope,
      fn a, ..rest, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'rest', fn rest, ·scope:
          ·ƒ_cont rest, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


--- --- ---
scoping and sequential bindings
--- --- ---

test 'calling a local — still goes through ·load', fn:
  expect cps_expr fn:
    inc = fn x: x + 1
    inc 5

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn x, ·scope, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·apply ·op_plus, x, 1, ·state, fn ·v_2, ·state:
                  ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope:
            ·store ·scope, ·id'inc', ·v_1, fn inc, ·scope:
              ·load ·scope, ·id'inc', fn inc, ·scope:
                ·apply inc, 5, ·state, fn ·v_3, ·state:
                  ·ƒ_cont ·v_3, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'chained binding is sequential ·store', fn:
  expect cps_expr fn:
    foo = spam = 1

  | equals_fink fn:
    ·store ·scope, ·id'spam', 1, fn spam, ·scope:
      ·store ·scope, ·id'foo', spam, fn foo, ·scope:
        ·ƒ_cont foo, ·state


# NOTE: Group with binding becomes an immediately-invoked zero-param ·closure;
# old IR used a `·scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked ·closure', fn:
  expect cps_expr fn:
    spam = (
      ni = ham 1
      ni
    )

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'ham', fn ham, ·scope:
          ·apply ham, 1, ·state, fn ·v_1, ·state:
            ·store ·scope, ·id'ni', ·v_1, fn ni, ·scope:
              ·load ·scope, ·id'ni', fn ni, ·scope:
                ·ƒ_cont ni, ·state
      fn ·v_0, ·chld_scope:
        ·apply ·v_0, ·state, fn ·v_2, ·state:
          ·store ·scope, ·id'spam', ·v_2, fn spam, ·scope:
            ·ƒ_cont spam, ·state

--- --- ---
functions — additional
--- --- ---

test 'identity function', fn:
  expect cps_expr fn:
    fn x: x

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'x', fn x, ·scope:
          ·ƒ_cont x, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state

test 'function with operator in body', fn:
  expect cps_expr fn:
    fn x: x + 1

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'x', fn x, ·scope:
            ·apply ·op_plus, x, 1, ·state, fn ·v_1, ·state:
              ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state

test 'try — result bound, code continues', fn:
  expect cps_expr fn:
    ni = try foo bar
    ni + 1

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'foo', fn foo, ·scope:
          ·load ·scope, ·id'bar', fn bar, ·scope:
            ·apply foo, bar, ·state, fn ·v_1, ·state:
              ·store ·scope, ·id'ni', ·v_1, fn ni, ·scope:
                ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                  ·load ·scope, ·id'ni', fn ni, ·scope:
                    ·apply ·op_plus, ni, 1, ·state, fn ·v_2, ·state:
                      ·ƒ_cont ·v_2, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


--- --- ---
seq/rec literals with spreads
--- --- ---

# NOTE: ·seq_append/·seq_concat/·rec_put/·rec_merge are loaded from ·scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_expr fn:
    [1, ..a, 2]

  | equals_fink fn:
    ·load ·scope, ·id'seq_append', fn ·seq_append, ·scope:
      ·apply ·seq_append, [], 1, ·state, fn ·v_0, ·state:
        ·load ·scope, ·id'seq_concat', fn ·seq_concat, ·scope:
          ·load ·scope, ·id'a', fn a, ·scope:
            ·apply ·seq_concat, ·v_0, a, ·state, fn ·v_1, ·state:
              ·load ·scope, ·id'seq_append', fn ·seq_append, ·scope:
                ·apply ·seq_append, ·v_1, 2, ·state, fn ·v_2, ·state:
                  ·ƒ_cont ·v_2, ·state

test 'seq literal leading spread', fn:
  expect cps_expr fn:
    [..a, ..b]

  | equals_fink fn:
    ·load ·scope, ·id'seq_concat', fn ·seq_concat, ·scope:
      ·load ·scope, ·id'a', fn a, ·scope:
        ·apply ·seq_concat, [], a, ·state, fn ·v_0, ·state:
          ·load ·scope, ·id'seq_concat', fn ·seq_concat, ·scope:
            ·load ·scope, ·id'b', fn b, ·scope:
              ·apply ·seq_concat, ·v_0, b, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state

test 'rec literal with spread', fn:
  expect cps_expr fn:
    {foo: a, ..b}

  | equals_fink fn:
    ·load ·scope, ·id'rec_put', fn ·rec_put, ·scope:
      ·load ·scope, ·id'a', fn a, ·scope:
        ·apply ·rec_put, {}, 'foo', a, ·state, fn ·v_0, ·state:
          ·load ·scope, ·id'rec_merge', fn ·rec_merge, ·scope:
            ·load ·scope, ·id'b', fn b, ·scope:
              ·apply ·rec_merge, ·v_0, b, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state

test 'rec literal leading spread', fn:
  expect cps_expr fn:
    {..a, ..b}

  | equals_fink fn:
    ·load ·scope, ·id'rec_merge', fn ·rec_merge, ·scope:
      ·load ·scope, ·id'a', fn a, ·scope:
        ·apply ·rec_merge, {}, a, ·state, fn ·v_0, ·state:
          ·load ·scope, ·id'rec_merge', fn ·rec_merge, ·scope:
            ·load ·scope, ·id'b', fn b, ·scope:
              ·apply ·rec_merge, ·v_0, b, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state


--- --- ---
varargs — spread preserved in IR
--- --- ---

# Spread is valid in the CPS IR — ·apply and fn params can contain ..arg / ..name.
# The IR stays readable Fink; codegen handles the actual flattening.

test 'varargs — call site spreads iterable', fn:
  expect cps_expr fn:
    foo 1, ..items

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·load ·scope, ·id'items', fn items, ·scope:
        ·apply foo, 1, ..items, ·state, fn ·v_0, ·state:
          ·ƒ_cont ·v_0, ·state


test 'call with spread — trailing iterable', fn:
  expect cps_expr fn:
    foo a, ..rest

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·load ·scope, ·id'a', fn a, ·scope:
        ·load ·scope, ·id'rest', fn rest, ·scope:
          ·apply foo, a, ..rest, ·state, fn ·v_0, ·state:
            ·ƒ_cont ·v_0, ·state


test 'call with spread — spread only', fn:
  expect cps_expr fn:
    foo ..items

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·load ·scope, ·id'items', fn items, ·scope:
        ·apply foo, ..items, ·state, fn ·v_0, ·state:
          ·ƒ_cont ·v_0, ·state


test 'call with spread — passes through from varargs fn', fn:
  expect cps_expr fn:
    fn ..args: foo ..args

  | equals_fink fn:
    ·closure ·scope,
      fn ..args, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'foo', fn foo, ·scope:
          ·load ·scope, ·id'args', fn args, ·scope:
            ·apply foo, ..args, ·state, fn ·v_1, ·state:
              ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


--- --- ---
module level
--- --- ---

test 'two bindings at module level', fn:
  expect cps_expr fn:
    foo = 1
    bar = 2

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·store ·scope, ·id'foo', 1, fn foo, ·scope:
          ·store ·scope, ·id'bar', 2, fn bar, ·scope:
            ·ƒ_cont bar, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


--- --- ---
free variable analysis
--- --- ---

# Free var pass — annotates ·closure scope arg with captured names.
#
# Convention:
#   plain `·scope` when fn captures nothing from outer scope
#   `{..·scope, ·op_plus, x}` — captures listed in ·load-encounter order
#     (ops first if encountered first; user names plain; params excluded)
#
# Analysis stops at nested ·closure boundaries (direct captures only).
# Params are excluded (they arrive as arguments, not from scope).
# Store-settled names within the fn body are also excluded from captures.

test 'free vars — fn with no captures', fn:
  expect cps_c_expr fn:
    fn a, b:
      a + b

  | equals_fink fn:
    ·closure ·scope,
      fn a, b, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'a', fn a, ·scope:
            ·load ·scope, ·id'b', fn b, ·scope:
              ·apply ·op_plus, a, b, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — fn with only literals', fn:
  expect cps_c_expr fn:
    fn x:
      42

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont: ·ƒ_cont 42, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures one outer var', fn:
  expect cps_c_expr fn:
    fn x:
      fn y:
        x + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn y, {..·scope, ·op_plus, x}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'y', fn y, ·scope:
                  ·apply ·op_plus, x, y, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures local binding', fn:
  expect cps_c_expr fn:
    fn x:
      z = x + 1
      fn y:
        z + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'x', fn x, ·scope:
            ·apply ·op_plus, x, 1, ·state, fn ·v_1, ·state:
              ·store ·scope, ·id'z', ·v_1, fn z, ·scope:
                ·closure ·scope,
                  fn y, {..·scope, ·op_plus, z}, ·state, ·ƒ_cont:
                    ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                      ·load ·scope, ·id'z', fn z, ·scope:
                        ·load ·scope, ·id'y', fn y, ·scope:
                          ·apply ·op_plus, z, y, ·state, fn ·v_3, ·state:
                            ·ƒ_cont ·v_3, ·state
                  fn ·v_2, ·chld_scope: ·ƒ_cont ·v_2, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — named outer, inner captures param', fn:
  expect cps_c_expr fn:
    add = fn x:
      fn y:
        x + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn y, {..·scope, ·op_plus, x}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'y', fn y, ·scope:
                  ·apply ·op_plus, x, y, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope:
        ·store ·scope, ·id'add', ·v_0, fn add, ·scope:
          ·ƒ_cont add, ·state


test 'free vars — two named fns no captures', fn:
  expect cps_c_expr fn:
    double = fn x: x + x
    triple = fn x: x + x + x

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'x', fn x, ·scope:
                  ·apply ·op_plus, x, x, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope:
            ·store ·scope, ·id'double', ·v_1, fn double, ·scope:
              ·closure ·scope,
                fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
                  ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                    ·load ·scope, ·id'x', fn x, ·scope:
                      ·load ·scope, ·id'x', fn x, ·scope:
                        ·apply ·op_plus, x, x, ·state, fn ·v_4, ·state:
                          ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                            ·load ·scope, ·id'x', fn x, ·scope:
                              ·apply ·op_plus, ·v_4, x, ·state, fn ·v_5, ·state:
                                ·ƒ_cont ·v_5, ·state
                fn ·v_3, ·chld_scope:
                  ·store ·scope, ·id'triple', ·v_3, fn triple, ·scope:
                    ·ƒ_cont triple, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — three levels of nesting', fn:
  expect cps_c_expr fn:
    fn a:
      fn b:
        fn c:
          a + b + c

  | equals_fink fn:
    ·closure ·scope,
      fn a, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn b, ·scope, ·state, ·ƒ_cont:
            ·closure ·scope,
              fn c, {..·scope, ·op_plus, a, b}, ·state, ·ƒ_cont:
                ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                  ·load ·scope, ·id'a', fn a, ·scope:
                    ·load ·scope, ·id'b', fn b, ·scope:
                      ·apply ·op_plus, a, b, ·state, fn ·v_3, ·state:
                        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                          ·load ·scope, ·id'c', fn c, ·scope:
                            ·apply ·op_plus, ·v_3, c, ·state, fn ·v_4, ·state:
                              ·ƒ_cont ·v_4, ·state
              fn ·v_2, ·chld_scope: ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


