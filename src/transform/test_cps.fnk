# NOTE: seq_append/seq_concat/rec_put/rec_merge are loaded from scope (not primitives)
# in cps_c — they're treated as regular identifier references.
test 'seq literal with spread', fn:
  expect cps_c_expr fn:
    [1, ..a, 2]

  | equals_fink fn:
    load scope, id'seq_append', fn ·seq_append, scope:
      apply ·seq_append, [], 1, state, fn v_0, state:
        load scope, id'seq_concat', fn ·seq_concat, scope:
          load scope, id'a', fn ·a, scope:
            apply ·seq_concat, v_0, ·a, state, fn v_1, state:
              load scope, id'seq_append', fn ·seq_append, scope:
                apply ·seq_append, v_1, 2, state, fn v_2, state:
                  ƒ_cont v_2, state

test 'seq literal leading spread', fn:
  expect cps_c_expr fn:
    [..a, ..b]

  | equals_fink fn:
    load scope, id'seq_concat', fn ·seq_concat, scope:
      load scope, id'a', fn ·a, scope:
        apply ·seq_concat, [], ·a, state, fn v_0, state:
          load scope, id'seq_concat', fn ·seq_concat, scope:
            load scope, id'b', fn ·b, scope:
              apply ·seq_concat, v_0, ·b, state, fn v_1, state:
                ƒ_cont v_1, state

test 'rec literal with spread', fn:
  expect cps_c_expr fn:
    {foo: a, ..b}

  | equals_fink fn:
    load scope, id'rec_put', fn ·rec_put, scope:
      load scope, id'a', fn ·a, scope:
        apply ·rec_put, {}, 'foo', ·a, state, fn v_0, state:
          load scope, id'rec_merge', fn ·rec_merge, scope:
            load scope, id'b', fn ·b, scope:
              apply ·rec_merge, v_0, ·b, state, fn v_1, state:
                ƒ_cont v_1, state

test 'rec literal leading spread', fn:
  expect cps_c_expr fn:
    {..a, ..b}

  | equals_fink fn:
    load scope, id'rec_merge', fn ·rec_merge, scope:
      load scope, id'a', fn ·a, scope:
