test 'two bindings at module level', fn:
  expect cps fn:
    foo = 1
    bar = 2

  , equals fn:
    module fn {register, ident}, $env, $state, $cont:
      register $env, ident'foo', 1, fn foo, $env:
        register $env, ident'bar', 2, fn bar, $env:
          $cont $env, $state

test 'forward ref', fn:
  expect cps fn:
    foo = fn a: foo a + 1
    foo 1

  , equals fn:
    module fn {register, resolve, apply, Fn, ident, op}, $env, $state, $cont:
      Fn $env
        fn a, $env, $state, $cont:
          resolve $env, op'+', fn $plus, $env:
            resolve $env, ident'foo', fn $foo, $env:
              apply $plus, a, 1, $state, fn $result, $state:
                $cont $result, $state
        fn fn_val, $child_env:
          register $child_env, ident'foo', fn_val, fn foo, $env:
            apply foo, 1, $state, fn _, $state:
              $cont $env, $state

test 'mutual recursion', fn:
  expect cps fn:
    is_even = fn n:
      match n:
        0: true
        _: is_odd n - 1

    is_odd  = fn n:
      match n:
        0: false,
        _: is_even n - 1

  , equals fn:
    module fn {register, resolve, apply, if, get_matcher, match_block, $panic, Fn, ident, op}, $env, $state, $cont:
      Fn $env, fn n, $env, $state, $cont:
        register $env, ident'n', n, fn n, $env:
          match_block n, $state,
            match_branch $env, fn v, $env, $fail, $success, $state:
              resolve $env, op'==', fn $eq, $env:
                apply $eq, v, 0, $state, fn $result, $state:
                  if $result,
                    fn $state: $success true, $state
                    fn $state: $fail $state
            match_branch $env, fn v, $env, $fail, $success, $state:
              resolve $env, op'-', fn $minus, $env:
                apply $minus, n, 1, $state, fn $v0, $state:
                  resolve $env, ident'is_odd', fn $is_odd, $env:
                    apply $is_odd, $v0, $state, $success
            fn $state:
              $panic 'no match', $state
            fn match_result, $state:
              $cont match_result, $state
      , fn is_even, $child_env:
        Fn $child_env, fn n, $env, $state, $cont:
          register $env, ident'n', n, fn n, $env:
            match_block n, $state,
              match_branch $env, fn v, $env, $fail, $success, $state:
                resolve $env, op'==', fn $eq, $env:
                  apply $eq, v, 0, $state, fn $result, $state:
                    if $result,
                      fn $state: $success false, $state
                      fn $state: $fail $state
              match_branch $env, fn v, $env, $fail, $success, $state:
                resolve $env, op'-', fn $minus, $env:
                  apply $minus, n, 1, $state, fn $v0, $state:
                    resolve $env, ident'is_even', fn $is_even, $env:
                      apply $is_even, $v0, $state, $success
              fn $state:
                $panic 'no match', $state
              fn match_result, $state:
                $cont match_result, $state
        , fn is_odd, $child_env:
          register $child_env, ident'is_even', is_even, fn is_even, $child_env:
            register $child_env, ident'is_odd', is_odd, fn is_odd, $env:
              $cont $env, $state