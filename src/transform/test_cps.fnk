scoping and sequential bindings
--- --- ---

test 'calling a local — still goes through load', fn:
  expect cps_c_expr fn:
    inc = fn x: x + 1
    inc 5

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        closure scope,
          fn ·x, scope, state, ƒ_cont:
            load scope, op'+', fn op_plus, scope:
              load scope, id'x', fn ·x, scope:
                apply op_plus, ·x, 1, state, fn v_2, state:
                  ƒ_cont v_2, state
          fn fn_1, chld_scope:
            store scope, id'inc', fn_1, fn ·inc, scope:
              load scope, id'inc', fn ·inc, scope:
                apply ·inc, 5, state, fn v_3, state:
                  ƒ_cont v_3, state
      fn fn_0, chld_scope: ƒ_cont fn_0, state


test 'chained binding is sequential store', fn:
  expect cps_c_expr fn:
    foo = spam = 1

  | equals_fink fn:
    store scope, id'spam', 1, fn ·spam, scope:
      store scope, id'foo', ·spam, fn ·foo, scope:
        ƒ_cont ·foo, state


# NOTE: Group with binding becomes an immediately-invoked zero-param closure;
# old IR used a `scope` primitive. Result of the call is bound to spam.
test 'group with binding — immediately-invoked closure', fn:
  expect cps_c_expr fn:
    spam = (
      ni = ham 1
      ni
    )

  | equals_fink fn:
    closure scope,
      fn scope, state, ƒ_cont:
        load scope, id'ham', fn ·ham, scope:
          apply ·ham, 1, state, fn v_1, state:
            store scope, id'ni', v_1, fn ·ni, scope:
              load scope, id'ni', fn ·ni, scope:
                ƒ_cont ·ni, state
      fn fn_0, chld_scope:
        apply fn_0, state, fn v_2, state:
          store scope, id'spam', v_2, fn ·spam, scope:
            ƒ_cont ·spam, state

