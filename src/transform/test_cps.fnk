multi-arg match
--- --- ---

test 'multi-arg match — fixed arity', fn:
  expect cps fn:
    match a, b:
      1, 2: 'one two'
      _, _: 'other'

  , equals fn:
    resolve $env, ident'a', fn a, $env:
      resolve $env, ident'b', fn b, $env:
        match_block a, b, $state,
          match_branch $env, fn v0, v1, $env, $fail, $success, $state:
            resolve $env, op'==', fn $eq, $env:
              apply $eq, v0, 1, $state, fn $r0, $state:
                if $r0,
                  fn $state:
                    apply $eq, v1, 2, $state, fn $r1, $state:
                      if $r1,
                        fn $state: $success 'one two', $state
                        fn $state: $fail $state
                  fn $state: $fail $state
          match_branch $env, fn v0, v1, $env, $fail, $success, $state:
            $success 'other', $state
          fn $state:
            $panic 'no match', $state
          fn match_result, $state:
            $cont match_result, $state

test 'multi-arg match — varargs arm', fn:
  expect cps fn:
    match a, ..rest:
      x, ..: 'has more'
      x, ..[]: 'exactly one'

  , equals fn:
    resolve $env, ident'a', fn a, $env:
      resolve $env, ident'rest', fn rest, $env:
        match_block a, ..rest, $state,
          match_branch $env, fn v0, ..vs, $env, $fail, $success, $state:
            match_has_more vs, $state,
              fn vs, $state: $success 'has more', $state
              fn vs, $state: $fail $state
          match_branch $env, fn v0, ..vs, $env, $fail, $success, $state:
            match_len vs, 0, $state,
              fn vs, $state: $success 'exactly one', $state
              fn vs, $state: $fail $state
          fn $state:
            $panic 'no match', $state
          fn match_result, $state:
            $cont match_result, $state

