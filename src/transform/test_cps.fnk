--- --- ---
CPS IR — design notes and transform examples
--- --- ---

# Every function has the full calling convention: fn ..args, env, state, ƒ_cont:
# env  — captured env (record of captured bindings; carried by the closure object)
# state — opaque mutable state (I/O, heap, effects; threaded through every call)
# ƒ_cont  — continuation (what to do with the result)
#
# Syntax convention:
#   prim args, fn …: — CPS call (threads env/state through continuation)
#
# Primitives:
#   store env, id'name', val, fn name, env:
#                              — bind name→value; ƒ_cont receives the value as the named param
#   load env, id'name', fn val, env:
#                              — look up name
#   apply func, arg1, ..args, state, fn $result, state:
#                              — dispatch to closure; closure carries its own env;
#                                state is threaded; ..args spreads an iterable as trailing args
#   closure env, fn a, ..rest, env, state, ƒ_cont: body
#   , fn fn_val, chld_env:   — always CPS; fn_val is the closure, chld_env is its
#                                unsettled env; store names into chld_env for forward refs;
#                                pass fn_val to ƒ_cont when no names need pre-storeing;
#                                ..rest collects trailing args as an iterable (no materialization)
#   scope env, fn env, ƒ_ok: body, fn result, state: ƒ_cont
#                              — create child scope; infallible; result delivered to outer ƒ_cont
#   seq_append seq, val, state, fn $seq, state:
#                              — append single element; [] is a valid literal base
#   seq_concat seq, other, state, fn $seq, state:
#                              — spread/concat; protocol-dispatches; leading spread uses a as base
#   rec_put rec, id'key', val, state, fn $rec, state:
#                              — set a field; {} is a valid literal base
#   rec_merge rec, other, state, fn $rec, state:
#                              — merge/spread; protocol-dispatches; leading spread uses a as base
#   range_excl start, end, state, fn $range, state:
#                              — exclusive range (0..10)
#   range_incl start, end, state, fn $range, state:
#                              — inclusive range (0...10)
#   match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
#                              — arm with child scope; takes parent env, passes child env
#                                to body; used as arms inside match_block
#
# apply does NOT receive env from caller — closure carries its own.
# state IS passed by caller — effects thread through every call.
#
# CPS IR nodes (subset of Fink AST):
#   closure      — fn params: body  (body is a single chained expression)
#   Apply   — apply func, arg1, ..., state, fn $result, state:
#   Bind    — name = value  (irrefutable; ƒ_cont is the next expression in the chain)
#   Try     — preserved for optimizer
#   Ident   — variable reference
#   literals — LitBool, LitInt, LitFloat, LitDecimal, LitStr
#              str_raw'...' — tagged template where str_raw is a built-in tag (always in scope)
#
# Eliminated during CPS:
#   Pipe, Partial, Group (transparent), Block, BindRight, Spread, Range,
#   Member, LitSeq, LitRec, ChainedCmp, StrTempl → all become Apply chains
#
# Pattern matching — Matchable protocol:
#   Pattern shapes ([..], {..}, etc.) are known at compile time. The value's type
#   is queried via the protocol registry: "does type-of-foo implement Matchable
#   for SeqPattern?" — matcher IS the type check, no separate is_seq needed.
#
#   Matcher primitives (always available, injected like load/apply):
#     matcher val, 'SeqPattern', state, fn m, ƒ_err, state:
#                              — acquire matcher context m (or fail = type mismatch)
#     match_pop_at m, i, state, fn m, val, ƒ_err, state:
#                              — extract element at index i; returns updated m
#     match_pop_field m, id'key', state, fn m, val, ƒ_err, state:
#                              — extract field by key; returns updated m
#     match_done m, state, fn m, state: ..., fn m, state:
#                              — two conts: non-empty rest / empty rest
#     match_rest m, state, fn m, rest, state:
#                              — consume all remaining into rest binding
#     match_len m, n, state, fn m, state: ..., fn m, state:
#                              — check exact remaining length (SeqMatcher only)
#
#   m is threaded through every call — immutable context, each op returns new m.
#
#   match_bind val, state,
#     fn v, state, ƒ_err, ƒ_ok: ...  — current env; irrefutable; ƒ_err → panic
#     fn state: panic ...               — fail handler
#     fn match_result, state: ...        — result ƒ_cont (called by ƒ_ok)
#
#   match_block val, state,
#     match_branch env, fn v, env, state, ƒ_err, ƒ_ok: ...  — one or more arms
#     fn state: panic ...               — exhaustion handler
#     fn match_result, state: ...        — result ƒ_cont (called by ƒ_ok)
#
#   ƒ_err    = fn state:         — arm failed; wired to next arm / exhaustion by match_block
#   ƒ_ok = fn result, state: — arm succeeded; wired to result ƒ_cont by match_block
#   Arms are tried in order; fail fast.
#
#
#  TODO: add support for full modules, which would use something like:
#     module fn {store, id, ..}, env, state, ƒ_cont:
#       # return the `env` so that names can be exported
#      ƒ_cont env


{test, expect, equals} = import '@fink/testing.fnk'
{cps, module} = import '@fink/compiler/transform'


--- --- ---
LitSeq — sequence construction
--- --- ---

test 'seq literal', fn:
  expect cps fn:
    [a, b, c]

  , equals fn:
    load env, id'a', fn ·a, env:
      seq_append [], ·a, state, fn v_seq, state:
        load env, id'b', fn ·b, env:
          seq_append v_seq, ·b, state, fn v_seq, state:
            load env, id'c', fn ·c, env:
              seq_append v_seq, ·c, state, fn v_seq, state:
                ƒ_cont v_seq, state

test 'seq literal with spread', fn:
  expect cps fn:
    [1, ..a, 2]

  , equals fn:
    seq_append [], 1, state, fn v_seq, state:
      load env, id'a', fn ·a, env:
        seq_concat v_seq, ·a, state, fn v_seq, state:
          seq_append v_seq, 2, state, fn v_seq, state:
            ƒ_cont v_seq, state

test 'seq literal leading spread', fn:
  expect cps fn:
    [..a, ..b]

  , equals fn:
    load env, id'a', fn ·a, env:
      load env, id'b', fn ·b, env:
        seq_concat ·a, ·b, state, fn v_seq, state:
          ƒ_cont v_seq, state


--- --- ---
LitRec — record construction
--- --- ---

test 'rec literal', fn:
  expect cps fn:
    {foo: a, bar: b}

  , equals fn:
    load env, id'a', fn ·a, env:
      rec_put {}, id'foo', ·a, state, fn v_rec, state:
        load env, id'b', fn ·b, env:
          rec_put v_rec, id'bar', ·b, state, fn v_rec, state:
            ƒ_cont v_rec, state


test 'rec literal with spread', fn:
  expect cps fn:
    {foo: a, ..b}

  , equals fn:
    load env, id'a', fn ·a, env:
      rec_put {}, id'foo', ·a, state, fn v_rec, state:
        load env, id'b', fn ·b, env:
          rec_merge v_rec, ·b, state, fn v_rec, state:
            ƒ_cont v_rec, state

test 'rec literal leading spread', fn:
  expect cps fn:
    {..a, ..b}

  , equals fn:
    load env, id'a', fn ·a, env:
      load env, id'b', fn ·b, env:
        rec_merge ·a, ·b, state, fn v_rec, state:
          ƒ_cont v_rec, state


--- --- ---
Range — range construction
--- --- ---

test 'exclusive range', fn:
  expect cps fn:
    0..10

  , equals fn:
    range_excl 0, 10, state, fn v_range, state:
      ƒ_cont v_range, state

test 'inclusive range', fn:
  expect cps fn:
    0...10

  , equals fn:
    range_incl 0, 10, state, fn v_range, state:
      ƒ_cont v_range, state




--- --- ---
StrTempl — string interpolation, StrRawTempl — tagged template
--- --- ---

test 'string interpolation', fn:
  expect cps fn:
    'hello ${name}!'

  , equals fn:
    load env, id'name', fn ·name, env:
      apply str_fmt, str_raw'hello ', ·name, str_raw'!', state, ƒ_cont

test 'string interpolation multiple exprs', fn:
  expect cps fn:
    '${a} + ${b} = ${c}'

  , equals fn:
    load env, id'a', fn ·a, env:
      load env, id'b', fn ·b, env:
        load env, id'c', fn ·c, env:
          apply str_fmt, ·a, str_raw' + ', ·b, str_raw' = ', ·c, state, ƒ_cont

test 'tagged template', fn:
  expect cps fn:
    fmt'hello ${name}!'

  , equals fn:
    load env, id'fmt', fn ·fmt, env:
      load env, id'name', fn ·name, env:
        apply ·fmt, str_raw'hello ', ·name, str_raw'!', state, ƒ_cont


--- --- ---
closure — closure captures env, apply does not receive env from caller
--- --- ---

test 'closure over outer variable', fn:
  expect cps fn:
    foo = fn a:
      ni = fn b:
        a + b
      ni

  , equals fn:
    closure env,
      fn ·a, env, state, ƒ_cont:
        store env, id'a', ·a, fn ·a, env:
          closure env,
            fn ·b, env, state, ƒ_cont:
              store env, id'b', ·b, fn ·b, env:
                load env, op'+', fn op_plus, env:
                  load env, id'a', fn ·a, env:
                    apply op_plus, ·a, ·b, state, ƒ_cont
            fn ·ni, chld_env:
              store chld_env, id'ni', ·ni, fn ·ni, env:
                ƒ_cont ·ni, state
      fn ·foo, chld_env:
        store chld_env, id'foo', ·foo, fn ·foo, env:
          ƒ_cont ·foo, state

--- --- ---
UnaryOp — loadd and applied like a single-arg function
--- --- ---

test 'boolean not', fn:
  expect cps fn:
    not x

  , equals fn:
    load env, id'not', fn op_not, env:
      load env, id'x', fn ·x, env:
        apply op_not, ·x, state, ƒ_cont

test 'numeric negation', fn:
  expect cps fn:
    -x

  , equals fn:
    load env, op'-', fn op_neg, env:
      load env, id'x', fn ·x, env:
        apply op_neg, ·x, state, ƒ_cont


--- --- ---
Member — static and computed field access
--- --- ---

test 'static member access', fn:
  expect cps fn:
    foo.bar

  , equals fn:
    load env, op'.', fn op_dot, env:
      load env, id'foo', fn ·foo, env:
        apply op_dot, ·foo, id'bar', state, ƒ_cont

test 'computed member access', fn:
  expect cps fn:
    foo.(key)

  , equals fn:
    load env, op'.', fn op_dot, env:
      load env, id'foo', fn ·foo, env:
        load env, id'key', fn ·key, env:
          apply op_dot, ·foo, ·key, state, ƒ_cont

test 'chained member access', fn:
  expect cps fn:
    a.b.c

  , equals fn:
    load env, op'.', fn op_dot, env:
      load env, id'a', fn ·a, env:
        apply op_dot, ·a, id'b', state, fn v_0, state:
          apply op_dot, v_0, id'c', state, ƒ_cont


--- --- ---
chained comparison
--- --- ---

test 'chained comparison', fn:
  expect cps fn:
    1 < x < 10

  , equals fn:
    load env, op'<', fn op_lt, env:
      load env, id'x', fn ·x, env:
        apply op_lt, 1, ·x, state, fn v_0, state:
          if v_0,
            fn state: apply op_lt, ·x, 10, state, ƒ_cont
            fn state: ƒ_cont false, state


--- --- ---
literals and bindings
--- --- ---

test 'simple literal binding', fn:
  expect cps fn:
    foo = 1

  , equals fn:
    store env, id'foo', 1, fn ·foo, env:
      ƒ_cont ·foo, state

test 'sequential bindings — ƒ_cont is next expression in chain', fn:
  expect cps fn:
    foo = 1
    bar = foo + 1

  , equals fn:
    store env, id'foo', 1, fn ·foo, env:
      load env, op'+', fn op_plus, env:
        load env, id'foo', fn ·foo, env:
          apply op_plus, ·foo, 1, state, fn ·bar, state:
            store env, id'bar', ·bar, fn ·bar, env:
              ƒ_cont ·bar, state

test 'binding rhs is a call', fn:
  expect cps fn:
    foo = add 1, 2

  , equals fn:
    load env, id'add', fn ·add, env:
      apply ·add, 1, 2, state, fn ·foo, state:
        store env, id'foo', ·foo, fn ·foo, env:
          ƒ_cont ·foo, state

--- --- ---
bind right
--- --- ---

test 'bind right — simple id', fn:
  expect cps fn:
    1 |= foo

  , equals fn:
    match_bind 1, state,
      fn v, state, ƒ_err, ƒ_ok:
        store env, id'foo', v, fn ·foo, env:
          ƒ_ok env, state
      fn state: panic 'no match', state
      fn v_result, state: ƒ_cont v_result, state

test 'bind right — destructuring pattern', fn:
  expect cps fn:
    [a, b] |= foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind foo, state,
        fn v, state, ƒ_err, ƒ_ok:
          # TODO: matcher, v, [], ...?
          matcher v, 'SeqPattern', state,
            fn m, ƒ_err, state:
              match_pop_at m, 0, state,
                fn m, a, ƒ_err, state:
                  match_pop_at m, 1, state,
                    fn m, b, ƒ_err, state:
                      match_len m, 0, state,
                        fn m, state:
                          store env, id'a', ·a, fn ·a, env:
                            store env, id'b', ·b, fn ·b, env:
                              ƒ_ok env, state
                        fn m, state: ƒ_err state
        fn state: panic 'no match', state
        fn v_result, state: ƒ_cont v_result, state

--- --- ---
try — early escape on error
--- --- ---

test 'try — bare expression', fn:
  expect cps fn:
    try foo bar

  , equals fn:
    load env, id'foo', fn ·foo, env:
      load env, id'bar', fn ·bar, env:
        apply ·foo, ·bar, state, fn res, state:
          err res, state,
            fn e, state: ƒ_cont e, state
            fn v_0, state: ƒ_cont v_0, state

test 'try — result bound, code continues', fn:
  expect cps fn:
    ni = try foo bar
    ni + 1

  , equals fn:
    load env, id'foo', fn ·foo, env:
      load env, id'bar', fn ·bar, env:
        apply ·foo, ·bar, state, fn res, state:
          err res, state,
            fn e, state: ƒ_cont e, state
            fn ·ni, state:
              store env, id'ni', ·ni, fn ·ni, env:
                load env, op'+', fn op_plus, env:
                  load env, id'ni', fn ·ni, env:
                    apply op_plus, ·ni, 1, state, ƒ_cont

--- --- ---
functions
--- --- ---

test 'identity function', fn:
  expect cps fn:
    fn x: x

  , equals fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          ƒ_cont ·x, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state

test 'function with operator in body', fn:
  expect cps fn:
    fn x: x + 1
  , equals fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          load env, op'+', fn op_plus, env:
            apply op_plus, ·x, 1, state, ƒ_cont
      fn ·fn_val, _: ƒ_cont ·fn_val, state

test 'function binding', fn:
  expect cps fn:
    inc = fn x: x + 1

  , equals fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          load env, op'+', fn op_plus, env:
            apply op_plus, ·x, 1, state, ƒ_cont
      fn ·inc, chld_env:
        store chld_env, id'inc', ·inc, fn ·inc, env:
          ƒ_cont ·inc, state

test 'multi-param function', fn:
  expect cps fn:
    fn x, y: x + y

  , equals fn:
    closure env,
      fn ·x, ·y, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          store env, id'y', ·y, fn ·y, env:
            load env, op'+', fn op_plus, env:
              apply op_plus, ·x, ·y, state, ƒ_cont
      fn ·fn_val, _: ƒ_cont ·fn_val, state

--- --- ---
varargs functions
--- --- ---

test 'varargs — collect rest', fn:
  expect cps fn:
    fn a, ..rest: rest

  , equals fn:
    closure env,
      fn ·a, ..·rest, env, state, ƒ_cont:
        store env, id'a', ·a, fn ·a, env:
          store env, id'rest', ·rest, fn ·rest, env:
            ƒ_cont ·rest, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state

test 'varargs — call site spreads iterable', fn:
  expect cps fn:
    foo 1, ..items

  , equals fn:
    load env, id'foo', fn ·foo, env:
      load env, id'items', fn ·items, env:
        apply ·foo, 1, ..·items, state, ƒ_cont

test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps fn:
    fn a, [1, ..b]: b

  , equals fn:
    closure env,
      fn ·a, ..·rest, env, state, ƒ_cont:
        store env, id'a', ·a, fn ·a, env:
          match_bind rest, state,
            fn v, state, ƒ_err, ƒ_ok:
              matcher v, 'SeqPattern', state,
                fn m, ƒ_err, state:
                  match_pop_at m, 0, state,
                    fn m, v_0, ƒ_err, state:
                      load env, op'==', fn op_eq, env:
                        apply op_eq, v_0, 1, state, fn v_result, state:
                          if v_result,
                            fn state:
                              match_rest m, state,
                                fn m, b, state:
                                  store env, id'b', ·b, fn ·b, env:
                                    ƒ_ok env, state
                            fn state: ƒ_err state
            fn state: panic 'no match', state
            fn v_result, state: ƒ_cont v_result, state
      fn ·fn_val, _: ƒ_cont ·fn_val, state

--- --- ---
application
--- --- ---

test 'simple call', fn:
  expect cps fn:
    add 1, 2

  , equals fn:
    load env, id'add', fn ·add, env:
      apply ·add, 1, 2, state, ƒ_cont

test 'nested call — inner result threaded to outer', fn:
  expect cps fn:
    add (mul 2, 3), 1

  , equals fn:
    load env, id'mul', fn ·mul, env:
      apply ·mul, 2, 3, state, fn v_0, state:
        load env, id'add', fn ·add, env:
          apply ·add, v_0, 1, state, ƒ_cont

test 'calling a local — still goes through load', fn:
  expect cps fn:
    inc = fn x: x + 1
    inc 5

  , equals fn:
    closure env,
      fn ·x, env, state, ƒ_cont:
        store env, id'x', ·x, fn ·x, env:
          load env, op'+', fn op_plus, env:
            apply op_plus, ·x, 1, state, ƒ_cont
      fn ·inc, chld_env:
        store chld_env, id'inc', ·inc, fn ·inc, env:
          apply ·inc, 5, state, ƒ_cont

test 'call with spread — trailing iterable', fn:
  expect cps fn:
    foo a, ..rest

  , equals fn:
    load env, id'foo', fn ·foo, env:
      load env, id'a', fn ·a, env:
        load env, id'rest', fn ·rest, env:
          apply ·foo, ·a, ..·rest, state, ƒ_cont

test 'call with spread — spread only', fn:
  expect cps fn:
    foo ..items

  , equals fn:
    load env, id'foo', fn ·foo, env:
      load env, id'items', fn ·items, env:
        apply ·foo, ..·items, state, ƒ_cont

test 'call with spread — passes through from varargs fn', fn:
  expect cps fn:
    fn ..args: foo ..args

  , equals fn:
    closure env,
      fn ..·args, env, state, ƒ_cont:
        store env, id'args', ·args, fn ·args, env:
          load env, id'foo', fn ·foo, env:
            apply ·foo, ..·args, state, ƒ_cont
      fn ·fn_val, _: ƒ_cont ·fn_val, state

--- --- ---
pipe — inlined to nested calls
--- --- ---

test 'simple pipe', fn:
  expect cps fn:
    x | f

  , equals fn:
    load env, id'f', fn ·f, env:
      apply ·f, ·x, state, ƒ_cont

test 'pipe chain', fn:
  expect cps fn:
    x | f | g

  , equals fn:
    load env, id'f', fn ·f, env:
      apply ·f, ·x, state, fn v_0, state:
        load env, id'g', fn ·g, env:
          apply ·g, v_0, state, ƒ_cont

--- --- ---
sequential expressions — each result threaded forward
--- --- ---

test 'three sequential bindings', fn:
  expect cps fn:
    a = 1
    b = 2
    c = a + b

  , equals fn:
    store env, id'a', 1, fn ·a, env:
      store env, id'b', 2, fn ·b, env:
        load env, op'+', fn op_plus, env:
          load env, id'a', fn ·a, env:
            load env, id'b', fn ·b, env:
              apply op_plus, ·a, ·b, state, fn ·c, state:
                store env, id'c', ·c, fn ·c, env:
                  ƒ_cont ·c, state

test 'expression result discarded', fn:
  expect cps fn:
    foo = 1
    log 'hello'
    bar = 2

  , equals fn:
    store env, id'foo', 1, fn ·foo, env:
      load env, id'log', fn ·log, env:
        apply ·log, 'hello', state, fn _, state:
          store env, id'bar', 2, fn ·bar, env:
            ƒ_cont ·bar, state


--- --- ---
scoping
--- --- ---

test 'child scopes', fn:
  expect cps fn:
    match n:
      a > 1:
        ni = a # ni is only available in the body of this arm
        ni

  , equals fn:
    match_block n, state,
      match_branch env, fn v, env, state, ƒ_err, ƒ_ok:
        load env, op'>', fn op_gt, env:
          store env, id'a', v, fn ·a, env:
            apply op_gt, ·a, 1, state, fn v_result, state:
              if v_result,
                fn state:
                  store env, id'ni', ·a, fn ·ni, env:
                    ƒ_ok ·ni, state
                fn state: ƒ_err state
      fn state: panic "no match", state
      fn match_result, state: ƒ_cont match_result, state


test 'group with binding creates child scope', fn:
  expect cps fn:
    spam = ( # creates a block scope
      ni = ham 1
      ni # ni does not leak out
    )

  , equals fn:
    scope env,
      fn env, ƒ_ok:
        load env, id'ham', fn ·ham, env:
          apply ·ham, 1, state, fn ·ni, state:
            store env, id'ni', ·ni, fn ·ni, env:
              load env, id'ni', fn ·ni, env:
                ƒ_ok ·ni, state
      fn ·spam, state:
        store env, id'spam', ·spam, fn ·spam, env:
          ƒ_cont ·spam, state


test 'chained binding is sequential store without child scope', fn:
  expect cps fn:
    foo = spam = 1

  , equals fn:
    store env, id'spam', 1, fn ·spam, env:
      store env, id'foo', ·spam, fn ·foo, env:
        ƒ_cont ·foo, state


--- --- ---
pattern bindings
--- --- ---

test 'irrefutable binding with guard', fn:
  expect cps fn:
    x > 2 = foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind ·foo, state,
        fn x, state, ƒ_err, ƒ_ok:
          load env, op'>', fn op_cmp, env:
            apply op_cmp, ·x, 2, state, fn v_result, state:
              if v_result,
                fn state:
                  store env, id'x', ·x, fn ·x, env:
                    ƒ_ok env, state
                fn state: ƒ_err state
        fn state: panic 'pattern mismatch', state
        fn match_result, state: ƒ_cont match_result, state

test 'seq pattern', fn:
  expect cps fn:
    [a, 1] = foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind ·foo, state,
        fn seq, state, ƒ_err, ƒ_ok:
          matcher seq, 'SeqPattern', state,
            fn m, ƒ_err, state:
              match_len m, 2, state,
                fn m, state:
                  match_pop_at m, 0, state,
                    fn m, a, state:
                      match_pop_at m, 1, state,
                        fn m, v_item1, state:
                          load env, op'==', fn op_eq, env:
                            apply op_eq, v_item1, 1, state, fn v_result, state:
                              if v_result,
                                fn state:
                                  store env, id'a', ·a, fn ·a, env:
                                    ƒ_ok env, state
                                fn state: ƒ_err state
                        fn m, state: ƒ_err state
                    fn m, state: ƒ_err state
                fn m, state: ƒ_err state
            fn state: ƒ_err state
        fn state: panic 'pattern mismatch', state
        fn match_result, state: ƒ_cont match_result, state

test 'rec pattern', fn:
  expect cps fn:
    {bar} = foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind ·foo, state,
        fn rec, state, ƒ_err, ƒ_ok:
          matcher rec, 'RecPattern', state,
            fn m, ƒ_err, state:
              match_pop_field m, id'bar', state,
                fn m, bar, state:
                  store env, id'bar', ·bar, fn ·bar, env:
                    ƒ_ok env, state
                fn m, state: ƒ_err state
            fn state: ƒ_err state
        fn state: panic 'pattern mismatch', state
        fn match_result, state: ƒ_cont match_result, state

test 'seq pattern with non-empty rest', fn:
  expect cps fn:
    [a, ..] = foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind ·foo, state,
        fn seq, state, ƒ_err, ƒ_ok:
          matcher seq, 'SeqPattern', state,
            fn m, ƒ_err, state:
              match_pop_at m, 0, state,
                fn m, a, state:
                  match_done m, state,
                    fn m, state: ƒ_err state
                    fn m, state:
                      store env, id'a', ·a, fn ·a, env:
                        ƒ_ok env, state
                fn m, state: ƒ_err state
            fn state: ƒ_err state
        fn state: panic 'pattern mismatch', state
        fn match_result, state: ƒ_cont match_result, state

test 'seq pattern with bound rest', fn:
  expect cps fn:
    [a, ..rest] = foo

  , equals fn:
    load env, id'foo', fn ·foo, env:
      match_bind ·foo, state,
        fn seq, state, ƒ_err, ƒ_ok:
          matcher seq, 'SeqPattern', state,
            fn m, ƒ_err, state:
              match_pop_at m, 0, state,
                fn m, a, state:
                  match_rest m, state,
                    fn m, rest, state:
                      store env, id'a', ·a, fn ·a, env:
                        store env, id'rest', ·rest, fn ·rest, env:
                          ƒ_ok env, state
                fn m, state: ƒ_err state
            fn state: ƒ_err state
        fn state: panic 'pattern mismatch', state
        fn match_result, state: ƒ_cont match_result, state

