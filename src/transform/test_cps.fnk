--- --- ---
CPS IR — design notes and transform examples
--- --- ---

# Every function has the full calling convention: fn args, $env, $state, $cont:
# $env  — captured env (record of captured bindings; carried by the closure object)
# $state — opaque mutable state (I/O, heap, effects; threaded through every call)
# $cont  — continuation (what to do with the result)
#
# Syntax convention:
#   prim args, fn …: — CPS call (threads env/state through continuation)
#
# Primitives:
#   register $env, ident'name', val, fn name, $env:
#                              — bind name→value; cont receives the value as the named param
#   resolve $env, ident'name', fn val, $env:
#                              — look up name
#   apply func, arg1, ..args, $state, fn $result, $state:
#                              — dispatch to closure; closure carries its own $env;
#                                $state is threaded; ..args spreads an iterable as trailing args
#   Fn $env, fn a, ..rest, $env, $state, $cont: body
#   , fn fn_val, $child_env:   — always CPS; fn_val is the closure, $child_env is its
#                                unsettled env; register names into $child_env for forward refs;
#                                pass fn_val to $cont when no names need pre-registering;
#                                ..rest collects trailing args as an iterable (no materialization)
#   child_env $env, fn $env, $success: body, fn result, $state: cont
#                              — create child scope; infallible; result delivered to outer cont
#   seq_append seq, val, $state, fn $seq, $state:
#                              — append single element; [] is a valid literal base
#   seq_concat seq, other, $state, fn $seq, $state:
#                              — spread/concat; protocol-dispatches; leading spread uses a as base
#   rec_set rec, ident'key', val, $state, fn $rec, $state:
#                              — set a field; {} is a valid literal base
#   rec_merge rec, other, $state, fn $rec, $state:
#                              — merge/spread; protocol-dispatches; leading spread uses a as base
#   range_excl start, end, $state, fn $range, $state:
#                              — exclusive range (0..10)
#   range_incl start, end, $state, fn $range, $state:
#                              — inclusive range (0...10)
#   match_branch $env, fn v, $env, $fail, $success, $state:
#                              — arm with child scope; takes parent $env, passes child $env
#                                to body; used as arms inside match_block
#
# apply does NOT receive $env from caller — closure carries its own.
# $state IS passed by caller — effects thread through every call.
#
# CPS IR nodes (subset of Fink AST):
#   Fn      — fn params: body  (body is a single chained expression)
#   Apply   — apply func, arg1, ..., $state, fn $result, $state:
#   Bind    — name = value  (irrefutable; cont is the next expression in the chain)
#   Try     — preserved for optimizer
#   Ident   — variable reference
#   literals — LitBool, LitInt, LitFloat, LitDecimal, LitStr
#              str_raw'...' — tagged template where str_raw is a built-in tag (always in scope)
#
# Eliminated during CPS:
#   Pipe, Partial, Group (transparent), Block, BindRight, Spread, Range,
#   Member, LitSeq, LitRec, ChainedCmp, StrTempl → all become Apply chains
#
# Pattern matching — Matchable protocol:
#   Pattern shapes ([..], {..}, etc.) are known at compile time. The value's type
#   is queried via the protocol registry: "does type-of-foo implement Matchable
#   for SeqPattern?" — get_matcher IS the type check, no separate is_seq needed.
#
#   Matcher primitives (always available, injected like resolve/apply):
#     get_matcher val, 'SeqPattern', $state, fn m, $fail, $state:
#                              — acquire matcher context m (or fail = type mismatch)
#     match_pop_at m, i, $state, fn m, val, $fail, $state:
#                              — extract element at index i; returns updated m
#     match_pop_field m, ident'key', $state, fn m, val, $fail, $state:
#                              — extract field by key; returns updated m
#     match_has_more m, $state, fn m, $state: ..., fn m, $state:
#                              — two conts: non-empty rest / empty rest
#     match_drain m, $state, fn m, rest, $state:
#                              — consume all remaining into rest binding
#     match_len m, n, $state, fn m, $state: ..., fn m, $state:
#                              — check exact remaining length (SeqMatcher only)
#
#   m is threaded through every call — immutable context, each op returns new m.
#
#   match_single val, $state,
#     fn v, $fail, $success, $state: ...  — current env; irrefutable; $fail → $panic
#     fn $state: $panic ...               — fail handler
#     fn match_result, $state: ...        — result cont (called by $success)
#
#   match_block val, $state,
#     match_branch $env, fn v, $env, $fail, $success, $state: ...  — one or more arms
#     fn $state: $panic ...               — exhaustion handler
#     fn match_result, $state: ...        — result cont (called by $success)
#
#   $fail    = fn $state:         — arm failed; wired to next arm / exhaustion by match_block
#   $success = fn result, $state: — arm succeeded; wired to result cont by match_block
#   Arms are tried in order; fail fast.

{test, expect, equals} = import '@fink/testing.fnk'
{cps, module} = import '@fink/compiler/transform'


--- --- ---
LitSeq — sequence construction
--- --- ---

test 'seq literal', fn:
  expect cps fn:
    [a, b, c]

  , equals fn:
    module fn {resolve, seq_append, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        seq_append [], a, $state, fn $seq, $state:
          resolve $env, ident'b', fn b, $env:
            seq_append $seq, b, $state, fn $seq, $state:
              resolve $env, ident'c', fn c, $env:
                seq_append $seq, c, $state, fn $seq, $state:
                  $cont $seq, $state

test 'seq literal with spread', fn:
  expect cps fn:
    [1, ..a, 2]

  , equals fn:
    module fn {resolve, seq_append, seq_concat, ident}, $env, $state, $cont:
      seq_append [], 1, $state, fn $seq, $state:
        resolve $env, ident'a', fn a, $env:
          seq_concat $seq, a, $state, fn $seq, $state:
            seq_append $seq, 2, $state, fn $seq, $state:
              $cont $seq, $state

test 'seq literal leading spread', fn:
  # leading spread: a owns construction, no [] needed
  expect cps fn:
    [..a, ..b]

  , equals fn:
    module fn {resolve, seq_concat, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        resolve $env, ident'b', fn b, $env:
          seq_concat a, b, $state, fn $seq, $state:
            $cont $seq, $state


--- --- ---
LitRec — record construction
--- --- ---

test 'rec literal', fn:
  expect cps fn:
    {foo: a, bar: b}

  , equals fn:
    module fn {resolve, rec_set, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        rec_set {}, ident'foo', a, $state, fn $rec, $state:
          resolve $env, ident'b', fn b, $env:
            rec_set $rec, ident'bar', b, $state, fn $rec, $state:
              $cont $rec, $state


test 'rec literal with spread', fn:
  expect cps fn:
    {foo: a, ..b}

  , equals fn:
    module fn {resolve, rec_set, rec_merge, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        rec_set {}, ident'foo', a, $state, fn $rec, $state:
          resolve $env, ident'b', fn b, $env:
            rec_merge $rec, b, $state, fn $rec, $state:
              $cont $rec, $state

test 'rec literal leading spread', fn:
  # leading spread: a owns construction, no {} needed
  expect cps fn:
    {..a, ..b}

  , equals fn:
    module fn {resolve, rec_merge, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        resolve $env, ident'b', fn b, $env:
          rec_merge a, b, $state, fn $rec, $state:
            $cont $rec, $state


--- --- ---
Range — range construction
--- --- ---

test 'exclusive range', fn:
  expect cps fn:
    0..10

  , equals fn:
    module fn {range_excl}, $env, $state, $cont:
      range_excl 0, 10, $state, fn $range, $state:
        $cont $range, $state

test 'inclusive range', fn:
  expect cps fn:
    0...10

  , equals fn:
    module fn {range_incl}, $env, $state, $cont:
      range_incl 0, 10, $state, fn $range, $state:
        $cont $range, $state




--- --- ---
StrTempl — string interpolation, StrRawTempl — tagged template
--- --- ---

test 'string interpolation', fn:
  expect cps fn:
    'hello ${name}!'

  , equals fn:
    module fn {resolve, apply, str_fmt, str_raw, ident}, $env, $state, $cont:
      resolve $env, ident'name', fn name, $env:
        apply str_fmt, str_raw'hello ', name, str_raw'!', $state, $cont

test 'string interpolation multiple exprs', fn:
  expect cps fn:
    '${a} + ${b} = ${c}'

  , equals fn:
    module fn {resolve, apply, str_fmt, str_raw, ident}, $env, $state, $cont:
      resolve $env, ident'a', fn a, $env:
        resolve $env, ident'b', fn b, $env:
          resolve $env, ident'c', fn c, $env:
            apply str_fmt, str_raw'', a, str_raw' + ', b, str_raw' = ', c, str_raw'', $state, $cont

test 'tagged template', fn:
  expect cps fn:
    fmt'hello ${name}!'

  , equals fn:
    module fn {resolve, apply, str_raw, ident}, $env, $state, $cont:
      resolve $env, ident'fmt', fn fmt, $env:
        resolve $env, ident'name', fn name, $env:
          apply fmt, str_raw'hello ', name, str_raw'!', $state, $cont


--- --- ---
closure — Fn captures env, apply does not receive env from caller
--- --- ---

test 'closure over outer variable', fn:
  expect cps fn:
    foo = fn a:
      ni = fn b:
        a + b
      ni

  , equals fn:
    module fn {register, resolve, apply, Fn, ident, op}, $env, $state, $cont:
      Fn $env, fn a, $env, $state, $cont:
        register $env, ident'a', a, fn a, $env:
          Fn $env, fn b, $env, $state, $cont:
            register $env, ident'b', b, fn b, $env:
              resolve $env, op'+', fn $plus, $env:
                resolve $env, ident'a', fn $a, $env:
                  apply $plus, $a, b, $state, fn $result, $state:
                    $cont $result, $state
          , fn ni, $child_env:
            register $child_env, ident'ni', ni, fn ni, $env:
              $cont ni, $state
      , fn foo, $child_env:
        register $child_env, ident'foo', foo, fn foo, $env:
          $cont $env, $state

--- --- ---
UnaryOp — resolved and applied like a single-arg function
--- --- ---

test 'boolean not', fn:
  expect cps fn:
    not x

  , equals fn:
    resolve $env, ident'not', fn $not, $env:
      resolve $env, ident'x', fn x, $env:
        apply $not, x, $state, $cont

test 'numeric negation', fn:
  expect cps fn:
    -x

  , equals fn:
    resolve $env, op'-', fn $neg, $env:
      resolve $env, ident'x', fn x, $env:
        apply $neg, x, $state, $cont


--- --- ---
Member — static and computed field access
--- --- ---

test 'static member access', fn:
  expect cps fn:
    foo.bar

  , equals fn:
    resolve $env, op'.', fn $dot, $env:
      resolve $env, ident'foo', fn foo, $env:
        apply $dot, foo, ident'bar', $state, $cont

test 'computed member access', fn:
  expect cps fn:
    foo.(key)

  , equals fn:
    resolve $env, op'.', fn $dot, $env:
      resolve $env, ident'foo', fn foo, $env:
        resolve $env, ident'key', fn key, $env:
          apply $dot, foo, key, $state, $cont

test 'chained member access', fn:
  expect cps fn:
    a.b.c

  , equals fn:
    resolve $env, op'.', fn $dot, $env:
      resolve $env, ident'a', fn a, $env:
        apply $dot, a, ident'b', $state, fn $v0, $state:
          apply $dot, $v0, ident'c', $state, $cont


--- --- ---
chained comparison
--- --- ---

test 'chained comparison', fn:
  expect cps fn:
    1 < x < 10

  , equals fn:
    resolve $env, op'<', fn $lt, $env:
      resolve $env, ident'x', fn x, $env:
        apply $lt, 1, x, $state, fn $v0, $state:
          if $v0,
            fn $state:
              apply $lt, x, 10, $state, $cont
            fn $state:
              $cont false, $state


--- --- ---
literals and bindings
--- --- ---

test 'simple literal binding', fn:
  expect cps fn:
    foo = 1

  , equals fn:
    module fn {register, ident}, $env, $state, $cont:
      register $env, ident'foo', 1, fn foo, $env:
        $cont $env, $state

test 'sequential bindings — cont is next expression in chain', fn:
  expect cps fn:
    foo = 1
    bar = foo + 1

  , equals fn:
    module fn {register, resolve, apply, ident, op}, $env, $state, $cont:
      register $env, ident'foo', 1, fn foo, $env:
        resolve $env, op'+', fn $plus, $env:
          resolve $env, ident'foo', fn $foo, $env:
            apply $plus, $foo, 1, $state, fn bar, $state:
              register $env, ident'bar', bar, fn bar, $env:
                $cont $env, $state

test 'binding rhs is a call', fn:
  expect cps fn:
    foo = add 1, 2

  , equals fn:
    module fn {register, resolve, apply, ident}, $env, $state, $cont:
      resolve $env, ident'add', fn $add, $env:
        apply $add, 1, 2, $state, fn foo, $state:
          register $env, ident'foo', foo, fn foo, $env:
            $cont $env, $state

--- --- ---
bind right
--- --- ---

test 'bind right — simple ident', fn:
  expect cps fn:
    1 |= foo

  , equals fn:
    module fn {register, match_single, $panic, ident}, $env, $state, $cont:
      match_single 1, $state,
        fn v, $fail, $success, $state:
          register $env, ident'foo', v, fn foo, $env:
            $success $env, $state
        fn $state: $panic 'no match', $state
        fn $result, $state: $cont $result, $state

test 'bind right — destructuring pattern', fn:
  expect cps fn:
    [a, b] |= foo

  , equals fn:
    module fn {register, resolve, match_single, get_matcher, match_pop_at, match_len, $panic, ident}, $env, $state, $cont:
      resolve $env, ident'foo', fn foo, $env:
        match_single foo, $state,
          fn v, $fail, $success, $state:
            get_matcher v, 'SeqPattern', $state,
              fn m, $fail, $state:
                match_pop_at m, 0, $state,
                  fn m, a, $fail, $state:
                    match_pop_at m, 1, $state,
                      fn m, b, $fail, $state:
                        match_len m, 0, $state,
                          fn m, $state:
                            register $env, ident'a', a, fn a, $env:
                              register $env, ident'b', b, fn b, $env:
                                $success $env, $state
                          fn m, $state: $fail $state
          fn $state: $panic 'no match', $state
          fn $result, $state: $cont $result, $state

--- --- ---
try — early escape on error
--- --- ---

test 'try — bare expression', fn:
  expect cps fn:
    try foo bar

  , equals fn:
    module fn {resolve, apply, handle_err, ident}, $env, $state, $cont:
      resolve $env, ident'foo', fn foo, $env:
        apply foo, bar, $state, fn res, $state:
          handle_err res, $state,
            fn e, $state: $cont e, $state
            fn $v0, $state: $cont $v0, $state

test 'try — result bound, code continues', fn:
  expect cps fn:
    ni = try foo bar
    ni + 1

  , equals fn:
    module fn {register, resolve, apply, handle_err, ident, op}, $env, $state, $cont:
      resolve $env, ident'foo', fn foo, $env:
        apply foo, bar, $state, fn res, $state:
          handle_err res, $state,
            fn e, $state: $cont e, $state
            fn ni, $state:
              register $env, ident'ni', ni, fn ni, $env:
                resolve $env, op'+', fn $plus, $env:
                  apply $plus, ni, 1, $state, $cont

--- --- ---
functions
--- --- ---

test 'identity function', fn:
  expect cps fn:
    fn x: x

  , equals fn:
    Fn $env, fn x, $env, $state, $cont:
      register $env, ident'x', x, fn x, $env:
        $cont x, $state
    , fn fn_val, _:
      $cont fn_val, $state

test 'function with operator in body', fn:
  expect cps fn:
    fn x: x + 1
  , equals fn:
    Fn $env, fn x, $env, $state, $cont:
      register $env, ident'x', x, fn x, $env:
        resolve $env, op'+', fn $plus, $env:
          apply $plus, x, 1, $state, fn $result, $state:
            $cont $result, $state
    , fn fn_val, _:
      $cont fn_val, $state

test 'function binding', fn:
  expect cps fn:
    inc = fn x: x + 1

  , equals fn:
    Fn $env, fn x, $env, $state, $cont:
      register $env, ident'x', x, fn x, $env:
        resolve $env, op'+', fn $plus, $env:
          apply $plus, x, 1, $state, fn $result, $state:
            $cont $result, $state
    , fn inc, $child_env:
      register $child_env, ident'inc', inc, fn inc, $env:
        $cont inc, $state

test 'multi-param function', fn:
  expect cps fn:
    fn x, y: x + y

  , equals fn:
    Fn $env, fn x, y, $env, $state, $cont:
      register $env, ident'x', x, fn x, $env:
        register $env, ident'y', y, fn y, $env:
          resolve $env, op'+', fn $plus, $env:
            apply $plus, x, y, $state, fn $result, $state:
              $cont $result, $state
    , fn fn_val, _:
      $cont fn_val, $state

--- --- ---
varargs functions
--- --- ---

test 'varargs — collect rest', fn:
  expect cps fn:
    fn a, ..rest: rest

  , equals fn:
    Fn $env, fn a, ..rest, $env, $state, $cont:
      register $env, ident'a', a, fn a, $env:
        register $env, ident'rest', rest, fn rest, $env:
          $cont rest, $state
    , fn fn_val, _:
      $cont fn_val, $state

test 'varargs — call site spreads iterable', fn:
  expect cps fn:
    foo 1, ..items

  , equals fn:
    resolve $env, ident'foo', fn foo, $env:
      resolve $env, ident'items', fn items, $env:
        apply foo, 1, ..items, $state, $cont

test 'varargs — complex destructuring desugars to pattern in body', fn:
  expect cps fn:
    fn a, [1, ..b]: b

  , equals fn:
    Fn $env, fn a, ..rest, $env, $state, $cont:
      register $env, ident'a', a, fn a, $env:
        match_single rest, $state,
          fn v, $fail, $success, $state:
            get_matcher v, 'SeqPattern', $state,
              fn m, $fail, $state:
                match_pop_at m, 0, $state,
                  fn m, $v0, $fail, $state:
                    resolve $env, op'==', fn $eq, $env:
                      apply $eq, $v0, 1, $state, fn $result, $state:
                        if $result,
                          fn $state:
                            match_drain m, $state,
                              fn m, b, $state:
                                register $env, ident'b', b, fn b, $env:
                                  $success $env, $state
                          fn $state: $fail $state
          fn $state: $panic 'no match', $state
          fn $result, $state: $cont $result, $state
    , fn fn_val, _:
      $cont fn_val, $state

--- --- ---
application
--- --- ---

test 'simple call', fn:
  expect cps fn:
    add 1, 2

  , equals fn:
    resolve $env, ident'add', fn $add, $env:
      apply $add, 1, 2, $state, $cont

test 'nested call — inner result threaded to outer', fn:
  expect cps fn:
    add (mul 2, 3), 1

  , equals fn:
    resolve $env, ident'mul', fn $mul, $env:
      apply $mul, 2, 3, $state, fn $v0, $state:
        resolve $env, ident'add', fn $add, $env:
          apply $add, $v0, 1, $state, $cont

test 'calling a local — still goes through resolve', fn:
  expect cps fn:
    inc = fn x: x + 1
    inc 5

  , equals fn:
    Fn $env, fn x, $env, $state, $cont:
      register $env, ident'x', x, fn x, $env:
        resolve $env, op'+', fn $plus, $env:
          apply $plus, x, 1, $state, fn $result, $state:
            $cont $result, $state
    , fn inc, $child_env:
      register $child_env, ident'inc', inc, fn inc, $env:
        apply inc, 5, $state, $cont

test 'call with spread — trailing iterable', fn:
  expect cps fn:
    foo a, ..rest

  , equals fn:
    resolve $env, ident'foo', fn foo, $env:
      resolve $env, ident'a', fn a, $env:
        resolve $env, ident'rest', fn rest, $env:
          apply foo, a, ..rest, $state, $cont

test 'call with spread — spread only', fn:
  expect cps fn:
    foo ..items

  , equals fn:
    resolve $env, ident'foo', fn foo, $env:
      resolve $env, ident'items', fn items, $env:
        apply foo, ..items, $state, $cont

test 'call with spread — passes through from varargs fn', fn:
  expect cps fn:
    fn ..args: foo ..args

  , equals fn:
    Fn $env, fn ..args, $env, $state, $cont:
      register $env, ident'args', args, fn args, $env:
        resolve $env, ident'foo', fn foo, $env:
          apply foo, ..args, $state, $cont
    , fn fn_val, _:
      $cont fn_val, $state

--- --- ---
pipe — inlined to nested calls
--- --- ---

test 'simple pipe', fn:
  expect cps fn:
    x | f

  , equals fn:
    resolve $env, ident'f', fn $f, $env:
      apply $f, x, $state, $cont

test 'pipe chain', fn:
  expect cps fn:
    x | f | g

  , equals fn:
    resolve $env, ident'f', fn $f, $env:
      apply $f, x, $state, fn $v0, $state:
        resolve $env, ident'g', fn $g, $env:
          apply $g, $v0, $state, $cont

--- --- ---
sequential expressions — each result threaded forward
--- --- ---

test 'three sequential bindings', fn:
  expect cps fn:
    a = 1
    b = 2
    c = a + b

  , equals fn:
    module fn {register, resolve, apply, ident, op}, $env, $state, $cont:
      register $env, ident'a', 1, fn a, $env:
        register $env, ident'b', 2, fn b, $env:
          resolve $env, op'+', fn $plus, $env:
            resolve $env, ident'a', fn $a, $env:
              resolve $env, ident'b', fn $b, $env:
                apply $plus, $a, $b, $state, fn c, $state:
                  register $env, ident'c', c, fn c, $env:
                    $cont $env, $state

test 'expression result discarded', fn:
  expect cps fn:
    foo = 1
    log 'hello'
    bar = 2

  , equals fn:
    module fn {register, resolve, apply, ident}, $env, $state, $cont:
      register $env, ident'foo', 1, fn foo, $env:
        resolve $env, ident'log', fn $log, $env:
          apply $log, 'hello', $state, fn _, $state:
            register $env, ident'bar', 2, fn bar, $env:
              $cont $env, $state


--- --- ---
scoping
--- --- ---

test 'child scopes', fn:
  expect cps fn:
    match n:
      a > 1:
        ni = a # ni is only available in the body of this arm
        ni

  , equals fn:
    module fn {register, resolve, apply, if, match_block, match_branch, $panic, ident, op}, $env, $state, $cont:
      match_block n, $state,
        match_branch $env, fn v, $env, $fail, $success, $state:
          resolve $env, op'>', fn $gt, $env:
            register $env, ident'a', v, fn a, $env:
              apply $gt, a, 1, $state, fn $result, $state:
                if $result,
                  fn $state:
                    register $env, ident'ni', a, fn ni, $env:
                      $success ni, $state
                  fn $state:
                    $fail $state
        fn $state:
          $panic "no match", $state
        fn match_result, $state:
          $cont match_result, $state


test 'group with binding creates child scope', fn:
  expect cps fn:
    spam = ( # creates a block scope
      ni = ham 1
      ni # ni does not leak out
    )

  , equals fn:
    module fn {register, resolve, apply, child_env, match_single, $panic, ident}, $env, $state, $cont:
      child_env $env,
        fn $env, $success:
          resolve $env, ident'ham', fn ham, $env:
            apply ham, 1, $state, fn $result, $state:
              register $env, ident'ni', $result, fn ni, $env:
                $success ni, $state
        fn $block_result, $state:
          match_single $block_result, $state,
            fn $v, $fail, $success, $state:
              register $env, ident'spam', $v, fn spam, $env:
                $success spam, $state
            fn $state: $panic 'pattern mismatch', $state
            fn $match_result, $state:
              $cont $match_result, $state


test 'chained binding is sequential register without child scope', fn:
  expect cps fn:
    foo = spam = 1

  , equals fn:
    module fn {register, resolve, apply, match_single, $panic, ident}, $env, $state, $cont:
      match_single 1, $state,
        fn spam, $fail, $success, $state:
          register $env, ident'spam', spam, fn spam, $env:
            match_single spam, $state,
              fn foo, $fail, $success, $state:
                register $env, ident'foo', foo, fn foo, $env:
                  $success foo, $state
              fn $state:
                $panic 'pattern mismatch', $state
              fn match_result, $state:
                $cont match_result, $state
        fn $state:
          $panic 'pattern mismatch', $state
        fn match_result, $state:
          $cont match_result, $state


