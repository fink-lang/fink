      resolve $env, ident'foo', fn $foo, $env:
        match_single $foo, $state,
          fn x, $fail, $success, $state:
            resolve $env, op'>', fn $cmp, $env:
              apply $cmp, x, 2, $state, fn $result, $state:
                if $result,
                  fn $state:
                    register $env, ident'x', x, fn x, $env:
                      $success $env, $state
                  fn $state:
                    $fail $state
          fn $state:
            $panic 'pattern mismatch', $state
          fn match_result, $state:
            $cont match_result, $state

test 'seq pattern', fn:
  expect cps fn:
    [a, 1] = foo

  , equals fn:
    module fn {register, resolve, apply, if, get_matcher, match_len, match_pop_at, match_single, $panic, ident, op}, $env, $state, $cont:
      resolve $env, ident'foo', fn $foo, $env:
        match_single $foo, $state,
          fn seq, $fail, $success, $state:
            get_matcher seq, 'SeqPattern', $state,
              fn m, $fail, $state:
                match_len m, 2, $state,
                  fn m, $state:
                    match_pop_at m, 0, $state,
                      fn m, a, $state:
                        match_pop_at m, 1, $state,
                          fn m, $item1, $state:
                            resolve $env, op'==', fn $eq, $env:
                              apply $eq, $item1, 1, $state, fn $result, $state:
                                if $result,
                                  fn $state:
                                    register $env, ident'a', a, fn a, $env:
                                      $success $env, $state
                                  fn $state:
                                    $fail $state
                          fn m, $state:
                            $fail $state
                      fn m, $state:
                        $fail $state
                  fn m, $state:
                    $fail $state
              fn $state:
                $fail $state
          fn $state:
            $panic 'pattern mismatch', $state
          fn match_result, $state:
            $cont match_result, $state

