--- --- ---
cps_c IR — free variable analysis tests
--- --- ---

# Free var pass — annotates ·closure scope arg with captured names.
#
# Convention:
#   plain `·scope` when fn captures nothing from outer scope
#   `{..·scope, ·op_plus, x}` — captures listed in ·load-encounter order
#     (ops first if encountered first; user names plain; params excluded)
#
# Analysis stops at nested ·closure boundaries (direct captures only).
# Params are excluded (they arrive as arguments, not from scope).
# ·match_store-settled names within the fn body are also excluded from captures.
#
# Test format:
#   test 'name', fn:
#     expect cps_free_vars fn:
#       <fink source>
#
#     | equals_fink fn:
#       <expected cps output>

{test, expect, equals_fink, cps_free_vars} = import '!fake'
{·load, ·match_store, ·ƒ_cont, ·state, ·scope, ·id, ·op, ·apply, ·closure} = import '!fake'

--- --- ---
free variable analysis
--- --- ---

test 'free vars — fn with no captures', fn:
  expect cps_free_vars fn:
    fn a, b:
      a + b

  | equals_fink fn:
    ·closure ·scope,
      fn a, b, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'a', fn a, ·scope:
            ·load ·scope, ·id'b', fn b, ·scope:
              ·apply ·op_plus, a, b, ·state, fn ·v_1, ·state:
                ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — fn with only literals', fn:
  expect cps_free_vars fn:
    fn x:
      42

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont: ·ƒ_cont 42, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures one outer var', fn:
  expect cps_free_vars fn:
    fn x:
      fn y:
        x + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn y, {..·scope, ·op_plus, x}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'y', fn y, ·scope:
                  ·apply ·op_plus, x, y, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — closure captures local binding', fn:
  expect cps_free_vars fn:
    fn x:
      z = x + 1
      fn y:
        z + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
          ·load ·scope, ·id'x', fn x, ·scope:
            ·apply ·op_plus, x, 1, ·state, fn ·v_1, ·state:
              ·match_store ·scope, ·id'z', ·v_1, fn z, ·scope:
                ·closure ·scope,
                  fn y, {..·scope, ·op_plus, z}, ·state, ·ƒ_cont:
                    ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                      ·load ·scope, ·id'z', fn z, ·scope:
                        ·load ·scope, ·id'y', fn y, ·scope:
                          ·apply ·op_plus, z, y, ·state, fn ·v_3, ·state:
                            ·ƒ_cont ·v_3, ·state
                  fn ·v_2, ·chld_scope: ·ƒ_cont ·v_2, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — named outer, inner captures param', fn:
  expect cps_free_vars fn:
    add = fn x:
      fn y:
        x + y

  | equals_fink fn:
    ·closure ·scope,
      fn x, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn y, {..·scope, ·op_plus, x}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'y', fn y, ·scope:
                  ·apply ·op_plus, x, y, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope:
        ·match_store ·scope, ·id'add', ·v_0, fn add, ·scope:
          ·ƒ_cont add, ·state


test 'free vars — two named fns no captures', fn:
  expect cps_free_vars fn:
    double = fn x: x + x
    triple = fn x: x + x + x

  | equals_fink fn:
    ·closure ·scope,
      fn ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
              ·load ·scope, ·id'x', fn x, ·scope:
                ·load ·scope, ·id'x', fn x, ·scope:
                  ·apply ·op_plus, x, x, ·state, fn ·v_2, ·state:
                    ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope:
            ·match_store ·scope, ·id'double', ·v_1, fn double, ·scope:
              ·closure ·scope,
                fn x, {..·scope, ·op_plus}, ·state, ·ƒ_cont:
                  ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                    ·load ·scope, ·id'x', fn x, ·scope:
                      ·load ·scope, ·id'x', fn x, ·scope:
                        ·apply ·op_plus, x, x, ·state, fn ·v_4, ·state:
                          ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                            ·load ·scope, ·id'x', fn x, ·scope:
                              ·apply ·op_plus, ·v_4, x, ·state, fn ·v_5, ·state:
                                ·ƒ_cont ·v_5, ·state
                fn ·v_3, ·chld_scope:
                  ·match_store ·scope, ·id'triple', ·v_3, fn triple, ·scope:
                    ·ƒ_cont triple, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — three levels of nesting', fn:
  expect cps_free_vars fn:
    fn a:
      fn b:
        fn c:
          a + b + c

  | equals_fink fn:
    ·closure ·scope,
      fn a, ·scope, ·state, ·ƒ_cont:
        ·closure ·scope,
          fn b, ·scope, ·state, ·ƒ_cont:
            ·closure ·scope,
              fn c, {..·scope, ·op_plus, a, b}, ·state, ·ƒ_cont:
                ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                  ·load ·scope, ·id'a', fn a, ·scope:
                    ·load ·scope, ·id'b', fn b, ·scope:
                      ·apply ·op_plus, a, b, ·state, fn ·v_3, ·state:
                        ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                          ·load ·scope, ·id'c', fn c, ·scope:
                            ·apply ·op_plus, ·v_3, c, ·state, fn ·v_4, ·state:
                              ·ƒ_cont ·v_4, ·state
              fn ·v_2, ·chld_scope: ·ƒ_cont ·v_2, ·state
          fn ·v_1, ·chld_scope: ·ƒ_cont ·v_1, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


--- --- ---
free vars — match arms
--- --- ---

test 'free vars — match arm bindings are local', fn:
  expect cps_free_vars fn:
    fn val:
      match val:
        1: 'one'
        n: n

  | equals_fink fn:
    ·closure ·scope,
      fn val, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'val', fn val, ·scope:
          ·match_block val, ·panic, ·state,
            ·match_branch fn ·v_1, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
              ·match_value ·v_1, 1, ·ƒ_fail, fn ·scope, ·state:
                ·ƒ_cont 'one', ·state
            ·match_branch fn ·v_1, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
              ·match_store ·scope, ·id'n', ·v_1, fn n, ·scope:
                ·load ·scope, ·id'n', fn n, ·scope:
                  ·ƒ_cont n, ·state
            fn ·v_3, ·scope, ·state: ·ƒ_cont ·v_3, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state


test 'free vars — closure inside match arm captures arm binding', fn:
  expect cps_free_vars fn:
    fn val:
      match val:
        [head, ..tail]:
          fn x: head + x

  | equals_fink fn:
    ·closure ·scope,
      fn val, ·scope, ·state, ·ƒ_cont:
        ·load ·scope, ·id'val', fn val, ·scope:
          ·match_block val, ·panic, ·state,
            ·match_branch fn ·v_1, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
              ·match_seq ·v_1, ·ƒ_fail, fn ·m_2, ·scope, ·state:
                ·match_next ·m_2, ·ƒ_fail, fn ·v_3, ·m_4, ·scope, ·state:
                  ·match_store ·scope, ·id'head', ·v_3, fn head, ·scope:
                    ·match_rest ·m_4, ·ƒ_fail, fn ·v_5, ·scope, ·state:
                      ·match_store ·scope, ·id'tail', ·v_5, fn tail, ·scope:
                        ·closure ·scope,
                          fn x, {..·scope, ·op_plus, head}, ·state, ·ƒ_cont:
                            ·load ·scope, ·op'+', fn ·op_plus, ·scope:
                              ·load ·scope, ·id'head', fn head, ·scope:
                                ·load ·scope, ·id'x', fn x, ·scope:
                                  ·apply ·op_plus, head, x, ·state, fn ·v_8, ·state:
                                    ·ƒ_cont ·v_8, ·state
                          fn ·v_7, ·chld_scope: ·ƒ_cont ·v_7, ·state
            fn ·v_9, ·scope, ·state: ·ƒ_cont ·v_9, ·state
      fn ·v_0, ·chld_scope: ·ƒ_cont ·v_0, ·state
