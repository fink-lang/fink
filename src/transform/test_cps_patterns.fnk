seq patterns
--- --- ---

test 'seq — empty', fn:
  expect cps_expr fn:
    [] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_done ·m_0, ·panic, fn ·v_1, ·scope, ·state:
          ·ƒ_cont ·v_1, ·state


test 'seq — nested empty', fn:
  expect cps_expr fn:
    [a, []] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_next ·m_0, ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'a', ·v_1, fn a, ·scope:
            ·match_next ·m_2, ·panic, fn ·v_3, ·m_4, ·scope, ·state:
              ·match_seq ·v_3, ·panic, fn ·m_5, ·scope, ·state:
                ·match_done ·m_5, ·panic, fn ·v_6, ·scope, ·state:
                  ·match_done ·m_4, ·panic, fn ·v_7, ·scope, ·state:
                    ·ƒ_cont ·v_7, ·state


test 'seq — exact two elements', fn:
  expect cps_expr fn:
    [a, b] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_next ·m_0, ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'a', ·v_1, fn a, ·scope:
            ·match_next ·m_2, ·panic, fn ·v_3, ·m_4, ·scope, ·state:
              ·match_store ·scope, ·id'b', ·v_3, fn b, ·scope:
                ·match_done ·m_4, ·panic, fn ·v_5, ·scope, ·state:
                  ·ƒ_cont ·v_5, ·state



test 'seq — lone spread non-empty discard', fn:
  expect cps_expr fn:
    [..] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_not_done ·m_0, ·panic, fn ·scope, ·state:
          ·ƒ_cont ·v_1, ·state


test 'seq — spread non-empty bound', fn:
  expect cps_expr fn:
    [..rest] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_rest ·m_0, ·panic, fn ·v_1, ·scope, ·state:
          ·match_store ·scope, ·id'rest', ·v_1, fn rest, ·scope:
            ·ƒ_cont ·v_2, ·state


test 'seq — head then spread discard', fn:
  expect cps_expr fn:
    [head, ..] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_next ·m_0, ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'head', ·v_1, fn head, ·scope:
            ·match_not_done ·m_2, ·panic, fn ·scope, ·state:
              ·ƒ_cont ·v_3, ·state


test 'seq — head then spread bound', fn:
  expect cps_expr fn:
    [head, ..tail] = foo

  | equals_fink fn:
    ·load ·scope, ·id'foo', fn foo, ·scope:
      ·match_seq foo, ·panic, fn ·m_0, ·scope, ·state:
        ·match_next ·m_0, ·panic, fn ·v_1, ·m_2, ·scope, ·state:
          ·match_store ·scope, ·id'head', ·v_1, fn head, ·scope:
            ·match_rest ·m_2, ·panic, fn ·v_3, ·scope, ·state:
              ·match_store ·scope, ·id'tail', ·v_3, fn tail, ·scope:
                ·ƒ_cont ·v_4, ·state


