        ·match_branch fn ·v_0, ·scope, ·state, ·ƒ_cont, ·ƒ_fail:
          ·match_seq ·v_0, ·ƒ_fail, fn ·m_1, ·scope, ·state:
            ·match_next ·m_1, ·ƒ_fail, fn ·v_2, ·m_3, ·scope, ·state:
              ·match_store ·scope, ·id'a', ·v_2, fn a, ·scope:
                ·match_next ·m_3, ·ƒ_fail, fn ·v_4, ·m_5, ·scope, ·state:
                  ·match_store ·scope, ·id'b', ·v_4, fn b, ·scope:
                    ·match_done ·m_5, ·ƒ_fail, fn ·v_6, ·scope, ·state:
                      ·load ·scope, ·id'a', fn a, ·scope:
                        ·ƒ_cont a, ·state
        fn ·v_7, ·scope, ·state: ·ƒ_cont ·v_7, ·state

