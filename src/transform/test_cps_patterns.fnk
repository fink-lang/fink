rec patterns
--- --- ---

test 'rec — empty', fn:
  expect cps_pat fn:
    {} = foo

  | equals_fink fn:
    ·match_rec foo, ·panic, fn ·rec, ·scope, ·state:
      ·match_done ·rec, ·panic, fn ·scope, ·state:
        body


test 'rec — non-empty', fn:
  expect cps_pat fn:
    {..} = foo

  | equals_fink fn:
    ·match_rec foo, ·panic, fn ·rec, ·scope, ·state:
      ·match_not_done ·rec, ·panic, fn ·scope, ·state:
        body


test 'rec — partial match', fn:
  expect cps_pat fn:
    {x, y} = point

  | equals_fink fn:
    ·match_rec point, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'x', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn x, ·scope, ·state:
          ·match_field ·rec, 'y', ·panic, fn ·v_1, ·rec, ·scope, ·state:
            ·match_bind ·v_1, ·panic, fn y, ·scope, ·state:
              body


test 'rec — field rename', fn:
  expect cps_pat fn:
    {x, y: z} = point

  | equals_fink fn:
    ·match_rec point, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'x', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn x, ·scope, ·state:
          ·match_field ·rec, 'y', ·panic, fn ·v_1, ·rec, ·scope, ·state:
            ·match_bind ·v_1, ·panic, fn z, ·scope, ·state:
              body


test 'rec — open rest discarded', fn:
  expect cps_pat fn:
    {bar, ..} = foo

  | equals_fink fn:
    ·match_rec foo, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'bar', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn bar, ·scope, ·state:
          body


test 'rec — open rest bound', fn:
  expect cps_pat fn:
    {bar, ..rest} = foo

  | equals_fink fn:
    ·match_rec foo, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'bar', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn bar, ·scope, ·state:
          ·match_rest ·rec, ·panic, fn ·v_1, ·scope, ·state:
            ·match_bind ·v_1, ·panic, fn rest, ·scope, ·state:
              body


test 'rec — closed exact', fn:
  expect cps_pat fn:
    {bar, ..{}} = foo

  | equals_fink fn:
    ·match_rec foo, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'bar', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn bar, ·scope, ·state:
          ·match_done ·rec, ·panic, fn ·scope, ·state:
            body


test 'rec — closed with sub-pattern', fn:
  expect cps_pat fn:
    {foo, ..{bar, spam}} = x

  | equals_fink fn:
    ·match_rec x, ·panic, fn ·rec, ·scope, ·state:
      ·match_field ·rec, 'foo', ·panic, fn ·v_0, ·rec, ·scope, ·state:
        ·match_bind ·v_0, ·panic, fn foo, ·scope, ·state:
          ·match_rest ·rec, ·panic, fn ·v_1, ·scope, ·state:
            ·match_rec ·v_1, ·panic, fn ·rec, ·scope, ·state:
              ·match_field ·rec, 'bar', ·panic, fn ·v_2, ·rec, ·scope, ·state:
                ·match_bind ·v_2, ·panic, fn bar, ·scope, ·state:
                  ·match_field ·rec, 'spam', ·panic, fn ·v_3, ·rec, ·scope, ·state:
                    ·match_bind ·v_3, ·panic, fn spam, ·scope, ·state:
                      ·match_done ·rec, ·panic, fn ·scope, ·state:
                        body


