  ShrubNi = Shrub or Ni

  Signed = i8 or i16 or i32 or i64
  Unsigned = variant u8, u16, u32, u64
  Int = Signed or Unsigned
  Float = variant f8, f16, f32, f64
  Num = Float or Int

  ByteList = type [..u8]
  NumRec = type {..Num}
