{test, equals} = import 'std/testing.fnk'
{init_ctx, get_ctx_for} = import 'std/effects.fnk'

{write, read, stdin, stdout, stderr, with_custom_io} = import 'std/io.fnk'



test_read = fn filenum, _:
  'hello from ${filenum}'


test_write = fn filenum, data:
  upd_test_io fn ctx:
    {(filenum): writes} = ctx
    {(filenum): [..writes, data]}
  filenum

upd_test_io = init_ctx test_write, {(stdout): [], (stderr): []}

setup = fn:
  upd_test_io fn _:
    {(stdout): [], (stderr): []}


test 'stdout multiple messages', fn:
  setup _

  with_custom_io test_read, test_write, fn:
    write stdout, 'hello'
    write stdout, 'world'

  equals
    get_ctx_for test_write
    {(stdout): ['hello', 'world'], (stderr): []}


test 'stderr multiple messages', fn:
  setup _

  with_custom_io test_read, test_write, fn:
    write stderr, 'hello'
    write stderr, 'world'

  equals
    get_ctx_for test_write
    {(stderr): ['hello', 'world'], (stdout): []}


test 'read from stdin', fn:
  data = with_custom_io test_read, test_write, fn:
    read stdin, 1024

  equals
    data
    'hello from 0'
