{test, skip, equals, not_equals} = import 'std/testing.fnk'

{set} = import 'std/set.fnk'


# --- Construction ---

test 'set construct returns without trap', fn:
  equals
    set 1, 2, 3, 2
    set 1, 2, 3

# TODO bug with spread
skip test 'set construct with spread args', fn:
  equals
    set ..[1, 2, 2]
    set 1, 2


# --- Set algebra (formatted) ---

test 'set union via +', fn:
  s1 = set 1, 2
  s2 = set 2, 3
  equals
    s1 + s2
    set 1, 2, 3

test 'set union via or', fn:
  s1 = set 1, 2
  s2 = set 2, 3
  equals
    s1 or s2
    set 1, 2, 3

test 'set intersect via and', fn:
  s1 = set 1, 2, 3
  s2 = set 2, 3, 4
  equals
    s1 and s2
    set 2, 3

test 'set difference via -', fn:
  s1 = set 1, 2, 3
  s2 = set 2, 3
  equals
    s1 - s2
    set 1

test 'set sym diff via xor', fn:
  s1 = set 1, 2, 3
  s2 = set 2, 3, 4
  equals
    s1 xor s2
    set 1, 4


# --- Structural equality ---

test 'set eq via ==', fn:
  s1 = set 1, 2, 3
  s2 = set 3, 1, 2
  equals
    s1
    s2

test 'set nested in rec equal', fn:
  equals
    {a: set 1, 2}
    {a: set 2, 1}

test 'set nested in rec unequal', fn:
  not_equals
    {a: set 1, 2}
    {a: set 1, 3}

test 'set nested in list equal', fn:
  equals
    [set 1, 2]
    [set 2, 1]

test 'set neq via !=', fn:
  s1 = set 1, 2
  s2 = set 1, 2, 3
  not_equals
    s1
    s2


# --- Subset / superset / membership / disjoint ---

test 'set subset via <=', fn:
  s1 = set 1, 2
  s2 = set 1, 2, 3
  equals
    s1 <= s2
    true

test 'set superset via >=', fn:
  s1 = set 1, 2, 3
  s2 = set 1, 2
  equals
    s1 >= s2
    true

test 'set strict subset via <', fn:
  s1 = set 1, 2
  s2 = set 1, 2, 3
  equals
    s1 < s2
    true

test 'set strict subset equal is false', fn:
  s1 = set 1, 2
  s2 = set 1, 2
  equals
    s1 < s2
    false

test 'set strict superset via >', fn:
  s1 = set 1, 2, 3
  s2 = set 1, 2
  equals
    s1 > s2
    true

test 'set membership via in', fn:
  s = set 1, 2, 3
  equals
    2 in s
    true

test 'set non-membership via in', fn:
  s = set 1, 2, 3
  equals
    4 in s
    false

test 'set non-membership via not in', fn:
  s = set 1, 2, 3
  equals
    4 not in s
    true

test 'set disjoint via ><', fn:
  s1 = set 1, 2
  s2 = set 3, 4
  equals
    s1 >< s2
    true

test 'set non-disjoint via ><', fn:
  s1 = set 1, 2
  s2 = set 2, 3
  equals
    s1 >< s2
    false


# --- Destructure / match ---

test 'list destructure empty (sanity)', fn:
  s = []
  equals
    match s:
      []: 'empty'
      _: 'non-empty'
    'empty'

test 'list destructure with import (sanity)', fn:
  s = []
  equals
    match s:
      []: 'empty'
      _: 'non-empty'
    'empty'

test 'set match non-empty (probe)', fn:
  s = set 1, 2
  equals
    match s:
      []: 'empty'
      _: 'non-empty'
    'non-empty'

test 'set destructure empty', fn:
  s = set _
  equals
    match s:
      []: 'empty'
      _: 'non-empty'
    'empty'

test 'set destructure non-empty', fn:
  s = set 1, 2, 3
  equals
    match s:
      []: 'empty'
      _: 'non-empty'
    'non-empty'

test 'set destructure peel one', fn:
  s = set 1, 2, 3
  equals
    match s:
      []: 0
      [a, ..]: a + 100
    101


# Integer 1 and float 1.0 are distinct keys: deep_eq is type-strict
# even within the math family. The set keeps both -- duplicate `1` is
# deduped, but `1` and `1.0` survive separately. (The formatter prints
# both as `1` -- distinct only in their underlying type.)
test 'set distinguishes int from float', fn:
  not_equals
    set 1, 1.0, 1
    set 1, 1
