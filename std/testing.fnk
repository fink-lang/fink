
{write, stderr} = import 'std/io.fnk'
{suspend, init_ctx} = import 'std/effects.fnk'
{get_trace, get_module_url, get_loc} = import 'std/trace.fnk'


skip = fn tc:
  upd_tests fn {tests}:
    [..rest, {name, body}] = tests
    test_case = {name, body, skip: true}
    [test_case, {tests: [..rest, test_case]}]


test = fn name, body:
  test_case = {name, body, skip: false}
  add_test test_case


upd_tests = init_ctx test, {tests: [], curr: {}}


upd_curr_test = fn upd_fn:
  upd_tests fn {curr: test_case}:
    [r, upd] = upd_fn test_case
    [r, {curr: {..test_case, ..upd}}]


set_curr_test = fn test_case:
  upd_tests fn _:
    [test_case, {curr: test_case}]


add_test = fn test_case:
  upd_tests fn {tests}:
    [test_case, {tests: [..tests, test_case]}]


run_test = fn test_case:
  set_curr_test test_case

  run_result = suspend fn resume:
    {name, body, skip} = upd_curr_test fn {name, body, skip}:
      [{name, body, skip}, {abort: resume}]


    write stderr, '${name} ... '
    match skip:
      false: body _
      true: true

    resume {success: true, skip}

  match run_result:
    {failure}:
      write stderr, 'FAIL\n  ${failure}\n\n'
      false
    {success: true, skip: false}:
      write stderr, 'SUCCESS\n'
      true
    {skip: true}:
      write stderr, 'SKIPPED\n'
      true


trace_to_str = fn t, s:
  match t:
    []: s
    [[mid, cid], ..rest]:
      murl = get_module_url mid
      trace_to_str rest, '${s}\n  ${murl}:${get_loc mid, cid} (${mid}:${cid})'



fail = fn msg:
  trace = get_trace 5

  failure = trace_to_str trace, '${msg}\nTraceback:'

  abort = upd_curr_test fn {abort}:
    [abort, {result: {failure}}]

  abort {failure}



run_tests = fn tests, fail_cnt:
  match tests:
    []: fail_cnt
    [test, ..rest]:
      succ = run_test test

      cnt = match succ:
        true: fail_cnt
        false: fail_cnt + 1

      run_tests rest, cnt



test_all = fn:
  tests = upd_tests fn {tests}:
    [tests, {tests: []}]

  run_tests tests, 0



equals = fn actual, expected:
  match actual == expected:
    true: true
    false: fail 'act: ${actual}\n  ==\n  exp: ${expected}'



not_equals = fn actual, expected:
  match actual != expected:
    true: true
    false: fail 'act: ${actual}\n  !=\n  exp: ${expected}'



