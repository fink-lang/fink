{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'set_ctx survives a builtin op in between', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'foo'
    x = 1 + 2
    get_ctx_for testing
  | equals ":
    foo


test 'ctx set in outer scope reads in nested fn', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    ni = set_ctx_for testing, 1

    inner = fn foo:
      x = set_ctx_for testing, foo + 1
      x

    inner ni
    get_ctx_for testing
  | equals ƒink:
    2



test 'ctx survives stdout write', fn:
  expect run ƒink:
    {stdout, write} = import 'std/io.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'writer-ctx'
    write stdout, ''
    get_ctx_for testing
  | equals ":
    writer-ctx



# Protocols dispatchers (op_plus etc.) forward ctx to their cont without
# consulting it for dispatch. After an arbitrary numeric op chain, ctx
# should still be the caller's.
test 'ctx survives arithmetic chain', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'math-ctx'
    foo = 1 + 2 * 3 - 4
    get_ctx_for testing
  | equals ":
    math-ctx


# Pattern match arms are CPS conts under the hood; ctx must survive
# match dispatch.
test 'ctx survives match', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'match-ctx'
    match 'x':
      'x': 1
      _: 0
    get_ctx_for testing
  | equals ":
    match-ctx


# Channel I/O via the host bridge (HostChannel) — write goes through
# interop_channel_send. ctx should survive that too.
test 'ctx survives stderr write', fn:
  expect run ƒink:
    {stderr, write} = import 'std/io.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'stderr-ctx'
    write stderr, ''
    get_ctx_for testing
  | equals ":
    stderr-ctx


# std/math.wat's per-fn closures (abs, sqrt, sin, cos, log, ...) now
# forward the caller's ctx into apply_1 — previously they discarded it.
test 'ctx survives sqrt', fn:
  expect run ƒink:
    {sqrt} = import 'std/math.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'math-fn-ctx'
    sqrt 16.0
    get_ctx_for testing
  | equals ":
    math-fn-ctx




# `repr x` and `fmt x` as user-imported fns. The bare-@impl wrapper in
# the .wat file returns a no-capture $Closure; the user-import binding
# receives the closure value; apply_3 dispatches with caller's ctx.
test 'ctx survives repr', fn:
  expect run ƒink:
    {repr} = import 'std/repr.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'repr-ctx'
    repr 42
    get_ctx_for testing
  | equals ":
    repr-ctx


# `fmt x` as a direct user-imported call (not template-string interp,
# which goes through the StrFmt builtin sym path with ctx threaded).
test 'ctx survives fmt as imported fn', fn:
  expect run ƒink:
    {fmt} = import 'std/str.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'fmt-ctx'
    fmt 42
    get_ctx_for testing
  | equals ":
    fmt-ctx


# -- ctx survival across std runtime ops ------------------------------
#
# These cover std runtime impls (list/dict/set/str/range non-seq ops)
# that historically passed `(ref.null any)` as ctx. Each test sets ctx,
# exercises one op, then reads ctx back -- the op's continuation must
# resume under the caller's ctx, not a fresh/null one.


test 'ctx survives range membership (op_in I64 Range)', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'range-in-ctx'
    foo = 5 in 0..10
    get_ctx_for testing
  | equals ":
    range-in-ctx


test 'ctx survives set membership (op_in _ Set)', fn:
  expect run ƒink:
    {set} = import 'std/set.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'set-in-ctx'
    foo = 2 in set 1, 2, 3
    get_ctx_for testing
  | equals ":
    set-in-ctx


test 'ctx survives set union (op_or Set Set)', fn:
  expect run ƒink:
    {set} = import 'std/set.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'set-or-ctx'
    foo = (set 1, 2) or (set 2, 3)
    get_ctx_for testing
  | equals ":
    set-or-ctx


test 'ctx survives rec membership (op_in _ Rec)', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'rec-in-ctx'
    foo = 'k' in {k: 1}
    get_ctx_for testing
  | equals ":
    rec-in-ctx


test 'ctx survives rec field access (op_dot Rec)', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'rec-dot-ctx'
    foo = {a: 1}.a
    get_ctx_for testing
  | equals ":
    rec-dot-ctx


test 'ctx survives rec put', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'rec-put-ctx'
    foo = {..{a: 1}, b: 2}
    get_ctx_for testing
  | equals ":
    rec-put-ctx


test 'ctx survives list index (op_dot List Int)', fn:
  expect run ƒink:
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'list-dot-ctx'
    foo = [10, 20, 30].(1)
    get_ctx_for testing
  | equals ":
    list-dot-ctx


# `list 1, 2, 3` is the user-importable constructor; its $_list_apply
# Fn3 wrapper receives ctx as a native param but historically discarded
# it when firing the user cont.
test 'ctx survives list constructor', fn:
  expect run ƒink:
    {list} = import 'std/list.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'list-ctor-ctx'
    foo = list 1, 2, 3
    get_ctx_for testing
  | equals ":
    list-ctor-ctx


# `set 1, 2, 3` — same pattern, $_set_apply.
test 'ctx survives set constructor', fn:
  expect run ƒink:
    {set} = import 'std/set.fnk'
    {unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, 'set-ctor-ctx'
    foo = set 1, 2, 3
    get_ctx_for testing
  | equals ":
    set-ctor-ctx


# -- suspend (raw cont capture, no handler) ---------------------------
#
# `suspend fn resume: body` is the lowest-level cont primitive: it
# captures the suspend expression's continuation as `resume`, then
# invokes the user fn with resume as argument. `resume v` transfers
# control to the captured cont with v becoming the value of the
# suspend expression. Multi-shot: resume may be called any number
# of times. If the user fn never calls resume, that thread of
# execution ends.

# Round-trip: suspend, call resume once with a value, observe
# control returning with that value.
test 'suspend: round-trip via captured cont', fn:
  expect run ƒink:
    {suspend} = import 'std/effects.fnk'

    result = suspend fn resume:
      resume 'fired'

    'got: ${result}'

  | equals ":
    got: fired



# Resume can be fired multiple times -- each fire re-enters the
# suspension point fresh. Stash the resume in ctx so the cont's
# downstream code can re-fire it on later phases.
test 'suspend: cont can be fired more than once', fn:
  expect run ƒink:
    {suspend, unique, set_ctx_for, get_ctx_for} = import 'std/effects.fnk'
    testing = unique _

    set_ctx_for testing, {count: 0, results: [], k: false}

    r = suspend fn resume:
      # Stash resume so it can be re-fired from the cont below.
      {results} = get_ctx_for testing
      set_ctx_for testing, {count: 1, results: [..results, 'init'], k: resume}
      resume 'a'

    {count, results, k} = get_ctx_for testing
    match count:
      1:
        # k holds resume; r is 'a'. Fire k again with 'b'.
        set_ctx_for testing, {count: 2, results: [..results, r], k}
        k 'b'
      _:
        # r is 'b'. Final pass.
        new_results = [..results, r]
        '${new_results}'

  | equals ":
    ['init', 'a', 'b']


test 'unique identity', fn:
  expect run ƒink:
    {unique} = import 'std/effects.fnk'

    id1 = unique _
    {pause} = import 'std/tasks.fnk'
    id2 = unique _

    id1 != id2

  | equals ƒink:
    true
