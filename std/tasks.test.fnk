{test, skip, expect, equals, run} = import '!fake'
{ƒink} = import '@fink/parse/blocks.fnk'


test 'spawning', fn:
  expect run ƒink:
    {upd_ctx_for, get_ctx_for, set_ctx_for, unique} = import 'std/effects.fnk'
    {spawn, pause, with_tasks} = import 'std/tasks.fnk'

    testing = unique _

    set_ctx_for testing, {foo: 'start'}

    pause_with_update = fn msg:
      pause msg
      {foo} = get_ctx_for testing
      upd_ctx_for testing,  {foo: '${foo} -> ${msg}'}

    with_tasks fn:
      spawn fn:
        pause_with_update 'A1'
        pause_with_update 'A2'
        pause_with_update 'A3'
        'A-done'

      spawn fn:
        pause_with_update 'B1'
        pause_with_update 'B1'
        'B-done'

    {foo} = get_ctx_for testing
    foo

  | equals ":
    start -> A1 -> B1 -> A2 -> B1 -> A3


test 'awaiting future', fn:
  expect run ƒink:
    {spawn, pause, with_tasks, await} = import 'std/tasks.fnk'

    with_tasks fn:
      fut = spawn fn:
        pause 'A pause'
        42

      await fut

  | equals ƒink:
    42
