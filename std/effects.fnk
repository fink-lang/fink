---
unique = fn:
  {id} = upd_ctx_unique fn {id}:
    {id: id + 1}
  # Wrap the counter so the identity is nominal (per mint) rather than a
  # bare int that could collide with a literal under structural equality.
  opaque id

upd_ctx_unique = init_ctx unique, {id: 0}



has_handler = fn perform, frames:
  match frames:
    []: false
    [f, ..rest]: match f.perform == perform:
      true: true
      false: has_handler perform, rest


get_perform = fn handler:
  perform = fn ..args:
    {frames} = get_ctx_for with

    match has_handler perform, frames:
      true: handler ..args
      # TODO false: ?!?!?

  perform


effect = fn handler:
  # {reg} = get_ctx_for with
  perform = get_perform handler
  # upd_ctx_with fn ..: {reg: {..reg, (perform): handler}}
  perform


push_frame = fn frame:
  upd_ctx_with fn {frames}:
    {frames: [frame, ..frames]}


pop_frame = fn id:
  # TODO need to pop all to frame with `id` and call any finalizers
  upd_ctx_with fn {frames: [frame, ..frames]}:
    # TODO run finalizers on frame
    {frames}


get_curr_frame = fn:
  {frames: [frame]} = get_ctx_for with
  frame


upd_curr_frame = fn updates:
  upd_ctx_with fn {frames: [frame, ..frames]}:
    updated_frame = {..frame, ..updates}
    {frames: [updated_frame, ..frames]}



add_finallizer = fn final_fn:
  upd_curr_frame fn {finalizers}:
    {finalizers: [..finalizers, final_fn]}



with = fn perform, body:
  id = unique _

  result = suspend fn return:
    push_frame {id, retry: body, return, perform}
    return body _

  pop_frame id
  result

upd_ctx_with = init_ctx with, {frames: []}


