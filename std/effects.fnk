---
# TODO, do we even need an upd_ctx_for as public API?
upd_ctx_for = fn ctx_id, update:
  ctx = get_ctx_for ctx_id

  upd_rslt = update ctx

  match upd_rslt:
    [result, updates]:
      set_ctx_for ctx_id, {..ctx, ..updates}
      result
    updates:
      set_ctx_for ctx_id, {..ctx, ..updates}


