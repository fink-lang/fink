{test, skip, equals} = import 'std/testing.fnk'

{suspend, unique, init_ctx, get_ctx_for, set_ctx_for} = import 'std/effects.fnk'

{write, stdout} = import 'std/io.fnk'
{sqrt} = import 'std/math.fnk'
{repr} = import 'std/repr.fnk'
{fmt} = import 'std/fmt.fnk'
{list} = import 'std/list.fnk'
{set} = import 'std/set.fnk'


test 'init_ctx and updates', fn:
  testing = unique _

  upd_ctx_testing = init_ctx testing, {foo: 'spam', bar: 21}

  {foo, bar} = upd_ctx_testing fn {bar}:
    {bar: bar * 2}

  equals
    [foo, bar]
    ['spam', 42]


test 'ctx updates with custom result', fn:
  testing = unique _

  upd_ctx_testing = init_ctx testing, {foo: 'spam', bar: 21}

  {foo, bar} = upd_ctx_testing fn {bar: old, foo}:
    bar = old * 2
    [{foo, bar}, {bar}]

  equals
    [foo, bar]
    ['spam', 42]


test 'suspend: round-trip via captured cont', fn:
  result = suspend fn resume:
    resume 'fired'

  equals
    result
    'fired'



test 'suspend: cont can be fired more than once', fn:
  testing = unique _

  upd_ctx_testing = init_ctx testing, {count: 0, results: [], k: false}

  r = suspend fn resume:
    # Stash resume so it can be re-fired from the cont below.
    upd_ctx_testing fn {results}:
      {count: 1, results: [..results, 'init'], resume}

    resume 'a'

  {count, results, resume} = get_ctx_for testing
  rslt = match count:
    1:
      upd_ctx_testing fn {count, results}:
        {count: count + 1, results: [..results, r], resume}
      resume 'b'
    _:
      [..results, r]

  equals
    rslt
    ['init', 'a', 'b']





# Seq-literal elements must evaluate left-to-right (source order). The
# cons-list build is right-to-left internally, but evaluation order is
# observable through side effects and must follow source order. A
# ctx-threaded counter reveals the order: slot 0 must hold the first
# tick, not the last.
test 'seq literal evaluates elements left to right', fn:
  counter = unique _
  upd = init_ctx counter, {n: 0}

  tick = fn:
    {n} = upd fn {n}:
      {n: n + 1}
    n

  equals
    [tick _; tick _; tick _]
    [1, 2, 3]


# Rec fields are unordered for storage, but the field-value expressions
# still evaluate left-to-right (source order) -- observable via side
# effects. Read fields back by name: `a` (written first) must hold the
# first tick, `c` the last.
test 'rec literal evaluates fields left to right', fn:
  counter = unique _
  upd = init_ctx counter, {n: 0}

  tick = fn:
    {n} = upd fn {n}:
      {n: n + 1}
    n

  equals
    {a: (tick _); b: (tick _); c: (tick _)}
    {b: 2, a: 1, c: 3}




# --- --- --- low level regression tests for context threading --- --- ---

test 'set_ctx survives a builtin op in between', fn:
  testing = unique _

  set_ctx_for testing, 'foo'
  x = 1 + 2

  equals
    get_ctx_for testing
    'foo'


test 'ctx set in outer scope reads in nested fn', fn:
  testing = unique _

  ni = set_ctx_for testing, 1

  inner = fn foo:
    x = set_ctx_for testing, foo + 1
    x

  inner ni

  equals
    get_ctx_for testing
    2


# should not write to real stdout
skip test 'ctx survives stdout write', fn:
  testing = unique _

  set_ctx_for testing, 'writer-ctx'
  write stdout, 'effects-test'

  equals
    get_ctx_for testing
    'writer-ctx'



# Protocols dispatchers (op_plus etc.) forward ctx to their cont without
# consulting it for dispatch. After an arbitrary numeric op chain, ctx
# should still be the caller's.
test 'ctx survives arithmetic chain', fn:
  testing = unique _

  set_ctx_for testing, 'math-ctx'
  foo = 1 + 2 * 3 - 4

  equals
    get_ctx_for testing
    'math-ctx'


# Pattern match arms are CPS conts under the hood; ctx must survive
# match dispatch.
test 'ctx survives match', fn:
  testing = unique _

  set_ctx_for testing, 'match-ctx'
  match 'x':
    'x': 1
    _: 0

  equals
    get_ctx_for testing
    'match-ctx'


# std/math.wat's per-fn closures (abs, sqrt, sin, cos, log, ...) now
# forward the caller's ctx into apply_1 — previously they discarded it.
test 'ctx survives sqrt', fn:
  testing = unique _

  set_ctx_for testing, 'math-fn-ctx'
  sqrt 16.0

  equals
    get_ctx_for testing
    'math-fn-ctx'




# `repr x` and `fmt x` as user-imported fns. The bare-@impl wrapper in
# the .wat file returns a no-capture $Closure; the user-import binding
# receives the closure value; apply_3 dispatches with caller's ctx.
test 'ctx survives repr', fn:
  testing = unique _

  set_ctx_for testing, 'repr-ctx'
  repr 42

  equals
    get_ctx_for testing
    'repr-ctx'


# `fmt x` as a direct user-imported call (not template-string interp,
# which goes through the StrFmt builtin sym path with ctx threaded).
test 'ctx survives fmt as imported fn', fn:
  testing = unique _

  set_ctx_for testing, 'fmt-ctx'
  fmt 42

  equals
    get_ctx_for testing
    'fmt-ctx'



# -- ctx survival across std runtime ops ------------------------------
#
# These cover std runtime impls (list/dict/set/str/range non-seq ops)
# that historically passed `(ref.null any)` as ctx. Each test sets ctx,
# exercises one op, then reads ctx back -- the op's continuation must
# resume under the caller's ctx, not a fresh/null one.


test 'ctx survives range membership (op_in I64 Range)', fn:
  testing = unique _

  set_ctx_for testing, 'range-in-ctx'
  foo = 5 in 0..10

  equals
    get_ctx_for testing
    'range-in-ctx'


test 'ctx survives set membership (op_in _ Set)', fn:
  testing = unique _

  set_ctx_for testing, 'set-in-ctx'
  foo = 2 in set 1, 2, 3

  equals
    get_ctx_for testing
    'set-in-ctx'


test 'ctx survives set union (op_or Set Set)', fn:
  testing = unique _

  set_ctx_for testing, 'set-or-ctx'
  foo = (set 1, 2) or (set 2, 3)

  equals
    get_ctx_for testing
    'set-or-ctx'


test 'ctx survives rec membership (op_in _ Rec)', fn:
  testing = unique _

  set_ctx_for testing, 'rec-in-ctx'
  foo = 'k' in {k: 1}

  equals
    get_ctx_for testing
    'rec-in-ctx'


test 'ctx survives rec field access (op_dot Rec)', fn:
  testing = unique _

  set_ctx_for testing, 'rec-dot-ctx'
  foo = {a: 1}.a

  equals
    get_ctx_for testing
    'rec-dot-ctx'


test 'ctx survives rec put', fn:
  testing = unique _

  set_ctx_for testing, 'rec-put-ctx'
  foo = {..{a: 1}, b: 2}

  equals
    get_ctx_for testing
    'rec-put-ctx'


test 'ctx survives list index (op_dot List Int)', fn:
  testing = unique _

  set_ctx_for testing, 'list-dot-ctx'
  foo = [10, 20, 30].(1)

  equals
    get_ctx_for testing
    'list-dot-ctx'


# `list 1, 2, 3` is the user-importable constructor; its $_list_apply
# Fn3 wrapper receives ctx as a native param but historically discarded
# it when firing the user cont.
test 'ctx survives list constructor', fn:
  testing = unique _

  set_ctx_for testing, 'list-ctor-ctx'
  foo = list 1, 2, 3

  equals
    get_ctx_for testing
    'list-ctor-ctx'


# `set 1, 2, 3` — same pattern, $_set_apply.
test 'ctx survives set constructor', fn:
  testing = unique _

  set_ctx_for testing, 'set-ctor-ctx'
  foo = set 1, 2, 3
  equals
    get_ctx_for testing
    'set-ctor-ctx'

