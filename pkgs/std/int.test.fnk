{test, skip, equals, not_equals} = import 'std/testing.fnk'
{int} = import 'std/int.fnk'


test 'int type guard matches an integer', fn:
  equals
    match 42:
      int i: i
      _: 'no match'
    42

test 'int type guard rejects a float', fn:
  equals
    match 3.14:
      int i: i
      _: 'no match'
    'no match'

test 'int type guard rejects a string', fn:
  equals
    match 'hello':
      int i: i
      _: 'no match'
    'no match'


# Integer literals. A bare decimal is the implicit int constructor
# (math family, signed). Hex / octal / binary are the bits family --
# all u64 -- and do not mix with the math family (`0xFF == 255` traps),
# so bits-family literals are compared against each other.

test 'int literal', fn:
  equals
    42
    42

test 'int decimal separator', fn:
  equals
    1_000_000
    1000000


# --- Signed (math family) ---
#
# Bare decimals are math-family signed. A leading `+`/`-` is a sign on
# the literal (in statement position; as a bare call argument `+`/`-`
# parses as the infix operator, so bind first then compare).

test 'int negative literal', fn:
  equals
    -5
    -5

test 'int negative differs from positive', fn:
  not_equals
    -5
    5

test 'int signed arithmetic', fn:
  equals
    -5 + 3
    -2

test 'int plus prefix', fn:
  x = +1
  equals
    x
    1


# --- Bits family (hex / octal / binary) ---

test 'hex literal', fn:
  equals
    0xFF
    0xFF

test 'hex equals octal same value', fn:
  equals
    0xFF
    0o377

test 'hex equals binary same value', fn:
  equals
    0xFF
    0b1111_1111

test 'hex separator', fn:
  equals
    0xFF_FF
    0xFFFF


# --- Integer-only arithmetic ---
#
# These are defined on ints only (they trap on floats), so they belong
# to int, not the tower-wide num operators.

test 'integer division', fn:
  equals
    7 // 2
    3

test 'divmod', fn:
  [q, r] = 10 /% 3
  equals
    [q, r]
    [3, 1]

test 'modulo', fn:
  equals
    10 %% 3
    1

# `%` is remainder (sign follows the dividend); `%%` is true modulus
# (sign follows the divisor). They differ on negative operands.
test 'remainder', fn:
  equals
    7 % 3
    1

test 'remainder negative follows dividend', fn:
  equals
    -7 % 3
    -1

# TODO bug: `%%` should be true modulus (sign follows divisor), so
# -7 %% 3 == 2 (docs/language.md). It currently returns -1 (behaves like
# remainder for negatives). Un-skip when true-modulus is implemented.
skip test 'modulo negative follows divisor', fn:
  equals
    -7 %% 3
    2


# --- Bits-family comparison ---
#
# 0x8000000000000000 is i64::MIN as signed bits but 2^63 unsigned.
# Verifies u64 comparison routes through the unsigned ops, not signed.

test 'unsigned greater than above i64::MAX', fn:
  equals
    0x8000000000000000 > 0x1
    true


# --- Bitwise operators ---
#
# Results stay in the bits family, so expected values are bits-family
# literals (comparing a bits result to a decimal would cross families
# and trap).

test 'bitwise and', fn:
  equals
    0xFF and 0x0F
    0x0F

test 'bitwise or', fn:
  equals
    0xFF or 0x0F
    0xFF

test 'bitwise xor', fn:
  equals
    0xFF xor 0x0F
    0xF0

test 'bitwise not', fn:
  equals
    not 0x0
    0xFFFF_FFFF_FFFF_FFFF

test 'bitwise shift left', fn:
  equals
    0x1 << 8
    0x100

test 'bitwise shift right', fn:
  equals
    0x100 >> 4
    0x10

test 'rotate left', fn:
  equals
    0x1 <<< 4
    0x10

test 'rotate right', fn:
  equals
    0x10 >>> 4
    0x1
