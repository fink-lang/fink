
{write, stderr} = import 'std/io.fnk'
{suspend, init_ctx} = import 'std/effects.fnk'
{get_trace, get_module_url, get_loc} = import 'std/trace.fnk'


skip = fn tc:
  upd_tests fn {tests}:
    [..rest, prev] = tests
    test_case = {..prev, skip: true}
    [test_case, {tests: [..rest, test_case]}]


test = fn name, body:
  [_, [mid, cid]] = get_trace 2
  url = '${get_module_url mid}:${get_loc mid, cid}'
  test_case = {name, body, url, skip: false}
  add_test test_case


upd_tests = init_ctx test, {tests: [], curr: {}}


upd_curr_test = fn upd_fn:
  upd_tests fn {curr: test_case}:
    [r, upd] = upd_fn test_case
    [r, {curr: {..test_case, ..upd}}]


set_curr_test = fn test_case:
  upd_tests fn _:
    [test_case, {curr: test_case}]


add_test = fn test_case:
  upd_tests fn {tests}:
    [test_case, {tests: [..tests, test_case]}]


run_test = fn test_case:
  set_curr_test test_case

  run_result = suspend fn resume:
    {body} = upd_curr_test fn t:
      [t, {abort: resume}]

    body _
    resume {success: true}

  run_result


trace_to_str = fn t, s:
  match t:
    []: s
    [[mid, cid], ..rest]:
      murl = get_module_url mid
      trace_to_str rest, '${s}\n  ${murl}:${get_loc mid, cid} (${mid}:${cid})'



fail = fn msg:
  trace = get_trace 5

  failure = trace_to_str trace, '${msg}\nTraceback:'

  abort = upd_curr_test fn {abort}:
    [abort, {result: {failure}}]

  abort {failure}



run_tests = fn tests, succ_cnt, fail_cnt, skip_cnt:
  match tests:
    []: [succ_cnt, fail_cnt, skip_cnt]
    [test, ..rest]:

      write stderr, '${test.url} ${test.name} ... '
      cnts = match test:
        {skip: true}:
          write stderr, 'SKIPPED\n'
          [succ_cnt, fail_cnt, skip_cnt + 1]
        _:
          result = run_test test
          match result:
            {failure}:
              write stderr, 'FAIL\n  ${failure}\n\n'
              [succ_cnt, fail_cnt + 1, skip_cnt]
            {success: true}:
              write stderr, 'SUCCESS\n'
              [succ_cnt + 1, fail_cnt, skip_cnt]


      run_tests rest, ..cnts



test_all = fn:
  tests = upd_tests fn {tests}:
    [tests, {tests: []}]

  [passed, failed, skipped] = run_tests tests, 0, 0, 0
  total = passed + failed + skipped
  write stderr, '\nTotal: ${total}, Passed: ${passed}, Failed: ${failed} Skipped: ${skipped}\n'
  failed



equals = fn actual, expected:
  match actual == expected:
    true: true
    false: fail 'act: ${actual}\n  ==\n  exp: ${expected}'



not_equals = fn actual, expected:
  match actual != expected:
    true: true
    false: fail 'act: ${actual}\n  !=\n  exp: ${expected}'



